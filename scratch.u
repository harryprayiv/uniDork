    -> b)
Tmdb.upsertDetailsSql =
  use Codec optional text
  sql
    "INSERT INTO movies (tmdb_id, imdb_id, tvdb_id, title, original_title, original_language, year, runtime_min, overview, tagline, mpaa, vote_average, vote_count, collection, details_json) VALUES ("
    %% var integer
