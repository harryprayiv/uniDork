test> Tmdb.tokenOverlapPercent.test =
  use Universal eq
  List.flatMap
    check
    [ eq
        (Tmdb.tokenOverlapPercent
          "hot tube time machine" "hot tub time machine")
        75
    , eq
        (Tmdb.tokenOverlapPercent
          "avatar fire and ash" "avatar fire and ash")
        100
    , eq (Tmdb.tokenOverlapPercent "foo bar" "foo baz") 50
    , eq (Tmdb.tokenOverlapPercent "completely different" "totally other") 0
    , eq (Tmdb.tokenOverlapPercent "" "anything") 0
    , eq (Tmdb.tokenOverlapPercent "single" "single word") 100
    ]