Db.pt : Text -> [Optional Text]
Db.pt t = Codec.encode Codec.text t

Db.pot : Optional Text -> [Optional Text]
Db.pot v = [v]

Db.pi : Int -> [Optional Text]
Db.pi i = Codec.encode integer i

Db.poi : Optional Int -> [Optional Text]
Db.poi = cases
  None   -> [None]
  Some i -> Codec.encode integer i

Db.pf : Float -> [Optional Text]
Db.pf f = Codec.encode Codec.double f

Db.pobi : Optional Int -> [Optional Text]
Db.pobi = cases
  None   -> [None]
  Some i -> Codec.encode bigint i

Db.withIndex : [a] -> [(Nat, a)]
Db.withIndex xs =
  use List +:
  use Nat +
  go acc i = cases
    []      -> List.reverse acc
    x +: ys -> go ((i, x) +: acc) (i + 1) ys
  go [] 0 xs

Db.foreach_ : (a ->{g} b) -> [a] ->{g} ()
Db.foreach_ f xs =
  step acc x =
    _ = f x
    acc
  _ = List.foldLeft step () xs
  ()

Db.countMovies : '{IO, Exception} ()
Db.countMovies = do
  singleIO Db.config do
    q = sql "SELECT COUNT(*) FROM movies" |> typedQuery bigint
    counts = Query.execute q
    match counts with
      n +: _ -> printLine (Text.join "" ["movies in db: ", Int.toText n])
      []     -> printLine "no result"

Db.upsertWith
  pcUpsert
  pcVid
  pcDVid
  pcAud
  pcDAud
  pcSub
  pcDSub
  pcAct
  pcDAct
  pcGen
  pcDGen
  pcTag
  pcDTag
  pcCou
  pcDCou
  pcStu
  pcDStu
  pcDir
  pcDDir
  pcCre
  pcDCre
  actualRuntimeSec
  m = 
  transaction do
    use List ++
    use Nat toInt
    use Optional map
    k = MovieId.kodi (Movie.id m)
    csum = Optional.getOrElse "" (Movie.checksum m)
    mid = Movie.id m
    t = Movie.title m
    s = Movie.scoring m
    sd = FileInfo.streams (Movie.fileInfo m)
    vid = StreamDetails.video sd
    tax = Movie.taxonomy m
    fm = Movie.folderMeta m
    indexedAudios = Db.withIndex (StreamDetails.audios sd)
    indexedSubs = Db.withIndex (StreamDetails.subtitles sd)
    indexedActors = Db.withIndex (Movie.actors m)
    del pc =
      _ = bindAndExecuteCommand pc (Db.pt csum)
      ()
    repList delPc insPc vals =
      _ = del delPc
      Db.foreach_
        (v -> bindAndExecuteCommand insPc (Db.pt csum ++ Db.pt v)) vals
    _ = printLine (Text.join "" ["upserting: ", k, " (", csum, ")"])
    _ =
      bindAndExecuteCommand
        pcUpsert
        (Db.pt k
          ++ Db.pot (MovieId.imdb mid)
          ++ Db.pot (MovieId.tmdb mid)
          ++ Db.pot (MovieId.tvdb mid)
          ++ Db.pt (Title.display t)
          ++ Db.pt (Title.original t)
          ++ Db.pt (Title.sort t)
          ++ Db.pot (Movie.collection m)
          ++ Db.poi (map toInt (Scoring.year s))
          ++ Db.pf (Scoring.rating s)
          ++ Db.pi (toInt (Scoring.votes s))
          ++ Db.pt (Scoring.mpaa s)
          ++ Db.poi (map toInt (Movie.runtime m))
          ++ Db.pt (Movie.plot m)
          ++ Db.pt (Movie.tagline m)
          ++ Db.pot (Movie.folderPath m)
          ++ Db.pot (Movie.nfoPath m)
          ++ Db.pot (Movie.videoFilePath m)
          ++ Db.pobi (map toInt (Movie.fileSizeBytes m))
          ++ Db.pot (Movie.checksum m)
          ++ Db.pot (FolderMeta.rawSize fm)
          ++ Db.pot (FolderMeta.resolution fm)
          ++ Db.pot (FolderMeta.videoCodec fm)
          ++ Db.poi (map toInt (FolderMeta.bitDepth fm))
          ++ Db.poi (map toInt (FolderMeta.runtimeMin fm))
          ++ Db.poi (map toInt actualRuntimeSec))
    _ = del pcDVid
    _ =
      bindAndExecuteCommand
        pcVid
        (Db.pt csum
          ++ Db.pt (Video.codec vid)
          ++ Db.pf (Video.aspect vid)
          ++ Db.pi (toInt (Video.width vid))
          ++ Db.pi (toInt (Video.height vid)))
    _ = del pcDAud
    _ =
      Db.foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAud
              (Db.pt csum
                ++ Db.pi (toInt i)
                ++ Db.pt (Audio.codec a)
                ++ Db.pt (Audio.language a)
                ++ Db.pi (toInt (Audio.channels a))))
        indexedAudios
    _ = del pcDSub
    _ =
      Db.foreach_
        (cases
          (i, sub) ->
            bindAndExecuteCommand
              pcSub
              (Db.pt csum ++ Db.pi (toInt i) ++ Db.pt (Subtitle.language sub)))
        indexedSubs
    _ = del pcDAct
    _ =
      Db.foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAct
              (Db.pt csum
                ++ Db.pi (toInt i)
                ++ Db.pt (Actor.name a)
                ++ Db.pt (Actor.role a)))
        indexedActors
    _ = repList pcDGen pcGen (Taxonomy.genres tax)
    _ = repList pcDTag pcTag (Taxonomy.tags tax)
    _ = repList pcDCou pcCou (Taxonomy.countries tax)
    _ = repList pcDStu pcStu (Taxonomy.studios tax)
    _ = repList pcDDir pcDir (Taxonomy.directors tax)
    _ = repList pcDCre pcCre (Taxonomy.credits tax)
    ()

type Probe.Format
  = { duration : Float, sizeBytes : Optional Nat, bitRate : Optional Nat }

type Probe.Result
  = { format : Probe.Format }

type Probe.AudioTrack
  = { index : Nat,
      codec : Text,
      language : Optional Text,
      title : Optional Text,
      channels : Nat,
      channelLayout : Text,
      isDefault : Boolean,
      isComment : Boolean,
      isVisualImpaired : Boolean }

Probe.AudioTrack.fromJson : '{unison_json_1_4_2.Decoder} Probe.AudioTrack
Probe.AudioTrack.fromJson =
  do
    use Decoder boolean nat optional! text
    use object at at!
    index = at! "index" nat
    codec = at! "codec" text
    language = optional! (at "language" text)
    title = optional! (at "title" text)
    channels = at! "channels" nat
    channelLayout = at! "channel_layout" text
    isDefault = at! "default" boolean
    isComment = at! "comment" boolean
    isVisualImpaired = at! "visual_impaired" boolean
    Probe.AudioTrack.AudioTrack
      index
      codec
      language
      title
      channels
      channelLayout
      isDefault
      isComment
      isVisualImpaired

Probe.parseFloat : Text -> Float
Probe.parseFloat t = Optional.getOrElse 0.0 (Float.fromText (trim t))

Probe.optNatStringAt : Text ->{unison_json_1_4_2.Decoder} Optional Nat
Probe.optNatStringAt key =
  match Decoder.optional! (object.at key Decoder.text) with
    None   -> None
    Some s -> Nat.fromText (trim s)

Probe.Format.fromJson : '{unison_json_1_4_2.Decoder} Probe.Format
Probe.Format.fromJson = do
  durStr = object.at! "duration" Decoder.text
  duration = Probe.parseFloat durStr
  sizeBytes = Probe.optNatStringAt "size"
  bitRate = Probe.optNatStringAt "bit_rate"
  Probe.Format.Format duration sizeBytes bitRate

Probe.Result.fromJson : '{unison_json_1_4_2.Decoder} Probe.Result
Probe.Result.fromJson = do
  format = object.at! "format" Probe.Format.fromJson
  Probe.Result.Result format

Probe.cacheRoot : Text
Probe.cacheRoot = "/home/bismuth/.cache/uniDork/ffprobe"

Probe.readSidecar : Text ->{IO, Exception} Optional Probe.Result
Probe.readSidecar videoPath =
  use Text ++
  jsonPath = FilePath (Probe.cacheRoot ++ videoPath ++ ".json")
  match 
    catch do
      raw = readFileUtf8 jsonPath
      Decoder.run Probe.Result.fromJson raw
   with
    Left _  -> None
    Right r -> Some r

Probe.runtimeSec : Probe.Result -> Nat
Probe.runtimeSec r =
  use Float <
  d = Probe.Format.duration (Probe.Result.format r)
  if d < 0.0 then 0
  else
    asText = Float.toText d
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    Optional.getOrElse 0 (Nat.fromText intPart)

Db.migrate : '{IO, Exception} ()
Db.migrate =
  do
    singleIO Db.config do
      _ = Db.runDDLList [Db.moviesDdl]
      _ = Db.runDDLList Db.childDdl
      _ = Db.runDDLList Db.indexDdl
      Db.runDDLList
        [ "ALTER TABLE movies ADD COLUMN IF NOT EXISTS actual_runtime_sec INTEGER"
        ]

Tmdb.cachedSearchWith pq pc token sourcePath title year =
  match Tmdb.readDbCacheWith pq sourcePath with
    Some cached -> cached
    None        ->
      result = Tmdb.search token title year
      _ = Tmdb.writeDbCacheWith pc sourcePath title year result
      result

Rename.insertLogSql =
  use Codec optional text
  sql
    "INSERT INTO rename_log (source_path, outcome, target_path, reason) VALUES ("
    %% var text
    %% sql ", "
    %% var text
    %% sql ", "
    %% var (optional text)
    %% sql ", "
    %% var (optional text)
    %% sql ")"
    |> buildCommand

-- ============================================================
-- Cleanup helpers (unchanged from prior turn, included for completeness)
-- ============================================================

-- ============================================================
-- Outcome with DuplicateRemoved variant
-- ============================================================

type Rename.Outcome
  = NoVideo Text
  | NoProbe Text
  | Renamed Text Text
  | NoMatch Text Text
  | Conflict Text Text
  | RenameError Text Text
  | DuplicateRemoved Text Text

Rename.Outcome.parts :
  Rename.Outcome -> (Text, Text, Optional Text, Optional Text)
Rename.Outcome.parts = cases
  Rename.Outcome.Renamed s t          -> (s, "renamed",           Some t, None)
  Rename.Outcome.NoVideo s            -> (s, "no_video",          None,   None)
  Rename.Outcome.NoMatch s r          -> (s, "no_match",          None,   Some r)
  Rename.Outcome.NoProbe s            -> (s, "no_probe",          None,   None)
  Rename.Outcome.Conflict s t         -> (s, "conflict",          Some t, None)
  Rename.Outcome.RenameError s m      -> (s, "error",             None,   Some m)
  Rename.Outcome.DuplicateRemoved s t -> (s, "duplicate_removed", Some t, None)

Rename.Outcome.toJson : Rename.Outcome -> Json
Rename.Outcome.toJson = cases
  Rename.Outcome.Renamed src tgt ->
    Json.object
      [ ("outcome", Json.text "renamed")
      , ("source",  Json.text src)
      , ("target",  Json.text tgt)
      ]
  Rename.Outcome.NoVideo src ->
    Json.object
      [("outcome", Json.text "no_video"), ("source", Json.text src)]
  Rename.Outcome.NoMatch src reason ->
    Json.object
      [ ("outcome", Json.text "no_match")
      , ("source",  Json.text src)
      , ("reason",  Json.text reason)
      ]
  Rename.Outcome.NoProbe src ->
    Json.object
      [("outcome", Json.text "no_probe"), ("source", Json.text src)]
  Rename.Outcome.Conflict src existing ->
    Json.object
      [ ("outcome",  Json.text "conflict")
      , ("source",   Json.text src)
      , ("existing", Json.text existing)
      ]
  Rename.Outcome.RenameError src msg ->
    Json.object
      [ ("outcome", Json.text "error")
      , ("source",  Json.text src)
      , ("message", Json.text msg)
      ]
  Rename.Outcome.DuplicateRemoved src existing ->
    Json.object
      [ ("outcome",  Json.text "duplicate_removed")
      , ("source",   Json.text src)
      , ("existing", Json.text existing)
      ]

-- ============================================================
-- Duplicate detection: ask the database.
--
-- Joins rename_log to stage_probes on source_path. A row comes back iff
-- some source with this crc32 was previously renamed successfully. The
-- returned target_path is just informational for the log/print line.
-- ============================================================

Rename.selectRenamedTargetByCrcSql =
  sql "SELECT rl.target_path FROM rename_log rl JOIN stage_probes sp ON sp.source_path = rl.source_path WHERE rl.outcome = 'renamed' AND sp.crc32 = "
    %% var Codec.text
    %% sql " ORDER BY rl.recorded_at DESC LIMIT 1"
    |> typedQuery Codec.text

Rename.findPriorTargetForCrcWith pq crc =
  match
    catch do
      portal = bindQuery pq (Db.pt crc)
      (rows, _) = executeQueryPortal portal 0
      rows
  with
    Left _   -> None
    Right rs ->
      match rs with
        []       -> None
        tgt +: _ -> Some tgt

Stage.ProbeResult.primaryAudio : Stage.ProbeResult -> Optional Stage.AudioInfo
Stage.ProbeResult.primaryAudio pr = List.head (Stage.ProbeResult.audios pr)

Rename.writeOutcome : Text -> Rename.Outcome ->{IO, Exception} ()
Rename.writeOutcome _unused o =
  use List ++
  (src, outcome, target, reason) = Rename.Outcome.parts o
  _ = 
    catch do
      singleIO Db.config do
        pc = prepareCommand Rename.insertLogSql
        _ =
          bindAndExecuteCommand
            pc (Db.pt src ++ Db.pt outcome ++ Db.pot target ++ Db.pot reason)
        PreparedCommand.close pc
  ()

Rename.writeOutcomeWith pc o =
  use List ++
  (src, outcome, target, reason) = Rename.Outcome.parts o
  _ = 
    catch do
      bindAndExecuteCommand
        pc (Db.pt src ++ Db.pt outcome ++ Db.pot target ++ Db.pot reason)
  ()

Tmdb.cachePath : Text -> FilePath
Tmdb.cachePath folderName =
  use Text ++
  FilePath (Tmdb.cacheRoot ++ "/" ++ folderName ++ ".json")

Tmdb.writeCacheEntry : Text -> Either Text Tmdb.SearchResponse ->{IO} ()
Tmdb.writeCacheEntry folderName result =
  use Tmdb.CachedSearch CachedSearch
  entry = match result with
    Right r -> CachedSearch folderName (Some r) None
    Left e  -> CachedSearch folderName None (Some e)
  payload = Json.toText (Tmdb.CachedSearch.toJson entry)
  _ = catch do writeFileUtf8 (Tmdb.cachePath folderName) payload
  ()

type Tmdb.Result
  = { tmdbId : Nat,
      title : Text,
      originalTitle : Text,
      originalLanguage : Text,
      releaseDate : Text,
      popularity : Float,
      overview : Text }

Tmdb.detailsRequest : Text -> Nat -> HttpRequest
Tmdb.detailsRequest token tmdbId =
  use HttpRequest addHeader
  use Text ++
  HttpRequest.get (Tmdb.detailsURI tmdbId)
    |> addHeader "Authorization" ("Bearer " ++ token)
    |> addHeader "Accept" "application/json"

Tmdb.fetchDetailsBody : Text -> Nat ->{IO} Either Text Text
Tmdb.fetchDetailsBody token tmdbId =
  req = Tmdb.detailsRequest token tmdbId
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          bodyText ok
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Tmdb.selectDetailsSql =
  sql "SELECT details_json FROM tmdb_details_cache WHERE tmdb_id = "
    %% var integer
    |> typedQuery Codec.text

Tmdb.upsertDetailsSql =
  sql "INSERT INTO tmdb_details_cache (tmdb_id, details_json) VALUES ("
    %% var integer
    %% sql ", "
    %% var Codec.text
    %% sql
         ") ON CONFLICT (tmdb_id) DO UPDATE SET details_json = EXCLUDED.details_json, fetched_at = NOW()"
    |> buildCommand

Tmdb.readDetailsBodyWith pq tmdbId = match 
  catch do
    portal = bindQuery pq (Db.pi (Nat.toInt tmdbId))
    (rows, _) = executeQueryPortal portal 0
    rows
 with
  Left _   -> None
  Right rs ->
    match rs with
      []       -> None
      raw +: _ -> Some raw

Tmdb.writeDetailsBodyWith pc tmdbId body =
  use List ++
  _ = 
    catch do bindAndExecuteCommand pc (Db.pi (Nat.toInt tmdbId) ++ Db.pt body)
  ()

Tmdb.cachedDetailsWith pq pc token tmdbId =
  parse body = match catch do Decoder.run Tmdb.Details.fromJson body with
    Right d -> Right d
    Left f  -> Left (Failure.message f)
  match Tmdb.readDetailsBodyWith pq tmdbId with
    Some body -> parse body
    None      ->
      match Tmdb.fetchDetailsBody token tmdbId with
        Left err   -> Left err
        Right body ->
          _ = Tmdb.writeDetailsBodyWith pc tmdbId body
          parse body

Tmdb.runtimeWinner pq pc token probeMin tied =
  use Nat - <= >
  tolerance = 15
  checkOne candidate =
    (r, _) = candidate
    match Tmdb.cachedDetailsWith pq pc token (Tmdb.Result.tmdbId r) with
      Right d ->
        rt = Tmdb.Details.runtime d
        if Universal.eq rt 0 then None
        else
          diff = if rt > probeMin then rt - probeMin else probeMin - rt
          if diff <= tolerance then Some candidate else None
      Left _  -> None
  inRange = List.filterMap checkOne tied
  match inRange with
    [only] -> Some only
    _      -> None

Tmdb.pickBestWithRuntime pqDet pcDet token maybeProbeMin scored =
  use Float *
  threshold = 40
  popularityRatio = 3.0
  belowThreshold n = n Nat.< threshold
  popularityClearWinner winner second =
    second * popularityRatio Float.< Tmdb.Result.popularity winner
  match Tmdb.maxScore scored with
    None -> None
    Some best ->
      if belowThreshold best then None
      else
        tied = List.filter (cases (_, s) -> Universal.eq s best) scored
        match tied with
          [] -> None
          [only] -> Some only
          _ ->
            runtimePick =
              match maybeProbeMin with
                Some probeMin ->
                  Tmdb.runtimeWinner pqDet pcDet token probeMin tied
                None -> None
            match runtimePick with
              Some w -> Some w
              None ->
                match Tmdb.popularityWinner tied with
                  Some (winner, second) ->
                    (rWinner, _) = winner
                    if popularityClearWinner rWinner second then Some winner
                    else None
                  None -> None

Tmdb.tokenOverlapPercent : Text -> Text -> Nat
Tmdb.tokenOverlapPercent a b =
  use Nat * / < >
  use Universal eq
  toks t = List.filter (p -> Text.size p > 0) (Text.split ?\s t)
  ta = toks a
  tb = toks b
  if eq (List.size ta) 0 then 0
  else
    if eq (List.size tb) 0 then 0
    else
      smaller = if List.size ta < List.size tb then ta else tb
      larger = if List.size ta < List.size tb then tb else ta
      matching =
        List.filter
          (tok -> List.any (s -> eq s tok) larger) smaller
      List.size matching * 100 / List.size smaller

Tmdb.pickBest : [(Tmdb.Result, Nat)] -> Optional (Tmdb.Result, Nat)
Tmdb.pickBest scored =
  use Float *
  threshold = 40
  popularityRatio = 3.0
  belowThreshold n = n Nat.< threshold
  popularityClearWinner winner second =
    second * popularityRatio Float.< Tmdb.Result.popularity winner
  match Tmdb.maxScore scored with
    None -> None
    Some best ->
      if belowThreshold best then None
      else
        tied = List.filter (cases (_, s) -> Universal.eq s best) scored
        match tied with
          [] -> None
          [only] -> Some only
          _ ->
            match Tmdb.popularityWinner tied with
              Some (winner, second) ->
                (rWinner, _) = winner
                if popularityClearWinner rWinner second then Some winner
                else None
              None -> None

