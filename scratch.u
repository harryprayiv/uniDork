Db.upsertWith :
  PreparedCommand r20 a20
  -> PreparedCommand r19 a19
  -> PreparedCommand r18 a18
  -> PreparedCommand r17 a17
  -> PreparedCommand r16 a16
  -> PreparedCommand r15 a15
  -> PreparedCommand r14 a14
  -> PreparedCommand r13 a13
  -> PreparedCommand r12 a12
  -> PreparedCommand r11 a11
  -> PreparedCommand r10 a10
  -> PreparedCommand r9 a9
  -> PreparedCommand r8 a8
  -> PreparedCommand r7 a7
  -> PreparedCommand r6 a6
  -> PreparedCommand r5 a5
  -> PreparedCommand r4 a4
  -> PreparedCommand r3 a3
  -> PreparedCommand r2 a2
  -> PreparedCommand r1 a1
  -> PreparedCommand r a
  -> Optional Nat
  -> Movie
  ->{IO, Exception, Postgres} ()
Db.upsertWith
  pcUpsert
  pcVid
  pcDVid
  pcAud
  pcDAud
  pcSub
  pcDSub
  pcAct
  pcDAct
  pcGen
  pcDGen
  pcTag
  pcDTag
  pcCou
  pcDCou
  pcStu
  pcDStu
  pcDir
  pcDDir
  pcCre
  pcDCre
  actualRuntimeSec
  m = 
  transaction do
    use Db foreach_ pi
    use List ++
    use Movie checksum id
    use Nat toInt
    use Optional map
    k = kodi (id m)
    csum = Optional.getOrElse "" (checksum m)
    mid = id m
    t = Movie.title m
    s = scoring m
    sd = FileInfo.streams (fileInfo m)
    vid = StreamDetails.video sd
    tax = taxonomy m
    fm = folderMeta m
    indexedAudios = withIndex (StreamDetails.audios sd)
    indexedSubs = withIndex (StreamDetails.subtitles sd)
    indexedActors = withIndex (actors m)
    del pc =
      _ = bindAndExecuteCommand pc (pt csum)
      ()
    repList delPc insPc vals =
      _ = del delPc
      foreach_ (v -> bindAndExecuteCommand insPc (pt csum ++ pt v)) vals
    _ = printLine (Text.join "" ["upserting: ", k, " (", csum, ")"])
    _ =
      bindAndExecuteCommand
        pcUpsert
        (pt k
          ++ pot (MovieId.imdb mid)
          ++ pot (MovieId.tmdb mid)
          ++ pot (tvdb mid)
          ++ pt (display t)
          ++ pt (original t)
          ++ pt (Title.sort t)
          ++ pot (Movie.collection m)
          ++ poi (map toInt (Scoring.year s))
          ++ pf (rating s)
          ++ pi (toInt (votes s))
          ++ pt (Scoring.mpaa s)
          ++ poi (map toInt (Movie.runtime m))
          ++ pt (plot m)
          ++ pt (Movie.tagline m)
          ++ pot (folderPath m)
          ++ pot (nfoPath m)
          ++ pot (videoFilePath m)
          ++ pobi (map toInt (fileSizeBytes m))
          ++ pot (checksum m)
          ++ pot (rawSize fm)
          ++ pot (resolution fm)
          ++ pot (videoCodec fm)
          ++ poi (map toInt (FolderMeta.bitDepth fm))
          ++ poi (map toInt (runtimeMin fm))
          ++ poi (map toInt actualRuntimeSec))
    _ = del pcDVid
    _ =
      bindAndExecuteCommand
        pcVid
        (pt csum
          ++ pt (Video.codec vid)
          ++ pf (aspect vid)
          ++ pi (toInt (Video.width vid))
          ++ pi (toInt (Video.height vid)))
    _ = del pcDAud
    _ =
      foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAud
              (pt csum
                ++ pi (toInt i)
                ++ pt (Audio.codec a)
                ++ pt (Audio.language a)
                ++ pi (toInt (Audio.channels a))))
        indexedAudios
    _ = del pcDSub
    _ =
      foreach_
        (cases
          (i, sub) ->
            bindAndExecuteCommand
              pcSub (pt csum ++ pi (toInt i) ++ pt (Subtitle.language sub)))
        indexedSubs
    _ = del pcDAct
    _ =
      foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAct
              (pt csum ++ pi (toInt i) ++ pt (Actor.name a) ++ pt (role a)))
        indexedActors
    _ = repList pcDGen pcGen (Taxonomy.genres tax)
    _ = repList pcDTag pcTag (Taxonomy.tags tax)
    _ = repList pcDCou pcCou (countries tax)
    _ = repList pcDStu pcStu (studios tax)
    _ = repList pcDDir pcDir (Taxonomy.directors tax)
    _ = repList pcDCre pcCre (Taxonomy.credits tax)
    ()

Db.withIndex : [a] -> [(Nat, a)]
Db.withIndex xs =
  use List +:
  use Nat +
  go acc i = cases
    []      -> List.reverse acc
    x +: ys -> go ((i, x) +: acc) (i + 1) ys
  go [] 0 xs

demo : '{IO, Exception} ()
demo =
  do
    use Text ++
    token = Subs.readToken()
    outcomes =
      fetchAndSaveByImdb
        token
        "tt1375666"
        (FilePath "/tmp/subs-test")
        "inception"
        ["en", "es", "th"]
    Db.foreach_
      (cases
        Saved lang p   -> printLine ("saved " ++ lang ++ " -> " ++ p)
        NotFound lang  -> printLine ("none for " ++ lang)
        Errored lang e -> printLine ("error " ++ lang ++ ": " ++ e)) outcomes

emptyFolderMeta : FolderMeta
emptyFolderMeta = FolderMeta None None None None None None

exampleMovie : Movie
exampleMovie =
  use Actor Actor
  Movie
    (MovieId "tt0167260" (Some "tt0167260") (Some "122") None)
    (Title
      "The Lord of the Rings: The Return of the King"
      "The Lord of the Rings: The Return of the King"
      "Lord of the Rings, The: The Return of the King")
    (Some "The Lord of the Rings Collection")
    (Some 201)
    (Scoring (Some 2003) 8.9 12000 "PG-13")
    "Aragorn leads the World of Men against Sauron's army..."
    "The eye of the enemy is moving."
    (Taxonomy
      ["Adventure", "Fantasy"]
      []
      ["New Zealand", "United States"]
      ["New Line Cinema"]
      ["Peter Jackson"]
      ["Fran Walsh"])
    (FileInfo
      (StreamDetails
        (Video.Video "h264" 2.39 1920 800)
        [Audio "ac3" "eng" 6]
        [Subtitle "eng"]))
    (Some "/movies/lotr-rotk/lotr-rotk.mkv")
    (Some "a3f1c9")
    [Actor "Elijah Wood" "Frodo Baggins", Actor "Viggo Mortensen" "Aragorn"]
    (Some "/movies/lotr-rotk")
    (Some "/movies/lotr-rotk/lotr-rotk.nfo")
    None
    emptyFolderMeta

FileInfo.fromJson : '{unison_json_1_4_2.Decoder} FileInfo
FileInfo.fromJson = do
  streams = object.at! "streams" StreamDetails.fromJson
  FileInfo streams

FileInfo.toJson : FileInfo -> Json
FileInfo.toJson f =
  Json.object [("streams", StreamDetails.toJson (FileInfo.streams f))]

filePathBasename : FilePath -> Text
filePathBasename fp = match List.reverse (Text.split ?/ (filePathText fp)) with
  last +: _ -> last
  []        -> filePathText fp

filePathText : FilePath -> Text
filePathText = cases FilePath t -> t

findFirstNfo : [Text] -> Optional Text
findFirstNfo = List.find isNfo

findFirstVideo : [Text] -> Optional Text
findFirstVideo = List.find isVideo

FolderMeta.fromJson : '{unison_json_1_4_2.Decoder} FolderMeta
FolderMeta.fromJson = do
  use Decoder nat optional! text
  use object at
  rawSize = optional! (at "rawSize" text)
  resolution = optional! (at "resolution" text)
  videoCodec = optional! (at "videoCodec" text)
  bitDepth = optional! (at "bitDepth" nat)
  runtimeMin = optional! (at "runtimeMin" nat)
  checksum = optional! (at "checksum" text)
  FolderMeta rawSize resolution videoCodec bitDepth runtimeMin checksum

FolderMeta.toJson : FolderMeta -> Json
FolderMeta.toJson f =
  use Json nat text
  Json.object
    [ ("rawSize", toJsonOpt text (rawSize f))
    , ("resolution", toJsonOpt text (resolution f))
    , ("videoCodec", toJsonOpt text (videoCodec f))
    , ("bitDepth", toJsonOpt nat (FolderMeta.bitDepth f))
    , ("runtimeMin", toJsonOpt nat (runtimeMin f))
    , ("checksum", toJsonOpt text (FolderMeta.checksum f))
    ]

isNfo : Text -> Boolean
isNfo name = endsWith ".nfo" name

isVideo : Text -> Boolean
isVideo name =
  lower = Text.toLowercase name
  List.any (ext -> endsWith ext lower) videoExtensions

leftToOpt : Either a b -> Optional a
leftToOpt = cases
  Left p  -> Some p
  Right _ -> None

List.chunk : Nat -> [a] -> [[a]]
List.chunk n xs =
  use List +: size
  use Nat <=
  if Universal.eq (size xs) 0 then []
  else
    if size xs <= n then [xs]
    else List.take n xs +: List.chunk n (List.drop n xs)

List.distinctText : [Text] -> [Text]
List.distinctText xs =
  use List :+
  step acc x = if List.any (y -> Universal.eq x y) acc then acc else acc :+ x
  List.foldLeft step [] xs

Movie.fromJson : '{unison_json_1_4_2.Decoder} Movie
Movie.fromJson =
  do
    use Decoder nat optional! text
    use object at at!
    id = at! "id" MovieId.fromJson
    title = at! "title" Title.fromJson
    collection = optional! (at "collection" text)
    runtime = optional! (at "runtime" nat)
    scoring = at! "scoring" Scoring.fromJson
    plot = at! "plot" text
    tagline = at! "tagline" text
    taxonomy = at! "taxonomy" Taxonomy.fromJson
    fileInfo = at! "fileInfo" FileInfo.fromJson
    videoFilePath = optional! (at "videoFilePath" text)
    checksum = optional! (at "checksum" text)
    actors = at! "actors" (Decoder.array Actor.fromJson)
    folderPath = optional! (at "folderPath" text)
    nfoPath = optional! (at "nfoPath" text)
    fileSizeBytes = optional! (at "fileSizeBytes" nat)
    folderMeta = at! "folderMeta" FolderMeta.fromJson
    Movie
      id
      title
      collection
      runtime
      scoring
      plot
      tagline
      taxonomy
      fileInfo
      videoFilePath
      checksum
      actors
      folderPath
      nfoPath
      fileSizeBytes
      folderMeta

Movie.fromNdjsonLine : Text -> Either Failure Movie
Movie.fromNdjsonLine line = catch do Decoder.run Movie.fromJson (trim line)

test> Movie.roundtrip.test =
  encoded = toNdjsonLine exampleMovie
  match fromNdjsonLine encoded with
    Left failure -> [Fail (Failure.message failure)]
    Right m      -> check (Universal.eq m exampleMovie)

Movie.toJson : Movie -> Json
Movie.toJson m =
  use Json nat text
  Json.object
    [ ("id", MovieId.toJson (Movie.id m))
    , ("title", Title.toJson (Movie.title m))
    , ("collection", toJsonOpt text (Movie.collection m))
    , ("runtime", toJsonOpt nat (Movie.runtime m))
    , ("scoring", Scoring.toJson (scoring m))
    , ("plot", text (plot m))
    , ("tagline", text (Movie.tagline m))
    , ("taxonomy", Taxonomy.toJson (taxonomy m))
    , ("fileInfo", FileInfo.toJson (fileInfo m))
    , ("videoFilePath", toJsonOpt text (videoFilePath m))
    , ("checksum", toJsonOpt text (Movie.checksum m))
    , ("actors", Json.array (List.map Actor.toJson (actors m)))
    , ("folderPath", toJsonOpt text (folderPath m))
    , ("nfoPath", toJsonOpt text (nfoPath m))
    , ("fileSizeBytes", toJsonOpt nat (fileSizeBytes m))
    , ("folderMeta", FolderMeta.toJson (folderMeta m))
    ]

Movie.toNdjsonLine : Movie -> Text
Movie.toNdjsonLine m =
  use Text ++
  Json.toText (Movie.toJson m) ++ "\n"

MovieId.fromJson : '{unison_json_1_4_2.Decoder} MovieId
MovieId.fromJson = do
  use Decoder optional! text
  use object at
  kodi = object.at! "kodi" text
  imdb = optional! (at "imdb" text)
  tmdb = optional! (at "tmdb" text)
  tvdb = optional! (at "tvdb" text)
  MovieId kodi imdb tmdb tvdb

MovieId.toJson : MovieId -> Json
MovieId.toJson m =
  use Json text
  Json.object
    [ ("kodi", text (kodi m))
    , ("imdb", toJsonOpt text (MovieId.imdb m))
    , ("tmdb", toJsonOpt text (MovieId.tmdb m))
    , ("tvdb", toJsonOpt text (tvdb m))
    ]

Nfo.actorBlock : (Text, Text) -> [Text]
Nfo.actorBlock = cases
  (name, role) ->
    use Text ++
    esc = escapeXml
    [ "  <actor>"
    , "    <name>" ++ esc name ++ "</name>"
    , "    <role>" ++ esc role ++ "</role>"
    , "  </actor>"
    ]

Nfo.allText : Soup ->{Throw XMLError} Text
Nfo.allText s = Text.join "" (Soup.texts s)

Nfo.aspectRatio : Nat -> Nat -> Text
Nfo.aspectRatio w h =
  use Nat % * + / toText
  use Text ++
  if Universal.eq h 0 then "0.000"
  else
    rounded = (w * 1000 + h / 2) / h
    whole = rounded / 1000
    frac = rounded % 1000
    fracStr = padLeft 3 "0" (toText frac)
    toText whole ++ "." ++ fracStr

test> Nfo.aspectRatio.test =
  use Universal eq
  List.flatMap
    check
    [ eq (aspectRatio 1920 1080) "1.778"
    , eq (aspectRatio 640 480) "1.333"
    , eq (aspectRatio 1280 720) "1.778"
    , eq (aspectRatio 100 100) "1.000"
    , eq (aspectRatio 100 0) "0.000"
    ]

Nfo.audioBlock : AudioInfo -> [Text]
Nfo.audioBlock a =
  use Text ++
  esc = escapeXml
  [ "      <audio>"
  , "        <codec>" ++ esc (AudioInfo.codec a) ++ "</codec>"
  , "        <language>" ++ esc (AudioInfo.language a) ++ "</language>"
  , "        <channels>" ++ Nat.toText (AudioInfo.channels a) ++ "</channels>"
  , "      </audio>"
  ]

Nfo.countryLine : Text -> Text
Nfo.countryLine c =
  use Text ++
  "  <country>" ++ escapeXml c ++ "</country>"

Nfo.dedup : [Movie] -> [Movie]
Nfo.dedup movies =
  step : Map Text Movie -> Movie -> Map Text Movie
  step acc m =
    use Map insert
    use Movie collection
    id = kodi (Movie.id m)
    match Map.get id acc with
      None          -> insert id m acc
      Some existing ->
        merged = match (collection existing, collection m) with
          (None, Some _) -> Movie.collection.set (collection m) existing
          _              -> existing
        insert id merged acc
  Map.values (List.foldLeft step Map.empty movies)

Nfo.descendantAttr : Text -> Text -> Soup -> Optional Text
Nfo.descendantAttr elemName attrName s = 
  Throw.toOptional do Soup.attribute attrName (Soup.findFirst elemName s)

Nfo.directorLine : Text -> Text
Nfo.directorLine d =
  use Text ++
  "  <director>" ++ escapeXml d ++ "</director>"

Nfo.extractChecksum : Text -> Optional Text
Nfo.extractChecksum _ = None

Nfo.extractImdbId : Movie -> Optional Text
Nfo.extractImdbId m = MovieId.imdb (Movie.id m)

Nfo.extractTitle : Movie -> Optional Text
Nfo.extractTitle m =
  t = display (Movie.title m)
  if Universal.eq (Text.size t) 0 then None else Some t

Nfo.extractTmdbId : Movie -> Optional Nat
Nfo.extractTmdbId m = match MovieId.tmdb (Movie.id m) with
  None   -> None
  Some s -> Nat.fromText (trim s)

Nfo.extractYear : Movie -> Optional Nat
Nfo.extractYear m = Scoring.year (scoring m)

Nfo.fileinfoBlock : ProbeResult -> [Text]
Nfo.fileinfoBlock pr =
  use List flatMap
  use Nat toText
  esc = escapeXml
  vid = ProbeResult.video pr
  vc = VideoInfo.codec vid
  vw = VideoInfo.width vid
  vh = VideoInfo.height vid
  videoLines =
    [ "      <video>"
    , "        <codec>" Text.++ esc vc Text.++ "</codec>"
    , "        <aspect>" Text.++ aspectRatio vw vh Text.++ "</aspect>"
    , "        <width>" Text.++ toText vw Text.++ "</width>"
    , "        <height>" Text.++ toText vh Text.++ "</height>"
    , "      </video>"
    ]
  audioLines = flatMap audioBlock (ProbeResult.audios pr)
  subtitleLines = flatMap subtitleBlock (ProbeResult.subtitles pr)
  result =
    ["  <fileinfo>", "    <streamdetails>"]
      List.++ videoLines
      List.++ audioLines
      List.++ subtitleLines
      List.++ ["    </streamdetails>", "  </fileinfo>"]
  result

Nfo.floatOr : Float -> Text -> Float
Nfo.floatOr default t = Optional.getOrElse default (Float.fromText t)

Nfo.generate : Tmdb.Result -> Details -> ProbeResult -> Text
Nfo.generate _r d pr =
  use Details title
  use List map
  use Nat >
  use Text join size
  use Universal eq
  esc = escapeXml
  yearText = match releaseYear (Details.releaseDate d) with
    Some y -> Nat.toText y
    None   -> ""
  releaseDate = Details.releaseDate d
  imdbId = Optional.getOrElse "" (Details.imdbId d)
  tmdbText = Nat.toText (Details.tmdbId d)
  crc32 = ProbeResult.crc32 pr
  sortTitle = Nfo.sortTitle (title d) releaseDate
  setBlock = match Details.collection d with
    Some col -> ["  <set>" Text.++ esc col Text.++ "</set>"]
    None     -> ["  <set />"]
  premieredBlock =
    if size releaseDate > 0 then
      ["  <premiered>" Text.++ esc releaseDate Text.++ "</premiered>"]
    else []
  tmdbUniqueId =
    [ join
        ""
        [ "  <uniqueid type=\"tmdb\" default=\"true\">"
        , tmdbText
        , "</uniqueid>"
        ]
    ]
  imdbUniqueId =
    if eq (size imdbId) 0 then []
    else [join "" ["  <uniqueid type=\"imdb\">", esc imdbId, "</uniqueid>"]]
  crcUniqueId =
    if eq (size crc32) 0 then []
    else [join "" ["  <uniqueid type=\"crc32\">", esc crc32, "</uniqueid>"]]
  uniqueIdLines = tmdbUniqueId List.++ imdbUniqueId List.++ crcUniqueId
  genreLines = map genreLine (Details.genres d)
  tagLines = map tagLine (Details.tags d)
  countryLines = map countryLine (Details.productionCountries d)
  studioLines = map studioLine (productionStudios d)
  directorLines = map directorLine (Details.directors d)
  writerLines = map writerLine (Details.writers d)
  actorLines = List.flatMap actorBlock (Details.cast d)
  fileinfoLines = fileinfoBlock pr
  header =
    [ "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\" ?>"
    , "<movie>"
    , "  <title>" Text.++ esc (title d) Text.++ "</title>"
    , "  <originaltitle>"
        Text.++ esc (Details.originalTitle d)
        Text.++ "</originaltitle>"
    , "  <sorttitle>" Text.++ esc sortTitle Text.++ "</sorttitle>"
    ]
  scoring =
    [ "  <year>" Text.++ yearText Text.++ "</year>"
    , "  <rating>"
        Text.++ Float.toText (Details.voteAverage d)
        Text.++ "</rating>"
    , "  <votes>" Text.++ Nat.toText (Details.voteCount d) Text.++ "</votes>"
    , "  <mpaa>" Text.++ esc (Details.mpaa d) Text.++ "</mpaa>"
    , "  <id>" Text.++ esc imdbId Text.++ "</id>"
    ]
  plotEtc =
    [ "  <plot>" Text.++ esc (Details.overview d) Text.++ "</plot>"
    , "  <tagline>" Text.++ esc (Details.tagline d) Text.++ "</tagline>"
    , "  <runtime>" Text.++ Nat.toText (Details.runtime d) Text.++ "</runtime>"
    ]
  imdbElem =
    if eq (size imdbId) 0 then []
    else
      [ join
          ""
          [ "  <imdb id='"
          , imdbId
          , "'>http://www.imdb.com/title/"
          , imdbId
          , "</imdb>"
          ]
      ]
  tmdbElem =
    [ join
        ""
        [ "  <tmdb id='"
        , tmdbText
        , "'>http://www.themoviedb.org/movie/"
        , tmdbText
        , "</tmdb>"
        ]
    ]
  urlElems = imdbElem List.++ tmdbElem
  footer = ["</movie>", ""]
  allLines =
    header
      List.++ setBlock
      List.++ scoring
      List.++ premieredBlock
      List.++ uniqueIdLines
      List.++ plotEtc
      List.++ genreLines
      List.++ tagLines
      List.++ countryLines
      List.++ studioLines
      List.++ actorLines
      List.++ directorLines
      List.++ writerLines
      List.++ fileinfoLines
      List.++ urlElems
      List.++ footer
  join "\n" allLines

Nfo.genreLine : Text -> Text
Nfo.genreLine g =
  use Text ++
  "  <genre>" ++ escapeXml g ++ "</genre>"

Nfo.missingToNdjson : [FilePath] -> Text
Nfo.missingToNdjson ps =
  use Text ++
  Text.join
    "" (List.map (p -> Json.toText (Json.text (filePathText p)) ++ "\n") ps)

Nfo.natOr : Nat -> Text -> Nat
Nfo.natOr default t = Optional.getOrElse default (Nat.fromText t)

Nfo.optText : Text -> Soup -> Optional Text
Nfo.optText tag s = match tryXml do allText (Soup.findFirst tag s) with
  Some t -> if Universal.eq (Text.size t) 0 then None else Some t
  None   -> None

Nfo.padLeft : Nat -> Text -> Text -> Text
Nfo.padLeft target pad t =
  use Nat <
  use Text ++
  if Text.size t < target then Nfo.padLeft target pad (pad ++ t) else t

Nfo.parse : Text -> Either Text Movie
Nfo.parse xml = match withXML xml parseMovie with
  Left err       -> Left err
  Right (m +: _) -> Right m
  Right []       -> Left "no <movie> element found"

test> Nfo.parse.test =
  match Nfo.parse sampleNfo with
    Left err -> [Fail err]
    Right m ->
      check (Universal.eq (display (Movie.title m)) "The Return of the King")

Nfo.parseActor : Soup ->{Throw XMLError} Actor
Nfo.parseActor s =
  name = textOr "" "name" s
  role = textOr "" "role" s
  Actor.Actor name role

Nfo.parseActors : Soup -> [Actor]
Nfo.parseActors s = silentBranches do
  a = Soup.named "actor" s
  parseActor a

Nfo.parseAudio : Soup ->{Throw XMLError} Audio
Nfo.parseAudio s =
  codec = textOr "" "codec" s
  language = textOr "" "language" s
  channels = natOr 0 (textOr "0" "channels" s)
  Audio codec language channels

Nfo.parseCollection : Soup -> Optional Text
Nfo.parseCollection s =
  use Soup findFirst
  modern = Throw.toOptional do
    setElem = findFirst "set" s
    nameElem = findFirst "name" setElem
    allText nameElem
  match modern with
    Some n ->
      trimmed = trim n
      if Universal.eq (Text.size trimmed) 0 then optText "set" s
      else Some trimmed
    None -> optText "set" s

Nfo.parseFileInfo : Soup ->{Throw XMLError} FileInfo
Nfo.parseFileInfo s =
  streams = parseStreamDetails (Soup.findFirst "streamdetails" s)
  FileInfo streams

Nfo.parseFolderName : Text -> FolderMeta
Nfo.parseFolderName name =
  csum = textAfter "~" name
  brackets = textBetween "[" "]" name
  base = FolderMeta.checksum.set csum emptyFolderMeta
  match brackets with
    None -> base
    Some content ->
      List.foldLeft
        (acc p -> classifyPiece (trim p) acc) base (Text.split ?\s content)

Nfo.parseMovie : Soup ->{Throw XMLError} Movie
Nfo.parseMovie s =
  id = parseMovieId s
  title = parseTitle s
  collection = parseCollection s
  runtime = Optional.map (natOr 0) (optText "runtime" s)
  scoring = parseScoring s
  plot = textOr "" "plot" s
  tagline = textOr "" "tagline" s
  taxonomy = parseTaxonomy s
  fileInfo = match catch do parseFileInfo s with
    Left _  -> FileInfo (StreamDetails (Video.Video "" 0.0 0 0) [] [])
    Right f -> f
  Movie
    id
    title
    collection
    runtime
    scoring
    plot
    tagline
    taxonomy
    fileInfo
    None
    None
    (parseActors s)
    None
    None
    None
    emptyFolderMeta

Nfo.parseMovieId : Soup ->{Throw XMLError} MovieId
Nfo.parseMovieId s =
  imdb = match uniqueIdOfType "imdb" s with
    Some v -> Some v
    None   -> descendantAttr "imdb" "id" s
  tmdb = match uniqueIdOfType "tmdb" s with
    Some v -> Some v
    None   -> descendantAttr "tmdb" "id" s
  tvdb = match uniqueIdOfType "tvdb" s with
    Some v -> Some v
    None   -> descendantAttr "tvdb" "id" s
  kodi = match optText "id" s with
    Some k -> k
    None   -> Optional.getOrElse "" imdb
  MovieId kodi imdb tmdb tvdb

Nfo.parseRatingAndVotes : Soup -> (Float, Nat)
Nfo.parseRatingAndVotes s =
  use List find
  use Optional getOrElse
  use Soup attribute findFirst
  use Throw toOptional
  use Universal eq
  ratingsElem = toOptional do findFirst "ratings" s
  match ratingsElem with
    None    ->
      r = floatOr 0.0 (textOr "0" "rating" s)
      v = natOr 0 (textOr "0" "votes" s)
      (r, v)
    Some rs ->
      candidates : [(Optional Text, Optional Text, Float, Nat)]
      candidates = silentBranches do
        r = Soup.named "rating" rs
        name = toOptional do attribute "name" r
        dflt = toOptional do attribute "default" r
        valStr = allText (findFirst "value" r)
        votesStr = allText (findFirst "votes" r)
        val = getOrElse 0.0 (Float.fromText (trim valStr))
        vc = getOrElse 0 (Nat.fromText (trim votesStr))
        (name, dflt, val, vc)
      defaultMatch = find (cases (_, d, _, _) -> eq d (Some "true")) candidates
      imdbMatch = find (cases (n, _, _, _) -> eq n (Some "imdb")) candidates
      best = match defaultMatch with
        Some x -> Some x
        None   ->
          match imdbMatch with
            Some x -> Some x
            None   -> List.head candidates
      match best with
        Some (_, _, r, v) -> (r, v)
        None              -> (0.0, 0)

Nfo.parseScoring : Soup ->{Throw XMLError} Scoring
Nfo.parseScoring s =
  year = Optional.map (natOr 0) (optText "year" s)
  (rating, votes) = parseRatingAndVotes s
  mpaa = textOr "" "mpaa" s
  Scoring year rating votes mpaa

Nfo.parseStreamDetails : Soup ->{Throw XMLError} StreamDetails
Nfo.parseStreamDetails s =
  use Soup named
  video = parseVideo (Soup.findFirst "video" s)
  audios = silentBranches do
    a = named "audio" s
    parseAudio a
  subs = silentBranches do
    sb = named "subtitle" s
    parseSubtitle sb
  StreamDetails video audios subs

Nfo.parseSubtitle : Soup ->{Throw XMLError} Subtitle
Nfo.parseSubtitle s =
  language = textOr "" "language" s
  Subtitle language

Nfo.parseTaxonomy : Soup -> Taxonomy
Nfo.parseTaxonomy s =
  use Nfo texts
  Taxonomy
    (texts "genre" s)
    (texts "tag" s)
    (texts "country" s)
    (texts "studio" s)
    (texts "director" s)
    (texts "credits" s)

Nfo.parseTitle : Soup ->{Throw XMLError} Title
Nfo.parseTitle s =
  display = textOr "" "title" s
  original = textOr "" "originaltitle" s
  sort = textOr "" "sorttitle" s
  Title display original sort

Nfo.parseVideo : Soup ->{Throw XMLError} Video
Nfo.parseVideo s =
  codec = textOr "" "codec" s
  aspect = floatOr 0.0 (textOr "0" "aspect" s)
  width = natOr 0 (textOr "0" "width" s)
  height = natOr 0 (textOr "0" "height" s)
  Video.Video codec aspect width height

Nfo.processFolder : FilePath ->{IO, Exception} Either FilePath Movie
Nfo.processFolder folder =
  files = directoryContents.texts folder
  match findFirstNfo files with
    None -> Left folder
    Some nfoName ->
      nfoFp = pathJoin folder nfoName
      xml = readFileUtf8 nfoFp
      match Nfo.parse xml with
        Left _ -> Left folder
        Right m ->
          videoPath =
            Optional.map
              (vf -> filePathText (pathJoin folder vf)) (findFirstVideo files)
          folderName = filePathBasename folder
          folderMeta = parseFolderName folderName
          Right
            (m
              |> videoFilePath.set videoPath
              |> Movie.checksum.set (FolderMeta.checksum folderMeta)
              |> folderPath.set (Some (filePathText folder))
              |> nfoPath.set (Some (filePathText nfoFp))
              |> folderMeta.set folderMeta)

Nfo.requireText : Text -> Soup ->{Throw XMLError} Text
Nfo.requireText tag s = allText (Soup.findFirst tag s)

Nfo.sortTitle : Text -> Text -> Text
Nfo.sortTitle title releaseDate =
  use Nat >
  use Text ++ drop
  lower = Text.toLowercase title
  stripped =
    if startsWith "the " lower then drop 4 title
    else
      if startsWith "an " lower then drop 3 title
      else if startsWith "a " lower then drop 2 title else title
  if Text.size releaseDate > 0 then stripped ++ " :: " ++ releaseDate
  else stripped

test> Nfo.sortTitle.test =
  use Universal eq
  List.flatMap
    check
    [ eq (sortTitle "A Lobster Tale" "2006-01-01") "Lobster Tale :: 2006-01-01"
    , eq (sortTitle "The Matrix" "1999-03-31") "Matrix :: 1999-03-31"
    , eq
        (sortTitle "An American Tail" "1986-11-21")
        "American Tail :: 1986-11-21"
    , eq (sortTitle "Inception" "2010-07-15") "Inception :: 2010-07-15"
    , eq (sortTitle "Inception" "") "Inception"
    ]

Nfo.studioLine : Text -> Text
Nfo.studioLine s =
  use Text ++
  "  <studio>" ++ escapeXml s ++ "</studio>"

Nfo.subtitleBlock : SubtitleInfo -> [Text]
Nfo.subtitleBlock s =
  use Text ++
  esc = escapeXml
  [ "      <subtitle>"
  , "        <language>" ++ esc (SubtitleInfo.language s) ++ "</language>"
  , "      </subtitle>"
  ]

Nfo.tagLine : Text -> Text
Nfo.tagLine t =
  use Text ++
  "  <tag>" ++ escapeXml t ++ "</tag>"

Nfo.textOr : Text -> Text -> Soup -> Text
Nfo.textOr default tag s = Optional.getOrElse default (optText tag s)

Nfo.texts : Text -> Soup -> [Text]
Nfo.texts tag s = silentBranches do
  g = Soup.named tag s
  allText g

Nfo.toNdjson : [Movie] -> Text
Nfo.toNdjson ms = Text.join "" (List.map toNdjsonLine ms)

Nfo.tryReadFolder : FilePath ->{IO, Exception} Optional Movie
Nfo.tryReadFolder folder =
  files = directoryContents.texts folder
  match findFirstNfo files with
    None         -> None
    Some nfoName ->
      nfoPath = pathJoin folder nfoName
      match catch do readFileUtf8 nfoPath with
        Left _    -> None
        Right xml ->
          match Nfo.parse xml with
            Left _  -> None
            Right m -> Some m

Nfo.uniqueIdOfType : Text -> Soup -> Optional Text
Nfo.uniqueIdOfType wantType s =
  candidates : [(Text, Text)]
  candidates = silentBranches do
    u = Soup.named "uniqueid" s
    typeAttr = Soup.attribute "type" u
    textVal = allText u
    (typeAttr, textVal)
  match List.find (cases (t, _) -> Universal.eq t wantType) candidates with
    Some (_, v) -> Some (trim v)
    None        -> None

Nfo.writerLine : Text -> Text
Nfo.writerLine w =
  use Text ++
  "  <credits>" ++ escapeXml w ++ "</credits>"

parseConfigLine : Text -> Optional FilePath
parseConfigLine l =
  trimmed = trim l
  if Universal.eq (Text.size trimmed) 0 then None else Some (FilePath trimmed)

parseNatBefore : Text -> Text -> Optional Nat
parseNatBefore suffix t =
  use Nat -
  use Text size
  if endsWith suffix t then
    sz = size t - size suffix
    Nat.fromText (Text.take sz t)
  else None

pathJoin : FilePath -> Text -> FilePath
pathJoin base name =
  use Text ++
  (FilePath t) = base
  FilePath (t ++ "/" ++ name)

primaryAudio : Movie -> Optional Audio
primaryAudio m =
  match StreamDetails.audios (FileInfo.streams (fileInfo m)) with
    a +: _ -> Some a
    []     -> None

Probe.AudioTrack.fromJson : '{unison_json_1_4_2.Decoder} AudioTrack
Probe.AudioTrack.fromJson =
  do
    use Decoder boolean nat optional! text
    use object at at!
    index = at! "index" nat
    codec = at! "codec" text
    language = optional! (at "language" text)
    title = optional! (at "title" text)
    channels = at! "channels" nat
    channelLayout = at! "channel_layout" text
    isDefault = at! "default" boolean
    isComment = at! "comment" boolean
    isVisualImpaired = at! "visual_impaired" boolean
    AudioTrack
      index
      codec
      language
      title
      channels
      channelLayout
      isDefault
      isComment
      isVisualImpaired

Probe.cacheRoot : Text
Probe.cacheRoot = "/home/bismuth/.cache/uniDork/ffprobe"

Probe.Format.fromJson : '{unison_json_1_4_2.Decoder} Format
Probe.Format.fromJson = do
  durStr = object.at! "duration" Decoder.text
  duration = parseFloat durStr
  sizeBytes = optNatStringAt "size"
  bitRate = optNatStringAt "bit_rate"
  Format duration sizeBytes bitRate

Probe.optNatStringAt : Text ->{unison_json_1_4_2.Decoder} Optional Nat
Probe.optNatStringAt key =
  match Decoder.optional! (object.at key Decoder.text) with
    None   -> None
    Some s -> Nat.fromText (trim s)

Probe.parseFloat : Text -> Float
Probe.parseFloat t = Optional.getOrElse 0.0 (Float.fromText (trim t))

Probe.readSidecar : Text ->{IO, Exception} Optional Probe.Result
Probe.readSidecar videoPath =
  use Text ++
  jsonPath = FilePath (Probe.cacheRoot ++ videoPath ++ ".json")
  match 
    catch do
      raw = readFileUtf8 jsonPath
      Decoder.run Probe.Result.fromJson raw
   with
    Left _  -> None
    Right r -> Some r

Probe.Result.fromJson : '{unison_json_1_4_2.Decoder} Probe.Result
Probe.Result.fromJson = do
  format = object.at! "format" Format.fromJson
  Probe.Result.Result format

Probe.runtimeSec : Probe.Result -> Nat
Probe.runtimeSec r =
  use Float <
  d = Format.duration (Result.format r)
  if d < 0.0 then 0
  else
    asText = Float.toText d
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    Optional.getOrElse 0 (Nat.fromText intPart)

Relang.bestOf : [AudioTrack] -> Optional AudioTrack
Relang.bestOf tracks =
  step acc cur = match acc with
    None      -> Some cur
    Some best -> if betterThan cur best then Some cur else Some best
  List.foldLeft step None tracks

Relang.betterThan : AudioTrack -> AudioTrack -> Boolean
Relang.betterThan a b =
  use AudioTrack channels codec index
  use Nat < max
  use Universal eq
  ca = channels a
  cb = channels b
  if eq ca cb then
    ra = codecRank (codec a)
    rb = codecRank (codec b)
    if eq ra rb then index a < index b
    else
      if eq ra (max ra rb) && (if eq ra rb then false else true) then true
      else false
  else if eq ca (max ca cb) then true else false

Relang.codecRank : Text -> Nat
Relang.codecRank c =
  lower = Text.toLowercase c
  isIn xs = List.any (x -> Universal.eq x lower) xs
  if isIn losslessCodecs then 2 else if isIn lossyCodecs then 1 else 0

Relang.containsAnySubstring : [Text] -> Text -> Boolean
Relang.containsAnySubstring needles haystack =
  List.any
    (n -> (match Text.indexOf n haystack with
      Some _ -> true
      None   -> false)) needles

Relang.currentDefault : [AudioTrack] -> Optional Nat
Relang.currentDefault tracks = match List.find isDefault tracks with
  Some t -> Some (AudioTrack.index t)
  None   -> None

Relang.decide : Text -> [AudioTrack] -> Decision
Relang.decide tmdbOrigLang tracks =
  match toIso6392 tmdbOrigLang with
    None -> UnsupportedLanguage tmdbOrigLang
    Some code ->
      match selectTrack code tracks with
        None -> OriginalNotPresent code
        Some tr ->
          chosenIdx = AudioTrack.index tr
          match currentDefault tracks with
            None -> NoCurrentDefault chosenIdx
            Some curIdx ->
              if Universal.eq curIdx chosenIdx then AlreadyCorrect curIdx
              else SwitchTo curIdx chosenIdx

Relang.Decision.toJson : Decision -> Json
Relang.Decision.toJson = cases
  AlreadyCorrect i ->
    Json.object
      [("kind", Json.text "already_correct"), ("default_index", Json.nat i)]
  SwitchTo o n ->
    Json.object
      [ ("kind", Json.text "switch")
      , ("old_default_index", Json.nat o)
      , ("new_default_index", Json.nat n)
      ]
  OriginalNotPresent code ->
    Json.object
      [ ("kind", Json.text "original_not_present")
      , ("expected_language", Json.text code)
      ]
  UnsupportedLanguage code ->
    Json.object
      [ ("kind", Json.text "unsupported_language")
      , ("tmdb_code", Json.text code)
      ]
  NoCurrentDefault i ->
    Json.object
      [("kind", Json.text "no_current_default"), ("chosen_index", Json.nat i)]

Relang.isCommentaryOrDescriptive : AudioTrack -> Boolean
Relang.isCommentaryOrDescriptive tr =
  if isComment tr then true
  else
    if isVisualImpaired tr then true
    else
      match AudioTrack.title tr with
        None    -> false
        Some tt -> titleSuggestsCommentary tt

Relang.losslessCodecs : [Text]
Relang.losslessCodecs =
  ["truehd", "dts-hd", "flac", "pcm_s24le", "pcm_s16le", "mlp"]

Relang.lossyCodecs : [Text]
Relang.lossyCodecs = ["dts", "eac3", "ac3", "aac", "opus", "vorbis", "mp3"]

Relang.selectTrack : Text -> [AudioTrack] -> Optional AudioTrack
Relang.selectTrack origLang3 tracks =
  use List filter
  use Universal eq
  strict = filter (t -> eq (AudioTrack.language t) (Some origLang3)) tracks
  candidates =
    if eq (List.size strict) 0 then filter (titleMatches origLang3) tracks
    else strict
  surviving =
    filter
      (t -> (if isCommentaryOrDescriptive t then false else true)) candidates
  bestOf surviving

Relang.splitMany : [Char] -> Text -> [Text]
Relang.splitMany seps t =
  step acc c = List.flatMap (p -> Text.split c p) acc
  result = List.foldLeft step [t] seps
  List.filter (p -> (if Universal.eq p "" then false else true)) result

Relang.titleAliases : Text -> [Text]
Relang.titleAliases = cases
  "eng" -> ["english", "eng", "en"]
  "ita" -> ["italian", "italiano", "ita", "it"]
  "jpn" -> ["japanese", "jpn", "jp"]
  "kor" -> ["korean", "kor", "kr"]
  "fra" -> ["french", "francais", "français", "fra", "fre", "fr", "vf", "vff"]
  "deu" -> ["german", "deutsch", "ger", "deu", "de"]
  "spa" -> ["spanish", "espanol", "español", "spa", "esp", "es"]
  "por" -> ["portuguese", "portugues", "português", "por", "pt"]
  "rus" -> ["russian", "rus", "ru"]
  "zho" -> ["chinese", "mandarin", "cantonese", "zho", "chi", "zh"]
  "swe" -> ["swedish", "svenska", "swe", "sv"]
  "dan" -> ["danish", "dansk", "dan", "da"]
  "nor" -> ["norwegian", "norsk", "nor", "no"]
  "nld" -> ["dutch", "nederlands", "nld", "dut", "nl"]
  "fin" -> ["finnish", "suomi", "fin", "fi"]
  "pol" -> ["polish", "polski", "pol", "pl"]
  _     -> []

Relang.titleMatches : Text -> AudioTrack -> Boolean
Relang.titleMatches code tr = match AudioTrack.title tr with
  None    -> false
  Some tt ->
    use List any
    aliases = titleAliases code
    lower = Text.toLowercase tt
    words = splitMany titleSeparators lower
    any (w -> any (a -> Universal.eq w a) aliases) words

Relang.titleSeparators : [Char]
Relang.titleSeparators = [?\s, ?-, ?_, ?., ?,, ?(, ?), ?[, ?], ?/]

Relang.titleSuggestsCommentary : Text -> Boolean
Relang.titleSuggestsCommentary tt =
  lower = Text.toLowercase tt
  markers =
    [ "comment"
    , "descriptive"
    , "director"
    , "vfx"
    , "isolated"
    , "audio description"
    , "narration"
    , "for the visually"
    ]
  containsAnySubstring markers lower

Relang.toIso6392 : Text -> Optional Text
Relang.toIso6392 = cases
  "en" -> Some "eng"
  "ja" -> Some "jpn"
  "ko" -> Some "kor"
  "zh" -> Some "zho"
  "fr" -> Some "fra"
  "de" -> Some "deu"
  "it" -> Some "ita"
  "es" -> Some "spa"
  "pt" -> Some "por"
  "ru" -> Some "rus"
  "sv" -> Some "swe"
  "da" -> Some "dan"
  "no" -> Some "nor"
  "nl" -> Some "nld"
  "fi" -> Some "fin"
  "pl" -> Some "pol"
  "tr" -> Some "tur"
  "hi" -> Some "hin"
  "ar" -> Some "ara"
  "he" -> Some "heb"
  "th" -> Some "tha"
  "vi" -> Some "vie"
  "id" -> Some "ind"
  "hu" -> Some "hun"
  "cs" -> Some "ces"
  "ro" -> Some "ron"
  "el" -> Some "ell"
  "uk" -> Some "ukr"
  _    -> None

Rename.acTag : Text -> Text
Rename.acTag raw =
  use Universal eq
  upper = Text.toUppercase raw
  if eq upper "AC3" then "AC3"
  else
    if eq upper "EAC3" then "EAC3"
    else
      if eq upper "AAC" then "AAC"
      else
        if eq upper "DTS" then "DTS"
        else
          if eq upper "TRUEHD" then "TrueHD"
          else
            if eq upper "FLAC" then "FLAC"
            else
              if eq upper "OPUS" then "Opus"
              else if eq upper "MP3" then "MP3" else upper

Rename.applyFormat : [FormatPart] -> Rename.Context -> Text
Rename.applyFormat parts ctx =
  render = cases
    Literal t             -> t
    FormatPart.Token name -> resolveToken ctx name
  Text.join "" (List.map render parts)

Rename.audioPart : ProbeResult -> Text
Rename.audioPart pr =
  match ProbeResult.primaryAudio pr with
    None -> "noaudio-0"
    Some a ->
      acTag (AudioInfo.codec a)
        Text.++ "-"
        Text.++ channelsTag (AudioInfo.channels a)

Rename.basenameNoExt : Text -> Text
Rename.basenameNoExt filename =
  use List reverse
  parts = Text.split ?. filename
  match reverse parts with
    _ +: []   -> filename
    _ +: rest -> Text.join "." (reverse rest)
    []        -> filename

Rename.buildNfo : MovieDetails -> ProbeResult -> Text
Rename.buildNfo d pr =
  use List flatMap map
  use MovieDetails releaseDate
  use Text ++ size
  use Universal eq
  esc = escapeXml
  yearText = match releaseYear (releaseDate d) with
    Some y -> Nat.toText y
    None   -> ""
  vid = ProbeResult.video pr
  audio = ProbeResult.primaryAudio pr
  optTagLine tag value =
    if eq (size value) 0 then []
    else ["  <" ++ tag ++ ">" ++ esc value ++ "</" ++ tag ++ ">"]
  genreLines =
    map
      (g -> "  <genre>" ++ esc (Genre.name g) ++ "</genre>")
      (MovieDetails.genres d)
  countryLines =
    map
      (c -> "  <country>" ++ esc (Country.name c) ++ "</country>")
      (MovieDetails.productionCountries d)
  studioLines =
    map
      (s -> "  <studio>" ++ esc (Studio.name s) ++ "</studio>")
      (productionCompanies d)
  directorLines =
    map
      (m -> "  <director>" ++ esc (CrewMember.name m) ++ "</director>")
      (MovieDetails.directors d)
  writerLines =
    map
      (m -> "  <credits>" ++ esc (CrewMember.name m) ++ "</credits>")
      (MovieDetails.writers d)
  cast = List.take maxCast (castList d)
  actorLines =
    flatMap
      (a ->
        [ "  <actor>"
        , "    <name>" ++ esc (CastMember.name a) ++ "</name>"
        , "    <role>" ++ esc (character a) ++ "</role>"
        , "    <order>" ++ Nat.toText (order a) ++ "</order>"
        , "  </actor>"
        ])
      cast
  setLines =
    match MovieDetails.collection d with
      None -> []
      Some c ->
        [ "  <set>"
        , "    <name>" ++ esc (Collection.name c) ++ "</name>"
        , "  </set>"
        ]
  posterLines = match posterPath d with
    None   -> []
    Some p -> ["  <thumb>" ++ imageBaseUrl ++ p ++ "</thumb>"]
  fanartLines =
    match backdropPath d with
      None -> []
      Some p ->
        [ "  <fanart>"
        , "    <thumb>" ++ imageBaseUrl ++ p ++ "</thumb>"
        , "  </fanart>"
        ]
  audioLines =
    match audio with
      None -> []
      Some a ->
        [ "      <audio>"
        , "        <codec>" ++ esc (AudioInfo.codec a) ++ "</codec>"
        , "        <channels>"
            ++ Nat.toText (AudioInfo.channels a)
            ++ "</channels>"
        , "      </audio>"
        ]
  mpaaLines = optTagLine "mpaa" (MovieDetails.mpaa d)
  taglineLines = optTagLine "tagline" (MovieDetails.tagline d)
  premieredLines = optTagLine "premiered" (releaseDate d)
  yearLines =
    if eq (size yearText) 0 then [] else ["  <year>" ++ yearText ++ "</year>"]
  runtimeLines = match MovieDetails.runtime d with
    None   -> []
    Some r -> ["  <runtime>" ++ Nat.toText r ++ "</runtime>"]
  imdbLines =
    match MovieDetails.imdb d with
      None -> []
      Some i ->
        [ "  <id>" ++ esc i ++ "</id>"
        , "  <uniqueid type=\"imdb\">" ++ esc i ++ "</uniqueid>"
        ]
  uidTmdb =
    [ "  <uniqueid type=\"tmdb\" default=\"true\">"
        ++ Nat.toText (MovieDetails.id d)
        ++ "</uniqueid>"
    ]
  rating = MovieDetails.voteAverage d
  votes = MovieDetails.voteCount d
  ratingLines =
    [ "  <ratings>"
    , "    <rating name=\"tmdb\" max=\"10\" default=\"true\">"
    , "      <value>" ++ Float.toText rating ++ "</value>"
    , "      <votes>" ++ Nat.toText votes ++ "</votes>"
    , "    </rating>"
    , "  </ratings>"
    ]
  crcLines = ["  <crc32>" ++ ProbeResult.crc32 pr ++ "</crc32>"]
  durSec = durationSeconds (ProbeResult.durationSec pr)
  fileInfoOpen =
    [ "  <fileinfo>"
    , "    <streamdetails>"
    , "      <video>"
    , "        <codec>" ++ esc (VideoInfo.codec vid) ++ "</codec>"
    , "        <width>" ++ Nat.toText (VideoInfo.width vid) ++ "</width>"
    , "        <height>" ++ Nat.toText (VideoInfo.height vid) ++ "</height>"
    , "        <durationinseconds>"
        ++ Nat.toText durSec
        ++ "</durationinseconds>"
    , "      </video>"
    ]
  fileInfoClose = ["    </streamdetails>", "  </fileinfo>"]
  header =
    [ "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>"
    , "<movie>"
    , "  <title>" ++ esc (MovieDetails.title d) ++ "</title>"
    , "  <originaltitle>"
        ++ esc (MovieDetails.originalTitle d)
        ++ "</originaltitle>"
    , "  <plot>" ++ esc (MovieDetails.overview d) ++ "</plot>"
    ]
  footer = ["</movie>", ""]
  userRatingLines = ["  <userrating>0</userrating>", "  <top250>0</top250>"]
  allLines =
    flatMap
      (x -> x)
      [ header
      , taglineLines
      , ratingLines
      , userRatingLines
      , runtimeLines
      , mpaaLines
      , premieredLines
      , yearLines
      , setLines
      , genreLines
      , countryLines
      , studioLines
      , directorLines
      , writerLines
      , imdbLines
      , uidTmdb
      , posterLines
      , fanartLines
      , actorLines
      , crcLines
      , fileInfoOpen
      , audioLines
      , fileInfoClose
      , footer
      ]
  Text.join "\n" allLines

Rename.channelsTag : Nat -> Text
Rename.channelsTag ch =
  use Universal eq
  if eq ch 1 then "1.0"
  else
    if eq ch 2 then "2.0"
    else if eq ch 6 then "5.1" else if eq ch 8 then "7.1" else Nat.toText ch

test> Rename.channelsTag.test =
  use Universal eq
  List.flatMap
    check
    [ eq (channelsTag 2) "2.0"
    , eq (channelsTag 6) "5.1"
    , eq (channelsTag 8) "7.1"
    , eq (channelsTag 3) "3"
    ]

Rename.checkAgreement : Optional Movie -> Text ->{IO, Exception} ()
Rename.checkAgreement maybeNfo folderName =
  match maybeNfo with
    None -> ()
    Some m ->
      match parseReleaseName folderName with
        None -> ()
        Some p ->
          match (extractTitle m, extractYear m) with
            (Some nfoTitle, Some nfoYear) ->
              use Nat toText
              use Tmdb normalize
              use Universal eq
              regexTitle = ParsedRelease.title p
              regexYear = ParsedRelease.year p
              sameTitle = eq (normalize nfoTitle) (normalize regexTitle)
              sameYear = eq nfoYear regexYear
              if sameTitle && sameYear then ()
              else
                printLine
                  (Text.join
                    ""
                    [ "  DISAGREE: nfo=\""
                    , nfoTitle
                    , "\" ("
                    , toText nfoYear
                    , ") vs regex=\""
                    , regexTitle
                    , "\" ("
                    , toText regexYear
                    , ")"
                    ])
            _ -> ()

Rename.cleanupSource : Boolean
Rename.cleanupSource = true

Rename.collapseSpaces : Text -> Text
Rename.collapseSpaces t =
  use Nat >
  parts = Text.split ?\s t
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  Text.join " " nonEmpty

Rename.deleteProbeBySourceSql : Command a (Text -> a)
Rename.deleteProbeBySourceSql =
  sql "DELETE FROM stage_probes WHERE source_path = " %% var Codec.text
    |> buildCommand

Rename.deleteProbeRowWith : PreparedCommand r a -> Text ->{Postgres} ()
Rename.deleteProbeRowWith pcDel sourcePath =
  _ = catch do bindAndExecuteCommand pcDel (pt sourcePath)
  ()

Rename.deriveTitleYear : Optional Movie -> Text -> Optional (Text, Nat)
Rename.deriveTitleYear maybeNfo folderName =
  fromNfo = match maybeNfo with
    None   -> None
    Some m ->
      match (extractTitle m, extractYear m) with
        (Some t, Some y) -> Some (t, y)
        _                -> None
  match fromNfo with
    Some r -> Some r
    None   ->
      match parseReleaseName folderName with
        None   -> None
        Some p -> Some (ParsedRelease.title p, ParsedRelease.year p)

Rename.durationSeconds : Float -> Nat
Rename.durationSeconds d =
  use Float <
  if d < 0.0 then 0
  else
    asText = Float.toText d
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    Optional.getOrElse 0 (Nat.fromText intPart)

Rename.editionKeywords : [Text]
Rename.editionKeywords =
  [ "EXTENDED"
  , "REMASTERED"
  , "UNRATED"
  , "THEATRICAL"
  , "DIRECTORS.CUT"
  , "DIRECTORS_CUT"
  , "DIRECTORS CUT"
  , "PROPER"
  , "REPACK"
  , "ANNIVERSARY"
  , "IMAX"
  , "OPEN.MATTE"
  , "OPEN_MATTE"
  , "OPENMATTE"
  ]

Rename.effectiveBitRate : Optional Nat -> Nat -> Float -> Nat
Rename.effectiveBitRate br sizeBytes durationSec = match br with
  Some b -> b
  None   ->
    use Nat * /
    secs = durationSeconds durationSec
    if Universal.eq secs 0 then 0 else sizeBytes * 8 / secs

Rename.escapeXml : Text -> Text
Rename.escapeXml t =
  t |> replaceAll "&" "&amp;" |> replaceAll "<" "&lt;" |> replaceAll ">" "&gt;"

Rename.executeOne :
  PreparedCommand r a
  -> [FormatPart]
  -> [FormatPart]
  -> Optional Text
  -> RenameRow
  ->{IO, Exception, Postgres} Rename.Outcome
Rename.executeOne pcProposed folderFmt fileFmt subsToken row =
  use Decoder run
  use Failure message
  crc = RenameRow.crc32 row
  sourceText = originalPath row
  sourceVideo = FilePath sourceText
  m = toMovieRecord row
  prParsed = catch do run ProbeResult.fromJson (probeJson row)
  match prParsed with
    Left f -> RenameError sourceText (message f)
    Right pr ->
      nfoText = match catch do run Details.fromJson (detailsJson row) with
        Right d -> Nfo.generate (resultFromDetails d) d pr
        Left _  -> minimalNfoM m crc
      videoExt = fileExt sourceText
      base = renderName fileFmt m pr
      targetFolderText =
        targetRoot Text.++ "/" Text.++ renderName folderFmt m pr
      targetFolder = FilePath targetFolderText
      targetVideo = pathJoin targetFolder (base Text.++ videoExt)
      targetNfo = pathJoin targetFolder (nfoBase base Text.++ ".nfo")
      targetVideoText = filePathText targetVideo
      if targetHasCrc targetFolder crc then
        _ = catch do removeFile sourceVideo
        DuplicateRemoved sourceText targetVideoText
      else
        if Boolean.not (pathExists sourceVideo) then NoVideo sourceText
        else
          if pathExists targetVideo then Conflict sourceText targetVideoText
          else
            match 
              catch do
                _ =
                  if isDirectory targetFolder then ()
                  else
                    _ = createDirectory targetFolder
                    ()
                _ = writeFileUtf8 targetNfo nfoText
                renameFile sourceVideo targetVideo
             with
              Right _ ->
                use List ++
                _ = catch do maybeFetchSubsM subsToken m targetFolder base
                _ = 
                  catch do
                    bindAndExecuteCommand
                      pcProposed (pt base ++ pt targetFolderText ++ pt crc)
                Renamed sourceText targetVideoText
              Left f -> RenameError sourceText (message f)

Rename.extractTags : Text -> [Text]
Rename.extractTags name =
  upper = Text.toUppercase name
  List.filter
    (kw -> (match Text.indexOf kw upper with
      Some _ -> true
      None   -> false)) editionKeywords

Rename.fileBaseName : Tmdb.Result -> ProbeResult -> Text
Rename.fileBaseName r pr =
  use Text ++
  vid = ProbeResult.video pr
  ny = titleYear r
  bracketed =
    vcTag (VideoInfo.codec vid)
      ++ "_"
      ++ Nat.toText (VideoInfo.bitDepth vid)
      ++ "b_"
      ++ resolutionStr (VideoInfo.width vid) (VideoInfo.height vid)
      ++ "_"
      ++ mbps
           (effectiveBitRate
             (VideoInfo.bitRate vid)
             (ProbeResult.sizeBytes pr)
             (ProbeResult.durationSec pr))
      ++ "_"
      ++ audioPart pr
  ny ++ " [" ++ bracketed ++ "] ~" ++ ProbeResult.crc32 pr

Rename.fileExt : Text -> Text
Rename.fileExt path =
  lower = Text.toLowercase path
  if endsWith ".mkv" lower then ".mkv"
  else
    if endsWith ".mp4" lower then ".mp4"
    else
      if endsWith ".avi" lower then ".avi"
      else
        if endsWith ".mov" lower then ".mov"
        else
          if endsWith ".wmv" lower then ".wmv"
          else if endsWith ".flv" lower then ".flv" else ""

Rename.fileFormat : Text
Rename.fileFormat =
  "{ny} {tags} [{vc}_{bitdepth}b_{resolution}_{mbps}_{ac}-{channels}_{group}] ~{crc32}"

Rename.findPriorTargetForCrcWith :
  PreparedQuery r a b -> Text ->{Postgres} Optional b
Rename.findPriorTargetForCrcWith pq crc = match 
  catch do
    portal = bindQuery pq (pt crc)
    (rows, _) = executeQueryPortal portal 0
    rows
 with
  Left _   -> None
  Right rs ->
    match rs with
      []       -> None
      tgt +: _ -> Some tgt

Rename.folderFormat : Text
Rename.folderFormat =
  "{ny} [{gigabytes}.{vf}.{vc}.{bitdepth}b.{minutes}min] ~{crc32}"

Rename.folderName : Tmdb.Result -> ProbeResult -> Text
Rename.folderName r pr =
  use Nat toText
  use Text ++
  vid = ProbeResult.video pr
  ny = titleYear r
  parts =
    gigabytes (ProbeResult.sizeBytes pr)
      ++ "."
      ++ vfTag (VideoInfo.width vid) (VideoInfo.height vid)
      ++ "."
      ++ vcTag (VideoInfo.codec vid)
      ++ "."
      ++ toText (VideoInfo.bitDepth vid)
      ++ "b."
      ++ toText (Rename.minutes (ProbeResult.durationSec pr))
      ++ "min"
  ny ++ " [" ++ parts ++ "] ~" ++ ProbeResult.crc32 pr

Rename.gigabytes : Nat -> Text
Rename.gigabytes bytes =
  use Nat % * + / >= toText
  use Text ++
  oneGb = 1073741824
  tenths = (bytes * 10 + oneGb / 2) / oneGb
  whole = tenths / 10
  if whole >= 10 then
    rounded = (bytes + oneGb / 2) / oneGb
    toText rounded ++ " GB"
  else
    f = tenths % 10
    toText whole ++ "." ++ toText f ++ " GB"

test> Rename.gigabytes.test =
  use Universal eq
  List.flatMap
    check
    [ eq (gigabytes 0) "0.0 GB"
    , eq (gigabytes 1073741824) "1.0 GB"
    , eq (gigabytes 5368709120) "5.0 GB"
    , eq (gigabytes 8589934592) "8.0 GB"
    , eq (gigabytes 12884901888) "12 GB"
    , eq (gigabytes 25769803776) "24 GB"
    , eq (gigabytes 429496729) "0.4 GB"
    ]

