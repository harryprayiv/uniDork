Db.upsertOne : Movie ->{IO, Exception, Postgres} ()
Db.upsertOne m = 
  transaction do
    use Db foreach_ pi
    use List ++
    use Movie id
    use Nat toInt
    use Optional map
    use PreparedCommand close
    pcIns = prepareCommand insertMovieSql
    pcUpd = prepareCommand updateMovieSql
    pcVid = prepareCommand insertVideoSql
    pcDVid = prepareCommand (deleteChildSql "movie_video_streams")
    pcAud = prepareCommand insertAudioSql
    pcDAud = prepareCommand (deleteChildSql "movie_audio_tracks")
    pcSub = prepareCommand insertSubSql
    pcDSub = prepareCommand (deleteChildSql "movie_subtitles")
    pcAct = prepareCommand insertActorSql
    pcDAct = prepareCommand (deleteChildSql "movie_actors")
    pcGen = prepareCommand insertGenreSql
    pcDGen = prepareCommand (deleteChildSql "movie_genres")
    pcTag = prepareCommand insertTagSql
    pcDTag = prepareCommand (deleteChildSql "movie_tags")
    pcCou = prepareCommand insertCountrySql
    pcDCou = prepareCommand (deleteChildSql "movie_countries")
    pcStu = prepareCommand insertStudioSql
    pcDStu = prepareCommand (deleteChildSql "movie_studios")
    pcDir = prepareCommand insertDirectorSql
    pcDDir = prepareCommand (deleteChildSql "movie_directors")
    pcCre = prepareCommand insertCreditSql
    pcDCre = prepareCommand (deleteChildSql "movie_credits")
    k = kodi (id m)
    mid = id m
    t = Movie.title m
    s = scoring m
    sd = FileInfo.streams (fileInfo m)
    vid = StreamDetails.video sd
    tax = taxonomy m
    fm = folderMeta m
    indexedAudios = withIndex (StreamDetails.audios sd)
    indexedSubs = withIndex (StreamDetails.subtitles sd)
    indexedActors = withIndex (actors m)
    del pc =
      _ = bindAndExecuteCommand pc (pt k)
      ()
    repList delPc insPc vals =
      _ = del delPc
      foreach_ (v -> bindAndExecuteCommand insPc (pt k ++ pt v)) vals
    _ = printLine (Text.join "" ["upserting: ", k])
    _ = bindAndExecuteCommand pcIns (pt k)
    _ =
      bindAndExecuteCommand
        pcUpd
        (pt k
          ++ pot (MovieId.imdb mid)
          ++ pot (MovieId.tmdb mid)
          ++ pt (display t)
          ++ pt (original t)
          ++ pt (Title.sort t)
          ++ pot (Movie.collection m)
          ++ poi (map toInt (Scoring.year s))
          ++ pf (rating s)
          ++ pi (toInt (votes s))
          ++ pt (Scoring.mpaa s)
          ++ poi (map toInt (Movie.runtime m))
          ++ pt (plot m)
          ++ pt (Movie.tagline m)
          ++ pot (folderPath m)
          ++ pot (nfoPath m)
          ++ pot (videoFilePath m)
          ++ pobi (map toInt (fileSizeBytes m))
          ++ pot (Movie.checksum m)
          ++ pot (rawSize fm)
          ++ pot (resolution fm)
          ++ pot (videoCodec fm)
          ++ poi (map toInt (FolderMeta.bitDepth fm))
          ++ poi (map toInt (runtimeMin fm)))
    _ = del pcDVid
    _ =
      bindAndExecuteCommand
        pcVid
        (pt k
          ++ pt (Video.codec vid)
          ++ pf (aspect vid)
          ++ pi (toInt (Video.width vid))
          ++ pi (toInt (Video.height vid)))
    _ = del pcDAud
    _ =
      foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAud
              (pt k
                ++ pi (toInt i)
                ++ pt (Audio.codec a)
                ++ pt (Audio.language a)
                ++ pi (toInt (Audio.channels a))))
        indexedAudios
    _ = del pcDSub
    _ =
      foreach_
        (cases
          (i, sub) ->
            bindAndExecuteCommand
              pcSub (pt k ++ pi (toInt i) ++ pt (Subtitle.language sub)))
        indexedSubs
    _ = del pcDAct
    _ =
      foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAct (pt k ++ pi (toInt i) ++ pt (Actor.name a) ++ pt (role a)))
        indexedActors
    _ = repList pcDGen pcGen (Taxonomy.genres tax)
    _ = repList pcDTag pcTag (Taxonomy.tags tax)
    _ = repList pcDCou pcCou (countries tax)
    _ = repList pcDStu pcStu (studios tax)
    _ = repList pcDDir pcDir (Taxonomy.directors tax)
    _ = repList pcDCre pcCre (Taxonomy.credits tax)
    _ = close pcIns
    _ = close pcUpd
    _ = close pcVid
    _ = close pcDVid
    _ = close pcAud
    _ = close pcDAud
    _ = close pcSub
    _ = close pcDSub
    _ = close pcAct
    _ = close pcDAct
    _ = close pcGen
    _ = close pcDGen
    _ = close pcTag
    _ = close pcDTag
    _ = close pcCou
    _ = close pcDCou
    _ = close pcStu
    _ = close pcDStu
    _ = close pcDir
    _ = close pcDDir
    _ = close pcCre
    close pcDCre

