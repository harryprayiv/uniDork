Db.upsertMovie :
  PreparedCommand r1 a1 -> PreparedCommand r a -> Movie ->{Postgres} ()
Db.upsertMovie pc1 pc2 m =
  use Command encodeArgs
  use Movie id title
  use Nat toInt
  use Optional map
  yearInt = map toInt (Scoring.year (scoring m))
  votesInt = toInt (votes (scoring m))
  runtimeInt = map toInt (Movie.runtime m)
  sizeInt = map toInt (fileSizeBytes m)
  bitDepthInt = map toInt (FolderMeta.bitDepth (folderMeta m))
  runtimeMinInt = map toInt (runtimeMin (folderMeta m))
  video = StreamDetails.video (FileInfo.streams (fileInfo m))
  audioCodec = match primaryAudio m with
    Some a -> Audio.codec a
    None   -> ""
  audioChannels = match primaryAudio m with
    Some a -> toInt (Audio.channels a)
    None   -> +0
  audioLang = match primaryAudio m with
    Some a -> Audio.language a
    None   -> ""
  tax = taxonomy m
  streams = FileInfo.streams (fileInfo m)
  kodiId = kodi (id m)
  args1 =
    encodeArgs
      upsertSql
      kodiId
      (MovieId.imdb (id m))
      (MovieId.tmdb (id m))
      (display (title m))
      (original (title m))
      (Title.sort (title m))
      (Movie.collection m)
      yearInt
      (rating (scoring m))
      votesInt
      (Scoring.mpaa (scoring m))
      runtimeInt
      (plot m)
      (Movie.tagline m)
      (folderPath m)
      (nfoPath m)
      (videoFilePath m)
      sizeInt
      (Video.codec video)
      (aspect video)
      (toInt (Video.width video))
      (toInt (Video.height video))
      audioCodec
      audioChannels
      audioLang
      (Movie.checksum m)
      (rawSize (folderMeta m))
      (resolution (folderMeta m))
      (videoCodec (folderMeta m))
      bitDepthInt
      runtimeMinInt
      (textsAsJson (Taxonomy.genres tax))
      (textsAsJson (Taxonomy.tags tax))
      (textsAsJson (countries tax))
      (textsAsJson (studios tax))
      (textsAsJson (Taxonomy.directors tax))
      (textsAsJson (Taxonomy.credits tax))
  args2 =
    encodeArgs
      updateArraysSql
      (actorsAsJson (actors m))
      (audiosAsJson (StreamDetails.audios streams))
      (subtitlesAsJson (StreamDetails.subtitles streams))
      kodiId
  _ = bindAndExecuteCommand pc1 args1
  _ = bindAndExecuteCommand pc2 args2
  ()

Db.upsertMovies : [Movie] ->{IO, Exception} ()
Db.upsertMovies movies = singleIO Db.config do Db.foreach_ upsertOne movies

