Stage.ffprobeArgs : Text -> [Text]
Stage.ffprobeArgs path =
  [ "-v"
  , "quiet"
  , "-print_format"
  , "json"
  , "-show_format"
  , "-show_streams"
  , path
  ]

Stage.fileMtime : Text ->{IO, Exception} Optional Int
Stage.fileMtime path = match 
  catch do
    (stdin, stdout, _, p) = Process.start "stat" ["-c", "%Y", path]
    _ = Handle.close stdin
    out = drainHandle stdout
    code = Process.wait p
    (code, out)
 with
  Left _            -> None
  Right (code, out) ->
    if code Nat.== 0 then
      match Nat.fromText (trim out) with
        Some n -> Some (Nat.toInt n)
        None   -> None
    else None

Stage.fileStat : Text ->{IO} Optional (Int, Nat)
Stage.fileStat path = match (statField "%Y" path, statField "%s" path) with
  (Some mtT, Some szT) ->
    match (Nat.fromText mtT, Nat.fromText szT) with
      (Some m, Some s) -> Some (Nat.toInt m, s)
      _                -> None
  _                    -> None

Stage.forkChunk :
  [(a, Text)] ->{IO, Exception} [(a, Text, Either Text ProbeResult)]
Stage.forkChunk chunk =
  use List +: foldLeft reverse
  use Text ++
  forkStep acc item =
    (_, videoPath) = item
    _ = printLine ("  start: " ++ filePathBasename (FilePath videoPath))
    forkProbe item +: acc
  readStep acc pr =
    r = Promise.read pr
    (_, videoPath, outcome) = r
    base = filePathBasename (FilePath videoPath)
    _ = match outcome with
      Left err -> printLine ("   FAIL: " ++ base ++ "  " ++ err)
      Right _  -> printLine ("   done: " ++ base)
    r +: acc
  promises = reverse (foldLeft forkStep [] chunk)
  reverse (foldLeft readStep [] promises)

Stage.forkProbe : (a, Text) ->{IO} Promise (a, Text, Either Text ProbeResult)
Stage.forkProbe = cases
  (folderOpt, videoPath) ->
    p = Promise.new()
    _ = concurrent.fork do
      outcome = match catch do probeWithCrc videoPath with
        Left f           -> Left (Failure.message f)
        Right (Left e)   -> Left e
        Right (Right pr) -> Right pr
      write_ p (folderOpt, videoPath, outcome)
    p

Stage.fromRaw : Text -> Text -> RawProbe -> ProbeResult
Stage.fromRaw videoPath crc raw =
  use List filter map
  use RawStream language pixFmt
  streams = RawProbe.streams raw
  fmt = RawProbe.format raw
  isType ty s = Universal.eq (codecType s) ty
  videoStreams = filter (isType "video") streams
  audioStreams = filter (isType "audio") streams
  subStreams = filter (isType "subtitle") streams
  videoInfo =
    match List.head videoStreams with
      None -> VideoInfo "" 0 0 8 "" None
      Some v ->
        bd = bitDepthFrom (bitsPerRawSample v) (pixFmt v)
        VideoInfo
          (codecName v)
          (RawStream.width v)
          (RawStream.height v)
          bd
          (pixFmt v)
          (RawStream.bitRate v)
  audios =
    map
      (s ->
        AudioInfo
          (codecName s)
          (RawStream.channels s)
          (RawStream.channelLayout s)
          (language s))
      audioStreams
  subtitles = map (s -> SubtitleInfo (codecName s) (language s)) subStreams
  ProbeResult
    videoPath
    crc
    (RawFormat.sizeBytes fmt)
    (RawFormat.durationSec fmt)
    videoInfo
    audios
    subtitles

test> Stage.fromRaw.test =
  match catch do Decoder.run RawProbe.fromJson exampleFfprobeJson with
    Left f -> [Fail (Failure.message f)]
    Right rp ->
      use List size
      use Universal eq
      pr = fromRaw "/movies/x.mkv" "ABCD1234" rp
      v = ProbeResult.video pr
      List.flatMap
        check
        [ eq (videoPath pr) "/movies/x.mkv"
        , eq (ProbeResult.crc32 pr) "ABCD1234"
        , eq (ProbeResult.sizeBytes pr) 2600000000
        , eq (durationSeconds (ProbeResult.durationSec pr)) 5025
        , eq (VideoInfo.codec v) "hevc"
        , eq (VideoInfo.width v) 1920
        , eq (VideoInfo.height v) 1080
        , eq (VideoInfo.bitDepth v) 10
        , eq (VideoInfo.bitRate v) (Some 5000000)
        , eq (size (ProbeResult.audios pr)) 1
        , eq (size (ProbeResult.subtitles pr)) 1
        ]

test> Stage.fromRawTracks.test =
  match catch do Decoder.run RawProbe.fromJson exampleFfprobeJson with
    Left f -> [Fail (Failure.message f)]
    Right rp ->
      use List head
      use Universal eq
      pr = fromRaw "/movies/x.mkv" "ABCD1234" rp
      audioOk =
        match head (ProbeResult.audios pr) with
          None -> false
          Some a ->
            eq (AudioInfo.codec a) "eac3" && eq (AudioInfo.channels a) 6
              && eq (AudioInfo.channelLayout a) "5.1"
              && eq (AudioInfo.language a) "eng"
      subOk =
        match head (ProbeResult.subtitles pr) with
          None -> false
          Some s ->
            eq (SubtitleInfo.codec s) "subrip"
              && eq (SubtitleInfo.language s) "eng"
      List.flatMap check [audioOk, subOk]

Stage.insertBySize : (Nat, a) -> [(Nat, a)] -> [(Nat, a)]
Stage.insertBySize x sorted =
  use List +:
  use Nat <=
  (xk, _) = x
  match sorted with
    []        -> [x]
    y +: rest ->
      (yk, _) = y
      if xk <= yk then x +: sorted else y +: Stage.insertBySize x rest

Stage.isCachedWith : PreparedQuery r a Int -> Text -> Int ->{Postgres} Boolean
Stage.isCachedWith pq sourcePath mtime = match 
  catch do
    use List ++
    portal = bindQuery pq (pt sourcePath ++ Db.pi mtime)
    (rows, _) = executeQueryPortal portal 0
    rows
 with
  Left _   -> false
  Right rs ->
    match rs with
      n +: _ -> Boolean.not (Universal.eq n +0)
      []     -> false

Stage.isFileCachedWith :
  PreparedQuery r a Int -> Text -> Int -> Int ->{Postgres} Boolean
Stage.isFileCachedWith pq sourcePath mtime sizeBytes =
  match 
    catch do
      use List ++
      portal =
        bindQuery pq (pt sourcePath ++ Db.pi mtime ++ pobi (Some sizeBytes))
      (rows, _) = executeQueryPortal portal 0
      rows
   with
    Left _   -> false
    Right rs ->
      match rs with
        n +: _ -> Boolean.not (Universal.eq n +0)
        []     -> false

Stage.largestInFolderWith :
  PreparedQuery r a Text -> Text ->{Postgres} Optional ProbeResult
Stage.largestInFolderWith pq folderPath = match 
  catch do
    portal = bindQuery pq (pt folderPath)
    (rows, _) = executeQueryPortal portal 0
    rows
 with
  Left _   -> None
  Right rs ->
    match rs with
      []       -> None
      raw +: _ ->
        match catch do Decoder.run ProbeResult.fromJson raw with
          Right r -> Some r
          Left _  -> None

Stage.nfoHint :
  Text ->{IO, Exception} (Optional Text, Optional Nat, Optional Nat)
Stage.nfoHint videoPath =
  folder = parentDir (FilePath videoPath)
  match tryReadFolder folder with
    None   -> (None, None, None)
    Some m -> (extractTitle m, extractYear m, extractTmdbId m)

Stage.parseNatString : Optional Text -> Optional Nat
Stage.parseNatString = cases
  None   -> None
  Some s -> Nat.fromText (trim s)

Stage.partitionWork :
  PreparedQuery r a1 Int -> [(a, Text)] ->{IO, Postgres} [(a, Text)]
Stage.partitionWork pqCached work =
  use List +:
  step acc item =
    (_, videoPath) = item
    match fileStat videoPath with
      None -> (0, item) +: acc
      Some (mt, sz) ->
        if isFileCachedWith pqCached videoPath mt (Nat.toInt sz) then acc
        else (sz, item) +: acc
  withSizes = List.foldLeft step [] work
  sorted = sortBySize withSizes
  List.map (cases (_, item) -> item) sorted

Stage.probeBatch : [(a, Text)] ->{IO, Exception} [(a, Text, ProbeResult)]
Stage.probeBatch toProbe =
  use List foldLeft
  chunkStep acc chunk =
    use List ++
    results = forkChunk chunk
    kept = List.reverse (foldLeft collectResult [] results)
    acc ++ kept
  foldLeft chunkStep [] (List.chunk probeJobs toProbe)

Stage.probeCacheFreshSql : postgres.Query a (Text -> Int -> Int -> a) Int
Stage.probeCacheFreshSql =
  sql "SELECT COUNT(*) FROM probe_cache WHERE original_path = "
    %% var Codec.text
    %% sql " AND mtime >= "
    %% var integer
    %% sql " AND size_bytes = "
    %% var bigint
    |> typedQuery bigint

Stage.probeJobs : Nat
Stage.probeJobs = 8

test> Stage.probeJsonRoundtrip.test =
  match 
    catch do
      rp = Decoder.run RawProbe.fromJson exampleFfprobeJson
      fromRaw "/movies/x.mkv" "ABCD1234" rp
   with
    Left f -> [Fail (Failure.message f)]
    Right pr ->
      use List size
      use ProbeResult audios crc32 durationSec sizeBytes subtitles video
      use Universal eq
      use VideoInfo bitDepth bitRate codec
      encoded = Json.toText (ProbeResult.toJson pr)
      match catch do Decoder.run ProbeResult.fromJson encoded with
        Left f2 -> [Fail (Failure.message f2)]
        Right pr2 ->
          v1 = video pr
          v2 = video pr2
          List.flatMap
            check
            [ eq (crc32 pr2) (crc32 pr)
            , eq (sizeBytes pr2) (sizeBytes pr)
            , eq
                (durationSeconds (durationSec pr2))
                (durationSeconds (durationSec pr))
            , eq (bitDepth v2) (bitDepth v1)
            , eq (codec v2) (codec v1)
            , eq (bitRate v2) (bitRate v1)
            , eq (size (audios pr2)) (size (audios pr))
            , eq (size (subtitles pr2)) (size (subtitles pr))
            ]

Stage.ProbeResult.fromJson : '{unison_json_1_4_2.Decoder} ProbeResult
Stage.ProbeResult.fromJson =
  do
    use Decoder array optional! text
    use object at at!
    videoPath = at! "video_path" text
    crc32 = at! "crc32" text
    sizeBytes = at! "size_bytes" Decoder.nat
    durationSec = at! "duration_sec" Decoder.float
    video = at! "video" VideoInfo.fromJson
    audiosNew = optional! (at "audios" (array AudioInfo.fromJson))
    audiosLegacy = optional! (at "audio" AudioInfo.fromJson)
    audios = match audiosNew with
      Some a -> a
      None   ->
        match audiosLegacy with
          Some a -> [a]
          None   -> []
    subtitles =
      Optional.getOrElse
        [] (optional! (at "subtitles" (array SubtitleInfo.fromJson)))
    ProbeResult videoPath crc32 sizeBytes durationSec video audios subtitles

Stage.ProbeResult.primaryAudio : ProbeResult -> Optional AudioInfo
Stage.ProbeResult.primaryAudio pr = List.head (ProbeResult.audios pr)

Stage.ProbeResult.toJson : ProbeResult -> Json
Stage.ProbeResult.toJson pr =
  use Json array text
  use List map
  Json.object
    [ ("video_path", text (videoPath pr))
    , ("crc32", text (ProbeResult.crc32 pr))
    , ("size_bytes", Json.nat (ProbeResult.sizeBytes pr))
    , ("duration_sec", Json.float (ProbeResult.durationSec pr))
    , ("video", VideoInfo.toJson (ProbeResult.video pr))
    , ("audios", array (map AudioInfo.toJson (ProbeResult.audios pr)))
    , ("subtitles", array (map SubtitleInfo.toJson (ProbeResult.subtitles pr)))
    ]

Stage.probeViaFfprobe : Text -> Text ->{IO, Exception} Either Text ProbeResult
Stage.probeViaFfprobe videoPath crc = match runFfprobe videoPath with
  Left err  -> Left err
  Right raw ->
    match catch do Decoder.run RawProbe.fromJson raw with
      Left f   -> Left (Failure.message f)
      Right rp -> Right (fromRaw videoPath crc rp)

Stage.probeWithCrc : Text ->{IO, Exception} Either Text ProbeResult
Stage.probeWithCrc videoPath = match runRhashCrc32 videoPath with
  Left err  -> Left err
  Right crc -> probeViaFfprobe videoPath crc

Stage.RawFormat.fromJson : '{unison_json_1_4_2.Decoder} RawFormat
Stage.RawFormat.fromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at
  sizeText = optional! (at "size" text)
  sizeBytes = getOrElse 0 (parseNatString sizeText)
  durationText = getOrElse "0" (optional! (at "duration" text))
  durationSec = getOrElse 0.0 (Float.fromText (trim durationText))
  RawFormat sizeBytes durationSec

Stage.RawProbe.fromJson : '{unison_json_1_4_2.Decoder} RawProbe
Stage.RawProbe.fromJson =
  do
    use Decoder optional!
    use Optional getOrElse
    use object at
    streams =
      getOrElse
        [] (optional! (at "streams" (Decoder.array RawStream.fromJson)))
    format =
      getOrElse emptyRawFormat (optional! (at "format" RawFormat.fromJson))
    RawProbe streams format

Stage.RawStream.fromJson : '{unison_json_1_4_2.Decoder} RawStream
Stage.RawStream.fromJson =
  do
    use Decoder nat optional! text
    use Nat fromText
    use Optional getOrElse
    use object at
    codecType = getOrElse "" (optional! (at "codec_type" text))
    codecName = getOrElse "" (optional! (at "codec_name" text))
    width = getOrElse 0 (optional! (at "width" nat))
    height = getOrElse 0 (optional! (at "height" nat))
    pixFmt = getOrElse "" (optional! (at "pix_fmt" text))
    bitsPerRawSample = match optional! (at "bits_per_raw_sample" text) with
      None   -> None
      Some s -> Some (getOrElse 8 (fromText (trim s)))
    bitRate = match optional! (at "bit_rate" text) with
      None   -> None
      Some s -> if Universal.eq (trim s) "" then None else fromText (trim s)
    channels = getOrElse 0 (optional! (at "channels" nat))
    channelLayout = getOrElse "" (optional! (at "channel_layout" text))
    language = getOrElse "" (optional! (at "tags" tagLanguage))
    RawStream
      codecType
      codecName
      width
      height
      pixFmt
      bitsPerRawSample
      bitRate
      channels
      channelLayout
      language

Stage.readFromDb : Text ->{IO} Optional ProbeResult
Stage.readFromDb sourcePath = match 
  catch do
    singleIO Db.config do
      pq = prepareQuery selectProbeSql
      portal = bindQuery pq (pt sourcePath)
      (rows, _) = executeQueryPortal portal 0
      rows
 with
  Left _   -> None
  Right rs ->
    match rs with
      []       -> None
      raw +: _ ->
        match catch do Decoder.run ProbeResult.fromJson raw with
          Right r -> Some r
          Left _  -> None

Stage.readSidecar : Text ->{IO, Exception} Optional ProbeResult
Stage.readSidecar sourcePath = readFromDb sourcePath

Stage.runChunk :
  PreparedCommand r1 a2
  -> PreparedCommand r a1
  -> [(a, Text)]
  ->{IO, Exception, Postgres} ()
Stage.runChunk pcFiles pcGate chunk =
  results = forkChunk chunk
  Db.foreach_
    (cases
      (_, videoPath, outcome) ->
        match outcome with
          Left _   -> ()
          Right pr ->
            originalName = filePathBasename (FilePath videoPath)
            hint = nfoHint videoPath
            _ = upsertFileWith pcFiles videoPath originalName hint pr
            mtime = match fileStat videoPath with
              Some (mt, _) -> mt
              None         -> +0
            upsertProbeCacheWith pcGate videoPath mtime pr) results

Stage.runFfprobe : Text ->{IO, Exception} Either Text Text
Stage.runFfprobe path =
  match 
    catch do
      (stdin, stdout, _, p) = Process.start "ffprobe" (ffprobeArgs path)
      _ = Handle.close stdin
      out = drainHandle stdout
      code = Process.wait p
      (code, out)
   with
    Left f -> Left (Failure.message f)
    Right (code, out) ->
      if code Nat.== 0 then Right out
      else Left ("ffprobe exit " Text.++ Nat.toText code)

Stage.runProbeStage : '{IO, Exception} ()
Stage.runProbeStage =
  do
    use List size
    use Nat - toText
    use PreparedCommand close
    use Text ++
    staging = FilePath stagingDir
    if isDirectory staging then
      work = collectWork staging
      _ =
        printLine ("[stage-probe] " ++ toText (size work) ++ " video(s) found")
      singleIO Db.config do
        pqCached = prepareQuery probeCacheFreshSql
        pcFiles = prepareCommand upsertFileSql
        pcGate = prepareCommand upsertProbeCacheSql
        toProbe = partitionWork pqCached work
        _ =
          printLine
            (Text.join
              ""
              [ "[stage-probe] to probe: "
              , toText (size toProbe)
              , ", cached: "
              , toText (size work - size toProbe)
              ])
        chunks = List.chunk probeJobs toProbe
        _ = Db.foreach_ (runChunk pcFiles pcGate) chunks
        _ = close pcFiles
        _ = close pcGate
        printLine "[stage-probe] done"
    else printLine ("staging not found: " ++ stagingDir)

Stage.runRhashCrc32 : Text ->{IO, Exception} Either Text Text
Stage.runRhashCrc32 path =
  match 
    catch do
      (stdin, stdout, _, p) =
        Process.start "rhash" ["--crc32", "-p", "%C", path]
      _ = Handle.close stdin
      out = drainHandle stdout
      code = Process.wait p
      (code, out)
   with
    Left f -> Left (Failure.message f)
    Right (code, out) ->
      if code Nat.== 0 then Right (Text.toUppercase (trim out))
      else Left ("rhash exit " Text.++ Nat.toText code)

Stage.selectLargestInFolderSql : postgres.Query b (Text -> b) Text
Stage.selectLargestInFolderSql =
  use Codec text
  sql "SELECT probe_json FROM stage_probes WHERE folder_path = "
    %% var text
    %% sql
         " ORDER BY ((probe_json::json)->>'size_bytes')::bigint DESC NULLS LAST LIMIT 1"
    |> typedQuery text

Stage.selectProbeSql : postgres.Query a (Text -> a) Text
Stage.selectProbeSql =
  use Codec text
  sql "SELECT probe_json FROM stage_probes WHERE source_path = " %% var text
    |> typedQuery text

Stage.sidecarPath : Text -> FilePath
Stage.sidecarPath folderName =
  use Text ++
  FilePath (Stage.cacheRoot ++ "/" ++ folderName ++ ".json")

Stage.sortBySize : [(Nat, a)] -> [(Nat, a)]
Stage.sortBySize xs =
  step acc x = insertBySize x acc
  List.foldLeft step [] xs

Stage.statField : Text -> Text ->{IO} Optional Text
Stage.statField fmt path = match 
  catch do
    (stdin, stdout, _, p) = Process.start "stat" ["-c", fmt, path]
    _ = Handle.close stdin
    out = drainHandle stdout
    code = Process.wait p
    (code, out)
 with
  Left _            -> None
  Right (code, out) -> if code Nat.== 0 then Some (trim out) else None

Stage.SubtitleInfo.fromJson : '{unison_json_1_4_2.Decoder} SubtitleInfo
Stage.SubtitleInfo.fromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at
  codec = getOrElse "" (optional! (at "codec" text))
  language = getOrElse "" (optional! (at "language" text))
  SubtitleInfo codec language

Stage.SubtitleInfo.toJson : SubtitleInfo -> Json
Stage.SubtitleInfo.toJson s =
  use Json text
  Json.object
    [ ("codec", text (SubtitleInfo.codec s))
    , ("language", text (SubtitleInfo.language s))
    ]

Stage.tagLanguage : '{unison_json_1_4_2.Decoder} Text
Stage.tagLanguage =
  do
    match Decoder.optional! (object.at "language" Decoder.text) with
      Some l -> l
      None ->
        Optional.getOrElse
          "" (Decoder.optional! (object.at "LANGUAGE" Decoder.text))

Stage.upsertBatch :
  PreparedCommand r a -> [(Optional Text, Text, ProbeResult)] ->{Postgres} ()
Stage.upsertBatch pcUpsert results =
  Db.foreach_
    (cases
      (folderOpt, videoPath, pr) ->
        crc = ProbeResult.crc32 pr
        probeJson = Json.toText (ProbeResult.toJson pr)
        upsertProbeWith
          pcUpsert
          folderOpt
          videoPath
          (filePathBasename (FilePath videoPath))
          crc
          probeJson)
    results

Stage.upsertFileSql :
  Command
    b
    (Text
    -> Int
    -> Text
    -> Text
    -> Float
    -> Text
    -> Int
    -> Int
    -> Int
    -> Text
    -> Optional Text
    -> Optional Int
    -> Optional Int
    -> b)
Stage.upsertFileSql =
  use Codec optional text
  sql
    "INSERT INTO files (crc32, size_bytes, original_path, original_name, duration_sec, video_codec, width, height, bit_depth, probe_json, hint_title, hint_year, hint_tmdb_id) VALUES ("
    %% var text
    %% sql ", "
    %% var bigint
    %% sql ", "
    %% var text
    %% sql ", "
    %% var text
    %% sql ", "
    %% var Codec.double
    %% sql ", "
    %% var text
    %% sql ", "
    %% var integer
    %% sql ", "
    %% var integer
    %% sql ", "
    %% var integer
    %% sql ", "
    %% var text
    %% sql ", "
    %% var (optional text)
    %% sql ", "
    %% var (optional integer)
    %% sql ", "
    %% var (optional integer)
    %% sql
         ") ON CONFLICT (crc32, size_bytes) DO UPDATE SET original_path = EXCLUDED.original_path, original_name = EXCLUDED.original_name, duration_sec = EXCLUDED.duration_sec, video_codec = EXCLUDED.video_codec, width = EXCLUDED.width, height = EXCLUDED.height, bit_depth = EXCLUDED.bit_depth, probe_json = EXCLUDED.probe_json, hint_title = COALESCE(EXCLUDED.hint_title, files.hint_title), hint_year = COALESCE(EXCLUDED.hint_year, files.hint_year), hint_tmdb_id = COALESCE(EXCLUDED.hint_tmdb_id, files.hint_tmdb_id), probed_at = NOW()"
    |> buildCommand

Stage.upsertFileWith :
  PreparedCommand r a
  -> Text
  -> Text
  -> (Optional Text, Optional Nat, Optional Nat)
  -> ProbeResult
  ->{Postgres} ()
Stage.upsertFileWith pc originalPath originalName hint pr =
  use Db pi
  use List ++
  use Nat toInt
  use Optional map
  (hintTitle, hintYear, hintTmdb) = hint
  vid = ProbeResult.video pr
  probeJson = Json.toText (ProbeResult.toJson pr)
  _ = 
    catch do
      bindAndExecuteCommand
        pc
        (pt (ProbeResult.crc32 pr)
          ++ pobi (Some (toInt (ProbeResult.sizeBytes pr)))
          ++ pt originalPath
          ++ pt originalName
          ++ pf (ProbeResult.durationSec pr)
          ++ pt (VideoInfo.codec vid)
          ++ pi (toInt (VideoInfo.width vid))
          ++ pi (toInt (VideoInfo.height vid))
          ++ pi (toInt (VideoInfo.bitDepth vid))
          ++ pt probeJson
          ++ pot hintTitle
          ++ poi (map toInt hintYear)
          ++ poi (map toInt hintTmdb))
  ()

Stage.upsertProbeCacheSql : Command b (Text -> Int -> Int -> Text -> Int -> b)
Stage.upsertProbeCacheSql =
  use Codec text
  sql
    "INSERT INTO probe_cache (original_path, mtime, size_bytes, file_id) VALUES ("
    %% var text
    %% sql ", "
    %% var integer
    %% sql ", "
    %% var bigint
    %% sql ", (SELECT file_id FROM files WHERE crc32 = "
    %% var text
    %% sql " AND size_bytes = "
    %% var bigint
    %% sql
         ")) ON CONFLICT (original_path) DO UPDATE SET mtime = EXCLUDED.mtime, size_bytes = EXCLUDED.size_bytes, file_id = EXCLUDED.file_id, cached_at = NOW()"
    |> buildCommand

Stage.upsertProbeCacheWith :
  PreparedCommand r a -> Text -> Int -> ProbeResult ->{Postgres} ()
Stage.upsertProbeCacheWith pc originalPath mtime pr =
  use List ++
  sizeInt = Nat.toInt (ProbeResult.sizeBytes pr)
  _ = 
    catch do
      bindAndExecuteCommand
        pc
        (pt originalPath
          ++ Db.pi mtime
          ++ pobi (Some sizeInt)
          ++ pt (ProbeResult.crc32 pr)
          ++ pobi (Some sizeInt))
  ()

Stage.upsertProbeSql :
  Command b (Text -> Optional Text -> Text -> Text -> Text -> b)
Stage.upsertProbeSql =
  use Codec text
  sql
    "INSERT INTO stage_probes (source_path, folder_path, video_basename, crc32, probe_json) VALUES ("
    %% var text
    %% sql ", "
    %% var (Codec.optional text)
    %% sql ", "
    %% var text
    %% sql ", "
    %% var text
    %% sql ", "
    %% var text
    %% sql
         ") ON CONFLICT (source_path) DO UPDATE SET folder_path = EXCLUDED.folder_path, video_basename = EXCLUDED.video_basename, crc32 = EXCLUDED.crc32, probe_json = EXCLUDED.probe_json, probed_at = NOW()"
    |> buildCommand

Stage.upsertProbeWith :
  PreparedCommand r a
  -> Optional Text
  -> Text
  -> Text
  -> Text
  -> Text
  ->{Postgres} ()
Stage.upsertProbeWith pc folderOpt source basename crc probeJson =
  use List ++
  _ = 
    catch do
      bindAndExecuteCommand
        pc
        (pt source ++ pot folderOpt ++ pt basename ++ pt crc ++ pt probeJson)
  ()

Stage.VideoInfo.fromJson : '{unison_json_1_4_2.Decoder} VideoInfo
Stage.VideoInfo.fromJson = do
  use Decoder nat text
  use object at!
  codec = at! "codec" text
  width = at! "width" nat
  height = at! "height" nat
  bitDepth = at! "bit_depth" nat
  pixFmt = at! "pix_fmt" text
  bitRate = Decoder.optional! (object.at "bit_rate" nat)
  VideoInfo codec width height bitDepth pixFmt bitRate

Stage.VideoInfo.toJson : VideoInfo -> Json
Stage.VideoInfo.toJson v =
  use Json nat text
  Json.object
    [ ("codec", text (VideoInfo.codec v))
    , ("width", nat (VideoInfo.width v))
    , ("height", nat (VideoInfo.height v))
    , ("bit_depth", nat (VideoInfo.bitDepth v))
    , ("pix_fmt", text (VideoInfo.pixFmt v))
    , ("bit_rate", toJsonOpt nat (VideoInfo.bitRate v))
    ]

StreamDetails.fromJson : '{unison_json_1_4_2.Decoder} StreamDetails
StreamDetails.fromJson = do
  use Decoder array
  use object at!
  video = at! "video" Video.fromJson
  audios = at! "audios" (array Audio.fromJson)
  subtitles = at! "subtitles" (array Subtitle.fromJson)
  StreamDetails video audios subtitles

StreamDetails.toJson : StreamDetails -> Json
StreamDetails.toJson s =
  use Json array
  use List map
  Json.object
    [ ("video", Video.toJson (StreamDetails.video s))
    , ("audios", array (map Audio.toJson (StreamDetails.audios s)))
    , ("subtitles", array (map Subtitle.toJson (StreamDetails.subtitles s)))
    ]

Subs.allUnpackFiles : Subs.SearchResponse -> [UnpackFile]
Subs.allUnpackFiles r = List.flatMap unpackFiles (SearchResponse.subtitles r)

Subs.apiAuthority : Authority
Subs.apiAuthority = Authority None (HostName "api.subdl.com") None

Subs.downloadAuthority : Authority
Subs.downloadAuthority = Authority None (HostName "dl.subdl.com") None

Subs.downloadUnpackRaw : UnpackFile ->{IO} Either Text Text
Subs.downloadUnpackRaw uf =
  uri = UnpackFile.downloadURI uf
  req = HttpRequest.get uri |> HttpRequest.addHeader "Accept" "*/*"
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          bodyText ok
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Subs.downloadURI : Text -> URI
Subs.downloadURI urlPath =
  use Nat >
  use Path /
  parts = List.filter (p -> Text.size p > 0) (Text.split ?/ urlPath)
  path = List.foldLeft (acc p -> acc / p) Path.root parts
  URI
    Scheme.https
    (Some downloadAuthority)
    path
    (fromQuery Query.empty)
    Fragment.empty

