Tmdb.parseReleaseName : Text -> Optional Tmdb.ParsedRelease
Tmdb.parseReleaseName name =
  match Tmdb.findEnclosedYearAny name with
    Some (titlePrefix, year) ->
      cleaned = Tmdb.cleanTitle titlePrefix
      if Universal.eq (Text.size cleaned) 0 then None
      else Some (Tmdb.ParsedRelease.ParsedRelease name cleaned year None)
    None ->
      tokens = Tmdb.tokenize name
      match Tmdb.findYearIndex tokens with
        None -> None
        Some i ->
          match Tmdb.nth i tokens with
            None -> None
            Some yt ->
              match Tmdb.tokenAsYear yt with
                None -> None
                Some y ->
                  titleStr = trim (Text.join " " (List.take i tokens))
                  if Universal.eq (Text.size titleStr) 0 then None
                  else
                    Some
                      (Tmdb.ParsedRelease.ParsedRelease name titleStr y None)

Tmdb.buildParsedRelease :
  Text -> Optional Movie -> Optional Tmdb.ParsedRelease
Tmdb.buildParsedRelease folderName maybeNfo =
  nfoId = match maybeNfo with
    None   -> None
    Some m -> Nfo.extractTmdbId m
  fromNfo = match maybeNfo with
    None   -> None
    Some m -> match (Nfo.extractTitle m, Nfo.extractYear m) with
      (Some t, Some y) -> Some (t, y)
      _                -> None
  match fromNfo with
    Some (t, y) ->
      Some (Tmdb.ParsedRelease.ParsedRelease folderName t y nfoId)
    None        ->
      match Tmdb.parseReleaseName folderName with
        None   -> None
        Some p -> Some (Tmdb.ParsedRelease.nfoTmdbId.set nfoId p)

Tmdb.releaseYear : Text -> Optional Nat
Tmdb.releaseYear dateStr =
  use Nat <
  if Text.size dateStr < 4 then None
  else Tmdb.tokenAsYear (Text.take 4 dateStr)

Tmdb.scoreCandidate : Tmdb.ParsedRelease -> Tmdb.Result -> Nat
Tmdb.scoreCandidate p r =
  use Nat + - >
  use Universal eq
  q = Tmdb.normalize (Tmdb.ParsedRelease.title p)
  t = Tmdb.normalize (Tmdb.Result.title r)
  o = Tmdb.normalize (Tmdb.Result.originalTitle r)
  titleOk = eq q t || eq q o
  py = Tmdb.ParsedRelease.year p
  yearScore = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    None    -> 0
    Some ry ->
      if eq ry py then 20
      else
        diff = if ry > py then ry - py else py - ry
        if eq diff 1 then 10 else 0
  idOk = match Tmdb.ParsedRelease.nfoTmdbId p with
    Some n -> eq n (Tmdb.Result.tmdbId r)
    None   -> false
  idScore = if idOk then 50 else 0
  titleScore = if titleOk then 30 else 0
  idScore + titleScore + yearScore

-- Find the max score in a scored candidate list.
Tmdb.maxScore : [(Tmdb.Result, Nat)] -> Optional Nat
Tmdb.maxScore xs =
  use Nat 
  step acc cur =
    (_, s) = cur
    match acc with
      None   -> Some s
      Some a -> if a < s then Some s else Some a
  List.foldLeft step None xs

Tmdb.popularityWinner :
  [(Tmdb.Result, Nat)] -> Optional ((Tmdb.Result, Nat), Float)
Tmdb.popularityWinner tied =
  use Float >
  step acc cur =
    (rCur, _) = cur
    pCur = Tmdb.Result.popularity rCur
    match acc with
      None -> Some (cur, 0.0)
      Some (best, runnerUp) ->
        (rBest, _) = best
        pBest = Tmdb.Result.popularity rBest
        if pCur > pBest then Some (cur, pBest)
        else
          if pCur > runnerUp then Some (best, pCur)
          else Some (best, runnerUp)
  List.foldLeft step None tied

Tmdb.SearchResponse.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.SearchResponse
Tmdb.SearchResponse.fromJson = do
  results = object.at! "results" (Decoder.array Tmdb.Result.fromJson)
  Tmdb.SearchResponse.SearchResponse results

Tmdb.CachedSearch.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.CachedSearch
Tmdb.CachedSearch.fromJson = do
  use Decoder optional! text
  use object at
  folder = object.at! "folder" text
  response = optional! (at "response" Tmdb.SearchResponse.fromJson)
  error = optional! (at "error" text)
  Tmdb.CachedSearch.CachedSearch folder response error

Tmdb.readCache : Text ->{IO, Exception} Optional Tmdb.CachedSearch
Tmdb.readCache folderName =
  use Text ++
  jsonPath = FilePath (Tmdb.cacheRoot ++ "/" ++ folderName ++ ".json")
  match 
    catch do
      raw = readFileUtf8 jsonPath
      Decoder.run Tmdb.CachedSearch.fromJson raw
   with
    Left _  -> None
    Right s -> Some s

Tmdb.printCandidate : (Tmdb.Result, Nat) ->{IO, Exception} ()
Tmdb.printCandidate = cases
  (r, score) ->
    use Nat >=
    label =
      if Universal.eq score 100 then "[100%]"
      else
        if score >= 80 then "[ 80%]"
        else
          if score >= 50 then "[ 50%]"
          else if score >= 40 then "[ 40%]" else "[ low]"
    yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
      Some y -> Nat.toText y
      None   -> "????"
    printLine
      (Text.join ""
        [ "    "
        , label
        , " ("
        , Nat.toText score
        , "%) tmdb:"
        , Nat.toText (Tmdb.Result.tmdbId r)
        , " \""
        , Tmdb.Result.title r
        , "\" ("
        , yearText
        , ") pop="
        , Float.toText (Tmdb.Result.popularity r)
        ])

Tmdb.reportLooseVideoWith pq pc pqStage pqDet pcDet token videoFile =
  use Nat toText
  use ParsedRelease year
  use Text ++ join
  filename = filePathBasename videoFile
  name = basenameNoExt filename
  _ = printLine (join "" ["LOOSE:  ", filename])
  maybeProbeMin = match Stage.readWith pqStage (filePathText videoFile) with
    None    -> None
    Some pr -> Some (Rename.minutes (Stage.ProbeResult.durationSec pr))
  match parseReleaseName name with
    None ->
      _ = printLine "  parsed:  FAILED (no year + quality token)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      _ =
        printLine
          (join "" ["  parsed:  title=\"", ParsedRelease.title p, "\", year=", toText (year p)])
      result = cachedSearchWith pq pc token name (ParsedRelease.title p) (year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = results resp
          scored = List.map (r -> (r, scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ printCandidate scored
          _ =
            match pickBestWithRuntime pqDet pcDet token maybeProbeMin scored with
              Some (r, s) ->
                printLine
                  (join
                    ""
                    [ "  verdict: "
                    , toText s
                    , "% -> tmdb:"
                    , toText (Result.tmdbId r)
                    , " \""
                    , Result.title r
                    , "\""
                    ])
              None -> printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.reportFolderWith pq pc pqStage pqDet pcDet token folder =
  use Nat toText
  use ParsedRelease year
  use Text ++ join
  folderName = filePathBasename folder
  maybeNfo = tryReadFolder folder
  _ = printLine (join "" ["FOLDER: ", folderName])
  _ = match maybeNfo with
    Some m ->
      match extractTmdbId m with
        Some n -> printLine ("  NFO tmdb id: " ++ toText n)
        None   -> printLine "  NFO present (no tmdb id)"
    None   -> ()
  files = directoryContents.texts folder
  maybeProbeMin = match findFirstVideo files with
    None -> None
    Some videoName ->
      videoPath = pathJoin folder videoName
      match Stage.readWith pqStage (filePathText videoPath) with
        None    -> None
        Some pr -> Some (Rename.minutes (Stage.ProbeResult.durationSec pr))
  match buildParsedRelease folderName maybeNfo with
    None ->
      _ = printLine "  parsed:  FAILED (no title/year from NFO or folder name)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      idTag = match nfoTmdbId p with
        Some n -> " nfo-id=" ++ toText n
        None   -> ""
      _ =
        printLine
          (join
            ""
            ["  parsed:  title=\"", ParsedRelease.title p, "\", year=", toText (year p), idTag])
      result = cachedSearchWith pq pc token folderName (ParsedRelease.title p) (year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = results resp
          scored = List.map (r -> (r, scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ printCandidate scored
          _ =
            match pickBestWithRuntime pqDet pcDet token maybeProbeMin scored with
              Some (r, s) ->
                printLine
                  (join
                    ""
                    [ "  verdict: "
                    , toText s
                    , "% -> tmdb:"
                    , toText (Result.tmdbId r)
                    , " \""
                    , Result.title r
                    , "\""
                    ])
              None -> printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.cleanTitle : Text -> Text
Tmdb.cleanTitle t =
  use Nat >
  s1 = replaceAll "." " " t
  s2 = replaceAll "_" " " s1
  parts = Text.split ?\s s2
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  trim (Text.join " " nonEmpty)

Tmdb.findEnclosedYear : Text -> Text -> Text -> Optional (Text, Nat)
Tmdb.findEnclosedYear open close name =
  go offset =
    use Nat +
    use Text drop size take
    sub = drop offset name
    match Text.indexOf open sub with
      None -> None
      Some openIdx ->
        absOpen = offset + openIdx
        afterOpen = absOpen + size open
        cand = take 4 (drop afterOpen name)
        closeAt = afterOpen + 4
        match Tmdb.tokenAsYear cand with
          Some y ->
            actualClose = take (size close) (drop closeAt name)
            if Universal.eq actualClose close then
              Some (trim (take absOpen name), y)
            else go (absOpen + 1)
          None -> go (absOpen + 1)
  go 0

Tmdb.findEnclosedYearAny : Text -> Optional (Text, Nat)
Tmdb.findEnclosedYearAny name = match Tmdb.findEnclosedYear "(" ")" name with
  Some r -> Some r
  None   -> Tmdb.findEnclosedYear "[" "]" name

