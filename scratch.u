test> Subs.pickUnpackPrefersNonHi.test =
  match
    catch do
      Decoder.run Subs.SearchResponse.fromJson Subs.exampleUnpackedJson
  with
    Left f  -> [Fail (Failure.message f)]
    Right r ->
      flat = Subs.allUnpackFiles r
      match Subs.pickUnpackForLanguage "EN" flat with
        None        -> [Fail "expected an EN pick"]
        Some chosen ->
          use Universal eq
          List.flatMap
            check
            [ eq (Subs.UnpackFile.fileNId chosen) "fileEN1"
            , eq (Subs.UnpackFile.hearingImpaired chosen) false
            , eq (Subs.UnpackFile.format chosen) "srt"
            ]

test> Subs.pickUnpackPicksEachLanguage.test =
  match
    catch do
      Decoder.run Subs.SearchResponse.fromJson Subs.exampleUnpackedJson
  with
    Left f  -> [Fail (Failure.message f)]
    Right r ->
      flat = Subs.allUnpackFiles r
      en = Subs.pickUnpackForLanguage "EN" flat
      es = Subs.pickUnpackForLanguage "ES" flat
      th = Subs.pickUnpackForLanguage "TH" flat
      use Universal eq
      enId = Optional.map Subs.UnpackFile.fileNId en
      esId = Optional.map Subs.UnpackFile.fileNId es
      List.flatMap
        check
        [ eq enId (Some "fileEN1")
        , eq esId (Some "fileES1")
        , eq th None
        ]

test> Subs.pickUnpackFallsBackToHi.test =
