Tmdb.isQualityToken : Text -> Boolean
Tmdb.isQualityToken t =
  lower = Text.toLowercase t
  List.any (q -> Universal.eq q lower) Tmdb.qualityTokens

Tmdb.tokenAsYear : Text -> Optional Nat
Tmdb.tokenAsYear t =
  use Nat <= >=
  if Universal.eq (Text.size t) 4 then
    match Nat.fromText t with
      Some n -> if n >= 1900 && n <= 2030 then Some n else None
      None   -> None
  else None

Tmdb.tokenize : Text -> [Text]
Tmdb.tokenize name =
  use List flatMap
  use Nat >
  use Text split
  s1 = split ?. name
  s2 = flatMap (p -> split ?_ p) s1
  s3 = flatMap (p -> split ?\s p) s2
  List.filter (p -> Text.size p > 0) s3

Tmdb.nth : Nat -> [a] -> Optional a
Tmdb.nth i xs = List.head (List.drop i xs)

Tmdb.findYearIndex : [Text] -> Optional Nat
Tmdb.findYearIndex tokens =
  use Nat +
  pairs = Db.withIndex tokens
  qualifying =
    List.filterMap
      (cases
        (i, t) ->
          match Tmdb.tokenAsYear t with
            None   -> None
            Some _ ->
              match Tmdb.nth (i + 1) tokens with
                Some next -> if Tmdb.isQualityToken next then Some i else None
                None      -> None) pairs
  List.head qualifying

Tmdb.parseReleaseName : Text -> Optional Tmdb.ParsedRelease
Tmdb.parseReleaseName name =
  match Tmdb.findEnclosedYearAny name with
    Some (titlePrefix, year) ->
      cleaned = Tmdb.cleanTitle titlePrefix
      if Universal.eq (Text.size cleaned) 0 then None
      else Some (Tmdb.ParsedRelease.ParsedRelease name cleaned year None)
    None ->
      tokens = Tmdb.tokenize name
      match Tmdb.findYearIndex tokens with
        None -> None
        Some i ->
          match Tmdb.nth i tokens with
            None -> None
            Some yt ->
              match Tmdb.tokenAsYear yt with
                None -> None
                Some y ->
                  titleStr = trim (Text.join " " (List.take i tokens))
                  if Universal.eq (Text.size titleStr) 0 then None
                  else
                    Some
                      (Tmdb.ParsedRelease.ParsedRelease name titleStr y None)

-- Build a ParsedRelease from folder name plus optional NFO.
-- NFO title/year override folder-name regex when both are present.
-- NFO tmdb id rides along whether or not NFO supplied title/year.
Tmdb.buildParsedRelease :
  Text -> Optional Movie -> Optional Tmdb.ParsedRelease
Tmdb.buildParsedRelease folderName maybeNfo =
  nfoId = match maybeNfo with
    None   -> None
    Some m -> Nfo.extractTmdbId m
  fromNfo = match maybeNfo with
    None   -> None
    Some m -> match (Nfo.extractTitle m, Nfo.extractYear m) with
      (Some t, Some y) -> Some (t, y)
      _                -> None
  match fromNfo with
    Some (t, y) ->
      Some (Tmdb.ParsedRelease.ParsedRelease folderName t y nfoId)
    None        ->
      match Tmdb.parseReleaseName folderName with
        None   -> None
        Some p -> Some (Tmdb.ParsedRelease.nfoTmdbId.set nfoId p)

Tmdb.normalize : Text -> Text
Tmdb.normalize t =
  use Nat >
  use Text drop
  lower = Text.toLowercase t
  punct =
    [ "."
    , ","
    , ":"
    , ";"
    , "!"
    , "?"
    , "'"
    , "\""
    , "("
    , ")"
    , "["
    , "]"
    , "{"
    , "}"
    , "-"
    , "_"
    , "&"
    , "/"
    ]
  noPunct = List.foldLeft (acc p -> replaceAll p " " acc) lower punct
  parts = Text.split ?\s noPunct
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  joined = Text.join " " nonEmpty
  if startsWith "the " joined then drop 4 joined
  else
    if startsWith "an " joined then drop 3 joined
    else if startsWith "a " joined then drop 2 joined else joined

Tmdb.releaseYear : Text -> Optional Nat
Tmdb.releaseYear dateStr =
  use Nat <
  if Text.size dateStr < 4 then None
  else Tmdb.tokenAsYear (Text.take 4 dateStr)

Tmdb.scoreCandidate : Tmdb.ParsedRelease -> Tmdb.Result -> Nat
Tmdb.scoreCandidate p r =
  use Nat +
  q = Tmdb.normalize (Tmdb.ParsedRelease.title p)
  t = Tmdb.normalize (Tmdb.Result.title r)
  o = Tmdb.normalize (Tmdb.Result.originalTitle r)
  titleOk = Universal.eq q t || Universal.eq q o
  yearOk = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    Some y -> Universal.eq y (Tmdb.ParsedRelease.year p)
    None   -> false
  idOk = match Tmdb.ParsedRelease.nfoTmdbId p with
    Some n -> Universal.eq n (Tmdb.Result.tmdbId r)
    None   -> false
  idScore = if idOk then 50 else 0
  titleScore = if titleOk then 30 else 0
  yearScore = if yearOk then 20 else 0
  idScore + titleScore + yearScore

Tmdb.pickBest : [(Tmdb.Result, Nat)] -> Optional (Tmdb.Result, Nat)
Tmdb.pickBest scored =
  use Nat > >= +
  threshold = 50
  step acc cur = match cur with
    (_, curScore) -> match acc with
      None           -> Some (cur, 1)
      Some (best, n) -> match best with
        (_, bestScore) ->
          if curScore > bestScore then Some (cur, 1)
          else
            if Universal.eq curScore bestScore then Some (best, n + 1)
            else Some (best, n)
  match List.foldLeft step None scored with
    None           -> None
    Some (best, n) -> match best with
      (_, s) ->
        if Universal.eq n 1 && s >= threshold then Some best else None

Tmdb.Result.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.Result
Tmdb.Result.fromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at at!
  tmdbId = at! "id" Decoder.nat
  title = at! "title" text
  originalTitle = at! "original_title" text
  releaseDate = getOrElse "" (optional! (at "release_date" text))
  popularity = at! "popularity" Decoder.float
  overview = getOrElse "" (optional! (at "overview" text))
  Tmdb.Result.Result tmdbId title originalTitle releaseDate popularity overview

Tmdb.SearchResponse.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.SearchResponse
Tmdb.SearchResponse.fromJson = do
  results = object.at! "results" (Decoder.array Tmdb.Result.fromJson)
  Tmdb.SearchResponse.SearchResponse results

Tmdb.CachedSearch.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.CachedSearch
Tmdb.CachedSearch.fromJson = do
  use Decoder optional! text
  use object at
  folder = object.at! "folder" text
  response = optional! (at "response" Tmdb.SearchResponse.fromJson)
  error = optional! (at "error" text)
  Tmdb.CachedSearch.CachedSearch folder response error

Tmdb.readCache : Text ->{IO, Exception} Optional Tmdb.CachedSearch
Tmdb.readCache folderName =
  use Text ++
  jsonPath = FilePath (Tmdb.cacheRoot ++ "/" ++ folderName ++ ".json")
  match 
    catch do
      raw = readFileUtf8 jsonPath
      Decoder.run Tmdb.CachedSearch.fromJson raw
   with
    Left _  -> None
    Right s -> Some s

Tmdb.printCandidate : (Tmdb.Result, Nat) ->{IO, Exception} ()
Tmdb.printCandidate = cases
  (r, score) ->
    use Nat >= toText
    use Text join
    label =
      if Universal.eq score 100 then "[100%]"
      else
        if score >= 80 then "[ 80%]"
        else if score >= 50 then "[ 50%]" else "[ low]"
    yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
      Some y -> toText y
      None   -> "????"
    printLine
      (join
        ""
        [ "    "
        , label
        , " ("
        , toText score
        , "%) tmdb:"
        , toText (Tmdb.Result.tmdbId r)
        , " \""
        , Tmdb.Result.title r
        , "\" ("
        , yearText
        , ") pop="
        , Float.toText (Tmdb.Result.popularity r)
        ])

Tmdb.reportLooseVideo : Text -> FilePath ->{IO, Exception} ()
Tmdb.reportLooseVideo token videoFile =
  use Nat toText
  use Text ++ join
  filename = filePathBasename videoFile
  name = Rename.basenameNoExt filename
  _ = printLine (join "" ["LOOSE:  ", filename])
  match Tmdb.parseReleaseName name with
    None ->
      _ = printLine "  parsed:  FAILED (no year + quality token)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      _ =
        printLine
          (join
            ""
            [ "  parsed:  title=\""
            , Tmdb.ParsedRelease.title p
            , "\", year="
            , toText (Tmdb.ParsedRelease.year p)
            ])
      result =
        Tmdb.cachedSearch
          token
          name
          (Tmdb.ParsedRelease.title p)
          (Tmdb.ParsedRelease.year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, Tmdb.scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ Tmdb.printCandidate scored
          _ = match Tmdb.pickBest scored with
            Some (r, s) ->
              printLine
                (join
                  ""
                  [ "  verdict: "
                  , toText s
                  , "% -> tmdb:"
                  , toText (Tmdb.Result.tmdbId r)
                  , " \""
                  , Tmdb.Result.title r
                  , "\""
                  ])
            None        ->
              printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.reportFolder : Text -> FilePath ->{IO, Exception} ()
Tmdb.reportFolder token folder =
  use Nat toText
  use Text ++ join
  folderName = filePathBasename folder
  maybeNfo = Nfo.tryReadFolder folder
  _ = printLine (join "" ["FOLDER: ", folderName])
  _ = match maybeNfo with
    Some m -> match Nfo.extractTmdbId m with
      Some n -> printLine ("  NFO tmdb id: " ++ toText n)
      None   -> printLine "  NFO present (no tmdb id)"
    None   -> ()
  match Tmdb.buildParsedRelease folderName maybeNfo with
    None ->
      _ =
        printLine "  parsed:  FAILED (no title/year from NFO or folder name)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      idTag = match Tmdb.ParsedRelease.nfoTmdbId p with
        Some n -> " nfo-id=" ++ toText n
        None   -> ""
      _ =
        printLine
          (join
            ""
            [ "  parsed:  title=\""
            , Tmdb.ParsedRelease.title p
            , "\", year="
            , toText (Tmdb.ParsedRelease.year p)
            , idTag
            ])
      result =
        Tmdb.cachedSearch
          token
          folderName
          (Tmdb.ParsedRelease.title p)
          (Tmdb.ParsedRelease.year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, Tmdb.scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ Tmdb.printCandidate scored
          _ = match Tmdb.pickBest scored with
            Some (r, s) ->
              printLine
                (join
                  ""
                  [ "  verdict: "
                  , toText s
                  , "% -> tmdb:"
                  , toText (Tmdb.Result.tmdbId r)
                  , " \""
                  , Tmdb.Result.title r
                  , "\""
                  ])
            None        ->
              printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.cleanTitle : Text -> Text
Tmdb.cleanTitle t =
  use Nat >
  s1 = replaceAll "." " " t
  s2 = replaceAll "_" " " s1
  parts = Text.split ?\s s2
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  trim (Text.join " " nonEmpty)

Tmdb.findEnclosedYear : Text -> Text -> Text -> Optional (Text, Nat)
Tmdb.findEnclosedYear open close name =
  go offset =
    use Nat +
    use Text drop size take
    sub = drop offset name
    match Text.indexOf open sub with
      None -> None
      Some openIdx ->
        absOpen = offset + openIdx
        afterOpen = absOpen + size open
        cand = take 4 (drop afterOpen name)
        closeAt = afterOpen + 4
        match Tmdb.tokenAsYear cand with
          Some y ->
            actualClose = take (size close) (drop closeAt name)
            if Universal.eq actualClose close then
              Some (trim (take absOpen name), y)
            else go (absOpen + 1)
          None -> go (absOpen + 1)
  go 0

Tmdb.findEnclosedYearAny : Text -> Optional (Text, Nat)
Tmdb.findEnclosedYearAny name = match Tmdb.findEnclosedYear "(" ")" name with
  Some r -> Some r
  None   -> Tmdb.findEnclosedYear "[" "]" name

Tmdb.tokenPath : Text
Tmdb.tokenPath = "/home/bismuth/.config/uniDork/tmdb-token"

Tmdb.readToken : '{IO, Exception} Text
Tmdb.readToken = do trim (readFileUtf8 (FilePath Tmdb.tokenPath))

Tmdb.apiAuthority : Authority
Tmdb.apiAuthority = Authority None (HostName "api.themoviedb.org") None

Tmdb.searchURI : Text -> Nat -> URI
Tmdb.searchURI title year =
  use Path /
  path = Path.root / "3" / "search" / "movie"
  q = Query.empty & ("query", title) & ("year", Nat.toText year)
  URI Scheme.https (Some Tmdb.apiAuthority) path (fromQuery q) Fragment.empty

Tmdb.searchRequest : Text -> Text -> Nat -> HttpRequest
Tmdb.searchRequest token title year =
  use HttpRequest addHeader
  use Text ++
  HttpRequest.get (Tmdb.searchURI title year)
    |> addHeader "Authorization" ("Bearer " ++ token)
    |> addHeader "Accept" "application/json"

Tmdb.search : Text -> Text -> Nat ->{IO} Either Text Tmdb.SearchResponse
Tmdb.search token title year =
  req = Tmdb.searchRequest token title year
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          body = bodyText ok
          Decoder.run Tmdb.SearchResponse.fromJson body
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

type Stage.VideoInfo
  = { codec : Text,
      width : Nat,
      height : Nat,
      bitDepth : Nat,
      pixFmt : Text,
      bitRate : Optional Nat }

type Stage.AudioInfo
  = { codec : Text, channels : Nat, channelLayout : Text }

type Stage.ProbeResult
  = { videoPath : Text,
      crc32 : Text,
      sizeBytes : Nat,
      durationSec : Float,
      video : Stage.VideoInfo,
      audio : Optional Stage.AudioInfo }

Stage.VideoInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.VideoInfo
Stage.VideoInfo.fromJson = do
  use Decoder nat text
  use object at!
  codec = at! "codec" text
  width = at! "width" nat
  height = at! "height" nat
  bitDepth = at! "bit_depth" nat
  pixFmt = at! "pix_fmt" text
  bitRate = Decoder.optional! (object.at "bit_rate" nat)
  Stage.VideoInfo.VideoInfo codec width height bitDepth pixFmt bitRate

Stage.AudioInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.AudioInfo
Stage.AudioInfo.fromJson = do
  use Decoder text
  use object at!
  codec = at! "codec" text
  channels = at! "channels" Decoder.nat
  channelLayout = at! "channel_layout" text
  Stage.AudioInfo.AudioInfo codec channels channelLayout

Stage.ProbeResult.fromJson : '{unison_json_1_4_2.Decoder} Stage.ProbeResult
Stage.ProbeResult.fromJson =
  do
    use Decoder text
    use object at!
    videoPath = at! "video_path" text
    crc32 = at! "crc32" text
    sizeBytes = at! "size_bytes" Decoder.nat
    durationSec = at! "duration_sec" Decoder.float
    video = at! "video" Stage.VideoInfo.fromJson
    audio = Decoder.optional! (object.at "audio" Stage.AudioInfo.fromJson)
    Stage.ProbeResult.ProbeResult
      videoPath crc32 sizeBytes durationSec video audio

Stage.cacheRoot : Text
Stage.cacheRoot = "/home/bismuth/.cache/uniDork/stage"

Stage.sidecarPath : Text -> FilePath
Stage.sidecarPath folderName =
  use Text ++
  FilePath (Stage.cacheRoot ++ "/" ++ folderName ++ ".json")

Stage.readSidecar : Text ->{IO, Exception} Optional Stage.ProbeResult
Stage.readSidecar folderName = match 
  catch do
    raw = readFileUtf8 (Stage.sidecarPath folderName)
    Decoder.run Stage.ProbeResult.fromJson raw
 with
  Left _  -> None
  Right r -> Some r

Rename.targetRoot : Text
Rename.targetRoot =
  "/home/bismuth/NAS/video/_Unsorted/torrents/Complete/AMC/testMovies"

Rename.logDir : Text
Rename.logDir = "/home/bismuth/.cache/uniDork/rename-log"

Rename.gigabytes : Nat -> Text
Rename.gigabytes bytes =
  use Nat % * + / >= toText
  use Text ++
  oneGb = 1073741824
  tenths = (bytes * 10 + oneGb / 2) / oneGb
  whole = tenths / 10
  if whole >= 10 then
    rounded = (bytes + oneGb / 2) / oneGb
    toText rounded ++ " GB"
  else
    f = tenths % 10
    toText whole ++ "." ++ toText f ++ " GB"

Rename.truncSec : Float -> Nat
Rename.truncSec d =
  use Float <
  if d < 0.0 then 0
  else
    asText = Float.toText d
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    Optional.getOrElse 0 (Nat.fromText intPart)

Rename.minutes : Float -> Nat
Rename.minutes d =
  use Nat /
  Rename.truncSec d / 60

Rename.effectiveBitRate : Optional Nat -> Nat -> Float -> Nat
Rename.effectiveBitRate br sizeBytes durationSec = match br with
  Some b -> b
  None   ->
    use Nat * /
    secs = Rename.truncSec durationSec
    if Universal.eq secs 0 then 0 else sizeBytes * 8 / secs

Rename.mbps : Nat -> Text
Rename.mbps bps =
  use Nat % * + / >= toText
  use Text ++
  oneMbps = 1000000
  tenths = (bps * 10 + oneMbps / 2) / oneMbps
  whole = tenths / 10
  if whole >= 10 then
    rounded = (bps + oneMbps / 2) / oneMbps
    toText rounded ++ " Mbps"
  else
    f = tenths % 10
    toText whole ++ "." ++ toText f ++ " Mbps"

Rename.vfTag : Nat -> Nat -> Text
Rename.vfTag width height =
  use Nat >=
  if width >= 3000 || height >= 1700 then "2160p"
  else
    if width >= 2300 || height >= 1300 then "1440p"
    else
      if width >= 1800 || height >= 800 then "1080p"
      else
        if width >= 1100 || height >= 700 then "720p"
        else
          if height >= 540 then "576p"
          else if height >= 380 then "480p" else "SD"

Rename.vcTag : Text -> Text
Rename.vcTag raw =
  use Universal eq
  lower = Text.toLowercase raw
  if eq lower "hevc" then "x265"
  else
    if eq lower "h265" then "x265"
    else
      if eq lower "h264" then "x264"
      else
        if eq lower "avc" then "x264"
        else
          if eq lower "av1" then "av1"
          else
            if eq lower "vp9" then "vp9"
            else if eq lower "mpeg4" then "xvid" else lower

Rename.resolutionStr : Nat -> Nat -> Text
Rename.resolutionStr w h =
  use Nat toText
  use Text ++
  toText w ++ "x" ++ toText h

Rename.channelsTag : Nat -> Text
Rename.channelsTag ch =
  use Universal eq
  if eq ch 1 then "1.0"
  else
    if eq ch 2 then "2.0"
    else if eq ch 6 then "5.1" else if eq ch 8 then "7.1" else Nat.toText ch

Rename.acTag : Text -> Text
Rename.acTag raw =
  use Universal eq
  upper = Text.toUppercase raw
  if eq upper "AC3" then "AC3"
  else
    if eq upper "EAC3" then "EAC3"
    else
      if eq upper "AAC" then "AAC"
      else
        if eq upper "DTS" then "DTS"
        else
          if eq upper "TRUEHD" then "TrueHD"
          else
            if eq upper "FLAC" then "FLAC"
            else
              if eq upper "OPUS" then "Opus"
              else if eq upper "MP3" then "MP3" else upper

Rename.fileExt : Text -> Text
Rename.fileExt path =
  lower = Text.toLowercase path
  if endsWith ".mkv" lower then ".mkv"
  else
    if endsWith ".mp4" lower then ".mp4"
    else
      if endsWith ".avi" lower then ".avi"
      else
        if endsWith ".mov" lower then ".mov"
        else
          if endsWith ".wmv" lower then ".wmv"
          else if endsWith ".flv" lower then ".flv" else ""

Rename.escapeXml : Text -> Text
Rename.escapeXml t =
  t |> replaceAll "&" "&amp;" |> replaceAll "<" "&lt;" |> replaceAll ">" "&gt;"

type Rename.Outcome
  = NoVideo Text
  | NoProbe Text
  | Renamed Text Text
  | NoMatch Text Text
  | Conflict Text Text
  | RenameError Text Text

Rename.Outcome.toJson : Rename.Outcome -> Json
Rename.Outcome.toJson = cases
  Rename.Outcome.Renamed src tgt ->
    Json.object
      [ ("outcome", Json.text "renamed")
      , ("source", Json.text src)
      , ("target", Json.text tgt)
      ]
  Rename.Outcome.NoVideo src ->
    Json.object [("outcome", Json.text "no_video"), ("source", Json.text src)]
  Rename.Outcome.NoMatch src reason ->
    Json.object
      [ ("outcome", Json.text "no_match")
      , ("source", Json.text src)
      , ("reason", Json.text reason)
      ]
  Rename.Outcome.NoProbe src ->
    Json.object [("outcome", Json.text "no_probe"), ("source", Json.text src)]
  Rename.Outcome.Conflict src existing ->
    Json.object
      [ ("outcome", Json.text "conflict")
      , ("source", Json.text src)
      , ("existing", Json.text existing)
      ]
  Rename.Outcome.RenameError src msg ->
    Json.object
      [ ("outcome", Json.text "error")
      , ("source", Json.text src)
      , ("message", Json.text msg)
      ]

Rename.writeOutcome : Text -> Rename.Outcome ->{IO, Exception} ()
Rename.writeOutcome folderName o =
  use Text ++
  path = FilePath (Rename.logDir ++ "/" ++ folderName ++ ".json")
  writeFileUtf8 path (Json.toText (Rename.Outcome.toJson o))

Rename.runOne : Text -> FilePath ->{IO, Exception} ()
Rename.runOne token folder =
  use Text ++
  folderName = filePathBasename folder
  _ = printLine ("processing: " ++ folderName)
  outcome = Rename.processFolder token folder
  _ =
    match outcome with
      Rename.Outcome.Renamed _ tgt -> printLine ("  RENAMED -> " ++ tgt)
      Rename.Outcome.NoVideo _ ->
        printLine "  skip: no video (already renamed?)"
      Rename.Outcome.NoMatch _ reason -> printLine ("  skip: " ++ reason)
      Rename.Outcome.NoProbe _ ->
        printLine "  skip: no probe sidecar (run unidork-stage-probe)"
      Rename.Outcome.Conflict _ t -> printLine ("  skip: target exists " ++ t)
      Rename.Outcome.RenameError _ msg -> printLine ("  ERROR: " ++ msg)
  Rename.writeOutcome folderName outcome

test> Rename.gigabytes.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.gigabytes 0) "0.0 GB"
    , eq (Rename.gigabytes 1073741824) "1.0 GB"
    , eq (Rename.gigabytes 5368709120) "5.0 GB"
    , eq (Rename.gigabytes 8589934592) "8.0 GB"
    , eq (Rename.gigabytes 12884901888) "12 GB"
    , eq (Rename.gigabytes 25769803776) "24 GB"
    , eq (Rename.gigabytes 429496729) "0.4 GB"
    ]

test> Rename.mbps.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.mbps 0) "0.0 Mbps"
    , eq (Rename.mbps 1500000) "1.5 Mbps"
    , eq (Rename.mbps 5800000) "5.8 Mbps"
    , eq (Rename.mbps 11000000) "11 Mbps"
    , eq (Rename.mbps 31000000) "31 Mbps"
    ]

test> Rename.vfTag.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.vfTag 3840 2160) "2160p"
    , eq (Rename.vfTag 3840 2080) "2160p"
    , eq (Rename.vfTag 1920 1080) "1080p"
    , eq (Rename.vfTag 1920 800) "1080p"
    , eq (Rename.vfTag 1920 1040) "1080p"
    , eq (Rename.vfTag 1280 720) "720p"
    , eq (Rename.vfTag 720 576) "576p"
    , eq (Rename.vfTag 720 404) "480p"
    , eq (Rename.vfTag 640 360) "SD"
    ]

test> Rename.channelsTag.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.channelsTag 2) "2.0"
    , eq (Rename.channelsTag 6) "5.1"
    , eq (Rename.channelsTag 8) "7.1"
    , eq (Rename.channelsTag 3) "3"
    ]

Rename.basenameNoExt : Text -> Text
Rename.basenameNoExt filename =
  use List reverse
  parts = Text.split ?. filename
  match reverse parts with
    _ +: []   -> filename
    _ +: rest -> Text.join "." (reverse rest)
    []        -> filename

Rename.looseVideos : FilePath ->{IO, Exception} [FilePath]
Rename.looseVideos dir =
  entries = directoryContents.texts dir
  videoNames = List.filter isVideo entries
  step acc n =
    use List :+
    fp = pathJoin dir n
    if isDirectory fp then acc else acc :+ fp
  List.foldLeft step [] videoNames

Rename.runOneLoose : Text -> FilePath ->{IO, Exception} ()
Rename.runOneLoose token videoFile =
  use Text ++
  filename = filePathBasename videoFile
  name = Rename.basenameNoExt filename
  _ = printLine ("processing (loose): " ++ filename)
  outcome = Rename.processLooseVideo token videoFile
  _ =
    match outcome with
      Rename.Outcome.Renamed _ tgt -> printLine ("  RENAMED -> " ++ tgt)
      Rename.Outcome.NoVideo _ -> printLine "  skip: no video"
      Rename.Outcome.NoMatch _ reason -> printLine ("  skip: " ++ reason)
      Rename.Outcome.NoProbe _ ->
        printLine "  skip: no probe sidecar (run unidork-stage-probe)"
      Rename.Outcome.Conflict _ t -> printLine ("  skip: target exists " ++ t)
      Rename.Outcome.RenameError _ msg -> printLine ("  ERROR: " ++ msg)
  Rename.writeOutcome name outcome

uniDork.rename : '{IO, Exception} ()
uniDork.rename =
  do
    use List size
    use Nat toText
    use Text ++
    use Universal eq
    staging = FilePath Tmdb.stagingDir
    if isDirectory staging then
      token = Tmdb.readToken()
      entries = directoryContents.texts staging
      folderNames =
        List.filter
          (n ->
            (if eq n "." then false
            else if eq n ".." then false else isDirectory (pathJoin staging n)))
          entries
      folders = List.map (n -> pathJoin staging n) folderNames
      loose = Rename.looseVideos staging
      _ =
        printLine
          ("scanning "
            ++ toText (size folders)
            ++ " folder(s) and "
            ++ toText (size loose)
            ++ " loose video(s) under "
            ++ Tmdb.stagingDir)
      _ = printLine ""
      _ = Db.foreach_ (Rename.runOne token) folders
      Db.foreach_ (Rename.runOneLoose token) loose
    else printLine ("staging not found: " ++ Tmdb.stagingDir)

uniDork.identify : '{IO, Exception} ()
uniDork.identify =
  do
    use Nat toText
    use Text ++ join
    use Universal eq
    staging = FilePath Tmdb.stagingDir
    if isDirectory staging then
      token = Tmdb.readToken()
      entries = directoryContents.texts staging
      folderNames =
        List.filter
          (n ->
            (if eq n "." then false
            else if eq n ".." then false else isDirectory (pathJoin staging n)))
          entries
      folders = List.map (n -> pathJoin staging n) folderNames
      loose = Rename.looseVideos staging
      _ =
        printLine
          (join
            ""
            [ "scanning "
            , toText (List.size folders)
            , " folder(s) and "
            , toText (List.size loose)
            , " loose video(s) under "
            , Tmdb.stagingDir
            ])
      _ = printLine ""
      _ = Db.foreach_ (Tmdb.reportFolder token) folders
      Db.foreach_ (Tmdb.reportLooseVideo token) loose
    else printLine ("staging not found: " ++ Tmdb.stagingDir)

uniDork.batchSize : Nat
uniDork.batchSize = 50

List.chunk : Nat -> [a] -> [[a]]
List.chunk n xs =
  use List +: size
  use Nat <=
  if Universal.eq (size xs) 0 then []
  else
    if size xs <= n then [xs]
    else List.take n xs +: List.chunk n (List.drop n xs)

uniDork.collectFolders : [FilePath] ->{IO, Exception} [FilePath]
uniDork.collectFolders roots =
  addIfDir : FilePath -> [FilePath] -> Text ->{IO, Exception} [FilePath]
  addIfDir root acc name =
    use List +:
    fp = pathJoin root name
    if isDirectory fp then fp +: acc else acc
  perRoot root =
    basenames = directoryContents.texts root
    _ =
      printLine
        (Text.join
          ""
          [ "scanning: "
          , filePathText root
          , " ("
          , Nat.toText (List.size basenames)
          , " entries)"
          ])
    List.reverse (List.foldLeft (addIfDir root) [] basenames)
  List.flatMap perRoot roots

uniDork.processOne
  pcUpsert
  pcVid
  pcDVid
  pcAud
  pcDAud
  pcSub
  pcDSub
  pcAct
  pcDAct
  pcGen
  pcDGen
  pcTag
  pcDTag
  pcCou
  pcDCou
  pcStu
  pcDStu
  pcDir
  pcDDir
  pcCre
  pcDCre
  folder =
  match Nfo.processFolder folder with
    Left _ ->
      _ = printLine (Text.join "" ["  no nfo: ", filePathText folder])
      ()
    Right m ->
      actualRuntime = match Movie.videoFilePath m with
        None         -> None
        Some vidPath ->
          match Probe.readSidecar vidPath with
            None   -> None
            Some r -> Some (Probe.runtimeSec r)
      Db.upsertWith
        pcUpsert
        pcVid
        pcDVid
        pcAud
        pcDAud
        pcSub
        pcDSub
        pcAct
        pcDAct
        pcGen
        pcDGen
        pcTag
        pcDTag
        pcCou
        pcDCou
        pcStu
        pcDStu
        pcDir
        pcDDir
        pcCre
        pcDCre
        actualRuntime
        m

uniDork.processBatch : [FilePath] ->{IO, Exception} ()
uniDork.processBatch folders = 
  singleIO Db.config do
    use PreparedCommand close
    pcUpsert = prepareCommand Db.upsertMovieSql
    pcVid = prepareCommand Db.insertVideoSql
    pcDVid = prepareCommand (Db.deleteChildSql "movie_video_streams")
    pcAud = prepareCommand Db.insertAudioSql
    pcDAud = prepareCommand (Db.deleteChildSql "movie_audio_tracks")
    pcSub = prepareCommand Db.insertSubSql
    pcDSub = prepareCommand (Db.deleteChildSql "movie_subtitles")
    pcAct = prepareCommand Db.insertActorSql
    pcDAct = prepareCommand (Db.deleteChildSql "movie_actors")
    pcGen = prepareCommand Db.insertGenreSql
    pcDGen = prepareCommand (Db.deleteChildSql "movie_genres")
    pcTag = prepareCommand Db.insertTagSql
    pcDTag = prepareCommand (Db.deleteChildSql "movie_tags")
    pcCou = prepareCommand Db.insertCountrySql
    pcDCou = prepareCommand (Db.deleteChildSql "movie_countries")
    pcStu = prepareCommand Db.insertStudioSql
    pcDStu = prepareCommand (Db.deleteChildSql "movie_studios")
    pcDir = prepareCommand Db.insertDirectorSql
    pcDDir = prepareCommand (Db.deleteChildSql "movie_directors")
    pcCre = prepareCommand Db.insertCreditSql
    pcDCre = prepareCommand (Db.deleteChildSql "movie_credits")
    _ =
      Db.foreach_
        (uniDork.processOne
          pcUpsert
          pcVid
          pcDVid
          pcAud
          pcDAud
          pcSub
          pcDSub
          pcAct
          pcDAct
          pcGen
          pcDGen
          pcTag
          pcDTag
          pcCou
          pcDCou
          pcStu
          pcDStu
          pcDir
          pcDDir
          pcCre
          pcDCre)
        folders
    _ = close pcUpsert
    _ = close pcVid
    _ = close pcDVid
    _ = close pcAud
    _ = close pcDAud
    _ = close pcSub
    _ = close pcDSub
    _ = close pcAct
    _ = close pcDAct
    _ = close pcGen
    _ = close pcDGen
    _ = close pcTag
    _ = close pcDTag
    _ = close pcCou
    _ = close pcDCou
    _ = close pcStu
    _ = close pcDStu
    _ = close pcDir
    _ = close pcDDir
    _ = close pcCre
    close pcDCre

uniDork.runBatchSafe : Nat -> Nat -> [FilePath] ->{IO, Exception} ()
uniDork.runBatchSafe i n batch =
  use Nat toText
  use Text join
  _ =
    printLine
      (join
        ""
        [ "batch "
        , toText i
        , "/"
        , toText n
        , " ("
        , toText (List.size batch)
        , " folders)"
        ])
  match catch do uniDork.processBatch batch with
    Right _ -> ()
    Left f  -> printLine (join "" ["  BATCH FAILED: ", Failure.message f])

uniDork.batchedMain : Text ->{IO, Exception} ()
uniDork.batchedMain configPath =
  use List size
  use Nat toText
  use Text join
  configText = readFileUtf8 (FilePath configPath)
  dirs = List.filterMap parseConfigLine (lines configText)
  _ = Db.createSchema()
  _ = printLine "collecting folders..."
  folders = uniDork.collectFolders dirs
  total = size folders
  _ = printLine (join "" ["found ", toText total, " folders to process"])
  batches = List.chunk uniDork.batchSize folders
  nBatches = size batches
  _ =
    printLine
      (join
        ""
        [ "processing in "
        , toText nBatches
        , " batches of (up to) "
        , toText uniDork.batchSize
        ])
  step i batch =
    use Nat +
    _ = uniDork.runBatchSafe i nBatches batch
    i + 1
  _ = List.foldLeft step 1 batches
  printLine "done"

uniDork.batchedRun : '{IO, Exception} ()
uniDork.batchedRun = do uniDork.batchedMain "./uniDork.conf"

Nfo.tryReadFolder : FilePath ->{IO, Exception} Optional Movie
Nfo.tryReadFolder folder =
  files = directoryContents.texts folder
  match findFirstNfo files with
    None         -> None
    Some nfoName ->
      nfoPath = pathJoin folder nfoName
      match catch do readFileUtf8 nfoPath with
        Left _    -> None
        Right xml ->
          match Nfo.parse xml with
            Left _  -> None
            Right m -> Some m

Nfo.extractTmdbId : Movie -> Optional Nat
Nfo.extractTmdbId m = match MovieId.tmdb (Movie.id m) with
  None   -> None
  Some s -> Nat.fromText (trim s)

Nfo.extractImdbId : Movie -> Optional Text
Nfo.extractImdbId m = MovieId.imdb (Movie.id m)

Nfo.extractTitle : Movie -> Optional Text
Nfo.extractTitle m =
  t = Title.display (Movie.title m)
  if Universal.eq (Text.size t) 0 then None else Some t

Nfo.extractYear : Movie -> Optional Nat
Nfo.extractYear m = Scoring.year (Movie.scoring m)

Rename.deriveTitleYear : Optional Movie -> Text -> Optional (Text, Nat)
Rename.deriveTitleYear maybeNfo folderName =
  fromNfo = match maybeNfo with
    None   -> None
    Some m ->
      match (Nfo.extractTitle m, Nfo.extractYear m) with
        (Some t, Some y) -> Some (t, y)
        _                -> None
  match fromNfo with
    Some r -> Some r
    None   ->
      match Tmdb.parseReleaseName folderName with
        None   -> None
        Some p -> Some (Tmdb.ParsedRelease.title p, Tmdb.ParsedRelease.year p)

Rename.checkAgreement : Optional Movie -> Text ->{IO, Exception} ()
Rename.checkAgreement maybeNfo folderName =
  match maybeNfo with
    None -> ()
    Some m ->
      match Tmdb.parseReleaseName folderName with
        None -> ()
        Some p ->
          match (Nfo.extractTitle m, Nfo.extractYear m) with
            (Some nfoTitle, Some nfoYear) ->
              use Nat toText
              use Universal eq
              regexTitle = Tmdb.ParsedRelease.title p
              regexYear = Tmdb.ParsedRelease.year p
              sameTitle =
                eq (Tmdb.normalize nfoTitle) (Tmdb.normalize regexTitle)
              sameYear = eq nfoYear regexYear
              if sameTitle && sameYear then ()
              else
                printLine
                  (Text.join
                    ""
                    [ "  DISAGREE: nfo=\""
                    , nfoTitle
                    , "\" ("
                    , toText nfoYear
                    , ") vs regex=\""
                    , regexTitle
                    , "\" ("
                    , toText regexYear
                    , ")"
                    ])
            _ -> ()

Rename.executeMove :
  Text -> FilePath -> Nat -> Stage.ProbeResult ->{IO, Exception} Rename.Outcome
Rename.executeMove token sourceFolder tmdbId pr =
  use Rename.Outcome RenameError
  use Text ++
  sourceText = filePathText sourceFolder
  match cachedDetails token tmdbId with
    Left err -> RenameError sourceText (Text.join "" ["details fetch: ", err])
    Right d ->
      sourceVideo = FilePath (Stage.ProbeResult.videoPath pr)
      videoExt = Rename.fileExt (Stage.ProbeResult.videoPath pr)
      base = fileBaseName d pr
      targetFolderText = Rename.targetRoot ++ "/" ++ folderName d pr
      targetFolder = FilePath targetFolderText
      targetVideo = pathJoin targetFolder (base ++ videoExt)
      targetNfo = pathJoin targetFolder (base ++ ".nfo")
      if isDirectory targetFolder then
        Rename.Outcome.Conflict sourceText targetFolderText
      else
        match 
          catch do
            _ = createDirectory targetFolder
            _ = writeFileUtf8 targetNfo (buildNfo d pr)
            renameFile sourceVideo targetVideo
         with
          Right _ -> Rename.Outcome.Renamed sourceText targetFolderText
          Left f  -> RenameError sourceText (Failure.message f)

Rename.processFolder : Text -> FilePath ->{IO, Exception} Rename.Outcome
Rename.processFolder token folder =
  use Nat toText
  use Text ++
  folderName = filePathBasename folder
  folderText = filePathText folder
  files = directoryContents.texts folder
  match findFirstVideo files with
    None   -> Rename.Outcome.NoVideo folderText
    Some _ ->
      maybeNfo = Nfo.tryReadFolder folder
      _ = match maybeNfo with
        Some _ -> printLine "  found NFO in folder"
        None   -> ()
      _ = Rename.checkAgreement maybeNfo folderName
      directId = match maybeNfo with
        Some m -> Nfo.extractTmdbId m
        None   -> None
      match directId with
        Some tmdbId ->
          _ = printLine ("  using TMDB ID from NFO: " ++ toText tmdbId)
          match Stage.readSidecar folderName with
            None    -> Rename.Outcome.NoProbe folderText
            Some pr -> Rename.executeMove token folder tmdbId pr
        None        ->
          match Tmdb.buildParsedRelease folderName maybeNfo with
            None   ->
              Rename.Outcome.NoMatch
                folderText "no title/year from NFO or folder name"
            Some p ->
              searchResult =
                Tmdb.cachedSearch
                  token
                  folderName
                  (Tmdb.ParsedRelease.title p)
                  (Tmdb.ParsedRelease.year p)
              match searchResult with
                Left err   ->
                  Rename.Outcome.NoMatch folderText ("search: " ++ err)
                Right resp ->
                  candidates = Tmdb.SearchResponse.results resp
                  scored =
                    List.map
                      (r -> (r, Tmdb.scoreCandidate p r)) candidates
                  match Tmdb.pickBest scored with
                    None        ->
                      Rename.Outcome.NoMatch
                        folderText "no unique high-scoring match"
                    Some (r, _) ->
                      match Stage.readSidecar folderName with
                        None    -> Rename.Outcome.NoProbe folderText
                        Some pr ->
                          Rename.executeMove
                            token folder (Tmdb.Result.tmdbId r) pr

Rename.processLooseVideo : Text -> FilePath ->{IO, Exception} Rename.Outcome
Rename.processLooseVideo token videoFile =
  use Rename.Outcome NoMatch
  filename = filePathBasename videoFile
  name = Rename.basenameNoExt filename
  sourceText = filePathText videoFile
  match Tmdb.parseReleaseName name with
    None -> NoMatch sourceText "parse failed (no year + quality token)"
    Some p ->
      searchResult =
        Tmdb.cachedSearch
          token name (Tmdb.ParsedRelease.title p) (Tmdb.ParsedRelease.year p)
      match searchResult with
        Left err -> NoMatch sourceText (Text.join "" ["search: ", err])
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, Tmdb.scoreCandidate p r)) candidates
          match Tmdb.pickBest scored with
            None -> NoMatch sourceText "no single high-confidence match"
            Some (r, _) ->
              match Stage.readSidecar name with
                None -> Rename.Outcome.NoProbe sourceText
                Some pr ->
                  Rename.executeMove token videoFile (Tmdb.Result.tmdbId r) pr

-- The definitions below no longer typecheck with the changes above.
-- Please fix the errors and try `update` again.

Rename.fileBaseName : MovieDetails -> ProbeResult -> Text
Rename.fileBaseName d pr =
  use Text ++
  vid = ProbeResult.video pr
  ny = titleYear d
  audioPart =
    match audio pr with
      None -> "noaudio-0"
      Some a ->
        acTag (AudioInfo.codec a) ++ "-" ++ channelsTag (AudioInfo.channels a)
  bracketed =
    vcTag (VideoInfo.codec vid)
      ++ "_"
      ++ Nat.toText (VideoInfo.bitDepth vid)
      ++ "b_"
      ++ resolutionStr (VideoInfo.width vid) (VideoInfo.height vid)
      ++ "_"
      ++ mbps (Rename.effectiveBitRate
                 (VideoInfo.bitRate vid)
                 (ProbeResult.sizeBytes pr)
                 (ProbeResult.durationSec pr))
      ++ "_"
      ++ audioPart
  ny ++ " [" ++ bracketed ++ "] ~" ++ crc32 pr

Rename.folderName : MovieDetails -> ProbeResult -> Text
Rename.folderName d pr =
  use Nat toText
  use Text ++
  vid = ProbeResult.video pr
  ny = titleYear d
  parts =
    gigabytes (ProbeResult.sizeBytes pr)
      ++ "."
      ++ vfTag (VideoInfo.width vid) (VideoInfo.height vid)
      ++ "."
      ++ vcTag (VideoInfo.codec vid)
      ++ "."
      ++ toText (VideoInfo.bitDepth vid)
      ++ "b."
      ++ toText (Rename.minutes (durationSec pr))
      ++ "min"
  ny ++ " [" ++ parts ++ "] ~" ++ crc32 pr
