      rows
   with
    Left _   -> None
    Right rs ->
      match rs with
        []       -> None
        raw +: _ ->
          match catch do Decoder.run Tmdb.CachedSearch.fromJson raw with
            Left _  -> None
            Right c ->
              match Tmdb.CachedSearch.response c with
                Some r -> Some (Right r)
                None   ->
                  match Tmdb.CachedSearch.error c with
                    Some e -> Some (Left e)
                    None   -> None

type Stage.VideoInfo
  = { codec : Text,
      width : Nat,
      height : Nat,
      bitDepth : Nat,
      pixFmt : Text,
      bitRate : Optional Nat }

type Stage.AudioInfo
  = { codec : Text, channels : Nat, channelLayout : Text }

type Stage.ProbeResult
  = { videoPath : Text,
      crc32 : Text,
      sizeBytes : Nat,
      durationSec : Float,
      video : Stage.VideoInfo,
      audio : Optional Stage.AudioInfo }

Stage.VideoInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.VideoInfo
Stage.VideoInfo.fromJson = do
  use Decoder nat text
  use object at!
  codec = at! "codec" text
  width = at! "width" nat
  height = at! "height" nat
  bitDepth = at! "bit_depth" nat
  pixFmt = at! "pix_fmt" text
  bitRate = Decoder.optional! (object.at "bit_rate" nat)
  Stage.VideoInfo.VideoInfo codec width height bitDepth pixFmt bitRate

Stage.AudioInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.AudioInfo
Stage.AudioInfo.fromJson = do
  use Decoder text
  use object at!
  codec = at! "codec" text
  channels = at! "channels" Decoder.nat
  channelLayout = at! "channel_layout" text
  Stage.AudioInfo.AudioInfo codec channels channelLayout

Stage.ProbeResult.fromJson : '{unison_json_1_4_2.Decoder} Stage.ProbeResult
Stage.ProbeResult.fromJson =
  do
    use Decoder text
    use object at!
    videoPath = at! "video_path" text
    crc32 = at! "crc32" text
    sizeBytes = at! "size_bytes" Decoder.nat
    durationSec = at! "duration_sec" Decoder.float
    video = at! "video" Stage.VideoInfo.fromJson
    audio = Decoder.optional! (object.at "audio" Stage.AudioInfo.fromJson)
    Stage.ProbeResult.ProbeResult
      videoPath crc32 sizeBytes durationSec video audio

Stage.cacheRoot : Text
Stage.cacheRoot = "/home/bismuth/.cache/uniDork/stage"

Stage.sidecarPath : Text -> FilePath
Stage.sidecarPath folderName =
  use Text ++
  FilePath (Stage.cacheRoot ++ "/" ++ folderName ++ ".json")

Relang.currentDefault : [Probe.AudioTrack] -> Optional Nat
Relang.currentDefault tracks =
  match List.find Probe.AudioTrack.isDefault tracks with
    Some t -> Some (Probe.AudioTrack.index t)
    None   -> None

Relang.decide : Text -> [Probe.AudioTrack] -> Relang.Decision
Relang.decide tmdbOrigLang tracks =
  match Relang.toIso6392 tmdbOrigLang with
    None      -> Relang.Decision.UnsupportedLanguage tmdbOrigLang
    Some code -> match Relang.selectTrack code tracks with
      None    -> Relang.Decision.OriginalNotPresent code
      Some tr ->
        chosenIdx = Probe.AudioTrack.index tr
        match Relang.currentDefault tracks with
          None        -> Relang.Decision.NoCurrentDefault chosenIdx
          Some curIdx ->
            if Universal.eq curIdx chosenIdx then
              Relang.Decision.AlreadyCorrect curIdx
            else Relang.Decision.SwitchTo curIdx chosenIdx

type Relang.Decision
  = AlreadyCorrect Nat
  | SwitchTo Nat Nat
  | OriginalNotPresent Text
  | UnsupportedLanguage Text
  | NoCurrentDefault Nat

Relang.Decision.toJson : Relang.Decision -> Json
Relang.Decision.toJson = cases
  Relang.Decision.AlreadyCorrect i ->
    Json.object
      [("kind", Json.text "already_correct"), ("default_index", Json.nat i)]
  Relang.Decision.SwitchTo o n ->
    Json.object
      [ ("kind", Json.text "switch")
      , ("old_default_index", Json.nat o)
      , ("new_default_index", Json.nat n)
      ]
  Relang.Decision.OriginalNotPresent code ->
    Json.object
      [ ("kind", Json.text "original_not_present")
      , ("expected_language", Json.text code)
      ]
  Relang.Decision.UnsupportedLanguage code ->
    Json.object
      [("kind", Json.text "unsupported_language"), ("tmdb_code", Json.text code)]
  Relang.Decision.NoCurrentDefault i ->
    Json.object
      [("kind", Json.text "no_current_default"), ("chosen_index", Json.nat i)]

Relang.toIso6392 : Text -> Optional Text
Relang.toIso6392 = cases
  "en" -> Some "eng"
  "ja" -> Some "jpn"
  "ko" -> Some "kor"
  "zh" -> Some "zho"
  "fr" -> Some "fra"
  "de" -> Some "deu"
  "it" -> Some "ita"
  "es" -> Some "spa"
  "pt" -> Some "por"
  "ru" -> Some "rus"
  "sv" -> Some "swe"
  "da" -> Some "dan"
  "no" -> Some "nor"
  "nl" -> Some "nld"
  "fi" -> Some "fin"
  "pl" -> Some "pol"
  "tr" -> Some "tur"
  "hi" -> Some "hin"
  "ar" -> Some "ara"
  "he" -> Some "heb"
  "th" -> Some "tha"
  "vi" -> Some "vie"
  "id" -> Some "ind"
  "hu" -> Some "hun"
  "cs" -> Some "ces"
  "ro" -> Some "ron"
  "el" -> Some "ell"
  "uk" -> Some "ukr"
  _    -> None

Relang.titleAliases : Text -> [Text]
Relang.titleAliases = cases
  "eng" -> ["english", "eng", "en"]
  "ita" -> ["italian", "italiano", "ita", "it"]
  "jpn" -> ["japanese", "jpn", "jp"]
  "kor" -> ["korean", "kor", "kr"]
  "fra" -> ["french", "francais", "français", "fra", "fre", "fr", "vf", "vff"]
  "deu" -> ["german", "deutsch", "ger", "deu", "de"]
  "spa" -> ["spanish", "espanol", "español", "spa", "esp", "es"]
  "por" -> ["portuguese", "portugues", "português", "por", "pt"]
  "rus" -> ["russian", "rus", "ru"]
  "zho" -> ["chinese", "mandarin", "cantonese", "zho", "chi", "zh"]
  "swe" -> ["swedish", "svenska", "swe", "sv"]
  "dan" -> ["danish", "dansk", "dan", "da"]
  "nor" -> ["norwegian", "norsk", "nor", "no"]
  "nld" -> ["dutch", "nederlands", "nld", "dut", "nl"]
  "fin" -> ["finnish", "suomi", "fin", "fi"]
  "pol" -> ["polish", "polski", "pol", "pl"]
  _     -> []

Relang.splitMany : [Char] -> Text -> [Text]
Relang.splitMany seps t =
  use List flatMap
  step acc c = flatMap (p -> Text.split c p) acc
  result = List.foldLeft step [t] seps
  List.filter (p -> if Universal.eq p "" then false else true) result

Relang.titleSeparators : [Char]
Relang.titleSeparators = [?\s, ?-, ?_, ?., ?,, ?(, ?), ?[, ?], ?/]

Relang.titleMatches : Text -> Probe.AudioTrack -> Boolean
Relang.titleMatches code tr =
  match Probe.AudioTrack.title tr with
    None    -> false
    Some tt ->
      aliases = Relang.titleAliases code
      lower = Text.toLowercase tt
      words = Relang.splitMany Relang.titleSeparators lower
      List.any (w -> List.any (a -> Universal.eq w a) aliases) words

Relang.containsAnySubstring : [Text] -> Text -> Boolean
Relang.containsAnySubstring needles haystack =
  List.any
    (n -> match Text.indexOf n haystack with
      Some _ -> true
      None   -> false)
    needles

Relang.titleSuggestsCommentary : Text -> Boolean
Relang.titleSuggestsCommentary tt =
  lower = Text.toLowercase tt
  markers =
    [ "comment"
    , "descriptive"
    , "director"
    , "vfx"
    , "isolated"
    , "audio description"
    , "narration"
    , "for the visually"
    ]
  Relang.containsAnySubstring markers lower

Relang.isCommentaryOrDescriptive : Probe.AudioTrack -> Boolean
Relang.isCommentaryOrDescriptive tr =
  if Probe.AudioTrack.isComment tr then true
  else
    if Probe.AudioTrack.isVisualImpaired tr then true
    else match Probe.AudioTrack.title tr with
      None    -> false
      Some tt -> Relang.titleSuggestsCommentary tt

Relang.losslessCodecs : [Text]
Relang.losslessCodecs =
  ["truehd", "dts-hd", "flac", "pcm_s24le", "pcm_s16le", "mlp"]

Relang.lossyCodecs : [Text]
Relang.lossyCodecs =
  ["dts", "eac3", "ac3", "aac", "opus", "vorbis", "mp3"]

Relang.codecRank : Text -> Nat
Relang.codecRank c =
  lower = Text.toLowercase c
  isIn xs = List.any (x -> Universal.eq x lower) xs
  if isIn Relang.losslessCodecs then 2
  else if isIn Relang.lossyCodecs then 1 else 0

Relang.betterThan : Probe.AudioTrack -> Probe.AudioTrack -> Boolean
Relang.betterThan a b =
  use Nat 
  use Universal eq
  ca = Probe.AudioTrack.channels a
  cb = Probe.AudioTrack.channels b
  if eq ca cb then
    ra = Relang.codecRank (Probe.AudioTrack.codec a)
    rb = Relang.codecRank (Probe.AudioTrack.codec b)
    if eq ra rb then Probe.AudioTrack.index a < Probe.AudioTrack.index b
    else
      if eq ra (Nat.max ra rb) && (if eq ra rb then false else true) then true
      else false
  else
    if eq ca (Nat.max ca cb) then true else false

Relang.bestOf : [Probe.AudioTrack] -> Optional Probe.AudioTrack
Relang.bestOf tracks =
  step acc cur = match acc with
    None      -> Some cur
    Some best -> if Relang.betterThan cur best then Some cur else Some best
  List.foldLeft step None tracks

Relang.selectTrack :
  Text -> [Probe.AudioTrack] -> Optional Probe.AudioTrack
Relang.selectTrack origLang3 tracks =
  strict =
    List.filter
      (t -> Universal.eq (Probe.AudioTrack.language t) (Some origLang3))
      tracks
  candidates = if Universal.eq (List.size strict) 0 then
    List.filter (Relang.titleMatches origLang3) tracks
  else strict
  surviving =
    List.filter
      (t -> if Relang.isCommentaryOrDescriptive t then false else true)
      candidates
  Relang.bestOf surviving

Rename.targetRoot : Text
Rename.targetRoot =
  "/home/bismuth/NAS/video/_Unsorted/torrents/Complete/AMC/testMovies"

Rename.logDir : Text
Rename.logDir = "/home/bismuth/.cache/uniDork/rename-log"

Rename.gigabytes : Nat -> Text
Rename.gigabytes bytes =
  use Nat % * + / >= toText
  use Text ++
  oneGb = 1073741824
  tenths = (bytes * 10 + oneGb / 2) / oneGb
  whole = tenths / 10
  if whole >= 10 then
    rounded = (bytes + oneGb / 2) / oneGb
    toText rounded ++ " GB"
  else
    f = tenths % 10
    toText whole ++ "." ++ toText f ++ " GB"

Rename.truncSec : Float -> Nat
Rename.truncSec d =
  use Float <
  if d < 0.0 then 0
  else
    asText = Float.toText d
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    Optional.getOrElse 0 (Nat.fromText intPart)

Rename.minutes : Float -> Nat
Rename.minutes d =
  use Nat /
  Rename.truncSec d / 60

Rename.effectiveBitRate : Optional Nat -> Nat -> Float -> Nat
Rename.effectiveBitRate br sizeBytes durationSec = match br with
  Some b -> b
  None   ->
    use Nat * /
    secs = Rename.truncSec durationSec
    if Universal.eq secs 0 then 0 else sizeBytes * 8 / secs

Rename.executeMoveWith :
  [Rename.FormatPart] -> [Rename.FormatPart] ->
    Tmdb.Result -> FilePath -> Stage.ProbeResult -> Text ->{IO, Exception} Rename.Outcome
Rename.executeMoveWith folderFmt fileFmt r sourceVideo pr originalName =
  use Text ++
  sourceText = filePathText sourceVideo
  videoExt = Rename.fileExt (Stage.ProbeResult.videoPath pr)
  base = Rename.renderWith fileFmt r pr originalName
  targetFolderText =
    Rename.targetRoot ++ "/" ++ Rename.renderWith folderFmt r pr originalName
  targetFolder = FilePath targetFolderText
  targetVideo = pathJoin targetFolder (base ++ videoExt)
  targetNfo = pathJoin targetFolder (base ++ ".nfo")
  if isDirectory targetFolder then
    Rename.Outcome.Conflict sourceText targetFolderText
  else
    match
      catch do
        _ = createDirectory targetFolder
        _ = writeFileUtf8 targetNfo (Rename.minimalNfo r)
        renameFile sourceVideo targetVideo
     with
      Right _ -> Rename.Outcome.Renamed sourceText targetFolderText
      Left f  -> Rename.Outcome.RenameError sourceText (Failure.message f)

Rename.processFolderWith
  folderFmt fileFmt
  pqStage pqLargest pqSearch pcSearch pqDet pcDet token folder =
  use Rename.Outcome NoMatch NoProbe NoVideo
  folderName = filePathBasename folder
  folderText = filePathText folder
  match Stage.largestInFolderWith pqLargest folderText with
    Some pr ->
      videoPathText = Stage.ProbeResult.videoPath pr
      videoPath = FilePath videoPathText
      maybeNfo = Nfo.tryReadFolder folder
      _ = Rename.checkAgreement maybeNfo folderName
      probeMin = Some (Rename.minutes (Stage.ProbeResult.durationSec pr))
      match Rename.matchTmdbWith
        pqSearch pcSearch pqDet pcDet token folderName maybeNfo probeMin
       with
        Left err -> NoMatch folderText err
        Right r  ->
          Rename.executeMoveWith folderFmt fileFmt r videoPath pr folderName
    None ->
      files = directoryContents.texts folder
      match findFirstVideo files with
        None -> NoVideo folderText
        Some videoName ->
          NoProbe (filePathText (pathJoin folder videoName))

Rename.processLooseVideoWith
  folderFmt fileFmt
  pqStage pqSearch pcSearch pqDet pcDet token videoFile =
  use Rename.Outcome NoMatch NoProbe
  filename = filePathBasename videoFile
  name = Rename.basenameNoExt filename
  sourceText = filePathText videoFile
  match Stage.readWith pqStage sourceText with
    None    -> NoProbe sourceText
    Some pr ->
      probeMin = Some (Rename.minutes (Stage.ProbeResult.durationSec pr))
      match Rename.matchTmdbWith
        pqSearch pcSearch pqDet pcDet token name None probeMin
       with
        Left err -> NoMatch sourceText err
        Right r  ->
          Rename.executeMoveWith folderFmt fileFmt r videoFile pr name

Rename.runOneWith
  folderFmt fileFmt
  pqStage pqLargest pqSearch pcSearch pqDet pcDet pcLog token folder =
  use Text ++
  folderName = filePathBasename folder
  _ = printLine ("processing: " ++ folderName)
  outcome =
    Rename.processFolderWith
      folderFmt fileFmt
      pqStage pqLargest pqSearch pcSearch pqDet pcDet token folder
  _ = match outcome with
    Rename.Outcome.Renamed _ tgt -> printLine ("  RENAMED -> " ++ tgt)
    Rename.Outcome.NoVideo _ -> printLine "  skip: no video"
    Rename.Outcome.NoMatch _ reason -> printLine ("  skip: " ++ reason)
    Rename.Outcome.NoProbe src ->
      printLine
        ("  skip: no probe row for " ++ src ++ " (run unidork probe-stage)")
    Rename.Outcome.Conflict _ t -> printLine ("  skip: target exists " ++ t)
    Rename.Outcome.RenameError _ msg -> printLine ("  ERROR: " ++ msg)
  Rename.writeOutcomeWith pcLog outcome

Rename.runOneLooseWith
  folderFmt fileFmt
  pqStage pqSearch pcSearch pqDet pcDet pcLog token videoFile =
  use Text ++
  filename = filePathBasename videoFile
  _ = printLine ("processing (loose): " ++ filename)
  outcome =
    Rename.processLooseVideoWith
      folderFmt fileFmt
      pqStage pqSearch pcSearch pqDet pcDet token videoFile
  _ = match outcome with
    Rename.Outcome.Renamed _ tgt -> printLine ("  RENAMED -> " ++ tgt)
    Rename.Outcome.NoVideo _ -> printLine "  skip: no video"
    Rename.Outcome.NoMatch _ reason -> printLine ("  skip: " ++ reason)
    Rename.Outcome.NoProbe src ->
      printLine
        ("  skip: no probe row for " ++ src ++ " (run unidork probe-stage)")
    Rename.Outcome.Conflict _ t -> printLine ("  skip: target exists " ++ t)
    Rename.Outcome.RenameError _ msg -> printLine ("  ERROR: " ++ msg)
  Rename.writeOutcomeWith pcLog outcome

Rename.mbps : Nat -> Text
Rename.mbps bps =
  use Nat % * + / >= toText
  use Text ++
  oneMbps = 1000000
  tenths = (bps * 10 + oneMbps / 2) / oneMbps
  whole = tenths / 10
  if whole >= 10 then
    rounded = (bps + oneMbps / 2) / oneMbps
    toText rounded ++ " Mbps"
  else
    f = tenths % 10
    toText whole ++ "." ++ toText f ++ " Mbps"

Rename.vfTag : Nat -> Nat -> Text
Rename.vfTag width height =
  use Nat >=
  if width >= 3000 || height >= 1700 then "2160p"
  else
    if width >= 2300 || height >= 1300 then "1440p"
    else
      if width >= 1800 || height >= 800 then "1080p"
      else
        if width >= 1100 || height >= 700 then "720p"
        else
          if height >= 540 then "576p"
          else if height >= 380 then "480p" else "SD"

Rename.vcTag : Text -> Text
Rename.vcTag raw =
  use Universal eq
  lower = Text.toLowercase raw
  if eq lower "hevc" then "x265"
  else
    if eq lower "h265" then "x265"
    else
      if eq lower "h264" then "x264"
      else
        if eq lower "avc" then "x264"
        else
          if eq lower "av1" then "av1"
          else
            if eq lower "vp9" then "vp9"
            else if eq lower "mpeg4" then "xvid" else lower

Rename.resolutionStr : Nat -> Nat -> Text
Rename.resolutionStr w h =
  use Nat toText
  use Text ++
  toText w ++ "x" ++ toText h

Rename.channelsTag : Nat -> Text
Rename.channelsTag ch =
  use Universal eq
  if eq ch 1 then "1.0"
  else
    if eq ch 2 then "2.0"
    else if eq ch 6 then "5.1" else if eq ch 8 then "7.1" else Nat.toText ch

Rename.acTag : Text -> Text
Rename.acTag raw =
  use Universal eq
  upper = Text.toUppercase raw
  if eq upper "AC3" then "AC3"
  else
    if eq upper "EAC3" then "EAC3"
    else
      if eq upper "AAC" then "AAC"
      else
        if eq upper "DTS" then "DTS"
        else
          if eq upper "TRUEHD" then "TrueHD"
          else
            if eq upper "FLAC" then "FLAC"
            else
              if eq upper "OPUS" then "Opus"
              else if eq upper "MP3" then "MP3" else upper

Rename.audioPart : Stage.ProbeResult -> Text
Rename.audioPart pr =
  use Text ++
  match Stage.ProbeResult.audio pr with
    None   -> "noaudio-0"
    Some a ->
      Rename.acTag (Stage.AudioInfo.codec a)
        ++ "-"
        ++ Rename.channelsTag (Stage.AudioInfo.channels a)

Rename.fileBaseName : Tmdb.Result -> Stage.ProbeResult -> Text
Rename.fileBaseName r pr =
  use Nat toText
  use Text ++
  vid = Stage.ProbeResult.video pr
  ny = Rename.titleYear r
  bracketed =
    Rename.vcTag (Stage.VideoInfo.codec vid)
      ++ "_"
      ++ toText (Stage.VideoInfo.bitDepth vid)
      ++ "b_"
      ++ Rename.resolutionStr
           (Stage.VideoInfo.width vid) (Stage.VideoInfo.height vid)
      ++ "_"
      ++ Rename.mbps
           (Rename.effectiveBitRate
             (Stage.VideoInfo.bitRate vid)
             (Stage.ProbeResult.sizeBytes pr)
             (Stage.ProbeResult.durationSec pr))
      ++ "_"
      ++ Rename.audioPart pr
  ny ++ " [" ++ bracketed ++ "] ~" ++ Stage.ProbeResult.crc32 pr

Rename.fileExt : Text -> Text
Rename.fileExt path =
  lower = Text.toLowercase path
  if endsWith ".mkv" lower then ".mkv"
  else
    if endsWith ".mp4" lower then ".mp4"
    else
      if endsWith ".avi" lower then ".avi"
      else
        if endsWith ".mov" lower then ".mov"
        else
          if endsWith ".wmv" lower then ".wmv"
          else if endsWith ".flv" lower then ".flv" else ""

Rename.folderName : Tmdb.Result -> Stage.ProbeResult -> Text
Rename.folderName r pr =
  use Nat toText
  use Text ++
  vid = Stage.ProbeResult.video pr
  ny = Rename.titleYear r
  parts =
    Rename.gigabytes (Stage.ProbeResult.sizeBytes pr)
      ++ "."
      ++ Rename.vfTag (Stage.VideoInfo.width vid) (Stage.VideoInfo.height vid)
      ++ "."
      ++ Rename.vcTag (Stage.VideoInfo.codec vid)
      ++ "."
      ++ toText (Stage.VideoInfo.bitDepth vid)
      ++ "b."
      ++ toText (Rename.minutes (Stage.ProbeResult.durationSec pr))
      ++ "min"
  ny ++ " [" ++ parts ++ "] ~" ++ Stage.ProbeResult.crc32 pr

Rename.titleYear : Tmdb.Result -> Text
Rename.titleYear r =
  use Text ++
  yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    Some y -> Nat.toText y
    None   -> "0000"
  Rename.sanitize (Tmdb.Result.title r) ++ " (" ++ yearText ++ ")"

Rename.escapeXml : Text -> Text
Rename.escapeXml t =
  t |> replaceAll "&" "&amp;" |> replaceAll "<" "&lt;" |> replaceAll ">" "&gt;"

type Rename.Outcome
  = NoVideo Text
  | NoProbe Text
  | Renamed Text Text
  | NoMatch Text Text
  | Conflict Text Text
  | RenameError Text Text

Rename.minimalNfo : Tmdb.Result -> Text
Rename.minimalNfo r =
  use Nat toText
  use Text ++ join
  yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    Some y -> toText y
    None   -> ""
  tmdbText = toText (Tmdb.Result.tmdbId r)
  join "\n"
    [ "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\" ?>"
    , "<movie>"
    , "  <title>" ++ Rename.escapeXml (Tmdb.Result.title r) ++ "</title>"
    , "  <originaltitle>"
        ++ Rename.escapeXml (Tmdb.Result.originalTitle r)
        ++ "</originaltitle>"
    , "  <year>" ++ yearText ++ "</year>"
    , "  <plot>" ++ Rename.escapeXml (Tmdb.Result.overview r) ++ "</plot>"
    , "  <uniqueid type=\"tmdb\" default=\"true\">"
        ++ tmdbText
        ++ "</uniqueid>"
    , "  <id>" ++ tmdbText ++ "</id>"
    , "</movie>"
    , ""
    ]

Rename.checkAgreement : Optional Movie -> Text ->{IO, Exception} ()
Rename.checkAgreement maybeNfo folderName =
  match maybeNfo with
    None -> ()
    Some m ->
      match Tmdb.parseReleaseName folderName with
        None -> ()
        Some p ->
          match (Nfo.extractTitle m, Nfo.extractYear m) with
            (Some nfoTitle, Some nfoYear) ->
              use Nat toText
              use Universal eq
              regexTitle = Tmdb.ParsedRelease.title p
              regexYear = Tmdb.ParsedRelease.year p
              sameTitle =
                eq (Tmdb.normalize nfoTitle) (Tmdb.normalize regexTitle)
              sameYear = eq nfoYear regexYear
              if sameTitle && sameYear then ()
              else
                printLine
                  (Text.join ""
                    [ "  DISAGREE: nfo=\""
                    , nfoTitle
                    , "\" ("
                    , toText nfoYear
                    , ") vs regex=\""
                    , regexTitle
                    , "\" ("
                    , toText regexYear
                    , ")"
                    ])
            _ -> ()

Rename.matchTmdbWith pqSearch pcSearch pqDet pcDet token name maybeNfo maybeProbeMin =
  match Tmdb.buildParsedRelease name maybeNfo with
    None -> Left "no title/year from NFO or folder name"
    Some p ->
      match Tmdb.cachedSearchWith
        pqSearch pcSearch token name
        (Tmdb.ParsedRelease.title p)
        (Tmdb.ParsedRelease.year p) with
        Left err   -> Left err
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, Tmdb.scoreCandidate p r)) candidates
          match
            Tmdb.pickBestWithRuntime pqDet pcDet token maybeProbeMin scored
           with
            Some (r, _) -> Right r
            None        -> Left "no single high-scoring match"

Rename.Outcome.toJson : Rename.Outcome -> Json
Rename.Outcome.toJson = cases
  Rename.Outcome.Renamed src tgt ->
    Json.object
      [ ("outcome", Json.text "renamed")
      , ("source", Json.text src)
      , ("target", Json.text tgt)
      ]
  Rename.Outcome.NoVideo src ->
    Json.object [("outcome", Json.text "no_video"), ("source", Json.text src)]
  Rename.Outcome.NoMatch src reason ->
    Json.object
      [ ("outcome", Json.text "no_match")
      , ("source", Json.text src)
      , ("reason", Json.text reason)
      ]
  Rename.Outcome.NoProbe src ->
    Json.object [("outcome", Json.text "no_probe"), ("source", Json.text src)]
  Rename.Outcome.Conflict src existing ->
    Json.object
      [ ("outcome", Json.text "conflict")
      , ("source", Json.text src)
      , ("existing", Json.text existing)
      ]
  Rename.Outcome.RenameError src msg ->
    Json.object
      [ ("outcome", Json.text "error")
      , ("source", Json.text src)
      , ("message", Json.text msg)
      ]

-- ============================================================
-- Rename format DSL
--
-- A filebot-style template like:
--   "{ny} [{gigabytes}.{vf}.{vc}.{bitdepth}b.{minutes}min] ~{crc32}"
-- is parsed into a [FormatPart], then applied to a Context to
-- produce the final text.
-- ============================================================

type Rename.FormatPart
  = Literal Text
  | Token Text

-- Default templates. Editing these is the supported customization point.
Rename.folderFormat : Text
Rename.folderFormat =
  "{ny} [{gigabytes}.{vf}.{vc}.{bitdepth}b.{minutes}min] ~{crc32}"

Rename.fileFormat : Text
Rename.fileFormat =
  "{ny} {tags} [{vc}_{bitdepth}b_{resolution}_{mbps}_{ac}-{channels}_{group}] ~{crc32}"

-- Parse a template string into literal/token parts.
Rename.parseFormat : Text -> [Rename.FormatPart]
Rename.parseFormat template =
  use List ++
  use Nat >
  segments = Text.split ?{ template
  match segments with
    []           -> []
    [single]     ->
      if Text.size single > 0
      then [Rename.FormatPart.Literal single]
      else []
    first +: rest ->
      head =
        if Text.size first > 0
        then [Rename.FormatPart.Literal first]
        else []
      head ++ List.flatMap Rename.parseSegment rest

Rename.parseSegment : Text -> [Rename.FormatPart]
Rename.parseSegment seg =
  use List ++
  use Nat + >
  match Text.indexOf "}" seg with
    None   ->
      [Rename.FormatPart.Literal (Text.join "" ["{", seg])]
    Some i ->
      tokenName = Text.take i seg
      rest = Text.drop (i + 1) seg
      tokenPart = [Rename.FormatPart.Token tokenName]
      if Text.size rest > 0
      then tokenPart ++ [Rename.FormatPart.Literal rest]
      else tokenPart

-- The data a format needs to resolve any token.
type Rename.Context
  = { tmdb : Tmdb.Result
    , probe : Stage.ProbeResult
    , group : Optional Text
    , tags : [Text]
    , originalName : Text
    }

Rename.buildContext :
  Tmdb.Result -> Stage.ProbeResult -> Text -> Rename.Context
Rename.buildContext r pr originalName =
  Rename.Context.Context
    r
    pr
    (Rename.extractGroup originalName)
    (Rename.extractTags originalName)
    originalName

-- Resolve a single token. Unknown tokens become "".
Rename.resolveToken : Rename.Context -> Text -> Text
Rename.resolveToken ctx tok =
  use Rename.Context tmdb probe group tags
  r = tmdb ctx
  pr = probe ctx
  vid = Stage.ProbeResult.video pr
  match tok with
    "ny"         -> Rename.titleYear r
    "n"          -> Rename.sanitize (Tmdb.Result.title r)
    "y"          -> match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
                      Some y -> Nat.toText y
                      None   -> "0000"
    "gigabytes"  -> Rename.gigabytes (Stage.ProbeResult.sizeBytes pr)
    "vf"         -> Rename.vfTag
                      (Stage.VideoInfo.width vid)
                      (Stage.VideoInfo.height vid)
    "vc"         -> Rename.vcTag (Stage.VideoInfo.codec vid)
    "bitdepth"   -> Nat.toText (Stage.VideoInfo.bitDepth vid)
    "minutes"    -> Nat.toText
                      (Rename.minutes (Stage.ProbeResult.durationSec pr))
    "crc32"      -> Stage.ProbeResult.crc32 pr
    "resolution" -> Rename.resolutionStr
                      (Stage.VideoInfo.width vid)
                      (Stage.VideoInfo.height vid)
    "mbps"       -> Rename.mbps
                      (Rename.effectiveBitRate
                        (Stage.VideoInfo.bitRate vid)
                        (Stage.ProbeResult.sizeBytes pr)
                        (Stage.ProbeResult.durationSec pr))
    "ac"         -> match Stage.ProbeResult.audio pr with
                      Some a -> Rename.acTag (Stage.AudioInfo.codec a)
                      None   -> "noaudio"
    "channels"   -> match Stage.ProbeResult.audio pr with
                      Some a -> Rename.channelsTag (Stage.AudioInfo.channels a)
                      None   -> "0"
    "group"      -> Optional.getOrElse "" (group ctx)
    "tags"       -> Text.join " " (tags ctx)
    _            -> ""

Rename.applyFormat : [Rename.FormatPart] -> Rename.Context -> Text
Rename.applyFormat parts ctx =
  render = cases
    Rename.FormatPart.Literal t  -> t
    Rename.FormatPart.Token name -> Rename.resolveToken ctx name
  Text.join "" (List.map render parts)

-- ============================================================
-- Helpers: group/tag extraction, whitespace + underscore tightening
-- ============================================================

Rename.isLikelyGroupToken : Text -> Boolean
Rename.isLikelyGroupToken t =
  use Nat < >=
  sz = Text.size t
  if sz < 2 then false
  else
    if sz >= 30 then false
    else
      hasSpace = match Text.indexOf " " t with
        Some _ -> true
        None   -> false
      hasDot = match Text.indexOf "." t with
        Some _ -> true
        None   -> false
      if hasSpace then false
      else if hasDot then false else true

-- Try: token after the last "-" if it's a single clean word.
-- Else: last whitespace-separated word, unless it's a quality marker.
Rename.extractGroup : Text -> Optional Text
Rename.extractGroup name =
  trimmedName = trim name
  byDash = match List.reverse (Text.split ?- trimmedName) with
    last +: _ ->
      lt = trim last
      if Rename.isLikelyGroupToken lt then Some lt else None
    []        -> None
  match byDash with
    Some g -> Some g
    None   ->
      match List.reverse (Text.split ?\s trimmedName) with
        last +: _ ->
          lt = trim last
          if Rename.isLikelyGroupToken lt then
            if Tmdb.isQualityToken lt then None
            else Some lt
          else None
        [] -> None

Rename.editionKeywords : [Text]
Rename.editionKeywords =
  [ "EXTENDED", "REMASTERED", "UNRATED", "THEATRICAL"
  , "DIRECTORS.CUT", "DIRECTORS_CUT", "DIRECTORS CUT"
  , "PROPER", "REPACK", "ANNIVERSARY"
  , "IMAX", "OPEN.MATTE", "OPEN_MATTE", "OPENMATTE"
  ]

Rename.extractTags : Text -> [Text]
Rename.extractTags name =
  upper = Text.toUppercase name
  List.filter
    (kw -> match Text.indexOf kw upper with
      Some _ -> true
      None   -> false)
    Rename.editionKeywords

Rename.collapseSpaces : Text -> Text
Rename.collapseSpaces t =
  use Nat >
  parts = Text.split ?\s t
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  Text.join " " nonEmpty

-- Run replaceAll up to a few times so consecutive empty tokens collapse fully.
Rename.shrink : Text -> Text -> Text -> Text
Rename.shrink needle replacement t =
  t
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement

-- Final pass: collapse whitespace, then remove dangling underscores that
-- empty tokens leave behind inside bracketed sections.
Rename.tighten : Text -> Text
Rename.tighten t =
  t
    |> Rename.collapseSpaces
    |> Rename.shrink "__" "_"
    |> replaceAll "_]" "]"
    |> replaceAll "[_" "["
    |> replaceAll "_ " " "
    |> replaceAll " _" " "
    |> trim

-- ============================================================
-- Public render entry points used by Rename.executeMoveWith
-- ============================================================

Rename.renderWith :
  [Rename.FormatPart] -> Tmdb.Result -> Stage.ProbeResult -> Text -> Text
Rename.renderWith parsed r pr originalName =
  ctx = Rename.buildContext r pr originalName
  Rename.tighten (Rename.applyFormat parsed ctx)

test> Rename.gigabytes.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.gigabytes 0) "0.0 GB"
    , eq (Rename.gigabytes 1073741824) "1.0 GB"
    , eq (Rename.gigabytes 5368709120) "5.0 GB"
    , eq (Rename.gigabytes 8589934592) "8.0 GB"
    , eq (Rename.gigabytes 12884901888) "12 GB"
    , eq (Rename.gigabytes 25769803776) "24 GB"
    , eq (Rename.gigabytes 429496729) "0.4 GB"
    ]

test> Rename.mbps.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.mbps 0) "0.0 Mbps"
    , eq (Rename.mbps 1500000) "1.5 Mbps"
    , eq (Rename.mbps 5800000) "5.8 Mbps"
    , eq (Rename.mbps 11000000) "11 Mbps"
    , eq (Rename.mbps 31000000) "31 Mbps"
    ]

test> Rename.vfTag.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.vfTag 3840 2160) "2160p"
    , eq (Rename.vfTag 3840 2080) "2160p"
    , eq (Rename.vfTag 1920 1080) "1080p"
    , eq (Rename.vfTag 1920 800) "1080p"
    , eq (Rename.vfTag 1920 1040) "1080p"
    , eq (Rename.vfTag 1280 720) "720p"
    , eq (Rename.vfTag 720 576) "576p"
    , eq (Rename.vfTag 720 404) "480p"
    , eq (Rename.vfTag 640 360) "SD"
    ]

test> Rename.channelsTag.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.channelsTag 2) "2.0"
    , eq (Rename.channelsTag 6) "5.1"
    , eq (Rename.channelsTag 8) "7.1"
    , eq (Rename.channelsTag 3) "3"
    ]

test> Rename.parseFormat.test =
  use Universal eq
  lit = Rename.FormatPart.Literal
  tok = Rename.FormatPart.Token
  List.flatMap
    check
    [ eq (Rename.parseFormat "") []
    , eq (Rename.parseFormat "hello") [lit "hello"]
    , eq (Rename.parseFormat "{a}") [tok "a"]
    , eq (Rename.parseFormat "x{a}y") [lit "x", tok "a", lit "y"]
    , eq (Rename.parseFormat "{a}{b}") [tok "a", tok "b"]
    , eq
        (Rename.parseFormat "{ny} [{vf}]")
        [tok "ny", lit " [", tok "vf", lit "]"]
    ]

test> Rename.tighten.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.tighten "hello  world") "hello world"
    , eq (Rename.tighten "  hello   world  ") "hello world"
    , eq (Rename.tighten "a__b") "a_b"
    , eq (Rename.tighten "a___b") "a_b"
    , eq (Rename.tighten "[x_y_]") "[x_y]"
    , eq (Rename.tighten "[_x_y]") "[x_y]"
    ]

test> Rename.extractGroup.test =
  use Universal eq
  List.flatMap
    check
    [ eq
        (Rename.extractGroup "Under.Siege.1992.1080p.x265-Tigole")
        (Some "Tigole")
    , eq
        (Rename.extractGroup "Some Movie 2020 1080p BluRay x265 Tigole")
        (Some "Tigole")
    , eq
        (Rename.extractGroup "Title.2020.1080p.WEB-DL.x265-RG")
        (Some "RG")
    , eq (Rename.extractGroup "Generic Movie 2020 1080p") None
    , eq
        (Rename.extractGroup
          "War Machine 2026 1080p WEB-DL HEVC x265 10Bit DDP5.1 Subs KINGDOM_RG")
        (Some "KINGDOM_RG")
    ]

Rename.basenameNoExt : Text -> Text
Rename.basenameNoExt filename =
  use List reverse
  parts = Text.split ?. filename
  match reverse parts with
    _ +: []   -> filename
    _ +: rest -> Text.join "." (reverse rest)
    []        -> filename

Rename.sanitize : Text -> Text
Rename.sanitize t =
  use Nat >
  dropChars = ["'", "\"", "`"]
  spaceChars =
    [ ":", ";", ",", ".", "/", "\\", "?", "*", "<", ">", "|"
    , "!", "@", "#", "$", "%", "^", "&", "+", "=", "~"
    , "(", ")", "[", "]", "{", "}"
    , "—", "–"
    , "\n", "\t", "\r"
    ]
  dropped = List.foldLeft (acc c -> replaceAll c "" acc) t dropChars
  spaced = List.foldLeft (acc c -> replaceAll c " " acc) dropped spaceChars
  parts = Text.split ?\s spaced
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  trim (Text.join " " nonEmpty)

Rename.looseVideos : FilePath ->{IO, Exception} [FilePath]
Rename.looseVideos dir =
  entries = directoryContents.texts dir
  videoNames = List.filter isVideo entries
  step acc n =
    use List :+
    fp = pathJoin dir n
    if isDirectory fp then acc else acc :+ fp
  List.foldLeft step [] videoNames

uniDork.identify : '{IO, Exception} ()
uniDork.identify = do
  use Db foreach_
  use List size
  use Nat toText
  use Text ++
  use Universal eq
  staging = FilePath Tmdb.stagingDir
  if isDirectory staging then
    token = Tmdb.readToken()
    entries = directoryContents.texts staging
    folderNames =
      List.filter
        (n ->
          (if eq n "." then false
           else if eq n ".." then false
           else isDirectory (pathJoin staging n)))
        entries
    folders = List.map (n -> pathJoin staging n) folderNames
    loose = Rename.looseVideos staging
    _ =
      printLine
        (Text.join
          ""
          [ "scanning "
          , toText (size folders)
          , " folder(s) and "
          , toText (size loose)
          , " loose video(s) under "
          , Tmdb.stagingDir
          ])
    _ = printLine ""
    singleIO Db.config do
      pq = prepareQuery Tmdb.selectSearchSql
      pc = prepareCommand Tmdb.upsertSearchSql
      pqStage = prepareQuery Stage.selectProbeSql
      pqDet = prepareQuery Tmdb.selectDetailsSql
      pcDet = prepareCommand Tmdb.upsertDetailsSql
      _ = foreach_ (Tmdb.reportFolderWith pq pc pqStage pqDet pcDet token) folders
      _ = foreach_ (Tmdb.reportLooseVideoWith pq pc pqStage pqDet pcDet token) loose
      _ = PreparedCommand.close pc
      PreparedCommand.close pcDet
  else printLine ("staging not found: " ++ Tmdb.stagingDir)

uniDork.renameWith : Text -> Text -> '{IO, Exception} ()
uniDork.renameWith folderFmtText fileFmtText = do
  use Nat toText
  use Text ++ join
  use Universal eq
  folderFmt = Rename.parseFormat folderFmtText
  fileFmt = Rename.parseFormat fileFmtText
  staging = FilePath Tmdb.stagingDir
  if isDirectory staging then
    _ = catch do
          if isDirectory (FilePath Rename.targetRoot) then ()
          else
            _ = createDirectory (FilePath Rename.targetRoot)
            ()
    token = Tmdb.readToken()
    entries = directoryContents.texts staging
    folderNames =
      List.filter
        (n ->
          (if eq n "." then false
           else if eq n ".." then false
           else isDirectory (pathJoin staging n)))
        entries
    folders = List.map (n -> pathJoin staging n) folderNames
    loose = Rename.looseVideos staging
    _ =
      printLine
        (join ""
          [ "rename: "
          , toText (List.size folders)
          , " folder(s), "
          , toText (List.size loose)
          , " loose video(s) under "
          , Tmdb.stagingDir
          ])
    _ = printLine ""
    singleIO Db.config do
      pqStage = prepareQuery Stage.selectProbeSql
      pqLargest = prepareQuery Stage.selectLargestInFolderSql
      pqSearch = prepareQuery Tmdb.selectSearchSql
      pcSearch = prepareCommand Tmdb.upsertSearchSql
      pqDet = prepareQuery Tmdb.selectDetailsSql
      pcDet = prepareCommand Tmdb.upsertDetailsSql
      pcLog = prepareCommand Rename.insertLogSql
      _ =
        Db.foreach_
          (Rename.runOneWith
            folderFmt fileFmt
            pqStage pqLargest pqSearch pcSearch pqDet pcDet pcLog token) folders
      _ =
        Db.foreach_
          (Rename.runOneLooseWith
            folderFmt fileFmt
            pqStage pqSearch pcSearch pqDet pcDet pcLog token) loose
      _ = PreparedCommand.close pcSearch
      _ = PreparedCommand.close pcDet
      PreparedCommand.close pcLog
  else printLine ("staging not found: " ++ Tmdb.stagingDir)

uniDork.renameWithCombinedFormat : Text -> '{IO, Exception} ()
uniDork.renameWithCombinedFormat fullFormat = do
  use Text ++
  parts = Text.split ?/ fullFormat
  match List.reverse parts with
    []         ->
      _ = printLine "empty format"
      ()
    [_]        ->
      _ = printLine "format must contain '/' separating folder and file templates"
      ()
    fileFmt +: folderParts ->
      folderFmt = Text.join "/" (List.reverse folderParts)
      !(uniDork.renameWith folderFmt fileFmt)

uniDork.rename : '{IO, Exception} ()
uniDork.rename = uniDork.renameWith Rename.folderFormat Rename.fileFormat

uniDork.batchSize : Nat
uniDork.batchSize = 50

List.chunk : Nat -> [a] -> [[a]]
List.chunk n xs =
  use List +: size
  use Nat <=
  if Universal.eq (size xs) 0 then []
  else
    if size xs <= n then [xs]
    else List.take n xs +: List.chunk n (List.drop n xs)

uniDork.collectFolders : [FilePath] ->{IO, Exception} [FilePath]
uniDork.collectFolders roots =
  addIfDir : FilePath -> [FilePath] -> Text ->{IO, Exception} [FilePath]
  addIfDir root acc name =
    use List +:
    fp = pathJoin root name
    if isDirectory fp then fp +: acc else acc
  perRoot root =
    basenames = directoryContents.texts root
    _ =
      printLine
        (Text.join
          ""
          [ "scanning: "
          , filePathText root
          , " ("
          , Nat.toText (List.size basenames)
          , " entries)"
          ])
    List.reverse (List.foldLeft (addIfDir root) [] basenames)
  List.flatMap perRoot roots

uniDork.processOne
  pcUpsert
  pcVid
  pcDVid
  pcAud
  pcDAud
  pcSub
  pcDSub
  pcAct
  pcDAct
  pcGen
  pcDGen
  pcTag
  pcDTag
  pcCou
  pcDCou
  pcStu
  pcDStu
  pcDir
  pcDDir
  pcCre
  pcDCre
  folder =
  match Nfo.processFolder folder with
    Left _ ->
      _ = printLine (Text.join "" ["  no nfo: ", filePathText folder])
      ()
    Right m ->
      actualRuntime = match Movie.videoFilePath m with
        None         -> None
        Some vidPath ->
          match Probe.readSidecar vidPath with
            None   -> None
            Some r -> Some (Probe.runtimeSec r)
      Db.upsertWith
        pcUpsert
        pcVid
        pcDVid
        pcAud
        pcDAud
        pcSub
        pcDSub
        pcAct
        pcDAct
        pcGen
        pcDGen
        pcTag
        pcDTag
        pcCou
        pcDCou
        pcStu
        pcDStu
        pcDir
        pcDDir
        pcCre
        pcDCre
        actualRuntime
        m

uniDork.processBatch : [FilePath] ->{IO, Exception} ()
uniDork.processBatch folders = 
  singleIO Db.config do
    use PreparedCommand close
    pcUpsert = prepareCommand Db.upsertMovieSql
    pcVid = prepareCommand Db.insertVideoSql
    pcDVid = prepareCommand (Db.deleteChildSql "movie_video_streams")
    pcAud = prepareCommand Db.insertAudioSql
    pcDAud = prepareCommand (Db.deleteChildSql "movie_audio_tracks")
    pcSub = prepareCommand Db.insertSubSql
    pcDSub = prepareCommand (Db.deleteChildSql "movie_subtitles")
    pcAct = prepareCommand Db.insertActorSql
    pcDAct = prepareCommand (Db.deleteChildSql "movie_actors")
    pcGen = prepareCommand Db.insertGenreSql
    pcDGen = prepareCommand (Db.deleteChildSql "movie_genres")
    pcTag = prepareCommand Db.insertTagSql
    pcDTag = prepareCommand (Db.deleteChildSql "movie_tags")
    pcCou = prepareCommand Db.insertCountrySql
    pcDCou = prepareCommand (Db.deleteChildSql "movie_countries")
    pcStu = prepareCommand Db.insertStudioSql
    pcDStu = prepareCommand (Db.deleteChildSql "movie_studios")
    pcDir = prepareCommand Db.insertDirectorSql
    pcDDir = prepareCommand (Db.deleteChildSql "movie_directors")
    pcCre = prepareCommand Db.insertCreditSql
    pcDCre = prepareCommand (Db.deleteChildSql "movie_credits")
    _ =
      Db.foreach_
        (uniDork.processOne
          pcUpsert
          pcVid
          pcDVid
          pcAud
          pcDAud
          pcSub
          pcDSub
          pcAct
          pcDAct
          pcGen
          pcDGen
          pcTag
          pcDTag
          pcCou
          pcDCou
          pcStu
          pcDStu
          pcDir
          pcDDir
          pcCre
          pcDCre)
        folders
    _ = close pcUpsert
    _ = close pcVid
    _ = close pcDVid
    _ = close pcAud
    _ = close pcDAud
    _ = close pcSub
    _ = close pcDSub
    _ = close pcAct
    _ = close pcDAct
    _ = close pcGen
    _ = close pcDGen
    _ = close pcTag
    _ = close pcDTag
    _ = close pcCou
    _ = close pcDCou
    _ = close pcStu
    _ = close pcDStu
    _ = close pcDir
    _ = close pcDDir
    _ = close pcCre
    close pcDCre

uniDork.runBatchSafe : Nat -> Nat -> [FilePath] ->{IO, Exception} ()
uniDork.runBatchSafe i n batch =
  use Nat toText
  use Text join
  _ =
    printLine
      (join
        ""
        [ "batch "
        , toText i
        , "/"
        , toText n
        , " ("
        , toText (List.size batch)
        , " folders)"
        ])
  match catch do uniDork.processBatch batch with
    Right _ -> ()
    Left f  -> printLine (join "" ["  BATCH FAILED: ", Failure.message f])

uniDork.batchedMain : Text ->{IO, Exception} ()
uniDork.batchedMain configPath =
  use List size
  use Nat toText
  use Text join
  configText = readFileUtf8 (FilePath configPath)
  dirs = List.filterMap parseConfigLine (lines configText)
  _ = Db.createSchema()
  _ = printLine "collecting folders..."
  folders = uniDork.collectFolders dirs
  total = size folders
  _ = printLine (join "" ["found ", toText total, " folders to process"])
  batches = List.chunk uniDork.batchSize folders
  nBatches = size batches
  _ =
    printLine
      (join
        ""
        [ "processing in "
        , toText nBatches
        , " batches of (up to) "
        , toText uniDork.batchSize
        ])
  step i batch =
    use Nat +
    _ = uniDork.runBatchSafe i nBatches batch
    i + 1
  _ = List.foldLeft step 1 batches
  printLine "done"

uniDork.batchedRun : '{IO, Exception} ()
uniDork.batchedRun = do uniDork.batchedMain "./uniDork.conf"

Nfo.tryReadFolder : FilePath ->{IO, Exception} Optional Movie
Nfo.tryReadFolder folder =
  files = directoryContents.texts folder
  match findFirstNfo files with
    None         -> None
    Some nfoName ->
      nfoPath = pathJoin folder nfoName
      match catch do readFileUtf8 nfoPath with
        Left _    -> None
        Right xml ->
          match Nfo.parse xml with
            Left _  -> None
            Right m -> Some m

Nfo.extractTmdbId : Movie -> Optional Nat
Nfo.extractTmdbId m = match MovieId.tmdb (Movie.id m) with
  None   -> None
  Some s -> Nat.fromText (trim s)

Nfo.extractImdbId : Movie -> Optional Text
Nfo.extractImdbId m = MovieId.imdb (Movie.id m)

Nfo.extractTitle : Movie -> Optional Text
Nfo.extractTitle m =
  t = Title.display (Movie.title m)
  if Universal.eq (Text.size t) 0 then None else Some t

Nfo.extractYear : Movie -> Optional Nat
Nfo.extractYear m = Scoring.year (Movie.scoring m)

uniDork.cli : '{IO, Exception} ()
uniDork.cli = do
  args = !IO.getArgs
  match args with
    "import"   +: _    -> uniDork.batchedRun()
    "identify" +: _    -> uniDork.identify()
    "rename"   +: rest ->
      match rest with
        format +: _ -> !(uniDork.renameWithCombinedFormat format)
        []          -> uniDork.rename()
    _ ->
      _ = printLine "usage: unidork-import <import|identify|rename> [format]"
      ()