    %% sql ", "
    %% var (optional text)
    %% sql ", "
    %% var text
    %% sql ", "
    %% var text
    %% sql ", "
    %% var text
    %% sql ", "
    %% var (optional text)
    %% sql ", "
    %% var (optional integer)
    %% sql ", "
    %% var Codec.double
    %% sql ", "
    %% var integer
    %% sql ", "
    %% var text
    %% sql ", "
    %% var (optional integer)
    %% sql ", "
    %% var text
    %% sql ", "
    %% var text
    %% sql ", "
    %% var (optional text)
    %% sql ", "
    %% var (optional text)
    %% sql ", "
    %% var (optional text)
    %% sql ", "
    %% var (optional bigint)
    %% sql ", "
