Tmdb.readCache : Text ->{IO, Exception} Optional CachedSearch
Tmdb.readCache folderName =
  use Text ++
  jsonPath = FilePath (Tmdb.cacheRoot ++ "/" ++ folderName ++ ".json")
  match 
    catch do
      raw = readFileUtf8 jsonPath
      Decoder.run CachedSearch.fromJson raw
   with
    Left _  -> None
    Right s -> Some s

Tmdb.readDbCache : Text ->{IO} Optional (Either Text Tmdb.SearchResponse)
Tmdb.readDbCache sourcePath = match 
  catch do
    singleIO Db.config do
      pq = prepareQuery selectSearchSql
      portal = bindQuery pq (pt sourcePath)
      (rows, _) = executeQueryPortal portal 0
      rows
 with
  Left _   -> None
  Right rs ->
    match rs with
      []       -> None
      raw +: _ ->
        match catch do Decoder.run CachedSearch.fromJson raw with
          Left _  -> None
          Right c ->
            match CachedSearch.response c with
              Some r -> Some (Right r)
              None   ->
                match CachedSearch.error c with
                  Some e -> Some (Left e)
                  None   -> None

Tmdb.readDbCacheWith :
  PreparedQuery r a Text
  -> Text
  -> Nat
  ->{Postgres} Optional (Either Text Tmdb.SearchResponse)
Tmdb.readDbCacheWith pq title year = match 
  catch do
    use List ++
    portal = bindQuery pq (pt title ++ Db.pi (Nat.toInt year))
    (rows, _) = executeQueryPortal portal 0
    rows
 with
  Left _   -> None
  Right rs ->
    match rs with
      []       -> None
      raw +: _ ->
        match catch do Decoder.run CachedSearch.fromJson raw with
          Left _  -> None
          Right c ->
            match CachedSearch.response c with
              Some r -> Some (Right r)
              None   ->
                match CachedSearch.error c with
                  Some e -> Some (Left e)
                  None   -> None

Tmdb.readDetailsBodyWith : PreparedQuery r a b -> Nat ->{Postgres} Optional b
Tmdb.readDetailsBodyWith pq tmdbId = match 
  catch do
    portal = bindQuery pq (Db.pi (Nat.toInt tmdbId))
    (rows, _) = executeQueryPortal portal 0
    rows
 with
  Left _   -> None
  Right rs ->
    match rs with
      []       -> None
      raw +: _ -> Some raw

Tmdb.readToken : '{IO, Exception} Text
Tmdb.readToken = do trim (readFileUtf8 (FilePath Tmdb.tokenPath))

Tmdb.releaseDatesParser : '{unison_json_1_4_2.Decoder} [ReleaseInfo]
Tmdb.releaseDatesParser =
  do object.at! "results" (Decoder.array releaseInfoEntry)

Tmdb.releaseInfoEntry : '{unison_json_1_4_2.Decoder} ReleaseInfo
Tmdb.releaseInfoEntry =
  do
    use Decoder optional! text
    use Nat >
    use Optional getOrElse
    use object at
    country = object.at! "iso_3166_1" text
    certs =
      getOrElse
        []
        (optional!
          (at
            "release_dates"
            (Decoder.array do
              getOrElse "" (optional! (at "certification" text)))))
    nonEmpty = List.filter (s -> Text.size s > 0) certs
    cert = getOrElse "" (List.head nonEmpty)
    ReleaseInfo country cert

Tmdb.releaseYear : Text -> Optional Nat
Tmdb.releaseYear dateStr =
  use Nat <
  if Text.size dateStr < 4 then None else tokenAsYear (Text.take 4 dateStr)

Tmdb.reportFolder : Text -> FilePath ->{IO, Exception} ()
Tmdb.reportFolder token folder =
  use Nat toText
  use ParsedRelease year
  use Text ++ join
  folderName = filePathBasename folder
  maybeNfo = tryReadFolder folder
  _ = printLine (join "" ["FOLDER: ", folderName])
  _ = match maybeNfo with
    Some m ->
      match extractTmdbId m with
        Some n -> printLine ("  NFO tmdb id: " ++ toText n)
        None   -> printLine "  NFO present (no tmdb id)"
    None   -> ()
  match buildParsedRelease folderName maybeNfo with
    None ->
      _ = printLine "  parsed:  FAILED (no title/year from NFO or folder name)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      idTag = match nfoTmdbId p with
        Some n -> " nfo-id=" ++ toText n
        None   -> ""
      _ =
        printLine
          (join
            ""
            [ "  parsed:  title=\""
            , ParsedRelease.title p
            , "\", year="
            , toText (year p)
            , idTag
            ])
      result = cachedSearch token folderName (ParsedRelease.title p) (year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ printCandidate scored
          _ =
            match pickBest scored with
              Some (r, s) ->
                printLine
                  (join
                    ""
                    [ "  verdict: "
                    , toText s
                    , "% -> tmdb:"
                    , toText (Result.tmdbId r)
                    , " \""
                    , Result.title r
                    , "\""
                    ])
              None ->
                printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.reportFolderWith :
  PreparedQuery r4 a4 Text
  -> PreparedCommand r3 a3
  -> PreparedQuery r2 a2 Text
  -> PreparedQuery r1 a1 Text
  -> PreparedCommand r a
  -> Text
  -> FilePath
  ->{IO, Exception, Postgres} ()
Tmdb.reportFolderWith pq pc pqStage pqDet pcDet token folder =
  use Nat toText
  use ParsedRelease year
  use Text ++ join
  folderName = filePathBasename folder
  maybeNfo = tryReadFolder folder
  _ = printLine (join "" ["FOLDER: ", folderName])
  _ = match maybeNfo with
    Some m ->
      match extractTmdbId m with
        Some n -> printLine ("  NFO tmdb id: " ++ toText n)
        None   -> printLine "  NFO present (no tmdb id)"
    None   -> ()
  files = directoryContents.texts folder
  maybeProbeMin = match findFirstVideo files with
    None           -> None
    Some videoName ->
      videoPath = pathJoin folder videoName
      match largestInFolderWith pqStage (filePathText videoPath) with
        None    -> None
        Some pr -> Some (Rename.minutes (ProbeResult.durationSec pr))
  match buildParsedRelease folderName maybeNfo with
    None ->
      _ = printLine "  parsed:  FAILED (no title/year from NFO or folder name)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      idTag = match nfoTmdbId p with
        Some n -> " nfo-id=" ++ toText n
        None   -> ""
      _ =
        printLine
          (join
            ""
            [ "  parsed:  title=\""
            , ParsedRelease.title p
            , "\", year="
            , toText (year p)
            , idTag
            ])
      result = cachedSearchWith pq pc token (ParsedRelease.title p) (year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ printCandidate scored
          _ =
            match pickBestWithRuntime pqDet pcDet token maybeProbeMin scored with
              Some (r, s) ->
                printLine
                  (join
                    ""
                    [ "  verdict: "
                    , toText s
                    , "% -> tmdb:"
                    , toText (Result.tmdbId r)
                    , " \""
                    , Result.title r
                    , "\""
                    ])
              None ->
                printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.reportLooseVideo : Text -> FilePath ->{IO, Exception} ()
Tmdb.reportLooseVideo token videoFile =
  use Nat toText
  use ParsedRelease year
  use Text ++ join
  filename = filePathBasename videoFile
  name = basenameNoExt filename
  _ = printLine (join "" ["LOOSE:  ", filename])
  match parseReleaseName name with
    None ->
      _ = printLine "  parsed:  FAILED (no year + quality token)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      _ =
        printLine
          (join
            ""
            [ "  parsed:  title=\""
            , ParsedRelease.title p
            , "\", year="
            , toText (year p)
            ])
      result = cachedSearch token name (ParsedRelease.title p) (year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ printCandidate scored
          _ =
            match pickBest scored with
              Some (r, s) ->
                printLine
                  (join
                    ""
                    [ "  verdict: "
                    , toText s
                    , "% -> tmdb:"
                    , toText (Result.tmdbId r)
                    , " \""
                    , Result.title r
                    , "\""
                    ])
              None ->
                printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.reportLooseVideoWith :
  PreparedQuery r4 a4 Text
  -> PreparedCommand r3 a3
  -> PreparedQuery r2 a2 Text
  -> PreparedQuery r1 a1 Text
  -> PreparedCommand r a
  -> Text
  -> FilePath
  ->{IO, Exception, Postgres} ()
Tmdb.reportLooseVideoWith pq pc pqStage pqDet pcDet token videoFile =
  use Nat toText
  use ParsedRelease year
  use Text ++ join
  filename = filePathBasename videoFile
  name = basenameNoExt filename
  _ = printLine (join "" ["LOOSE:  ", filename])
  maybeProbeMin =
    match largestInFolderWith pqStage (filePathText videoFile) with
      None    -> None
      Some pr -> Some (Rename.minutes (ProbeResult.durationSec pr))
  match parseReleaseName name with
    None ->
      _ = printLine "  parsed:  FAILED (no year + quality token)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      _ =
        printLine
          (join
            ""
            [ "  parsed:  title=\""
            , ParsedRelease.title p
            , "\", year="
            , toText (year p)
            ])
      result = cachedSearchWith pq pc token (ParsedRelease.title p) (year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ printCandidate scored
          _ =
            match pickBestWithRuntime pqDet pcDet token maybeProbeMin scored with
              Some (r, s) ->
                printLine
                  (join
                    ""
                    [ "  verdict: "
                    , toText s
                    , "% -> tmdb:"
                    , toText (Result.tmdbId r)
                    , " \""
                    , Result.title r
                    , "\""
                    ])
              None ->
                printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.Result.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.Result
Tmdb.Result.fromJson =
  do
    use Decoder optional! text
    use Optional getOrElse
    use object at at!
    tmdbId = at! "id" Decoder.nat
    title = at! "title" text
    originalTitle = at! "original_title" text
    originalLanguage = getOrElse "" (optional! (at "original_language" text))
    releaseDate = getOrElse "" (optional! (at "release_date" text))
    popularity = at! "popularity" Decoder.float
    overview = getOrElse "" (optional! (at "overview" text))
    Tmdb.Result.Result
      tmdbId
      title
      originalTitle
      originalLanguage
      releaseDate
      popularity
      overview

Tmdb.Result.toJson : Tmdb.Result -> Json
Tmdb.Result.toJson r =
  use Json text
  Json.object
    [ ("id", Json.nat (Result.tmdbId r))
    , ("title", text (Result.title r))
    , ("original_title", text (Result.originalTitle r))
    , ("original_language", text (Result.originalLanguage r))
    , ("release_date", text (Result.releaseDate r))
    , ("popularity", Json.float (popularity r))
    , ("overview", text (Result.overview r))
    ]

Tmdb.runtimeWinner :
  PreparedQuery r1 a2 Text
  -> PreparedCommand r a1
  -> Text
  -> Nat
  -> [(Tmdb.Result, a)]
  ->{IO, Postgres} Optional (Tmdb.Result, a)
Tmdb.runtimeWinner pq pc token probeMin tied =
  use Nat - <= >
  tolerance = 15
  checkOne candidate =
    (r, _) = candidate
    match cachedDetailsWith pq pc token (Result.tmdbId r) with
      Right d ->
        rt = Details.runtime d
        if Universal.eq rt 0 then None
        else
          diff = if rt > probeMin then rt - probeMin else probeMin - rt
          if diff <= tolerance then Some candidate else None
      Left _  -> None
  inRange = List.filterMap checkOne tied
  match inRange with
    [only] -> Some only
    _      -> None

Tmdb.scoreCandidate : ParsedRelease -> Tmdb.Result -> Nat
Tmdb.scoreCandidate p r =
  use Nat + - > >=
  use Tmdb normalize
  use Universal eq
  q = normalize (ParsedRelease.title p)
  t = normalize (Result.title r)
  o = normalize (Result.originalTitle r)
  exactMatch = eq q t || eq q o
  ovT = tokenOverlapPercent q t
  ovO = tokenOverlapPercent q o
  bestOv = if ovT > ovO then ovT else ovO
  titleScore =
    if exactMatch then 30
    else if bestOv >= 75 then 20 else if bestOv >= 50 then 10 else 0
  py = ParsedRelease.year p
  yearScore = match releaseYear (Result.releaseDate r) with
    None    -> 0
    Some ry ->
      if eq ry py then 20
      else
        diff = if ry > py then ry - py else py - ry
        if eq diff 1 then 10 else 0
  idOk = match nfoTmdbId p with
    Some n -> eq n (Result.tmdbId r)
    None   -> false
  idScore = if idOk then 50 else 0
  idScore + titleScore + yearScore

Tmdb.search : Text -> Text -> Nat ->{IO} Either Text Tmdb.SearchResponse
Tmdb.search token title year =
  req = searchRequest token title year
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          body = bodyText ok
          Decoder.run Tmdb.SearchResponse.fromJson body
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Tmdb.searchRequest : Text -> Text -> Nat -> HttpRequest
Tmdb.searchRequest token title year =
  use HttpRequest addHeader
  use Text ++
  HttpRequest.get (searchURI title year)
    |> addHeader "Authorization" ("Bearer " ++ token)
    |> addHeader "Accept" "application/json"

Tmdb.SearchResponse.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.SearchResponse
Tmdb.SearchResponse.fromJson = do
  results = object.at! "results" (Decoder.array Tmdb.Result.fromJson)
  Tmdb.SearchResponse.SearchResponse results

Tmdb.SearchResponse.toJson : Tmdb.SearchResponse -> Json
Tmdb.SearchResponse.toJson r =
  Json.object
    [ ( "results"
      , Json.array (List.map Result.toJson (Tmdb.SearchResponse.results r))
      )
    ]

Tmdb.searchURI : Text -> Nat -> URI
Tmdb.searchURI title year =
  use Path /
  path = Path.root / "3" / "search" / "movie"
  q = Query.empty & ("query", title) & ("year", Nat.toText year)
  URI Scheme.https (Some Tmdb.apiAuthority) path (fromQuery q) Fragment.empty

