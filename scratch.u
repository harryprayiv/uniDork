    ]

Db.migrate : '{IO, Exception} ()
Db.migrate =
  do
    singleIO Db.config do
      _ = runDDLList [moviesDdl]
      _ = runDDLList childDdl
      _ = runDDLList indexDdl
      runDDLList
        [ "ALTER TABLE movies ADD COLUMN IF NOT EXISTS actual_runtime_sec INTEGER"
        ]

Db.moviesDdl : Text
Db.moviesDdl =
  Text.join
    ""
    [ "CREATE TABLE IF NOT EXISTS movies ("
    , "  id                 SERIAL PRIMARY KEY,"
    , "  folder_checksum    TEXT NOT NULL UNIQUE,"
    , "  kodi_id            TEXT NOT NULL DEFAULT '',"
    , "  imdb_id            TEXT,"
    , "  tmdb_id            TEXT,"
    , "  tvdb_id            TEXT,"
    , "  title              TEXT NOT NULL DEFAULT '',"
    , "  original_title     TEXT NOT NULL DEFAULT '',"
    , "  sort_title         TEXT NOT NULL DEFAULT '',"
    , "  collection         TEXT,"
    , "  year               INTEGER,"
    , "  rating             DOUBLE PRECISION NOT NULL DEFAULT 0,"
    , "  votes              INTEGER NOT NULL DEFAULT 0,"
    , "  mpaa               TEXT NOT NULL DEFAULT '',"
    , "  runtime            INTEGER,"
    , "  plot               TEXT NOT NULL DEFAULT '',"
    , "  tagline            TEXT NOT NULL DEFAULT '',"
    , "  folder_path        TEXT,"
    , "  nfo_path           TEXT,"
    , "  video_file_path    TEXT,"
    , "  file_size_bytes    BIGINT,"
    , "  parsed_size_str    TEXT,"
    , "  parsed_resolution  TEXT,"
    , "  parsed_codec       TEXT,"
    , "  parsed_bit_depth   INTEGER,"
    , "  parsed_runtime_min INTEGER,"
    , "  actual_runtime_sec INTEGER,"
    , "  imported_at        TIMESTAMPTZ NOT NULL DEFAULT NOW(),"
    , "  updated_at         TIMESTAMPTZ NOT NULL DEFAULT NOW()"
    , ")"
    ]

Db.nullableBigint : Codec (Optional Int)
Db.nullableBigint =
  enc = cases
    None   -> [None]
    Some i -> Codec.encode bigint i
  dec = cases
    None +: []   -> Right None
    Some t +: [] ->
      match Int.fromText t with
        None   -> Left "not a bigint"
        Some i -> Right (Some i)
    _            -> Left "err"
  custom (Codec.types bigint) enc dec

Db.nullableInt : Codec (Optional Int)
Db.nullableInt =
  enc = cases
    None   -> [None]
    Some i -> Codec.encode integer i
  dec = cases
    None +: []   -> Right None
    Some t +: [] ->
      match Int.fromText t with
        None   -> Left "not an int"
        Some i -> Right (Some i)
    _            -> Left "err"
  custom (Codec.types integer) enc dec

Db.nullableText : Codec (Optional Text)
Db.nullableText =
  enc = cases
    None   -> [None]
    Some t -> [Some t]
  dec = cases
    None +: []   -> Right None
    Some t +: [] -> Right (Some t)
    _            -> Left "err"
  custom (Codec.types Codec.text) enc dec

Db.pf : Float -> [Optional Text]
Db.pf f = Codec.encode Codec.double f

Db.pi : Int -> [Optional Text]
Db.pi i = Codec.encode integer i

Db.pobi : Optional Int -> [Optional Text]
Db.pobi = cases
  None   -> [None]
  Some i -> Codec.encode bigint i

Db.poi : Optional Int -> [Optional Text]
Db.poi = cases
  None   -> [None]
  Some i -> Codec.encode integer i

Db.pot : Optional Text -> [Optional Text]
Db.pot v = [v]

Db.probeCacheDdl : Text
Db.probeCacheDdl =
  Text.join
    ""
    [ "CREATE TABLE IF NOT EXISTS probe_cache ("
    , "  original_path TEXT PRIMARY KEY,"
    , "  mtime         BIGINT NOT NULL,"
    , "  size_bytes    BIGINT NOT NULL,"
    , "  file_id       BIGINT REFERENCES files(file_id) ON DELETE SET NULL,"
    , "  cached_at     TIMESTAMPTZ NOT NULL DEFAULT NOW()"
    , ")"
    ]

Db.pt : Text -> [Optional Text]
Db.pt t = Codec.encode Codec.text t

Db.resetSchema : '{IO, Exception} ()
Db.resetSchema = do
  singleIO Db.config do
    _ = runDDLList dropDdl
    _ = runDDLList [libraryMoviesDdl]
    _ = runDDLList childDdl
    _ = runDDLList [tmdbMoviesDdl]
    _ = runDDLList [filesDdl]
    _ = runDDLList [probeCacheDdl]
    _ = runDDLList [associationsDdl]
    _ = runDDLList cacheDdl
    runDDLList indexDdl

Db.runDDL : Command [Optional Text] [Optional Text] ->{Postgres} ()
Db.runDDL cmd =
  pc = prepareCommand cmd
  ignore (bindAndExecuteCommand pc (Command.encodeArgs cmd))

Db.runDDLList : [Text] ->{Postgres} ()
Db.runDDLList stmts =
  _ = List.map (s -> runDDL (sql s |> buildCommand)) stmts
  ()

Db.smokeTest : '{IO, Exception} ()
Db.smokeTest = do upsertMovies [exampleMovie]

Db.tmdbMoviesDdl : Text
Db.tmdbMoviesDdl =
  Text.join
    ""
    [ "CREATE TABLE IF NOT EXISTS movies ("
