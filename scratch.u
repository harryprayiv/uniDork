Tmdb.isQualityToken : Text -> Boolean
Tmdb.isQualityToken t =
  lower = Text.toLowercase t
  List.any (q -> Universal.eq q lower) Tmdb.qualityTokens

Tmdb.tokenAsYear : Text -> Optional Nat
Tmdb.tokenAsYear t =
  use Nat <= >=
  if Universal.eq (Text.size t) 4 then
    match Nat.fromText t with
      Some n -> if n >= 1900 && n <= 2030 then Some n else None
      None   -> None
  else None

Tmdb.tokenize : Text -> [Text]
Tmdb.tokenize name =
  use List flatMap
  use Nat >
  use Text split
  s1 = split ?. name
  s2 = flatMap (p -> split ?_ p) s1
  s3 = flatMap (p -> split ?\s p) s2
  List.filter (p -> Text.size p > 0) s3

Tmdb.nth : Nat -> [a] -> Optional a
Tmdb.nth i xs = List.head (List.drop i xs)

Tmdb.findYearIndex : [Text] -> Optional Nat
Tmdb.findYearIndex tokens =
  use Nat +
  pairs = Db.withIndex tokens
  qualifying =
    List.filterMap
      (cases
        (i, t) ->
          match Tmdb.tokenAsYear t with
            None   -> None
            Some _ ->
              match Tmdb.nth (i + 1) tokens with
                Some next -> if Tmdb.isQualityToken next then Some i else None
                None      -> None) pairs
  List.head qualifying

