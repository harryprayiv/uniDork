-- ====================================================================
-- PostgreSQL: helpers and utilities
-- ====================================================================

Db.pt : Text -> [Optional Text]
Db.pt t = Codec.encode Codec.text t

Db.pot : Optional Text -> [Optional Text]
Db.pot v = [v]

Db.pi : Int -> [Optional Text]
Db.pi i = Codec.encode integer i

Db.poi : Optional Int -> [Optional Text]
Db.poi = cases
  None   -> [None]
  Some i -> Codec.encode integer i

Db.pf : Float -> [Optional Text]
Db.pf f = Codec.encode Codec.double f

Db.pobi : Optional Int -> [Optional Text]
Db.pobi = cases
  None   -> [None]
  Some i -> Codec.encode bigint i

Db.withIndex : [a] -> [(Nat, a)]
Db.withIndex xs =
  use List +:
  use Nat +
  go acc i = cases
    []      -> List.reverse acc
    x +: ys -> go ((i, x) +: acc) (i + 1) ys
  go [] 0 xs

Db.foreach_ : (a ->{g} b) -> [a] ->{g} ()
Db.foreach_ f xs =
  step acc x =
    _ = f x
    acc
  _ = List.foldLeft step () xs
  ()

Db.countMovies : '{IO, Exception} ()
Db.countMovies = do
  singleIO Db.config do
    q = sql "SELECT COUNT(*) FROM movies" |> typedQuery bigint
    counts = Query.execute q
    match counts with
      n +: _ -> printLine (Text.join "" ["movies in db: ", Int.toText n])
      []     -> printLine "no result"


-- ====================================================================
-- Per-movie upsert. Child rows key on folder_checksum.
-- ====================================================================

Db.upsertWith
  pcUpsert pcVid pcDVid pcAud pcDAud pcSub pcDSub
  pcAct pcDAct pcGen pcDGen pcTag pcDTag pcCou pcDCou
  pcStu pcDStu pcDir pcDDir pcCre pcDCre actualRuntimeSec m =
  transaction do
    use Db foreach_
    use List ++
    use Nat toInt
    use Optional map
    k = MovieId.kodi (Movie.id m)
    csum = Optional.getOrElse "" (Movie.checksum m)
    mid = Movie.id m
    t = Movie.title m
    s = Movie.scoring m
    sd = FileInfo.streams (Movie.fileInfo m)
    vid = StreamDetails.video sd
    tax = Movie.taxonomy m
    fm = Movie.folderMeta m
    indexedAudios = Db.withIndex (StreamDetails.audios sd)
    indexedSubs = Db.withIndex (StreamDetails.subtitles sd)
    indexedActors = Db.withIndex (Movie.actors m)
    del pc =
      _ = bindAndExecuteCommand pc (Db.pt csum)
      ()
    repList delPc insPc vals =
      _ = del delPc
      foreach_ (v -> bindAndExecuteCommand insPc (Db.pt csum ++ Db.pt v)) vals
    _ = printLine (Text.join "" ["upserting: ", k, " (", csum, ")"])
    _ =
      bindAndExecuteCommand
        pcUpsert
        (Db.pt k
          ++ Db.pot (MovieId.imdb mid)
          ++ Db.pot (MovieId.tmdb mid)
          ++ Db.pot (MovieId.tvdb mid)
          ++ Db.pt (Title.display t)
          ++ Db.pt (Title.original t)
          ++ Db.pt (Title.sort t)
          ++ Db.pot (Movie.collection m)
          ++ Db.poi (map toInt (Scoring.year s))
          ++ Db.pf (Scoring.rating s)
          ++ Db.pi (toInt (Scoring.votes s))
          ++ Db.pt (Scoring.mpaa s)
          ++ Db.poi (map toInt (Movie.runtime m))
          ++ Db.pt (Movie.plot m)
          ++ Db.pt (Movie.tagline m)
          ++ Db.pot (Movie.folderPath m)
          ++ Db.pot (Movie.nfoPath m)
          ++ Db.pot (Movie.videoFilePath m)
          ++ Db.pobi (map toInt (Movie.fileSizeBytes m))
          ++ Db.pot (Movie.checksum m)
          ++ Db.pot (FolderMeta.rawSize fm)
          ++ Db.pot (FolderMeta.resolution fm)
          ++ Db.pot (FolderMeta.videoCodec fm)
          ++ Db.poi (map toInt (FolderMeta.bitDepth fm))
          ++ Db.poi (map toInt (FolderMeta.runtimeMin fm))
          ++ Db.poi (map toInt actualRuntimeSec))
    _ = del pcDVid
    _ =
      bindAndExecuteCommand
        pcVid
        (Db.pt csum
          ++ Db.pt (Video.codec vid)
          ++ Db.pf (Video.aspect vid)
          ++ Db.pi (toInt (Video.width vid))
          ++ Db.pi (toInt (Video.height vid)))
    _ = del pcDAud
    _ =
      foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAud
              (Db.pt csum
                ++ Db.pi (toInt i)
                ++ Db.pt (Audio.codec a)
                ++ Db.pt (Audio.language a)
                ++ Db.pi (toInt (Audio.channels a))))
        indexedAudios
    _ = del pcDSub
    _ =
      foreach_
        (cases
          (i, sub) ->
            bindAndExecuteCommand
              pcSub
              (Db.pt csum ++ Db.pi (toInt i) ++ Db.pt (Subtitle.language sub)))
        indexedSubs
    _ = del pcDAct
    _ =
      foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAct
              (Db.pt csum
                ++ Db.pi (toInt i)
                ++ Db.pt (Actor.name a)
                ++ Db.pt (Actor.role a)))
        indexedActors
    _ = repList pcDGen pcGen (Taxonomy.genres tax)
    _ = repList pcDTag pcTag (Taxonomy.tags tax)
    _ = repList pcDCou pcCou (Taxonomy.countries tax)
    _ = repList pcDStu pcStu (Taxonomy.studios tax)
    _ = repList pcDDir pcDir (Taxonomy.directors tax)
    _ = repList pcDCre pcCre (Taxonomy.credits tax)
    ()


-- ====================================================================
-- Batched import pipeline. Entry point: uniDork.batchedRun
-- ====================================================================

uniDork.batchSize : Nat
uniDork.batchSize = 50

List.chunk : Nat -> [a] -> [[a]]
List.chunk n xs =
  use List +: size
  use Nat <=
  if Universal.eq (size xs) 0 then []
  else
    if size xs <= n then [xs]
    else List.take n xs +: List.chunk n (List.drop n xs)

uniDork.collectFolders : [FilePath] ->{IO, Exception} [FilePath]
uniDork.collectFolders roots =
  addIfDir : FilePath -> [FilePath] -> Text ->{IO, Exception} [FilePath]
  addIfDir root acc name =
    use List +:
    fp = pathJoin root name
    if isDirectory fp then fp +: acc else acc
  perRoot root =
    basenames = directoryContents.texts root
    _ =
      printLine
        (Text.join
          ""
          [ "scanning: "
          , filePathText root
          , " ("
          , Nat.toText (List.size basenames)
          , " entries)"
          ])
    List.reverse (List.foldLeft (addIfDir root) [] basenames)
  List.flatMap perRoot roots

uniDork.processOne
  pcUpsert pcVid pcDVid pcAud pcDAud pcSub pcDSub
  pcAct pcDAct pcGen pcDGen pcTag pcDTag pcCou pcDCou
  pcStu pcDStu pcDir pcDDir pcCre pcDCre folder =
  match Nfo.processFolder folder with
    Left _ ->
      _ = printLine (Text.join "" ["  no nfo: ", filePathText folder])
      ()
    Right m ->
      actualRuntime = match Movie.videoFilePath m with
        None         -> None
        Some vidPath ->
          match Probe.readSidecar vidPath with
            None   -> None
            Some r -> Some (Probe.runtimeSec r)
      Db.upsertWith
        pcUpsert pcVid pcDVid pcAud pcDAud pcSub pcDSub
        pcAct pcDAct pcGen pcDGen pcTag pcDTag pcCou pcDCou
        pcStu pcDStu pcDir pcDDir pcCre pcDCre actualRuntime m

uniDork.processBatch : [FilePath] ->{IO, Exception} ()
uniDork.processBatch folders =
  singleIO Db.config do
    use PreparedCommand close
    pcUpsert = prepareCommand Db.upsertMovieSql
    pcVid = prepareCommand Db.insertVideoSql
    pcDVid = prepareCommand (Db.deleteChildSql "movie_video_streams")
    pcAud = prepareCommand Db.insertAudioSql
    pcDAud = prepareCommand (Db.deleteChildSql "movie_audio_tracks")
    pcSub = prepareCommand Db.insertSubSql
    pcDSub = prepareCommand (Db.deleteChildSql "movie_subtitles")
    pcAct = prepareCommand Db.insertActorSql
    pcDAct = prepareCommand (Db.deleteChildSql "movie_actors")
    pcGen = prepareCommand Db.insertGenreSql
    pcDGen = prepareCommand (Db.deleteChildSql "movie_genres")
    pcTag = prepareCommand Db.insertTagSql
    pcDTag = prepareCommand (Db.deleteChildSql "movie_tags")
    pcCou = prepareCommand Db.insertCountrySql
    pcDCou = prepareCommand (Db.deleteChildSql "movie_countries")
    pcStu = prepareCommand Db.insertStudioSql
    pcDStu = prepareCommand (Db.deleteChildSql "movie_studios")
    pcDir = prepareCommand Db.insertDirectorSql
    pcDDir = prepareCommand (Db.deleteChildSql "movie_directors")
    pcCre = prepareCommand Db.insertCreditSql
    pcDCre = prepareCommand (Db.deleteChildSql "movie_credits")
    _ =
      Db.foreach_
        (uniDork.processOne
          pcUpsert pcVid pcDVid pcAud pcDAud pcSub pcDSub
          pcAct pcDAct pcGen pcDGen pcTag pcDTag pcCou pcDCou
          pcStu pcDStu pcDir pcDDir pcCre pcDCre)
        folders
    _ = close pcUpsert
    _ = close pcVid
    _ = close pcDVid
    _ = close pcAud
    _ = close pcDAud
    _ = close pcSub
    _ = close pcDSub
    _ = close pcAct
    _ = close pcDAct
    _ = close pcGen
    _ = close pcDGen
    _ = close pcTag
    _ = close pcDTag
    _ = close pcCou
    _ = close pcDCou
    _ = close pcStu
    _ = close pcDStu
    _ = close pcDir
    _ = close pcDDir
    _ = close pcCre
    close pcDCre

uniDork.runBatchSafe : Nat -> Nat -> [FilePath] ->{IO, Exception} ()
uniDork.runBatchSafe i n batch =
  use Nat toText
  use Text join
  _ =
    printLine
      (join
        ""
        [ "batch "
        , toText i
        , "/"
        , toText n
        , " ("
        , toText (List.size batch)
        , " folders)"
        ])
  match catch do uniDork.processBatch batch with
    Right _ -> ()
    Left f  -> printLine (join "" ["  BATCH FAILED: ", Failure.message f])

uniDork.batchedMain : Text ->{IO, Exception} ()
uniDork.batchedMain configPath =
  use List size
  use Nat toText
  use Text join
  configText = readFileUtf8 (FilePath configPath)
  dirs = List.filterMap parseConfigLine (lines configText)
  _ = Db.createSchema()
  _ = printLine "collecting folders..."
  folders = uniDork.collectFolders dirs
  total = size folders
  _ = printLine (join "" ["found ", toText total, " folders to process"])
  batches = List.chunk uniDork.batchSize folders
  nBatches = size batches
  _ =
    printLine
      (join
        ""
        [ "processing in "
        , toText nBatches
        , " batches of (up to) "
        , toText uniDork.batchSize
        ])
  step i batch =
    use Nat +
    _ = uniDork.runBatchSafe i nBatches batch
    i + 1
  _ = List.foldLeft step 1 batches
  printLine "done"

uniDork.batchedRun : '{IO, Exception} ()
uniDork.batchedRun = do uniDork.batchedMain "./uniDork.conf"

-- ====================================================================
-- ffprobe sidecar JSON: parse <video>.ffprobe.json files produced by
-- the probe-library.fish pre-pass. Phase 1 reads only format.duration.
-- ====================================================================

type Probe.Format =
  { duration : Float,
    sizeBytes : Optional Nat,
    bitRate : Optional Nat }

type Probe.Result = { format : Probe.Format }

Probe.parseFloat : Text -> Float
Probe.parseFloat t = Optional.getOrElse 0.0 (Float.fromText (Text.trim t))

-- ffprobe encodes numeric fields like "size" and "bit_rate" as strings.
-- This helper reads an optional string field and parses it to a Nat.
Probe.optNatStringAt : Text ->{unison_json_1_4_2.Decoder} Optional Nat
Probe.optNatStringAt key =
  match Decoder.optional! (object.at key Decoder.text) with
    None   -> None
    Some s -> Nat.fromText (Text.trim s)

Probe.Format.fromJson : '{unison_json_1_4_2.Decoder} Probe.Format
Probe.Format.fromJson = do
  durStr = object.at! "duration" Decoder.text
  duration = Probe.parseFloat durStr
  sizeBytes = Probe.optNatStringAt "size"
  bitRate = Probe.optNatStringAt "bit_rate"
  Probe.Format.Format duration sizeBytes bitRate

Probe.Result.fromJson : '{unison_json_1_4_2.Decoder} Probe.Result
Probe.Result.fromJson = do
  format = object.at! "format" Probe.Format.fromJson
  Probe.Result.Result format

-- Must agree with UNIDORK_FFPROBE_CACHE in the dev shell. The cache mirrors
-- the source-path layout: a video at /a/b.mkv has its JSON at
-- <cacheRoot>/a/b.mkv.json.
Probe.cacheRoot : Text
Probe.cacheRoot = "/home/bismuth/.cache/uniDork/ffprobe"

Probe.readSidecar : Text ->{IO, Exception} Optional Probe.Result
Probe.readSidecar videoPath =
  use Text ++
  jsonPath = FilePath (Probe.cacheRoot ++ videoPath ++ ".json")
  match catch do
    raw = readFileUtf8 jsonPath
    Decoder.run Probe.Result.fromJson raw
  with
    Left _  -> None
    Right r -> Some r

-- Float seconds → Nat seconds (round to nearest, clamp negatives to 0).
Probe.runtimeSec : Probe.Result -> Nat
Probe.runtimeSec r =
  d = Probe.Format.duration (Probe.Result.format r)
  if Float.lt d 0.0 then 0
  else
    asText = Float.toText d
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    Optional.getOrElse 0 (Nat.fromText intPart)

-- ====================================================================
-- Schema migration: add the actual_runtime_sec column without dropping
-- existing data. Safe to run repeatedly.
-- ====================================================================

Db.migrate : '{IO, Exception} ()
Db.migrate = do
  singleIO Db.config do
