    , "  vote_average      DOUBLE PRECISION NOT NULL DEFAULT 0,"
    , "  vote_count        INTEGER NOT NULL DEFAULT 0,"
    , "  collection        TEXT,"
    , "  details_json      TEXT NOT NULL,"
    , "  fetched_at        TIMESTAMPTZ NOT NULL DEFAULT NOW()"
    , ")"
    ]

