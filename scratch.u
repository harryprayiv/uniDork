Db.insertPairSql : Text -> Text -> Command b (Text -> Text -> b)
Db.insertPairSql table col =
  use Codec text
  q =
    Text.join
      "" ["INSERT INTO ", table, " (folder_checksum, ", col, ") VALUES ("]
  sql q %% var text %% sql ", " %% var text %% sql ") ON CONFLICT DO NOTHING"
    |> buildCommand

