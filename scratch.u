    check
    [ eq
        (Rename.extractGroup "Under.Siege.1992.1080p.x265-Tigole")
        (Some "Tigole")
    , eq
        (Rename.extractGroup "Some Movie 2020 1080p BluRay x265 Tigole")
        (Some "Tigole")
    , eq (Rename.extractGroup "Title.2020.1080p.WEB-DL.x265-RG") (Some "RG")
    , eq (Rename.extractGroup "Generic Movie 2020 1080p") None
    , eq
        (Rename.extractGroup
          "War Machine 2026 1080p WEB-DL HEVC x265 10Bit DDP5.1 Subs KINGDOM_RG")
        (Some "KINGDOM_RG")
    ]

