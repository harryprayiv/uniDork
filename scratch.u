Scoring.fromJson : '{unison_json_1_4_2.Decoder} Scoring
Scoring.fromJson = do
  use Decoder nat
  use object at!
  year = Decoder.optional! (object.at "year" nat)
  rating = at! "rating" Decoder.float
  votes = at! "votes" nat
  mpaa = at! "mpaa" Decoder.text
  Scoring year rating votes mpaa

Scoring.toJson : Scoring -> Json
Scoring.toJson s =
  use Json nat
  Json.object
    [ ("year", toJsonOpt nat (Scoring.year s))
    , ("rating", Json.float (rating s))
    , ("votes", nat (votes s))
    , ("mpaa", Json.text (Scoring.mpaa s))
    ]

silentBranches : '{Each, Throw XMLError} a -> [a]
silentBranches thunk =
  List.filterMap (x -> x) (Each.toList do Throw.toOptional thunk)

Stage.AudioInfo.fromJson : '{unison_json_1_4_2.Decoder} AudioInfo
Stage.AudioInfo.fromJson =
  do
    use Decoder text
    use object at!
    codec = at! "codec" text
    channels = at! "channels" Decoder.nat
    channelLayout = at! "channel_layout" text
    language =
      Optional.getOrElse "" (Decoder.optional! (object.at "language" text))
    AudioInfo codec channels channelLayout language

Stage.AudioInfo.toJson : AudioInfo -> Json
Stage.AudioInfo.toJson a =
  use Json text
  Json.object
    [ ("codec", text (AudioInfo.codec a))
    , ("channels", Json.nat (AudioInfo.channels a))
    , ("channel_layout", text (AudioInfo.channelLayout a))
    , ("language", text (AudioInfo.language a))
    ]

Stage.bitDepthFrom : Optional Nat -> Text -> Nat
Stage.bitDepthFrom bprs pixFmt =
  match bprs with
    Some n -> n
    None ->
      contains needles =
        List.any
          (x -> (match Text.indexOf x pixFmt with
            Some _ -> true
            None   -> false)) needles
      if contains ["p10", "10le", "10be"] then 10
      else if contains ["p12", "12le", "12be"] then 12 else 8

test> Stage.bitDepthFrom.test =
  use Universal eq
  List.flatMap
    check
    [ eq (bitDepthFrom (Some 10) "yuv420p") 10
    , eq (bitDepthFrom (Some 8) "yuv420p10le") 8
    , eq (bitDepthFrom None "yuv420p10le") 10
    , eq (bitDepthFrom None "yuv420p12le") 12
    , eq (bitDepthFrom None "yuv420p") 8
    , eq (bitDepthFrom None "") 8
    ]

