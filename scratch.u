type Stage.VideoInfo
  = { codec : Text,
      width : Nat,
      height : Nat,
      bitDepth : Nat,
      pixFmt : Text,
      bitRate : Optional Nat }

Stage.VideoInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.VideoInfo
Stage.VideoInfo.fromJson = do
  use Decoder nat text
  use object at!
  codec = at! "codec" text
  width = at! "width" nat
  height = at! "height" nat
  bitDepth = at! "bit_depth" nat
  pixFmt = at! "pix_fmt" text
  bitRate = Decoder.optional! (object.at "bit_rate" nat)
  Stage.VideoInfo.VideoInfo codec width height bitDepth pixFmt bitRate

Stage.cacheRoot : Text
Stage.cacheRoot = "/home/bismuth/.cache/uniDork/stage"

Stage.sidecarPath : Text -> FilePath
Stage.sidecarPath folderName =
  use Text ++
  FilePath (Stage.cacheRoot ++ "/" ++ folderName ++ ".json")

type Stage.AudioInfo
  = { codec : Text, channels : Nat, channelLayout : Text, language : Text }

type Stage.SubtitleInfo
  = { codec : Text, language : Text }

type Stage.ProbeResult
  = { videoPath : Text,
      crc32 : Text,
      sizeBytes : Nat,
      durationSec : Float,
      video : Stage.VideoInfo,
      audios : [Stage.AudioInfo],
      subtitles : [Stage.SubtitleInfo] }

Relang.currentDefault : [Probe.AudioTrack] -> Optional Nat
Relang.currentDefault tracks =
  match List.find Probe.AudioTrack.isDefault tracks with
    Some t -> Some (Probe.AudioTrack.index t)
    None   -> None

Relang.decide : Text -> [Probe.AudioTrack] -> Relang.Decision
Relang.decide tmdbOrigLang tracks =
  match Relang.toIso6392 tmdbOrigLang with
    None -> Relang.Decision.UnsupportedLanguage tmdbOrigLang
    Some code ->
      match Relang.selectTrack code tracks with
        None -> Relang.Decision.OriginalNotPresent code
        Some tr ->
          chosenIdx = Probe.AudioTrack.index tr
          match Relang.currentDefault tracks with
            None -> Relang.Decision.NoCurrentDefault chosenIdx
            Some curIdx ->
              if Universal.eq curIdx chosenIdx then
                Relang.Decision.AlreadyCorrect curIdx
              else Relang.Decision.SwitchTo curIdx chosenIdx

type Relang.Decision
  = AlreadyCorrect Nat
  | NoCurrentDefault Nat
  | OriginalNotPresent Text
  | UnsupportedLanguage Text
  | SwitchTo Nat Nat

Relang.Decision.toJson : Relang.Decision -> Json
Relang.Decision.toJson = cases
  Relang.Decision.AlreadyCorrect i ->
    Json.object
      [("kind", Json.text "already_correct"), ("default_index", Json.nat i)]
  Relang.Decision.SwitchTo o n ->
    Json.object
      [ ("kind", Json.text "switch")
      , ("old_default_index", Json.nat o)
      , ("new_default_index", Json.nat n)
      ]
  Relang.Decision.OriginalNotPresent code ->
    Json.object
      [ ("kind", Json.text "original_not_present")
      , ("expected_language", Json.text code)
      ]
  Relang.Decision.UnsupportedLanguage code ->
    Json.object
      [ ("kind", Json.text "unsupported_language")
      , ("tmdb_code", Json.text code)
      ]
  Relang.Decision.NoCurrentDefault i ->
    Json.object
      [("kind", Json.text "no_current_default"), ("chosen_index", Json.nat i)]

Relang.toIso6392 : Text -> Optional Text
Relang.toIso6392 = cases
  "en" -> Some "eng"
  "ja" -> Some "jpn"
  "ko" -> Some "kor"
  "zh" -> Some "zho"
  "fr" -> Some "fra"
  "de" -> Some "deu"
  "it" -> Some "ita"
  "es" -> Some "spa"
  "pt" -> Some "por"
  "ru" -> Some "rus"
  "sv" -> Some "swe"
  "da" -> Some "dan"
  "no" -> Some "nor"
  "nl" -> Some "nld"
  "fi" -> Some "fin"
  "pl" -> Some "pol"
  "tr" -> Some "tur"
  "hi" -> Some "hin"
  "ar" -> Some "ara"
  "he" -> Some "heb"
  "th" -> Some "tha"
  "vi" -> Some "vie"
  "id" -> Some "ind"
  "hu" -> Some "hun"
  "cs" -> Some "ces"
  "ro" -> Some "ron"
  "el" -> Some "ell"
  "uk" -> Some "ukr"
  _    -> None

Relang.titleAliases : Text -> [Text]
Relang.titleAliases = cases
  "eng" -> ["english", "eng", "en"]
  "ita" -> ["italian", "italiano", "ita", "it"]
  "jpn" -> ["japanese", "jpn", "jp"]
  "kor" -> ["korean", "kor", "kr"]
  "fra" -> ["french", "francais", "français", "fra", "fre", "fr", "vf", "vff"]
  "deu" -> ["german", "deutsch", "ger", "deu", "de"]
  "spa" -> ["spanish", "espanol", "español", "spa", "esp", "es"]
  "por" -> ["portuguese", "portugues", "português", "por", "pt"]
  "rus" -> ["russian", "rus", "ru"]
  "zho" -> ["chinese", "mandarin", "cantonese", "zho", "chi", "zh"]
  "swe" -> ["swedish", "svenska", "swe", "sv"]
  "dan" -> ["danish", "dansk", "dan", "da"]
  "nor" -> ["norwegian", "norsk", "nor", "no"]
  "nld" -> ["dutch", "nederlands", "nld", "dut", "nl"]
  "fin" -> ["finnish", "suomi", "fin", "fi"]
  "pol" -> ["polish", "polski", "pol", "pl"]
  _     -> []

Relang.splitMany : [Char] -> Text -> [Text]
Relang.splitMany seps t =
  step acc c = List.flatMap (p -> Text.split c p) acc
  result = List.foldLeft step [t] seps
  List.filter (p -> (if Universal.eq p "" then false else true)) result

Relang.titleSeparators : [Char]
Relang.titleSeparators = [?\s, ?-, ?_, ?., ?,, ?(, ?), ?[, ?], ?/]

Relang.titleMatches : Text -> Probe.AudioTrack -> Boolean
Relang.titleMatches code tr = match Probe.AudioTrack.title tr with
  None    -> false
  Some tt ->
    use List any
    aliases = Relang.titleAliases code
    lower = Text.toLowercase tt
    words = Relang.splitMany Relang.titleSeparators lower
    any (w -> any (a -> Universal.eq w a) aliases) words

Relang.containsAnySubstring : [Text] -> Text -> Boolean
Relang.containsAnySubstring needles haystack =
  List.any
    (n -> (match Text.indexOf n haystack with
      Some _ -> true
      None   -> false)) needles

Relang.titleSuggestsCommentary : Text -> Boolean
Relang.titleSuggestsCommentary tt =
  lower = Text.toLowercase tt
  markers =
    [ "comment"
    , "descriptive"
    , "director"
    , "vfx"
    , "isolated"
    , "audio description"
    , "narration"
    , "for the visually"
    ]
  Relang.containsAnySubstring markers lower

Relang.isCommentaryOrDescriptive : Probe.AudioTrack -> Boolean
Relang.isCommentaryOrDescriptive tr =
  if Probe.AudioTrack.isComment tr then true
  else
    if Probe.AudioTrack.isVisualImpaired tr then true
    else
      match Probe.AudioTrack.title tr with
        None    -> false
        Some tt -> Relang.titleSuggestsCommentary tt

Relang.losslessCodecs : [Text]
Relang.losslessCodecs =
  ["truehd", "dts-hd", "flac", "pcm_s24le", "pcm_s16le", "mlp"]

Relang.lossyCodecs : [Text]
Relang.lossyCodecs = ["dts", "eac3", "ac3", "aac", "opus", "vorbis", "mp3"]

Relang.codecRank : Text -> Nat
Relang.codecRank c =
  lower = Text.toLowercase c
  isIn xs = List.any (x -> Universal.eq x lower) xs
  if isIn Relang.losslessCodecs then 2
  else if isIn Relang.lossyCodecs then 1 else 0

Relang.betterThan : Probe.AudioTrack -> Probe.AudioTrack -> Boolean
Relang.betterThan a b =
  use Nat < max
  use Universal eq
  ca = Probe.AudioTrack.channels a
  cb = Probe.AudioTrack.channels b
  if eq ca cb then
    ra = Relang.codecRank (Probe.AudioTrack.codec a)
    rb = Relang.codecRank (Probe.AudioTrack.codec b)
    if eq ra rb then Probe.AudioTrack.index a < Probe.AudioTrack.index b
    else
      if eq ra (max ra rb) && (if eq ra rb then false else true) then true
      else false
  else if eq ca (max ca cb) then true else false

Relang.bestOf : [Probe.AudioTrack] -> Optional Probe.AudioTrack
Relang.bestOf tracks =
  step acc cur = match acc with
    None      -> Some cur
    Some best -> if Relang.betterThan cur best then Some cur else Some best
  List.foldLeft step None tracks

Relang.selectTrack : Text -> [Probe.AudioTrack] -> Optional Probe.AudioTrack
Relang.selectTrack origLang3 tracks =
  use List filter
  use Universal eq
  strict =
    filter (t -> eq (Probe.AudioTrack.language t) (Some origLang3)) tracks
  candidates =
    if eq (List.size strict) 0 then
      filter (Relang.titleMatches origLang3) tracks
    else strict
  surviving =
    filter
      (t -> (if Relang.isCommentaryOrDescriptive t then false else true))
      candidates
  Relang.bestOf surviving

Rename.targetRoot : Text
Rename.targetRoot =
  "/home/bismuth/NAS/video/_Unsorted/torrents/Complete/AMC/testMovies"

Rename.logDir : Text
Rename.logDir = "/home/bismuth/.cache/uniDork/rename-log"

Rename.gigabytes : Nat -> Text
Rename.gigabytes bytes =
  use Nat % * + / >= toText
  use Text ++
  oneGb = 1073741824
  tenths = (bytes * 10 + oneGb / 2) / oneGb
  whole = tenths / 10
  if whole >= 10 then
    rounded = (bytes + oneGb / 2) / oneGb
    toText rounded ++ " GB"
  else
    f = tenths % 10
    toText whole ++ "." ++ toText f ++ " GB"

Rename.truncSec : Float -> Nat
Rename.truncSec d =
  use Float <
  if d < 0.0 then 0
  else
    asText = Float.toText d
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    Optional.getOrElse 0 (Nat.fromText intPart)

Rename.minutes : Float -> Nat
Rename.minutes d =
  use Nat /
  Rename.truncSec d / 60

Rename.effectiveBitRate : Optional Nat -> Nat -> Float -> Nat
Rename.effectiveBitRate br sizeBytes durationSec = match br with
  Some b -> b
  None   ->
    use Nat * /
    secs = Rename.truncSec durationSec
    if Universal.eq secs 0 then 0 else sizeBytes * 8 / secs

Rename.mbps : Nat -> Text
Rename.mbps bps =
  use Nat % * + / >= toText
  use Text ++
  oneMbps = 1000000
  tenths = (bps * 10 + oneMbps / 2) / oneMbps
  whole = tenths / 10
  if whole >= 10 then
    rounded = (bps + oneMbps / 2) / oneMbps
    toText rounded ++ " Mbps"
  else
    f = tenths % 10
    toText whole ++ "." ++ toText f ++ " Mbps"

Rename.vfTag : Nat -> Nat -> Text
Rename.vfTag width height =
  use Nat >=
  if width >= 3000 || height >= 1700 then "2160p"
  else
    if width >= 2300 || height >= 1300 then "1440p"
    else
      if width >= 1800 || height >= 800 then "1080p"
      else
        if width >= 1100 || height >= 700 then "720p"
        else
          if height >= 540 then "576p"
          else if height >= 380 then "480p" else "SD"

Rename.vcTag : Text -> Text
Rename.vcTag raw =
  use Universal eq
  lower = Text.toLowercase raw
  if eq lower "hevc" then "x265"
  else
    if eq lower "h265" then "x265"
    else
      if eq lower "h264" then "x264"
      else
        if eq lower "avc" then "x264"
        else
          if eq lower "av1" then "av1"
          else
            if eq lower "vp9" then "vp9"
            else if eq lower "mpeg4" then "xvid" else lower

Rename.resolutionStr : Nat -> Nat -> Text
Rename.resolutionStr w h =
  use Nat toText
  use Text ++
  toText w ++ "x" ++ toText h

Rename.channelsTag : Nat -> Text
Rename.channelsTag ch =
  use Universal eq
  if eq ch 1 then "1.0"
  else
    if eq ch 2 then "2.0"
    else if eq ch 6 then "5.1" else if eq ch 8 then "7.1" else Nat.toText ch

Rename.acTag : Text -> Text
Rename.acTag raw =
  use Universal eq
  upper = Text.toUppercase raw
  if eq upper "AC3" then "AC3"
  else
    if eq upper "EAC3" then "EAC3"
    else
      if eq upper "AAC" then "AAC"
      else
        if eq upper "DTS" then "DTS"
        else
          if eq upper "TRUEHD" then "TrueHD"
          else
            if eq upper "FLAC" then "FLAC"
            else
              if eq upper "OPUS" then "Opus"
              else if eq upper "MP3" then "MP3" else upper

Rename.fileBaseName : Tmdb.Result -> Stage.ProbeResult -> Text
Rename.fileBaseName r pr =
  use Text ++
  vid = Stage.ProbeResult.video pr
  ny = Rename.titleYear r
  bracketed =
    Rename.vcTag (Stage.VideoInfo.codec vid)
      ++ "_"
      ++ Nat.toText (Stage.VideoInfo.bitDepth vid)
      ++ "b_"
      ++ Rename.resolutionStr
           (Stage.VideoInfo.width vid) (Stage.VideoInfo.height vid)
      ++ "_"
      ++ Rename.mbps
           (Rename.effectiveBitRate
             (Stage.VideoInfo.bitRate vid)
             (Stage.ProbeResult.sizeBytes pr)
             (Stage.ProbeResult.durationSec pr))
      ++ "_"
      ++ Rename.audioPart pr
  ny ++ " [" ++ bracketed ++ "] ~" ++ Stage.ProbeResult.crc32 pr

Rename.fileExt : Text -> Text
Rename.fileExt path =
  lower = Text.toLowercase path
  if endsWith ".mkv" lower then ".mkv"
  else
    if endsWith ".mp4" lower then ".mp4"
    else
      if endsWith ".avi" lower then ".avi"
      else
        if endsWith ".mov" lower then ".mov"
        else
          if endsWith ".wmv" lower then ".wmv"
          else if endsWith ".flv" lower then ".flv" else ""

Rename.folderName : Tmdb.Result -> Stage.ProbeResult -> Text
Rename.folderName r pr =
  use Nat toText
  use Text ++
  vid = Stage.ProbeResult.video pr
  ny = Rename.titleYear r
  parts =
    Rename.gigabytes (Stage.ProbeResult.sizeBytes pr)
      ++ "."
      ++ Rename.vfTag (Stage.VideoInfo.width vid) (Stage.VideoInfo.height vid)
      ++ "."
      ++ Rename.vcTag (Stage.VideoInfo.codec vid)
      ++ "."
      ++ toText (Stage.VideoInfo.bitDepth vid)
      ++ "b."
      ++ toText (Rename.minutes (Stage.ProbeResult.durationSec pr))
      ++ "min"
  ny ++ " [" ++ parts ++ "] ~" ++ Stage.ProbeResult.crc32 pr

Rename.titleYear : Tmdb.Result -> Text
Rename.titleYear r =
  use Text ++
  yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    Some y -> Nat.toText y
    None   -> "0000"
  Rename.sanitize (Tmdb.Result.title r) ++ " (" ++ yearText ++ ")"

Rename.escapeXml : Text -> Text
Rename.escapeXml t =
  t |> replaceAll "&" "&amp;" |> replaceAll "<" "&lt;" |> replaceAll ">" "&gt;"

Rename.minimalNfo : Tmdb.Result -> Text
Rename.minimalNfo r =
  use Nat toText
  use Text ++
  yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    Some y -> toText y
    None   -> ""
  tmdbText = toText (Tmdb.Result.tmdbId r)
  Text.join
    "\n"
    [ "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\" ?>"
    , "<movie>"
    , "  <title>" ++ Rename.escapeXml (Tmdb.Result.title r) ++ "</title>"
    , "  <originaltitle>"
        ++ Rename.escapeXml (Tmdb.Result.originalTitle r)
        ++ "</originaltitle>"
    , "  <year>" ++ yearText ++ "</year>"
    , "  <plot>" ++ Rename.escapeXml (Tmdb.Result.overview r) ++ "</plot>"
    , "  <uniqueid type=\"tmdb\" default=\"true\">"
        ++ tmdbText
        ++ "</uniqueid>"
    , "  <id>" ++ tmdbText ++ "</id>"
    , "</movie>"
    , ""
    ]

Rename.checkAgreement : Optional Movie -> Text ->{IO, Exception} ()
Rename.checkAgreement maybeNfo folderName =
  match maybeNfo with
    None -> ()
    Some m ->
      match Tmdb.parseReleaseName folderName with
        None -> ()
        Some p ->
          match (Nfo.extractTitle m, Nfo.extractYear m) with
            (Some nfoTitle, Some nfoYear) ->
              use Nat toText
              use Universal eq
              regexTitle = Tmdb.ParsedRelease.title p
              regexYear = Tmdb.ParsedRelease.year p
              sameTitle =
                eq (Tmdb.normalize nfoTitle) (Tmdb.normalize regexTitle)
              sameYear = eq nfoYear regexYear
              if sameTitle && sameYear then ()
              else
                printLine
                  (Text.join
                    ""
                    [ "  DISAGREE: nfo=\""
                    , nfoTitle
                    , "\" ("
                    , toText nfoYear
                    , ") vs regex=\""
                    , regexTitle
                    , "\" ("
                    , toText regexYear
                    , ")"
                    ])
            _ -> ()

Rename.matchTmdbWith
  pqSearch pcSearch pqDet pcDet token name maybeNfo maybeProbeMin =
  match Tmdb.buildParsedRelease name maybeNfo with
    None -> Left "no title/year from NFO or folder name"
    Some p ->
      match Tmdb.cachedSearchWith
        pqSearch
        pcSearch
        token
        name
        (Tmdb.ParsedRelease.title p)
        (Tmdb.ParsedRelease.year p) with
        Left err -> Left err
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, Tmdb.scoreCandidate p r)) candidates
          match Tmdb.pickBestWithRuntime pqDet pcDet token maybeProbeMin scored with
            Some (r, _) -> Right r
            None        -> Left "no single high-scoring match"

type Rename.FormatPart
  = Literal Text
  | Token Text

Rename.folderFormat : Text
Rename.folderFormat =
  "{ny} [{gigabytes}.{vf}.{vc}.{bitdepth}b.{minutes}min] ~{crc32}"

Rename.fileFormat : Text
Rename.fileFormat =
  "{ny} {tags} [{vc}_{bitdepth}b_{resolution}_{mbps}_{ac}-{channels}_{group}] ~{crc32}"

Rename.parseFormat : Text -> [Rename.FormatPart]
Rename.parseFormat template =
  use List ++
  use Nat >
  use Rename.FormatPart Literal
  use Text size
  segments = Text.split ?{ template
  match segments with
    []            -> []
    [single]      -> if size single > 0 then [Literal single] else []
    first +: rest ->
      head = if size first > 0 then [Literal first] else []
      head ++ List.flatMap Rename.parseSegment rest

Rename.parseSegment : Text -> [Rename.FormatPart]
Rename.parseSegment seg =
  match Text.indexOf "}" seg with
    None -> [Rename.FormatPart.Literal (Text.join "" ["{", seg])]
    Some i ->
      use List ++
      use Nat + >
      tokenName = Text.take i seg
      rest = Text.drop (i + 1) seg
      tokenPart = [Rename.FormatPart.Token tokenName]
      if Text.size rest > 0 then tokenPart ++ [Rename.FormatPart.Literal rest]
      else tokenPart

type Rename.Context
  = { tmdb : Tmdb.Result,
      probe : Stage.ProbeResult,
      group : Optional Text,
      tags : [Text],
      originalName : Text }

Rename.buildContext :
  Tmdb.Result -> Stage.ProbeResult -> Text -> Rename.Context
Rename.buildContext r pr originalName =
  Rename.Context.Context
    r
    pr
    (Rename.extractGroup originalName)
    (Rename.extractTags originalName)
    originalName

Rename.applyFormat : [Rename.FormatPart] -> Rename.Context -> Text
Rename.applyFormat parts ctx =
  render = cases
    Rename.FormatPart.Literal t  -> t
    Rename.FormatPart.Token name -> Rename.resolveToken ctx name
  Text.join "" (List.map render parts)

Rename.isLikelyGroupToken : Text -> Boolean
Rename.isLikelyGroupToken t =
  use Nat < >=
  use Text indexOf
  sz = Text.size t
  if sz < 2 then false
  else
    if sz >= 30 then false
    else
      hasSpace = match indexOf " " t with
        Some _ -> true
        None   -> false
      hasDot = match indexOf "." t with
        Some _ -> true
        None   -> false
      if hasSpace then false else if hasDot then false else true

Rename.extractGroup : Text -> Optional Text
Rename.extractGroup name =
  use List reverse
  use Text split
  trimmedName = trim name
  byDash = match reverse (split ?- trimmedName) with
    last +: _ ->
      lt = trim last
      if Rename.isLikelyGroupToken lt then Some lt else None
    []        -> None
  match byDash with
    Some g -> Some g
    None ->
      match reverse (split ?\s trimmedName) with
        last +: _ ->
          lt = trim last
          if Rename.isLikelyGroupToken lt then
            if Tmdb.isQualityToken lt then None else Some lt
          else None
        [] -> None

Rename.editionKeywords : [Text]
Rename.editionKeywords =
  [ "EXTENDED"
  , "REMASTERED"
  , "UNRATED"
  , "THEATRICAL"
  , "DIRECTORS.CUT"
  , "DIRECTORS_CUT"
  , "DIRECTORS CUT"
  , "PROPER"
  , "REPACK"
  , "ANNIVERSARY"
  , "IMAX"
  , "OPEN.MATTE"
  , "OPEN_MATTE"
  , "OPENMATTE"
  ]

Rename.extractTags : Text -> [Text]
Rename.extractTags name =
  upper = Text.toUppercase name
  List.filter
    (kw -> (match Text.indexOf kw upper with
      Some _ -> true
      None   -> false)) Rename.editionKeywords

Rename.collapseSpaces : Text -> Text
Rename.collapseSpaces t =
  use Nat >
  parts = Text.split ?\s t
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  Text.join " " nonEmpty

Rename.shrink : Text -> Text -> Text -> Text
Rename.shrink needle replacement t =
  t
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement

Rename.tighten : Text -> Text
Rename.tighten t =
  t
    |> Rename.collapseSpaces
    |> Rename.shrink "__" "_"
    |> replaceAll "_]" "]"
    |> replaceAll "[_" "["
    |> replaceAll "_ " " "
    |> replaceAll " _" " "
    |> trim

Rename.renderWith :
  [Rename.FormatPart] -> Tmdb.Result -> Stage.ProbeResult -> Text -> Text
Rename.renderWith parsed r pr originalName =
  ctx = Rename.buildContext r pr originalName
  Rename.tighten (Rename.applyFormat parsed ctx)

Rename.basenameNoExt : Text -> Text
Rename.basenameNoExt filename =
  use List reverse
  parts = Text.split ?. filename
  match reverse parts with
    _ +: []   -> filename
    _ +: rest -> Text.join "." (reverse rest)
    []        -> filename

Rename.sanitize : Text -> Text
Rename.sanitize t =
  use List foldLeft
  use Nat >
  dropChars = ["'", "\"", "`"]
  spaceChars =
    [ ":"
    , ";"
    , ","
    , "."
    , "/"
    , "\\"
    , "?"
    , "*"
    , "<"
    , ">"
    , "|"
    , "!"
    , "@"
    , "#"
    , "$"
    , "%"
    , "^"
    , "&"
    , "+"
    , "="
    , "~"
    , "("
    , ")"
    , "["
    , "]"
    , "{"
    , "}"
    , "—"
    , "–"
    , "\n"
    , "\t"
    , "\r"
    ]
  dropped = foldLeft (acc c -> replaceAll c "" acc) t dropChars
  spaced = foldLeft (acc c -> replaceAll c " " acc) dropped spaceChars
  parts = Text.split ?\s spaced
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  trim (Text.join " " nonEmpty)

Rename.looseVideos : FilePath ->{IO, Exception} [FilePath]
Rename.looseVideos dir =
  entries = directoryContents.texts dir
  videoNames = List.filter isVideo entries
  step acc n =
    use List :+
    fp = pathJoin dir n
    if isDirectory fp then acc else acc :+ fp
  List.foldLeft step [] videoNames

uniDork.identify : '{IO, Exception} ()
uniDork.identify =
  do
    use List size
    use Nat toText
    use PreparedCommand close
    use Text ++
    use Universal eq
    staging = FilePath Tmdb.stagingDir
    if isDirectory staging then
      token = Tmdb.readToken()
      entries = directoryContents.texts staging
      folderNames =
        List.filter
          (n ->
            (if eq n "." then false
            else if eq n ".." then false else isDirectory (pathJoin staging n)))
          entries
      folders = List.map (n -> pathJoin staging n) folderNames
      loose = Rename.looseVideos staging
      _ =
        printLine
          (Text.join
            ""
            [ "scanning "
            , toText (size folders)
            , " folder(s) and "
            , toText (size loose)
            , " loose video(s) under "
            , Tmdb.stagingDir
            ])
      _ = printLine ""
      singleIO Db.config do
        pq = prepareQuery Tmdb.selectSearchSql
        pc = prepareCommand Tmdb.upsertSearchSql
        pqStage = prepareQuery Stage.selectProbeSql
        pqDet = prepareQuery Tmdb.selectDetailsSql
        pcDet = prepareCommand Tmdb.upsertDetailsSql
        _ =
          Db.foreach_
            (Tmdb.reportFolderWith pq pc pqStage pqDet pcDet token) folders
        _ =
          Db.foreach_
            (Tmdb.reportLooseVideoWith pq pc pqStage pqDet pcDet token) loose
        _ = close pc
        close pcDet
    else printLine ("staging not found: " ++ Tmdb.stagingDir)

uniDork.collectFolders : [FilePath] ->{IO, Exception} [FilePath]
uniDork.collectFolders roots =
  addIfDir : FilePath -> [FilePath] -> Text ->{IO, Exception} [FilePath]
  addIfDir root acc name =
    use List +:
    fp = pathJoin root name
    if isDirectory fp then fp +: acc else acc
  perRoot root =
    basenames = directoryContents.texts root
    _ =
      printLine
        (Text.join
          ""
          [ "scanning: "
          , filePathText root
          , " ("
          , Nat.toText (List.size basenames)
          , " entries)"
          ])
    List.reverse (List.foldLeft (addIfDir root) [] basenames)
  List.flatMap perRoot roots

uniDork.processOne
  pcUpsert
  pcVid
  pcDVid
  pcAud
  pcDAud
  pcSub
  pcDSub
  pcAct
  pcDAct
  pcGen
  pcDGen
  pcTag
  pcDTag
  pcCou
  pcDCou
  pcStu
  pcDStu
  pcDir
  pcDDir
  pcCre
  pcDCre
  folder =
  match Nfo.processFolder folder with
    Left _ ->
      _ = printLine (Text.join "" ["  no nfo: ", filePathText folder])
      ()
    Right m ->
      actualRuntime = match Movie.videoFilePath m with
        None         -> None
        Some vidPath ->
          match Probe.readSidecar vidPath with
            None   -> None
            Some r -> Some (Probe.runtimeSec r)
      Db.upsertWith
        pcUpsert
        pcVid
        pcDVid
        pcAud
        pcDAud
        pcSub
        pcDSub
        pcAct
        pcDAct
        pcGen
        pcDGen
        pcTag
        pcDTag
        pcCou
        pcDCou
        pcStu
        pcDStu
        pcDir
        pcDDir
        pcCre
        pcDCre
        actualRuntime
        m

uniDork.processBatch : [FilePath] ->{IO, Exception} ()
uniDork.processBatch folders = 
  singleIO Db.config do
    use PreparedCommand close
    pcUpsert = prepareCommand Db.upsertMovieSql
    pcVid = prepareCommand Db.insertVideoSql
    pcDVid = prepareCommand (Db.deleteChildSql "movie_video_streams")
    pcAud = prepareCommand Db.insertAudioSql
    pcDAud = prepareCommand (Db.deleteChildSql "movie_audio_tracks")
    pcSub = prepareCommand Db.insertSubSql
    pcDSub = prepareCommand (Db.deleteChildSql "movie_subtitles")
    pcAct = prepareCommand Db.insertActorSql
    pcDAct = prepareCommand (Db.deleteChildSql "movie_actors")
    pcGen = prepareCommand Db.insertGenreSql
    pcDGen = prepareCommand (Db.deleteChildSql "movie_genres")
    pcTag = prepareCommand Db.insertTagSql
    pcDTag = prepareCommand (Db.deleteChildSql "movie_tags")
    pcCou = prepareCommand Db.insertCountrySql
    pcDCou = prepareCommand (Db.deleteChildSql "movie_countries")
    pcStu = prepareCommand Db.insertStudioSql
    pcDStu = prepareCommand (Db.deleteChildSql "movie_studios")
    pcDir = prepareCommand Db.insertDirectorSql
    pcDDir = prepareCommand (Db.deleteChildSql "movie_directors")
    pcCre = prepareCommand Db.insertCreditSql
    pcDCre = prepareCommand (Db.deleteChildSql "movie_credits")
    _ =
      Db.foreach_
        (uniDork.processOne
          pcUpsert
          pcVid
          pcDVid
          pcAud
          pcDAud
          pcSub
          pcDSub
          pcAct
          pcDAct
          pcGen
          pcDGen
          pcTag
          pcDTag
          pcCou
          pcDCou
          pcStu
          pcDStu
          pcDir
          pcDDir
          pcCre
          pcDCre)
        folders
    _ = close pcUpsert
    _ = close pcVid
    _ = close pcDVid
    _ = close pcAud
    _ = close pcDAud
    _ = close pcSub
    _ = close pcDSub
    _ = close pcAct
    _ = close pcDAct
    _ = close pcGen
    _ = close pcDGen
    _ = close pcTag
    _ = close pcDTag
    _ = close pcCou
    _ = close pcDCou
    _ = close pcStu
    _ = close pcDStu
    _ = close pcDir
    _ = close pcDDir
    _ = close pcCre
    close pcDCre

uniDork.runBatchSafe : Nat -> Nat -> [FilePath] ->{IO, Exception} ()
uniDork.runBatchSafe i n batch =
  use Nat toText
  use Text join
  _ =
    printLine
      (join
        ""
        [ "batch "
        , toText i
        , "/"
        , toText n
        , " ("
        , toText (List.size batch)
        , " folders)"
        ])
  match catch do uniDork.processBatch batch with
    Right _ -> ()
    Left f  -> printLine (join "" ["  BATCH FAILED: ", Failure.message f])

uniDork.batchedMain : Text ->{IO, Exception} ()
uniDork.batchedMain configPath =
  use List size
  use Nat toText
  use Text join
  configText = readFileUtf8 (FilePath configPath)
  dirs = List.filterMap parseConfigLine (lines configText)
  _ = Db.createSchema()
  _ = printLine "collecting folders..."
  folders = uniDork.collectFolders dirs
  total = size folders
  _ = printLine (join "" ["found ", toText total, " folders to process"])
  batches = List.chunk uniDork.batchSize folders
  nBatches = size batches
  _ =
    printLine
      (join
        ""
        [ "processing in "
        , toText nBatches
        , " batches of (up to) "
        , toText uniDork.batchSize
        ])
  step i batch =
    use Nat +
    _ = uniDork.runBatchSafe i nBatches batch
    i + 1
  _ = List.foldLeft step 1 batches
  printLine "done"

uniDork.batchedRun : '{IO, Exception} ()
uniDork.batchedRun = do
  args = getArgs()
  configPath = match args with
    _ +: rest ->
      match rest with
        p +: _ -> p
        []     -> "./uniDork.conf"
    []        -> "./uniDork.conf"
  uniDork.batchedMain configPath

Nfo.tryReadFolder : FilePath ->{IO, Exception} Optional Movie
Nfo.tryReadFolder folder =
  files = directoryContents.texts folder
  match findFirstNfo files with
    None         -> None
    Some nfoName ->
      nfoPath = pathJoin folder nfoName
      match catch do readFileUtf8 nfoPath with
        Left _    -> None
        Right xml ->
          match Nfo.parse xml with
            Left _  -> None
            Right m -> Some m

Nfo.extractTmdbId : Movie -> Optional Nat
Nfo.extractTmdbId m = match MovieId.tmdb (Movie.id m) with
  None   -> None
  Some s -> Nat.fromText (trim s)

Nfo.extractImdbId : Movie -> Optional Text
Nfo.extractImdbId m = MovieId.imdb (Movie.id m)

Nfo.extractTitle : Movie -> Optional Text
Nfo.extractTitle m =
  t = Title.display (Movie.title m)
  if Universal.eq (Text.size t) 0 then None else Some t

Nfo.extractYear : Movie -> Optional Nat
Nfo.extractYear m = Scoring.year (Movie.scoring m)

Stage.AudioInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.AudioInfo
Stage.AudioInfo.fromJson =
  do
    use Decoder text
    use object at!
    codec = at! "codec" text
    channels = at! "channels" Decoder.nat
    channelLayout = at! "channel_layout" text
    language =
      Optional.getOrElse "" (Decoder.optional! (object.at "language" text))
    Stage.AudioInfo.AudioInfo codec channels channelLayout language

Stage.SubtitleInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.SubtitleInfo
Stage.SubtitleInfo.fromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at
  codec = getOrElse "" (optional! (at "codec" text))
  language = getOrElse "" (optional! (at "language" text))
  Stage.SubtitleInfo.SubtitleInfo codec language

Stage.ProbeResult.fromJson : '{unison_json_1_4_2.Decoder} Stage.ProbeResult
Stage.ProbeResult.fromJson =
  do
    use Decoder array optional! text
    use object at at!
    videoPath = at! "video_path" text
    crc32 = at! "crc32" text
    sizeBytes = at! "size_bytes" Decoder.nat
    durationSec = at! "duration_sec" Decoder.float
    video = at! "video" Stage.VideoInfo.fromJson
    audiosNew = optional! (at "audios" (array Stage.AudioInfo.fromJson))
    audiosLegacy = optional! (at "audio" Stage.AudioInfo.fromJson)
    audios = match audiosNew with
      Some a -> a
      None   ->
        match audiosLegacy with
          Some a -> [a]
          None   -> []
    subtitles =
      Optional.getOrElse
        [] (optional! (at "subtitles" (array Stage.SubtitleInfo.fromJson)))
    Stage.ProbeResult.ProbeResult
      videoPath crc32 sizeBytes durationSec video audios subtitles

Rename.audioPart : Stage.ProbeResult -> Text
Rename.audioPart pr =
  match Stage.ProbeResult.primaryAudio pr with
    None -> "noaudio-0"
    Some a ->
      Rename.acTag (Stage.AudioInfo.codec a)
        Text.++ "-"
        Text.++ Rename.channelsTag (Stage.AudioInfo.channels a)

Rename.resolveToken : Rename.Context -> Text -> Text
Rename.resolveToken ctx tok =
  use Nat toText
  r = Rename.Context.tmdb ctx
  pr = Rename.Context.probe ctx
  vid = Stage.ProbeResult.video pr
  match tok with
    "ny" -> Rename.titleYear r
    "n" -> Rename.sanitize (Tmdb.Result.title r)
    "y" ->
      match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
        Some y -> toText y
        None   -> "0000"
    "gigabytes" -> Rename.gigabytes (Stage.ProbeResult.sizeBytes pr)
    "vf" ->
      Rename.vfTag (Stage.VideoInfo.width vid) (Stage.VideoInfo.height vid)
    "vc" -> Rename.vcTag (Stage.VideoInfo.codec vid)
    "bitdepth" -> toText (Stage.VideoInfo.bitDepth vid)
    "minutes" -> toText (Rename.minutes (Stage.ProbeResult.durationSec pr))
    "crc32" -> Stage.ProbeResult.crc32 pr
    "resolution" ->
      Rename.resolutionStr
        (Stage.VideoInfo.width vid) (Stage.VideoInfo.height vid)
    "mbps" ->
      Rename.mbps
        (Rename.effectiveBitRate
          (Stage.VideoInfo.bitRate vid)
          (Stage.ProbeResult.sizeBytes pr)
          (Stage.ProbeResult.durationSec pr))
    "ac" ->
      match Stage.ProbeResult.primaryAudio pr with
        Some a -> Rename.acTag (Stage.AudioInfo.codec a)
        None   -> "noaudio"
    "channels" ->
      match Stage.ProbeResult.primaryAudio pr with
        Some a -> Rename.channelsTag (Stage.AudioInfo.channels a)
        None   -> "0"
    "group" -> Optional.getOrElse "" (Rename.Context.group ctx)
    "tags" -> Text.join " " (Rename.Context.tags ctx)
    _ -> ""

type Tmdb.Details
  = { tmdbId : Nat,
      imdbId : Optional Text,
      runtime : Nat,
      title : Text,
      originalTitle : Text,
      originalLanguage : Text,
      overview : Text,
      tagline : Text,
      releaseDate : Text,
      voteAverage : Float,
      voteCount : Nat,
      genres : [Text],
      productionCountries : [Text],
      productionStudios : [Text],
      collection : Optional Text,
      mpaa : Text,
      directors : [Text],
      writers : [Text],
      cast : [(Text, Text)],
      tags : [Text] }

Tmdb.namedObjectFromJson : '{unison_json_1_4_2.Decoder} Text
Tmdb.namedObjectFromJson = do object.at! "name" Decoder.text

Tmdb.isoCountryFromJson : '{unison_json_1_4_2.Decoder} Text
Tmdb.isoCountryFromJson = do object.at! "iso_3166_1" Decoder.text

Tmdb.castMemberFromJson : '{unison_json_1_4_2.Decoder} (Text, Text)
Tmdb.castMemberFromJson =
  do
    use Decoder text
    name = object.at! "name" text
    character =
      Optional.getOrElse "" (Decoder.optional! (object.at "character" text))
    (name, character)

Tmdb.crewMemberFromJson : '{unison_json_1_4_2.Decoder} (Text, Text, Text)
Tmdb.crewMemberFromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at
  name = object.at! "name" text
  job = getOrElse "" (optional! (at "job" text))
  department = getOrElse "" (optional! (at "department" text))
  (name, job, department)

Tmdb.singleCertFromJson : '{unison_json_1_4_2.Decoder} Text
Tmdb.singleCertFromJson =
  do
    Optional.getOrElse
      "" (Decoder.optional! (object.at "certification" Decoder.text))

Tmdb.countryReleaseFromJson : '{unison_json_1_4_2.Decoder} (Text, [Text])
Tmdb.countryReleaseFromJson = do
  use object at!
  country = at! "iso_3166_1" Decoder.text
  releases = at! "release_dates" (Decoder.array Tmdb.singleCertFromJson)
  (country, releases)

List.distinctText : [Text] -> [Text]
List.distinctText xs =
  use List :+
  step acc x = if List.any (y -> Universal.eq x y) acc then acc else acc :+ x
  List.foldLeft step [] xs

Tmdb.detailsURI : Nat -> URI
Tmdb.detailsURI tmdbId =
  use Path /
  path = Path.root / "3" / "movie" / Nat.toText tmdbId
  q = Query.empty & ("append_to_response", "credits,release_dates,keywords")
  URI Scheme.https (Some Tmdb.apiAuthority) path (fromQuery q) Fragment.empty

Tmdb.detailsFromResult : Tmdb.Result -> Tmdb.Details
Tmdb.detailsFromResult r =
  Tmdb.Details.Details
    (Tmdb.Result.tmdbId r)
    None
    0
    (Tmdb.Result.title r)
    (Tmdb.Result.originalTitle r)
    (Tmdb.Result.originalLanguage r)
    (Tmdb.Result.overview r)
    ""
    (Tmdb.Result.releaseDate r)
    0.0
    0
    []
    []
    []
    None
    ""
    []
    []
    []
    []

Nfo.padLeft : Nat -> Text -> Text -> Text
Nfo.padLeft target pad t =
  use Nat <
  use Text ++
  if Text.size t < target then Nfo.padLeft target pad (pad ++ t) else t

Nfo.aspectRatio : Nat -> Nat -> Text
Nfo.aspectRatio w h =
  use Nat % * + / toText
  use Text ++
  if Universal.eq h 0 then "0.000"
  else
    rounded = (w * 1000 + h / 2) / h
    whole = rounded / 1000
    frac = rounded % 1000
    fracStr = Nfo.padLeft 3 "0" (toText frac)
    toText whole ++ "." ++ fracStr

Nfo.sortTitle : Text -> Text -> Text
Nfo.sortTitle title releaseDate =
  use Nat >
  use Text ++ drop
  lower = Text.toLowercase title
  stripped =
    if startsWith "the " lower then drop 4 title
    else
      if startsWith "an " lower then drop 3 title
      else if startsWith "a " lower then drop 2 title else title
  if Text.size releaseDate > 0 then stripped ++ " :: " ++ releaseDate
  else stripped

Nfo.audioBlock : Stage.AudioInfo -> [Text]
Nfo.audioBlock a =
  use Text ++
  esc = Rename.escapeXml
  [ "      <audio>"
  , "        <codec>" ++ esc (Stage.AudioInfo.codec a) ++ "</codec>"
  , "        <language>" ++ esc (Stage.AudioInfo.language a) ++ "</language>"
  , "        <channels>"
      ++ Nat.toText (Stage.AudioInfo.channels a)
      ++ "</channels>"
  , "      </audio>"
  ]

Nfo.subtitleBlock : Stage.SubtitleInfo -> [Text]
Nfo.subtitleBlock s =
  use Text ++
  esc = Rename.escapeXml
  [ "      <subtitle>"
  , "        <language>"
      ++ esc (Stage.SubtitleInfo.language s)
      ++ "</language>"
  , "      </subtitle>"
  ]

Nfo.fileinfoBlock : Stage.ProbeResult -> [Text]
Nfo.fileinfoBlock pr =
  use List flatMap
  use Nat toText
  esc = Rename.escapeXml
  vid = Stage.ProbeResult.video pr
  vc = Stage.VideoInfo.codec vid
  vw = Stage.VideoInfo.width vid
  vh = Stage.VideoInfo.height vid
  videoLines =
    [ "      <video>"
    , "        <codec>" Text.++ esc vc Text.++ "</codec>"
    , "        <aspect>" Text.++ Nfo.aspectRatio vw vh Text.++ "</aspect>"
    , "        <width>" Text.++ toText vw Text.++ "</width>"
    , "        <height>" Text.++ toText vh Text.++ "</height>"
    , "      </video>"
    ]
  audioLines = flatMap Nfo.audioBlock (Stage.ProbeResult.audios pr)
  subtitleLines = flatMap Nfo.subtitleBlock (Stage.ProbeResult.subtitles pr)
  result =
    ["  <fileinfo>", "    <streamdetails>"]
      List.++ videoLines
      List.++ audioLines
      List.++ subtitleLines
      List.++ ["    </streamdetails>", "  </fileinfo>"]
  result

Nfo.genreLine : Text -> Text
Nfo.genreLine g =
  use Text ++
  "  <genre>" ++ Rename.escapeXml g ++ "</genre>"

Nfo.countryLine : Text -> Text
Nfo.countryLine c =
  use Text ++
  "  <country>" ++ Rename.escapeXml c ++ "</country>"

Nfo.studioLine : Text -> Text
Nfo.studioLine s =
  use Text ++
  "  <studio>" ++ Rename.escapeXml s ++ "</studio>"

Nfo.directorLine : Text -> Text
Nfo.directorLine d =
  use Text ++
  "  <director>" ++ Rename.escapeXml d ++ "</director>"

Nfo.writerLine : Text -> Text
Nfo.writerLine w =
  use Text ++
  "  <credits>" ++ Rename.escapeXml w ++ "</credits>"

Nfo.actorBlock : (Text, Text) -> [Text]
Nfo.actorBlock = cases
  (name, role) ->
    use Text ++
    esc = Rename.escapeXml
    [ "  <actor>"
    , "    <name>" ++ esc name ++ "</name>"
    , "    <role>" ++ esc role ++ "</role>"
    , "  </actor>"
    ]

Nfo.tagLine : Text -> Text
Nfo.tagLine t =
  use Text ++
  "  <tag>" ++ Rename.escapeXml t ++ "</tag>"

Nfo.generate : Tmdb.Result -> Tmdb.Details -> Stage.ProbeResult -> Text
Nfo.generate _r d pr =
  use List map
  use Nat >
  use Text join size
  use Universal eq
  esc = Rename.escapeXml
  yearText = match Tmdb.releaseYear (Tmdb.Details.releaseDate d) with
    Some y -> Nat.toText y
    None   -> ""
  releaseDate = Tmdb.Details.releaseDate d
  imdbId = Optional.getOrElse "" (Tmdb.Details.imdbId d)
  tmdbText = Nat.toText (Tmdb.Details.tmdbId d)
  crc32 = Stage.ProbeResult.crc32 pr
  sortTitle = Nfo.sortTitle (Tmdb.Details.title d) releaseDate
  setBlock = match Tmdb.Details.collection d with
    Some col -> ["  <set>" Text.++ esc col Text.++ "</set>"]
    None     -> ["  <set />"]
  premieredBlock =
    if size releaseDate > 0 then
      ["  <premiered>" Text.++ esc releaseDate Text.++ "</premiered>"]
    else []
  tmdbUniqueId =
    [ join
        ""
        [ "  <uniqueid type=\"tmdb\" default=\"true\">"
        , tmdbText
        , "</uniqueid>"
        ]
    ]
  imdbUniqueId =
    if eq (size imdbId) 0 then []
    else [join "" ["  <uniqueid type=\"imdb\">", esc imdbId, "</uniqueid>"]]
  crcUniqueId =
    if eq (size crc32) 0 then []
    else [join "" ["  <uniqueid type=\"crc32\">", esc crc32, "</uniqueid>"]]
  uniqueIdLines = tmdbUniqueId List.++ imdbUniqueId List.++ crcUniqueId
  genreLines = map Nfo.genreLine (Tmdb.Details.genres d)
  tagLines = map Nfo.tagLine (Tmdb.Details.tags d)
  countryLines = map Nfo.countryLine (Tmdb.Details.productionCountries d)
  studioLines = map Nfo.studioLine (Tmdb.Details.productionStudios d)
  directorLines = map Nfo.directorLine (Tmdb.Details.directors d)
  writerLines = map Nfo.writerLine (Tmdb.Details.writers d)
  actorLines = List.flatMap Nfo.actorBlock (Tmdb.Details.cast d)
  fileinfoLines = Nfo.fileinfoBlock pr
  header =
    [ "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\" ?>"
    , "<movie>"
    , "  <title>" Text.++ esc (Tmdb.Details.title d) Text.++ "</title>"
    , "  <originaltitle>"
        Text.++ esc (Tmdb.Details.originalTitle d)
        Text.++ "</originaltitle>"
    , "  <sorttitle>" Text.++ esc sortTitle Text.++ "</sorttitle>"
    ]
  scoring =
    [ "  <year>" Text.++ yearText Text.++ "</year>"
    , "  <rating>"
        Text.++ Float.toText (Tmdb.Details.voteAverage d)
        Text.++ "</rating>"
    , "  <votes>"
        Text.++ Nat.toText (Tmdb.Details.voteCount d)
        Text.++ "</votes>"
    , "  <mpaa>" Text.++ esc (Tmdb.Details.mpaa d) Text.++ "</mpaa>"
    , "  <id>" Text.++ esc imdbId Text.++ "</id>"
    ]
  plotEtc =
    [ "  <plot>" Text.++ esc (Tmdb.Details.overview d) Text.++ "</plot>"
    , "  <tagline>" Text.++ esc (Tmdb.Details.tagline d) Text.++ "</tagline>"
    , "  <runtime>"
        Text.++ Nat.toText (Tmdb.Details.runtime d)
        Text.++ "</runtime>"
    ]
  imdbElem =
    if eq (size imdbId) 0 then []
    else
      [ join
          ""
          [ "  <imdb id='"
          , imdbId
          , "'>http://www.imdb.com/title/"
          , imdbId
          , "</imdb>"
          ]
      ]
  tmdbElem =
    [ join
        ""
        [ "  <tmdb id='"
        , tmdbText
        , "'>http://www.themoviedb.org/movie/"
        , tmdbText
        , "</tmdb>"
        ]
    ]
  urlElems = imdbElem List.++ tmdbElem
  footer = ["</movie>", ""]
  allLines =
    header
      List.++ setBlock
      List.++ scoring
      List.++ premieredBlock
      List.++ uniqueIdLines
      List.++ plotEtc
      List.++ genreLines
      List.++ tagLines
      List.++ countryLines
      List.++ studioLines
      List.++ actorLines
      List.++ directorLines
      List.++ writerLines
      List.++ fileinfoLines
      List.++ urlElems
      List.++ footer
  join "\n" allLines

Rename.nfoBase : Text -> Text
Rename.nfoBase _videoBase = "movie"

Rename.subLanguages : [Text]
Rename.subLanguages = ["en", "es", "th"]

Rename.logSubOutcomes : [Subs.SaveOutcome] ->{IO, Exception} ()
Rename.logSubOutcomes outcomes =
  use Text ++
  Db.foreach_
    (cases
      Subs.SaveOutcome.Saved lang p ->
        printLine ("    SUB " ++ lang ++ " -> " ++ p)
      Subs.SaveOutcome.NotFound lang ->
        printLine ("    SUB " ++ lang ++ " not found")
      Subs.SaveOutcome.Errored lang e ->
        printLine ("    SUB " ++ lang ++ " error: " ++ e))
    outcomes

Rename.maybeFetchSubs :
  Optional Text -> Tmdb.Details -> FilePath -> Text ->{IO, Exception} ()
Rename.maybeFetchSubs maybeToken d targetFolder base =
  match maybeToken with
    None -> ()
    Some token ->
      if Universal.eq (List.size Rename.subLanguages) 0 then ()
      else
        outcomes = match Tmdb.Details.imdbId d with
          Some imdb ->
            Subs.fetchAndSaveByImdb
              token imdb targetFolder base Rename.subLanguages
          None ->
            Subs.fetchAndSaveByTmdb
              token
              (Tmdb.Details.tmdbId d)
              targetFolder
              base
              Rename.subLanguages
        Rename.logSubOutcomes outcomes

subDemo : '{IO, Exception} ()
subDemo = do
  token = Subs.readToken()
  outcomes =
    Subs.fetchAndSaveByImdb
      token
      "tt1375666"
      (FilePath "/tmp/subs-test")
      "inception"
      ["en", "es", "th"]
  Db.foreach_
    (cases
      Subs.SaveOutcome.Saved lang p   -> printLine ("saved " ++ lang ++ " -> " ++ p)
      Subs.SaveOutcome.NotFound lang  -> printLine ("none for " ++ lang)
      Subs.SaveOutcome.Errored lang e -> printLine ("error " ++ lang ++ ": " ++ e))
    outcomes

test> Rename.gigabytes.test =
  use Universal eq
  List.flatMap
    check
    [ eq (Rename.gigabytes 0) "0.0 GB"
    , eq (Rename.gigabytes 1073741824) "1.0 GB"
    , eq (Rename.gigabytes 5368709120) "5.0 GB"
    , eq (Rename.gigabytes 8589934592) "8.0 GB"
    , eq (Rename.gigabytes 12884901888) "12 GB"
    , eq (Rename.gigabytes 25769803776) "24 GB"
    , eq (Rename.gigabytes 429496729) "0.4 GB"
    ]

