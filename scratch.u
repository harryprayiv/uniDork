Resolve.ensureMovie :
  PreparedQuery r1 a1 Text
  -> PreparedCommand r a
  -> Text
  -> Nat
  ->{IO, Postgres} Boolean
Resolve.ensureMovie pqDet pcDet token tmdbId =
  match cachedDetailsWith pqDet pcDet token tmdbId with
    Right _ -> true
    Left _  -> false

Resolve.identify : '{IO, Exception} ()
Resolve.identify = runWith true

Resolve.optIntToNat : Optional Int -> Optional Nat
Resolve.optIntToNat = cases
  None   -> None
  Some i -> Nat.fromInt i

Resolve.printOutcome : Resolve.Outcome ->{IO, Exception} ()
Resolve.printOutcome = cases
  ResolvedById fid tmdbId ->
    printLine
      (Text.join
        ""
        [ "  file "
        , Int.toText fid
        , " -> tmdb:"
        , Nat.toText tmdbId
        , " (nfo id)"
        ])
  ResolvedBySearch fid tmdbId s ->
    printLine
      (Text.join
        ""
        [ "  file "
        , Int.toText fid
        , " -> tmdb:"
        , Nat.toText tmdbId
        , " ("
        , Nat.toText s
        , "%)"
        ])
  NoHint fid ->
    printLine
      ("  file " Text.++ Int.toText fid Text.++ " -> no title/year hint")
  NoTmdbMatch fid ->
    printLine
      ("  file " Text.++ Int.toText fid Text.++ " -> no confident match")
  SearchError fid err ->
    printLine (Text.join "" ["  file ", Int.toText fid, " -> error: ", err])

Resolve.resolveOne :
  Boolean
  -> PreparedQuery r5 a5 Text
  -> PreparedCommand r4 a4
  -> PreparedQuery r3 a3 Text
  -> PreparedCommand r2 a2
  -> PreparedCommand r1 a1
  -> PreparedCommand r a
  -> Text
  -> FileRow
  ->{IO, Postgres} Resolve.Outcome
Resolve.resolveOne
  dryRun pqSearch pcSearch pqDet pcDet pcAssoc pcDelOther token row =
  use FileRow originalName
  fileId = FileRow.fileId row
  match hintTmdbId row with
    Some tmdbId ->
      if ensureMovie pqDet pcDet token tmdbId then
        _ =
          if dryRun then ()
          else writeMatch pcAssoc pcDelOther fileId tmdbId 100 "nfo_id"
        ResolvedById fileId tmdbId
      else SearchError fileId "details fetch failed"
    None ->
      parsed = match (hintTitle row, hintYear row) with
        (Some t, Some y) -> Some (ParsedRelease (originalName row) t y None)
        _                -> parseReleaseName (basenameNoExt (originalName row))
      match parsed with
        None -> NoHint fileId
        Some p ->
          searchResult =
            cachedSearchWith
              pqSearch
              pcSearch
              token
              (ParsedRelease.title p)
              (ParsedRelease.year p)
          match searchResult with
            Left err -> SearchError fileId err
            Right resp ->
              candidates = Tmdb.SearchResponse.results resp
              scored = List.map (r -> (r, scoreCandidate p r)) candidates
              probeMin = Some (Rename.minutes (FileRow.durationSec row))
              match pickBestWithRuntime pqDet pcDet token probeMin scored with
                None -> NoTmdbMatch fileId
                Some (r, s) ->
                  tmdbId = Result.tmdbId r
                  if ensureMovie pqDet pcDet token tmdbId then
                    _ =
                      if dryRun then ()
                      else
                        writeMatch
                          pcAssoc pcDelOther fileId tmdbId s "title_year"
                    ResolvedBySearch fileId tmdbId s
                  else SearchError fileId "details fetch failed"

Resolve.rowToFile :
  (((((Int, Text), Float), Optional Text), Optional Int), Optional Int)
  -> FileRow
Resolve.rowToFile = cases
  (((((fid, oname), dur), ht), hy), htm) ->
    FileRow fid oname dur ht (optIntToNat hy) (optIntToNat htm)

Resolve.run : '{IO, Exception} ()
Resolve.run = runWith false

Resolve.runWith : Boolean -> '{IO, Exception} ()
Resolve.runWith dryRun =
  do
    use Text ++
    token = Tmdb.readToken()
    singleIO Db.config do
      pqFiles = prepareQuery selectUnresolvedSql
      pqSearch = prepareQuery selectSearchSql
      pcSearch = prepareCommand upsertSearchSql
      pqDet = prepareQuery selectDetailsSql
      pcDet = prepareCommand upsertDetailsSql
      pcAssoc = prepareCommand upsertAssociationSql
      pcDelOther = prepareCommand deleteOtherAssociationsSql
      rows = match 
        catch do
          portal = bindQuery pqFiles []
          (rs, _) = executeQueryPortal portal 0
          rs
       with
        Left _   -> []
        Right rs -> List.map rowToFile rs
      label = if dryRun then "[identify] " else "[resolve] "
      _ =
        printLine
          (label ++ Nat.toText (List.size rows) ++ " unresolved file(s)")
      step row =
        outcome =
          resolveOne
            dryRun pqSearch pcSearch pqDet pcDet pcAssoc pcDelOther token row
        printOutcome outcome
      _ = Db.foreach_ step rows
      _ = PreparedQuery.close pqFiles
      _ = PreparedQuery.close pqSearch
      _ = PreparedQuery.close pqDet
      _ = PreparedCommand.close pcSearch
      _ = PreparedCommand.close pcDet
      _ = PreparedCommand.close pcAssoc
      _ = PreparedCommand.close pcDelOther
      printLine
        (if dryRun then "[identify] done (no writes)" else "[resolve] done")

Resolve.selectUnresolvedSql :
  postgres.Query
    r r (((((Int, Text), Float), Optional Text), Optional Int), Optional Int)
Resolve.selectUnresolvedSql =
  use Codec optional text
  sql
    "SELECT f.file_id, f.original_name, f.duration_sec, f.hint_title, f.hint_year, f.hint_tmdb_id FROM files f LEFT JOIN associations a ON a.file_id = f.file_id WHERE a.file_id IS NULL"
    |> typedQuery
      (bigint
        ~ text
        ~ Codec.double
        ~ optional text
        ~ optional integer
        ~ optional integer)

Resolve.upsertAssociationSql : Command b (Int -> Int -> Int -> Text -> b)
Resolve.upsertAssociationSql =
  sql
    "INSERT INTO associations (file_id, tmdb_id, confidence, match_source) VALUES ("
    %% var bigint
    %% sql ", "
    %% var integer
    %% sql ", "
    %% var integer
    %% sql ", "
    %% var Codec.text
    %% sql
         ") ON CONFLICT (file_id, tmdb_id) DO UPDATE SET confidence = EXCLUDED.confidence, match_source = EXCLUDED.match_source, associated_at = NOW()"
    |> buildCommand

Resolve.writeMatch :
  PreparedCommand r1 a1
  -> PreparedCommand r a
  -> Int
  -> Nat
  -> Nat
  -> Text
  ->{Postgres} ()
Resolve.writeMatch pcAssoc pcDelOther fileId tmdbId confidence source =
  use Db pi
  use List ++
  use Nat toInt
  _ = 
    catch do
      bindAndExecuteCommand
        pcDelOther (pobi (Some fileId) ++ pi (toInt tmdbId))
  _ = 
    catch do
      bindAndExecuteCommand
        pcAssoc
        (pobi (Some fileId)
          ++ pi (toInt tmdbId)
          ++ pi (toInt confidence)
          ++ pt source)
  ()

rightToOpt : Either a b -> Optional b
rightToOpt = cases
  Left _  -> None
  Right m -> Some m

runarorama_postgres_2_5_1.postgres.net.messaging.PostgresMessaging.runIO :
  Connection {IO, Exception}
  -> Map Text Text
  -> '{h, IO, Exception, PostgresMessaging} a
  ->{h, IO, Exception} a
runarorama_postgres_2_5_1.postgres.net.messaging.PostgresMessaging.runIO
  conn parameters p =
  use STM atomically
  txnStatus = IO.ref None
  msgQueue : TQueue BackendMessage
  msgQueue = atomically do TQueue.empty()
  logBackendError e =
    use Text ++
    msg = toDebugText e
    has needle = match Text.indexOf needle msg with
      Some _ -> true
      None   -> false
    benignPatterns =
      [ "Bad file descriptor"
      , "abandoned connection"
      , "Unexpected EOF"
      , "Network.Socket.recvBuf"
      , "threadWait"
      ]
    if List.any has benignPatterns then ()
    else ignore (hush do printLine ("Error in backend driver: " ++ msg))
  concurrent.fork_ do
    goBackend : '{IO, Exception, PostgresBackend} () ->{IO, Exception} ()
    goBackend c =
      handle
        match catch c with
          Left e  -> logBackendError e
          Right _ -> ()
      with cases
        { offerBackendMessage msg -> k } ->
          atomically do TQueue.boundedEnqueue 4096 msg msgQueue
          goBackend do k()
        { offerTransactionStatus b -> k } ->
          Ref.write txnStatus (Some b)
          goBackend do k()
        { offerParameterStatus _ -> k } -> goBackend do k()
        { offerBackendKeyData _ -> k } -> goBackend do k()
        { offerNotification _ -> k } -> goBackend do k()
        { a } ->
          Exception.raise
            (Failure
              (typeLink ProtocolError) "Postgres abandoned connection" (Any a))
    match catch do goBackend do backend conn parameters with
      Left e  -> logBackendError e
      Right _ -> ()
  go : '{h, IO, Exception, PostgresMessaging} a ->{h, IO, Exception} a
  go p =
    handle p()
    with cases
      { trySendFrontendMessage msg -> k } ->
        bytes = do FrontendMessage.encode msg
        v = catch do Connection.send conn (encode.toBytes bytes)
        go do k v
      { tryGetTransactionStatus -> k } ->
        match Ref.read txnStatus with
          None ->
            go do
              k
                (Left
                  (Failure
                    (typeLink ProtocolError) "Session not started" (Any ())))
          Some bs -> go do k (Right bs)
      { tryAwaitBackendMessage -> k } ->
        msg = atomically do TQueue.dequeue msgQueue
        go do k (Right msg)
      { a } -> a
  go p

