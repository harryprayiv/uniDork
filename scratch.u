Tmdb.parseReleaseName : Text -> Optional Tmdb.ParsedRelease
Tmdb.parseReleaseName name =
  match Tmdb.findEnclosedYearAny name with
    Some (titlePrefix, year) ->
      cleaned = Tmdb.cleanTitle titlePrefix
      if Universal.eq (Text.size cleaned) 0 then None
      else Some (Tmdb.ParsedRelease.ParsedRelease name cleaned year None)
    None ->
      tokens = Tmdb.tokenize name
      match Tmdb.findYearIndex tokens with
        None -> None
        Some i ->
          match Tmdb.nth i tokens with
            None -> None
            Some yt ->
              match Tmdb.tokenAsYear yt with
                None -> None
                Some y ->
                  titleStr = trim (Text.join " " (List.take i tokens))
                  if Universal.eq (Text.size titleStr) 0 then None
                  else
                    Some
                      (Tmdb.ParsedRelease.ParsedRelease name titleStr y None)

Tmdb.buildParsedRelease : Text -> Optional Movie -> Optional Tmdb.ParsedRelease
Tmdb.buildParsedRelease folderName maybeNfo =
  nfoId = match maybeNfo with
    None   -> None
    Some m -> Nfo.extractTmdbId m
  fromNfo = match maybeNfo with
    None   -> None
    Some m ->
      match (Nfo.extractTitle m, Nfo.extractYear m) with
        (Some t, Some y) -> Some (t, y)
        _                -> None
  match fromNfo with
    Some (t, y) -> Some (Tmdb.ParsedRelease.ParsedRelease folderName t y nfoId)
    None        ->
      match Tmdb.parseReleaseName folderName with
        None   -> None
        Some p -> Some (Tmdb.ParsedRelease.nfoTmdbId.set nfoId p)

Tmdb.releaseYear : Text -> Optional Nat
Tmdb.releaseYear dateStr =
  use Nat <
  if Text.size dateStr < 4 then None
  else Tmdb.tokenAsYear (Text.take 4 dateStr)

Tmdb.scoreCandidate : Tmdb.ParsedRelease -> Tmdb.Result -> Nat
Tmdb.scoreCandidate p r =
  use Nat + - >= >
  use Universal eq
  q = Tmdb.normalize (Tmdb.ParsedRelease.title p)
  t = Tmdb.normalize (Tmdb.Result.title r)
  o = Tmdb.normalize (Tmdb.Result.originalTitle r)
  exactMatch = eq q t || eq q o
  ovT = Tmdb.tokenOverlapPercent q t
  ovO = Tmdb.tokenOverlapPercent q o
  bestOv = if ovT > ovO then ovT else ovO
  titleScore =
    if exactMatch then 30
    else
      if bestOv >= 75 then 20
      else if bestOv >= 50 then 10 else 0
  py = Tmdb.ParsedRelease.year p
  yearScore = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    None    -> 0
    Some ry ->
      if eq ry py then 20
      else
        diff = if ry > py then ry - py else py - ry
        if eq diff 1 then 10 else 0
  idOk = match Tmdb.ParsedRelease.nfoTmdbId p with
    Some n -> eq n (Tmdb.Result.tmdbId r)
    None   -> false
  idScore = if idOk then 50 else 0
  idScore + titleScore + yearScore

Tmdb.maxScore : [(Tmdb.Result, Nat)] -> Optional Nat
Tmdb.maxScore xs =
  use Nat <
  step acc = cases
    (_, s) ->
      match acc with
        None   -> Some s
        Some a -> if a < s then Some s else Some a
  List.foldLeft step None xs

Tmdb.popularityWinner :
  [(Tmdb.Result, Nat)] -> Optional ((Tmdb.Result, Nat), Float)
Tmdb.popularityWinner tied =
  use Float >
  step acc cur =
    (rCur, _) = cur
    pCur = Tmdb.Result.popularity rCur
    match acc with
      None -> Some (cur, 0.0)
      Some (best, runnerUp) ->
        (rBest, _) = best
        pBest = Tmdb.Result.popularity rBest
        if pCur > pBest then Some (cur, pBest)
        else
          if pCur > runnerUp then Some (best, pCur) else Some (best, runnerUp)
  List.foldLeft step None tied

Tmdb.SearchResponse.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.SearchResponse
Tmdb.SearchResponse.fromJson = do
  results = object.at! "results" (Decoder.array Tmdb.Result.fromJson)
  Tmdb.SearchResponse.SearchResponse results

Tmdb.CachedSearch.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.CachedSearch
Tmdb.CachedSearch.fromJson = do
  use Decoder optional! text
  use object at
  folder = object.at! "folder" text
  response = optional! (at "response" Tmdb.SearchResponse.fromJson)
  error = optional! (at "error" text)
  Tmdb.CachedSearch.CachedSearch folder response error

Tmdb.readCache : Text ->{IO, Exception} Optional Tmdb.CachedSearch
Tmdb.readCache folderName =
  use Text ++
  jsonPath = FilePath (Tmdb.cacheRoot ++ "/" ++ folderName ++ ".json")
  match 
    catch do
      raw = readFileUtf8 jsonPath
      Decoder.run Tmdb.CachedSearch.fromJson raw
   with
    Left _  -> None
    Right s -> Some s

Tmdb.printCandidate : (Tmdb.Result, Nat) ->{IO, Exception} ()
Tmdb.printCandidate = cases
  (r, score) ->
    use Nat >=
    label =
      if Universal.eq score 100 then "[100%]"
      else
        if score >= 80 then "[ 80%]"
        else
          if score >= 50 then "[ 50%]"
          else if score >= 40 then "[ 40%]" else "[ low]"
    yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
      Some y -> Nat.toText y
      None   -> "????"
    printLine
      (Text.join
        ""
        [ "    "
        , label
        , " ("
        , Nat.toText score
        , "%) tmdb:"
        , Nat.toText (Tmdb.Result.tmdbId r)
        , " \""
        , Tmdb.Result.title r
        , "\" ("
        , yearText
        , ") pop="
        , Float.toText (Tmdb.Result.popularity r)
        ])

Tmdb.reportLooseVideoWith pq pc pqStage pqDet pcDet token videoFile =
  use Nat toText
  use Text ++ join
  filename = filePathBasename videoFile
  name = Rename.basenameNoExt filename
  _ = printLine (join "" ["LOOSE:  ", filename])
  maybeProbeMin = match Stage.readWith pqStage (filePathText videoFile) with
    None    -> None
    Some pr -> Some (Rename.minutes (Stage.ProbeResult.durationSec pr))
  match Tmdb.parseReleaseName name with
    None ->
      _ = printLine "  parsed:  FAILED (no year + quality token)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      _ =
        printLine
          (join
            ""
            [ "  parsed:  title=\""
            , Tmdb.ParsedRelease.title p
            , "\", year="
            , toText (Tmdb.ParsedRelease.year p)
            ])
      result =
        Tmdb.cachedSearchWith
          pq
          pc
          token
          name
          (Tmdb.ParsedRelease.title p)
          (Tmdb.ParsedRelease.year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, Tmdb.scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ Tmdb.printCandidate scored
          _ =
            match Tmdb.pickBestWithRuntime
              pqDet pcDet token maybeProbeMin scored with
              Some (r, s) ->
                printLine
                  (join
                    ""
                    [ "  verdict: "
                    , toText s
                    , "% -> tmdb:"
                    , toText (Tmdb.Result.tmdbId r)
                    , " \""
                    , Tmdb.Result.title r
                    , "\""
                    ])
              None ->
                printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.reportFolderWith pq pc pqStage pqDet pcDet token folder =
  use Nat toText
  use Text ++ join
  folderName = filePathBasename folder
  maybeNfo = Nfo.tryReadFolder folder
  _ = printLine (join "" ["FOLDER: ", folderName])
  _ = match maybeNfo with
    Some m ->
      match Nfo.extractTmdbId m with
        Some n -> printLine ("  NFO tmdb id: " ++ toText n)
        None   -> printLine "  NFO present (no tmdb id)"
    None   -> ()
  files = directoryContents.texts folder
  maybeProbeMin = match findFirstVideo files with
    None           -> None
    Some videoName ->
      videoPath = pathJoin folder videoName
      match Stage.readWith pqStage (filePathText videoPath) with
        None    -> None
        Some pr -> Some (Rename.minutes (Stage.ProbeResult.durationSec pr))
  match Tmdb.buildParsedRelease folderName maybeNfo with
    None ->
      _ = printLine "  parsed:  FAILED (no title/year from NFO or folder name)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      idTag = match Tmdb.ParsedRelease.nfoTmdbId p with
        Some n -> " nfo-id=" ++ toText n
        None   -> ""
      _ =
        printLine
          (join
            ""
            [ "  parsed:  title=\""
            , Tmdb.ParsedRelease.title p
            , "\", year="
            , toText (Tmdb.ParsedRelease.year p)
            , idTag
            ])
      result =
        Tmdb.cachedSearchWith
          pq
          pc
          token
          folderName
          (Tmdb.ParsedRelease.title p)
          (Tmdb.ParsedRelease.year p)
      match result with
        Left err ->
          _ = printLine ("  error:   " ++ err)
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, Tmdb.scoreCandidate p r)) candidates
          _ = printLine ("  candidates: " ++ toText (List.size candidates))
          _ = Db.foreach_ Tmdb.printCandidate scored
          _ =
            match Tmdb.pickBestWithRuntime
              pqDet pcDet token maybeProbeMin scored with
              Some (r, s) ->
                printLine
                  (join
                    ""
                    [ "  verdict: "
                    , toText s
                    , "% -> tmdb:"
                    , toText (Tmdb.Result.tmdbId r)
                    , " \""
                    , Tmdb.Result.title r
                    , "\""
                    ])
              None ->
                printLine "  verdict: SKIP (no unique high-scoring match)"
          printLine ""

Tmdb.cleanTitle : Text -> Text
Tmdb.cleanTitle t =
  use Nat >
  s1 = replaceAll "." " " t
  s2 = replaceAll "_" " " s1
  parts = Text.split ?\s s2
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  trim (Text.join " " nonEmpty)

Tmdb.findEnclosedYear : Text -> Text -> Text -> Optional (Text, Nat)
Tmdb.findEnclosedYear open close name =
  go offset =
    use Nat +
    use Text drop size take
    sub = drop offset name
    match Text.indexOf open sub with
      None -> None
      Some openIdx ->
        absOpen = offset + openIdx
        afterOpen = absOpen + size open
        cand = take 4 (drop afterOpen name)
        closeAt = afterOpen + 4
        match Tmdb.tokenAsYear cand with
          Some y ->
            actualClose = take (size close) (drop closeAt name)
            if Universal.eq actualClose close then
              Some (trim (take absOpen name), y)
            else go (absOpen + 1)
          None -> go (absOpen + 1)
  go 0

Tmdb.findEnclosedYearAny : Text -> Optional (Text, Nat)
Tmdb.findEnclosedYearAny name = match Tmdb.findEnclosedYear "(" ")" name with
  Some r -> Some r
  None   -> Tmdb.findEnclosedYear "[" "]" name

Tmdb.tokenPath : Text
Tmdb.tokenPath = "/home/bismuth/.config/uniDork/tmdb-token"

Tmdb.readToken : '{IO, Exception} Text
Tmdb.readToken = do trim (readFileUtf8 (FilePath Tmdb.tokenPath))

Tmdb.apiAuthority : Authority
Tmdb.apiAuthority = Authority None (HostName "api.themoviedb.org") None

Tmdb.searchURI : Text -> Nat -> URI
Tmdb.searchURI title year =
  use Path /
  path = Path.root / "3" / "search" / "movie"
  q = Query.empty & ("query", title) & ("year", Nat.toText year)
  URI Scheme.https (Some Tmdb.apiAuthority) path (fromQuery q) Fragment.empty

Tmdb.searchRequest : Text -> Text -> Nat -> HttpRequest
Tmdb.searchRequest token title year =
  use HttpRequest addHeader
  use Text ++
  HttpRequest.get (Tmdb.searchURI title year)
    |> addHeader "Authorization" ("Bearer " ++ token)
    |> addHeader "Accept" "application/json"

Tmdb.search : Text -> Text -> Nat ->{IO} Either Text Tmdb.SearchResponse
Tmdb.search token title year =
  req = Tmdb.searchRequest token title year
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          body = bodyText ok
          Decoder.run Tmdb.SearchResponse.fromJson body
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Tmdb.upsertSearchSql =
  use Codec text
  sql
    "INSERT INTO tmdb_search_cache (source_path, search_title, search_year, payload) VALUES ("
    %% var text
    %% sql ", "
    %% var text
    %% sql ", "
    %% var integer
    %% sql ", "
    %% var text
    %% sql
         ") ON CONFLICT (source_path) DO UPDATE SET search_title = EXCLUDED.search_title, search_year = EXCLUDED.search_year, payload = EXCLUDED.payload, fetched_at = NOW()"
    |> buildCommand

Tmdb.writeDbCacheWith pc sourcePath title year result =
  use List ++
  use Tmdb.CachedSearch CachedSearch
  entry = match result with
    Right r -> CachedSearch sourcePath (Some r) None
    Left e  -> CachedSearch sourcePath None (Some e)
  payload = Json.toText (Tmdb.CachedSearch.toJson entry)
  _ = 
    catch do
      bindAndExecuteCommand
        pc
        (Db.pt sourcePath
          ++ Db.pt title
          ++ Db.pi (Nat.toInt year)
          ++ Db.pt payload)
  ()

Tmdb.selectSearchSql =
  use Codec text
  sql "SELECT payload FROM tmdb_search_cache WHERE source_path = " %% var text
    |> typedQuery text

Tmdb.readDbCacheWith pq sourcePath = match 
  catch do
    portal = bindQuery pq (Db.pt sourcePath)
    (rows, _) = executeQueryPortal portal 0
    rows
 with
  Left _   -> None
  Right rs ->
    match rs with
      []       -> None
      raw +: _ ->
        match catch do Decoder.run Tmdb.CachedSearch.fromJson raw with
          Left _  -> None
          Right c ->
            match Tmdb.CachedSearch.response c with
              Some r -> Some (Right r)
              None   ->
                match Tmdb.CachedSearch.error c with
                  Some e -> Some (Left e)
                  None   -> None

Tmdb.Details.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.Details
Tmdb.Details.fromJson =
  do
    use Decoder array nat optional! text
    use List filterMap find
    use Nat >
    use Optional getOrElse
    use Text size
    use Universal eq
    use object at at!
    tmdbId = at! "id" nat
    rawImdbId = getOrElse "" (optional! (at "imdb_id" text))
    imdbId = if eq (size rawImdbId) 0 then None else Some rawImdbId
    runtime = getOrElse 0 (optional! (at "runtime" nat))
    title = at! "title" text
    originalTitle = getOrElse "" (optional! (at "original_title" text))
    originalLanguage = getOrElse "" (optional! (at "original_language" text))
    overview = getOrElse "" (optional! (at "overview" text))
    tagline = getOrElse "" (optional! (at "tagline" text))
    releaseDate = getOrElse "" (optional! (at "release_date" text))
    voteAverage = getOrElse 0.0 (optional! (at "vote_average" Decoder.float))
    voteCount = getOrElse 0 (optional! (at "vote_count" nat))
    genres =
      getOrElse [] (optional! (at "genres" (array Tmdb.namedObjectFromJson)))
    countries =
      getOrElse
        []
        (optional! (at "production_countries" (array Tmdb.isoCountryFromJson)))
    studios =
      getOrElse
        []
        (optional! (at "production_companies" (array Tmdb.namedObjectFromJson)))
    collection = optional! (at "belongs_to_collection" do at! "name" text)
    releaseResults =
      getOrElse
        []
        (optional!
          (at "release_dates" do
            at! "results" (array Tmdb.countryReleaseFromJson)))
    certForUS = cases (c, _) -> eq c "US"
    nonEmpty c = size c > 0
    mpaa = match find certForUS releaseResults with
      Some (_, certs) ->
        match find nonEmpty certs with
          Some c -> c
          None   -> ""
      None            -> ""
    cast =
      getOrElse
        []
        (optional! (at "credits" do at! "cast" (array Tmdb.castMemberFromJson)))
    crew =
      getOrElse
        []
        (optional! (at "credits" do at! "crew" (array Tmdb.crewMemberFromJson)))
    isDirector = cases (n, j, _) -> if eq j "Director" then Some n else None
    isWriter = cases (n, _, d) -> if eq d "Writing" then Some n else None
    directors = List.distinctText (filterMap isDirector crew)
    writers = List.distinctText (filterMap isWriter crew)
    tags =
      getOrElse
        []
        (optional!
          (at "keywords" do at! "keywords" (array Tmdb.namedObjectFromJson)))
    Tmdb.Details.Details
      tmdbId
      imdbId
      runtime
      title
      originalTitle
      originalLanguage
      overview
      tagline
      releaseDate
      voteAverage
      voteCount
      genres
      countries
      studios
      collection
      mpaa
      directors
      writers
      cast
      tags

-- Subs.u
-- subdl.com subtitle search + raw download client.
--
-- Scope: search by IMDb/TMDB id with unpack=1, parse JSON, pick raw
-- unpack files per language, download them, write them to disk as
-- "<base>.<lang>.<ext>".
-- Out of scope: result caching, retries, integration with the rename
-- pipeline. Those are layered above this module.

Subs.tokenPath : Text
Subs.tokenPath = "/home/bismuth/.config/uniDork/sub-token"

Subs.readToken : '{IO, Exception} Text
Subs.readToken = do trim (readFileUtf8 (FilePath Subs.tokenPath))

Subs.apiAuthority : Authority
Subs.apiAuthority = Authority None (HostName "api.subdl.com") None

Subs.downloadAuthority : Authority
Subs.downloadAuthority = Authority None (HostName "dl.subdl.com") None

-- ============================================================
-- Types
-- ============================================================

type Subs.MovieResult
  = { imdbId : Optional Text,
      tmdbId : Optional Nat,
      sdId : Optional Nat,
      kind : Text,
      name : Text,
      year : Optional Nat }

type Subs.UnpackFile
  = { fileNId : Text,
      name : Text,
      releaseName : Text,
      language : Text,
      format : Text,
      hearingImpaired : Boolean,
      size : Nat,
      urlPath : Text }

type Subs.SubtitleItem
  = { releaseName : Text,
      fileName : Text,
      urlPath : Text,
      language : Optional Text,
      hearingImpaired : Optional Boolean,
      fullSeason : Optional Boolean,
      season : Optional Nat,
      episode : Optional Nat,
      unpackFiles : [Subs.UnpackFile] }

type Subs.SearchResponse
  = { ok : Boolean,
      error : Optional Text,
      results : [Subs.MovieResult],
      subtitles : [Subs.SubtitleItem] }

type Subs.SaveOutcome
  = Saved Text Text
  | NotFound Text
  | Errored Text Text

-- ============================================================
-- Decoders
-- ============================================================

Subs.MovieResult.fromJson : '{unison_json_1_4_2.Decoder} Subs.MovieResult
Subs.MovieResult.fromJson = do
  use Decoder nat optional! text
  use object at at!
  imdbId = optional! (at "imdb_id" text)
  tmdbId = optional! (at "tmdb_id" nat)
  sdId = optional! (at "sd_id" nat)
  kind = at! "type" text
  name = at! "name" text
  year = optional! (at "year" nat)
  Subs.MovieResult.MovieResult imdbId tmdbId sdId kind name year

Subs.UnpackFile.fromJson : '{unison_json_1_4_2.Decoder} Subs.UnpackFile
Subs.UnpackFile.fromJson =
  do
    use Decoder boolean nat optional! text
    use Optional getOrElse
    use object at at!
    fileNId = at! "file_n_id" text
    name = at! "name" text
    releaseName = getOrElse "" (optional! (at "release_name" text))
    language = at! "language" text
    format = at! "format" text
    hi = getOrElse false (optional! (at "hi" boolean))
    size = getOrElse 0 (optional! (at "size" nat))
    urlPath = at! "url" text
    Subs.UnpackFile.UnpackFile
      fileNId name releaseName language format hi size urlPath

Subs.SubtitleItem.fromJson : '{unison_json_1_4_2.Decoder} Subs.SubtitleItem
Subs.SubtitleItem.fromJson =
  do
    use Decoder array boolean nat optional! text
    use Optional getOrElse
    use object at at!
    releaseName = getOrElse "" (optional! (at "release_name" text))
    fileName = getOrElse "" (optional! (at "name" text))
    urlPath = at! "url" text
    language = optional! (at "language" text)
    hi = optional! (at "hi" boolean)
    fullSeason = optional! (at "full_season" boolean)
    season = optional! (at "season" nat)
    episode = optional! (at "episode" nat)
    unpackFiles =
      getOrElse
        []
        (optional! (at "unpack_files" (array Subs.UnpackFile.fromJson)))
    Subs.SubtitleItem.SubtitleItem
      releaseName
      fileName
      urlPath
      language
      hi
      fullSeason
      season
      episode
      unpackFiles

Subs.SearchResponse.fromJson :
  '{unison_json_1_4_2.Decoder} Subs.SearchResponse
Subs.SearchResponse.fromJson =
  do
    use Decoder array boolean optional! text
    use Optional getOrElse
    use object at at!
    ok = at! "status" boolean
    error = optional! (at "error" text)
    results =
      getOrElse
        [] (optional! (at "results" (array Subs.MovieResult.fromJson)))
    subtitles =
      getOrElse
        [] (optional! (at "subtitles" (array Subs.SubtitleItem.fromJson)))
    Subs.SearchResponse.SearchResponse ok error results subtitles

-- ============================================================
-- URI building
-- ============================================================

Subs.imdbSearchURI : Text -> Text -> Text -> URI
Subs.imdbSearchURI apiKey imdbId languages =
  use Path /
  path = Path.root / "api" / "v1" / "subtitles"
  q =
    Query.empty
      & ("api_key", apiKey)
      & ("type", "movie")
      & ("subs_per_page", "30")
      & ("unpack", "1")
      & ("imdb_id", imdbId)
      & ("languages", languages)
  URI Scheme.https (Some Subs.apiAuthority) path (fromQuery q) Fragment.empty

Subs.tmdbSearchURI : Text -> Nat -> Text -> URI
Subs.tmdbSearchURI apiKey tmdbId languages =
  use Path /
  path = Path.root / "api" / "v1" / "subtitles"
  q =
    Query.empty
      & ("api_key", apiKey)
      & ("type", "movie")
      & ("subs_per_page", "30")
      & ("unpack", "1")
      & ("tmdb_id", Nat.toText tmdbId)
      & ("languages", languages)
  URI Scheme.https (Some Subs.apiAuthority) path (fromQuery q) Fragment.empty

Subs.downloadURI : Text -> URI
Subs.downloadURI urlPath =
  use Nat >
  use Path /
  parts = List.filter (p -> Text.size p > 0) (Text.split ?/ urlPath)
  path = List.foldLeft (acc p -> acc / p) Path.root parts
  URI
    Scheme.https
    (Some Subs.downloadAuthority)
    path
    (fromQuery Query.empty)
    Fragment.empty

Subs.SubtitleItem.downloadURI : Subs.SubtitleItem -> URI
Subs.SubtitleItem.downloadURI s =
  Subs.downloadURI (Subs.SubtitleItem.urlPath s)

Subs.UnpackFile.downloadURI : Subs.UnpackFile -> URI
Subs.UnpackFile.downloadURI uf =
  Subs.downloadURI (Subs.UnpackFile.urlPath uf)

-- ============================================================
-- Language helpers
-- ============================================================

Subs.languagesParam : [Text] -> Text
Subs.languagesParam langs =
  Text.join "," (List.map Text.toUppercase langs)

Subs.normLang : Text -> Text
Subs.normLang t = Text.toLowercase (trim t)

-- ============================================================
-- HTTP
-- ============================================================

Subs.searchRequestImdb : Text -> Text -> Text -> HttpRequest
Subs.searchRequestImdb apiKey imdbId languages =
  use HttpRequest addHeader
  HttpRequest.get (Subs.imdbSearchURI apiKey imdbId languages)
    |> addHeader "Accept" "application/json"

Subs.searchRequestTmdb : Text -> Nat -> Text -> HttpRequest
Subs.searchRequestTmdb apiKey tmdbId languages =
  use HttpRequest addHeader
  HttpRequest.get (Subs.tmdbSearchURI apiKey tmdbId languages)
    |> addHeader "Accept" "application/json"

Subs.searchByImdb :
  Text -> Text -> Text ->{IO} Either Text Subs.SearchResponse
Subs.searchByImdb apiKey imdbId languages =
  req = Subs.searchRequestImdb apiKey imdbId languages
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          body = bodyText ok
          Decoder.run Subs.SearchResponse.fromJson body
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Subs.searchByTmdb :
  Text -> Nat -> Text ->{IO} Either Text Subs.SearchResponse
Subs.searchByTmdb apiKey tmdbId languages =
  req = Subs.searchRequestTmdb apiKey tmdbId languages
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          body = bodyText ok
          Decoder.run Subs.SearchResponse.fromJson body
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Subs.downloadUnpackRaw : Subs.UnpackFile ->{IO} Either Text Text
Subs.downloadUnpackRaw uf =
  use HttpRequest addHeader
  uri = Subs.UnpackFile.downloadURI uf
  req = HttpRequest.get uri |> addHeader "Accept" "*/*"
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          bodyText ok
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

-- ============================================================
-- Picking candidates
-- ============================================================

Subs.languageMatches : Text -> Subs.SubtitleItem -> Boolean
Subs.languageMatches target item =
  match Subs.SubtitleItem.language item with
    None    -> false
    Some la -> Universal.eq (Subs.normLang la) (Subs.normLang target)

Subs.isFullSeason : Subs.SubtitleItem -> Boolean
Subs.isFullSeason item =
  match Subs.SubtitleItem.fullSeason item with
    Some true -> true
    _         -> false

Subs.isHi : Subs.SubtitleItem -> Boolean
Subs.isHi item =
  match Subs.SubtitleItem.hearingImpaired item with
    Some true -> true
    _         -> false

Subs.pickBestForMovie :
  Text -> [Subs.SubtitleItem] -> Optional Subs.SubtitleItem
Subs.pickBestForMovie lang items =
  notSeason =
    List.filter
      (i -> (if Subs.isFullSeason i then false else true)) items
  withLang = List.filter (Subs.languageMatches lang) notSeason
  pool =
    if Universal.eq (List.size withLang) 0 then notSeason else withLang
  nonHi = List.filter (i -> (if Subs.isHi i then false else true)) pool
  match List.head nonHi with
    Some s -> Some s
    None   -> List.head pool

Subs.unpackLanguageMatches : Text -> Subs.UnpackFile -> Boolean
Subs.unpackLanguageMatches target uf =
  Universal.eq
    (Subs.normLang (Subs.UnpackFile.language uf)) (Subs.normLang target)

Subs.unpackIsSrt : Subs.UnpackFile -> Boolean
Subs.unpackIsSrt uf =
  Universal.eq (Subs.normLang (Subs.UnpackFile.format uf)) "srt"

Subs.unpackIsHi : Subs.UnpackFile -> Boolean
Subs.unpackIsHi uf = Subs.UnpackFile.hearingImpaired uf

Subs.allUnpackFiles : Subs.SearchResponse -> [Subs.UnpackFile]
Subs.allUnpackFiles r =
  List.flatMap
    Subs.SubtitleItem.unpackFiles (Subs.SearchResponse.subtitles r)

Subs.pickUnpackForLanguage :
  Text -> [Subs.UnpackFile] -> Optional Subs.UnpackFile
Subs.pickUnpackForLanguage lang files =
  langMatches = List.filter (Subs.unpackLanguageMatches lang) files
  srtMatches = List.filter Subs.unpackIsSrt langMatches
  pool =
    if Universal.eq (List.size srtMatches) 0 then langMatches else srtMatches
  nonHi =
    List.filter
      (uf -> (if Subs.unpackIsHi uf then false else true)) pool
  match List.head nonHi with
    Some s -> Some s
    None   -> List.head pool

-- ============================================================
-- Save: one search call, then one download per requested language.
-- File naming: "<baseName>.<lower-lang>.<format>"  (e.g. movie.en.srt)
-- ============================================================

Subs.saveOneLanguage :
  FilePath
  -> Text
  -> [Subs.UnpackFile]
  -> Text
  ->{IO} Subs.SaveOutcome
Subs.saveOneLanguage targetDir baseName allFiles lang =
  use Text ++
  langCode = Subs.normLang lang
  match Subs.pickUnpackForLanguage lang allFiles with
    None -> Subs.SaveOutcome.NotFound langCode
    Some uf ->
      match Subs.downloadUnpackRaw uf with
        Left err   -> Subs.SaveOutcome.Errored langCode err
        Right body ->
          ext = Subs.normLang (Subs.UnpackFile.format uf)
          filename = baseName ++ "." ++ langCode ++ "." ++ ext
          path = pathJoin targetDir filename
          match catch do writeFileUtf8 path body with
            Left f  -> Subs.SaveOutcome.Errored langCode (Failure.message f)
            Right _ -> Subs.SaveOutcome.Saved langCode (filePathText path)

Subs.fetchAndSaveByImdb :
  Text
  -> Text
  -> FilePath
  -> Text
  -> [Text]
  ->{IO} [Subs.SaveOutcome]
Subs.fetchAndSaveByImdb apiKey imdbId targetDir baseName langs =
  langsParam = Subs.languagesParam langs
  match Subs.searchByImdb apiKey imdbId langsParam with
    Left err  ->
      List.map (l -> Subs.SaveOutcome.Errored (Subs.normLang l) err) langs
    Right resp ->
      allFiles = Subs.allUnpackFiles resp
      List.map (Subs.saveOneLanguage targetDir baseName allFiles) langs

Subs.fetchAndSaveByTmdb :
  Text
  -> Nat
  -> FilePath
  -> Text
  -> [Text]
  ->{IO} [Subs.SaveOutcome]
Subs.fetchAndSaveByTmdb apiKey tmdbId targetDir baseName langs =
  langsParam = Subs.languagesParam langs
  match Subs.searchByTmdb apiKey tmdbId langsParam with
    Left err  ->
      List.map (l -> Subs.SaveOutcome.Errored (Subs.normLang l) err) langs
    Right resp ->
      allFiles = Subs.allUnpackFiles resp
      List.map (Subs.saveOneLanguage targetDir baseName allFiles) langs

