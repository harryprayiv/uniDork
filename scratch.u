    check
    [ eq (Rename.vfTag 3840 2160) "2160p"
    , eq (Rename.vfTag 3840 2080) "2160p"
    , eq (Rename.vfTag 1920 1080) "1080p"
    , eq (Rename.vfTag 1920 800) "1080p"
    , eq (Rename.vfTag 1920 1040) "1080p"
    , eq (Rename.vfTag 1280 720) "720p"
