-- ====================================================================
-- PostgreSQL: helpers and utilities
-- ====================================================================

Db.pt : Text -> [Optional Text]
Db.pt t = Codec.encode Codec.text t

Db.pot : Optional Text -> [Optional Text]
Db.pot v = [v]

Db.pi : Int -> [Optional Text]
Db.pi i = Codec.encode integer i

Db.poi : Optional Int -> [Optional Text]
Db.poi = cases
  None   -> [None]
  Some i -> Codec.encode integer i

Db.pf : Float -> [Optional Text]
Db.pf f = Codec.encode Codec.double f

Db.pobi : Optional Int -> [Optional Text]
Db.pobi = cases
  None   -> [None]
  Some i -> Codec.encode bigint i

Db.withIndex : [a] -> [(Nat, a)]
Db.withIndex xs =
  use List +:
  use Nat +
  go acc i = cases
    []      -> List.reverse acc
    x +: ys -> go ((i, x) +: acc) (i + 1) ys
  go [] 0 xs

Db.foreach_ : (a ->{g} b) -> [a] ->{g} ()
Db.foreach_ f xs =
  step acc x =
    _ = f x
    acc
  _ = List.foldLeft step () xs
  ()

Db.countMovies : '{IO, Exception} ()
Db.countMovies = do
  singleIO Db.config do
    q = sql "SELECT COUNT(*) FROM movies" |> typedQuery bigint
    counts = Query.execute q
    match counts with
      n +: _ -> printLine (Text.join "" ["movies in db: ", Int.toText n])
      []     -> printLine "no result"


-- ====================================================================
-- Per-movie upsert. Child rows key on folder_checksum.
-- ====================================================================

Db.upsertWith
  pcUpsert pcVid pcDVid pcAud pcDAud pcSub pcDSub
  pcAct pcDAct pcGen pcDGen pcTag pcDTag pcCou pcDCou
  pcStu pcDStu pcDir pcDDir pcCre pcDCre actualRuntimeSec m =
  transaction do
    use Db foreach_
    use List ++
    use Nat toInt
    use Optional map
    k = MovieId.kodi (Movie.id m)
    csum = Optional.getOrElse "" (Movie.checksum m)
    mid = Movie.id m
    t = Movie.title m
    s = Movie.scoring m
    sd = FileInfo.streams (Movie.fileInfo m)
    vid = StreamDetails.video sd
    tax = Movie.taxonomy m
    fm = Movie.folderMeta m
    indexedAudios = Db.withIndex (StreamDetails.audios sd)
    indexedSubs = Db.withIndex (StreamDetails.subtitles sd)
    indexedActors = Db.withIndex (Movie.actors m)
    del pc =
      _ = bindAndExecuteCommand pc (Db.pt csum)
      ()
    repList delPc insPc vals =
      _ = del delPc
      foreach_ (v -> bindAndExecuteCommand insPc (Db.pt csum ++ Db.pt v)) vals
    _ = printLine (Text.join "" ["upserting: ", k, " (", csum, ")"])
    _ =
      bindAndExecuteCommand
        pcUpsert
        (Db.pt k
          ++ Db.pot (MovieId.imdb mid)
          ++ Db.pot (MovieId.tmdb mid)
          ++ Db.pot (MovieId.tvdb mid)
          ++ Db.pt (Title.display t)
          ++ Db.pt (Title.original t)
          ++ Db.pt (Title.sort t)
          ++ Db.pot (Movie.collection m)
          ++ Db.poi (map toInt (Scoring.year s))
          ++ Db.pf (Scoring.rating s)
          ++ Db.pi (toInt (Scoring.votes s))
          ++ Db.pt (Scoring.mpaa s)
          ++ Db.poi (map toInt (Movie.runtime m))
          ++ Db.pt (Movie.plot m)
          ++ Db.pt (Movie.tagline m)
          ++ Db.pot (Movie.folderPath m)
          ++ Db.pot (Movie.nfoPath m)
          ++ Db.pot (Movie.videoFilePath m)
          ++ Db.pobi (map toInt (Movie.fileSizeBytes m))
          ++ Db.pot (Movie.checksum m)
          ++ Db.pot (FolderMeta.rawSize fm)
          ++ Db.pot (FolderMeta.resolution fm)
          ++ Db.pot (FolderMeta.videoCodec fm)
          ++ Db.poi (map toInt (FolderMeta.bitDepth fm))
          ++ Db.poi (map toInt (FolderMeta.runtimeMin fm))
          ++ Db.poi (map toInt actualRuntimeSec))
    _ = del pcDVid
    _ =
      bindAndExecuteCommand
        pcVid
        (Db.pt csum
          ++ Db.pt (Video.codec vid)
          ++ Db.pf (Video.aspect vid)
          ++ Db.pi (toInt (Video.width vid))
          ++ Db.pi (toInt (Video.height vid)))
    _ = del pcDAud
    _ =
      foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAud
              (Db.pt csum
                ++ Db.pi (toInt i)
                ++ Db.pt (Audio.codec a)
                ++ Db.pt (Audio.language a)
                ++ Db.pi (toInt (Audio.channels a))))
        indexedAudios
    _ = del pcDSub
    _ =
      foreach_
        (cases
          (i, sub) ->
            bindAndExecuteCommand
              pcSub
              (Db.pt csum ++ Db.pi (toInt i) ++ Db.pt (Subtitle.language sub)))
        indexedSubs
    _ = del pcDAct
    _ =
      foreach_
        (cases
          (i, a) ->
            bindAndExecuteCommand
              pcAct
              (Db.pt csum
                ++ Db.pi (toInt i)
                ++ Db.pt (Actor.name a)
                ++ Db.pt (Actor.role a)))
        indexedActors
    _ = repList pcDGen pcGen (Taxonomy.genres tax)
    _ = repList pcDTag pcTag (Taxonomy.tags tax)
    _ = repList pcDCou pcCou (Taxonomy.countries tax)
    _ = repList pcDStu pcStu (Taxonomy.studios tax)
    _ = repList pcDDir pcDir (Taxonomy.directors tax)
    _ = repList pcDCre pcCre (Taxonomy.credits tax)
    ()

-- ====================================================================
-- ffprobe sidecar JSON: parse <video>.ffprobe.json files produced by
-- the probe-library.fish pre-pass. Phase 1 reads only format.duration.
-- ====================================================================

type Probe.Format =
  { duration : Float,
    sizeBytes : Optional Nat,
    bitRate : Optional Nat }

type Probe.Result = { format : Probe.Format }

Probe.parseFloat : Text -> Float
Probe.parseFloat t = Optional.getOrElse 0.0 (Float.fromText (Text.trim t))

-- ffprobe encodes numeric fields like "size" and "bit_rate" as strings.
-- This helper reads an optional string field and parses it to a Nat.
Probe.optNatStringAt : Text ->{unison_json_1_4_2.Decoder} Optional Nat
Probe.optNatStringAt key =
  match Decoder.optional! (object.at key Decoder.text) with
    None   -> None
    Some s -> Nat.fromText (Text.trim s)

Probe.Format.fromJson : '{unison_json_1_4_2.Decoder} Probe.Format
Probe.Format.fromJson = do
  durStr = object.at! "duration" Decoder.text
  duration = Probe.parseFloat durStr
  sizeBytes = Probe.optNatStringAt "size"
  bitRate = Probe.optNatStringAt "bit_rate"
  Probe.Format.Format duration sizeBytes bitRate

Probe.Result.fromJson : '{unison_json_1_4_2.Decoder} Probe.Result
Probe.Result.fromJson = do
  format = object.at! "format" Probe.Format.fromJson
  Probe.Result.Result format

-- Must agree with UNIDORK_FFPROBE_CACHE in the dev shell. The cache mirrors
-- the source-path layout: a video at /a/b.mkv has its JSON at
-- <cacheRoot>/a/b.mkv.json.
Probe.cacheRoot : Text
Probe.cacheRoot = "/home/bismuth/.cache/uniDork/ffprobe"

Probe.readSidecar : Text ->{IO, Exception} Optional Probe.Result
Probe.readSidecar videoPath =
  use Text ++
  jsonPath = FilePath (Probe.cacheRoot ++ videoPath ++ ".json")
  match catch do
    raw = readFileUtf8 jsonPath
    Decoder.run Probe.Result.fromJson raw
  with
    Left _  -> None
    Right r -> Some r

-- Float seconds → Nat seconds (round to nearest, clamp negatives to 0).
Probe.runtimeSec : Probe.Result -> Nat
Probe.runtimeSec r =
  d = Probe.Format.duration (Probe.Result.format r)
  if Float.lt d 0.0 then 0
  else
    asText = Float.toText d
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    Optional.getOrElse 0 (Nat.fromText intPart)

-- ====================================================================
-- Schema migration: add the actual_runtime_sec column without dropping
-- existing data. Safe to run repeatedly.
-- ====================================================================

Db.migrate : '{IO, Exception} ()
Db.migrate = do
  singleIO Db.config do
    _ = Db.runDDLList [Db.moviesDdl]
    _ = Db.runDDLList Db.childDdl
    _ = Db.runDDLList Db.indexDdl
    Db.runDDLList
      [ "ALTER TABLE movies ADD COLUMN IF NOT EXISTS actual_runtime_sec INTEGER"
      ]

-- ====================================================================
-- TMDB identification (Phase 1: report only, no writes)
--
-- Reads cached search responses produced by the tmdb-search bash script,
-- re-parses release names with a strict year-pivot algorithm, scores
-- candidates, and prints a report. No file or DB writes in this phase.
-- ====================================================================

Tmdb.cachePath : Text -> FilePath
Tmdb.cachePath folderName =
  use Text ++
  FilePath (Tmdb.cacheRoot ++ "/" ++ folderName ++ ".json")

Tmdb.writeCacheEntry
  : Text -> Either Text Tmdb.SearchResponse ->{IO} ()
Tmdb.writeCacheEntry folderName result =
  entry = match result with
    Right r -> Tmdb.CachedSearch.CachedSearch folderName (Some r) None
    Left e  -> Tmdb.CachedSearch.CachedSearch folderName None (Some e)
  payload = Json.toText (Tmdb.CachedSearch.toJson entry)
  _ = catch do writeFileUtf8 (Tmdb.cachePath folderName) payload
  ()

-- Read from cache; on miss, hit API and write the result (success or
-- error) to cache.
Tmdb.cachedSearch
  : Text -> Text -> Text -> Nat ->{IO} Either Text Tmdb.SearchResponse
Tmdb.cachedSearch token folderName title year =
  fromCache = catch do
    raw = readFileUtf8 (Tmdb.cachePath folderName)
    Decoder.run Tmdb.CachedSearch.fromJson raw
  match fromCache with
    Right c ->
      match Tmdb.CachedSearch.response c with
        Some r -> Right r
        None ->
          match Tmdb.CachedSearch.error c with
            Some e -> Left e
            None   -> Left "cached entry has neither response nor error"
    Left _ ->
      result = Tmdb.search token title year
      _ = Tmdb.writeCacheEntry folderName result
      result

type Tmdb.Result =
  { tmdbId : Nat,
    title : Text,
    originalTitle : Text,
    releaseDate : Text,
    popularity : Float,
    overview : Text }

type Tmdb.SearchResponse = { results : [Tmdb.Result] }

type Tmdb.CachedSearch =
  { folder : Text,
    response : Optional Tmdb.SearchResponse,
    error : Optional Text }

type Tmdb.ParsedRelease =
  { rawName : Text,
    title : Text,
    year : Nat }

type Tmdb.Confidence
  = High
  | Low Text


Tmdb.stagingDir : Text
Tmdb.stagingDir =
  "/home/bismuth/NAS/video/_Unsorted/torrents/Complete/renameQue/Movies"

Tmdb.cacheRoot : Text
Tmdb.cacheRoot = "/home/bismuth/.cache/uniDork/tmdb/search"


-- ============================================================
-- Year-pivot release-name parser
-- ============================================================

-- Tokens that appear immediately after the release year in release names.
-- Used to disambiguate the year-of-release from years in the title.
Tmdb.qualityTokens : [Text]
Tmdb.qualityTokens =
  [ "1080p", "720p", "2160p", "4k", "480p", "576p", "uhd"
  , "bluray", "blu-ray", "bdrip", "webrip", "web-dl", "webdl", "web"
  , "hdrip", "dvdrip", "hdtv", "remux", "cam", "ts", "telesync", "hdcam"
  , "x264", "x265", "hevc", "avc", "h264", "h265", "av1", "xvid"
  , "ddp", "ddp5", "dts", "ac3", "aac", "atmos", "truehd", "flac", "eac3"
  , "8bit", "10bit", "12bit"
  , "hdr", "hdr10", "hdr10+", "dv", "dolby"
  , "amzn", "nf", "hulu", "atvp", "max", "dsnp", "mtv", "pmtp", "ma"
  , "internal", "upscaled", "proper", "repack"
  , "unrated", "extended", "theatrical", "remastered", "anniversary"
  , "directors" ]

Tmdb.isQualityToken : Text -> Boolean
Tmdb.isQualityToken t =
  lower = Text.toLowercase t
  List.any (q -> Universal.eq q lower) Tmdb.qualityTokens

Tmdb.tokenAsYear : Text -> Optional Nat
Tmdb.tokenAsYear t =
  use Nat <= >=
  if Universal.eq (Text.size t) 4 then
    match Nat.fromText t with
      Some n -> if (n >= 1900) && (n <= 2030) then Some n else None
      None   -> None
  else None

Tmdb.tokenize : Text -> [Text]
Tmdb.tokenize name =
  s1 = Text.split ?. name
  s2 = List.flatMap (p -> Text.split ?_ p) s1
  s3 = List.flatMap (p -> Text.split ?\s p) s2
  List.filter (p -> Nat.gt (Text.size p) 0) s3

Tmdb.nth : Nat -> [a] -> Optional a
Tmdb.nth i xs = List.head (List.drop i xs)

-- Walk indexed tokens, pick the first year that is immediately followed
-- by a quality token. Strict mode: no quality follower → no year.
Tmdb.findYearIndex : [Text] -> Optional Nat
Tmdb.findYearIndex tokens =
  use Nat +
  pairs = Db.withIndex tokens
  qualifying =
    List.filterMap
      (cases
        (i, t) ->
          match Tmdb.tokenAsYear t with
            None   -> None
            Some _ ->
              match Tmdb.nth (i + 1) tokens with
                Some next ->
                  if Tmdb.isQualityToken next then Some i else None
                None -> None)
      pairs
  List.head qualifying

Tmdb.parseReleaseName : Text -> Optional Tmdb.ParsedRelease
Tmdb.parseReleaseName name =
  match Tmdb.findEnclosedYearAny name with
    Some (titlePrefix, year) ->
      cleaned = Tmdb.cleanTitle titlePrefix
      if Universal.eq (Text.size cleaned) 0 then None
      else Some (Tmdb.ParsedRelease.ParsedRelease name cleaned year)
    None ->
      tokens = Tmdb.tokenize name
      match Tmdb.findYearIndex tokens with
        None   -> None
        Some i ->
          match Tmdb.nth i tokens with
            None    -> None
            Some yt ->
              match Tmdb.tokenAsYear yt with
                None   -> None
                Some y ->
                  titleStr = trim (Text.join " " (List.take i tokens))
                  if Universal.eq (Text.size titleStr) 0 then None
                  else
                    Some
                      (Tmdb.ParsedRelease.ParsedRelease name titleStr y)


-- ============================================================
-- Title normalization for strict comparison
-- ============================================================

Tmdb.normalize : Text -> Text
Tmdb.normalize t =
  lower = Text.toLowercase t
  punct =
    [ ".", ",", ":", ";", "!", "?", "'", "\""
    , "(", ")", "[", "]", "{", "}", "-", "_", "&", "/" ]
  noPunct = List.foldLeft (acc p -> replaceAll p " " acc) lower punct
  parts = Text.split ?\s noPunct
  nonEmpty = List.filter (p -> Nat.gt (Text.size p) 0) parts
  joined = Text.join " " nonEmpty
  if startsWith "the " joined then Text.drop 4 joined
  else if startsWith "an " joined then Text.drop 3 joined
  else if startsWith "a " joined then Text.drop 2 joined
  else joined


-- ============================================================
-- Strict scorer
-- ============================================================

Tmdb.releaseYear : Text -> Optional Nat
Tmdb.releaseYear dateStr =
  if Nat.lt (Text.size dateStr) 4 then None
  else Tmdb.tokenAsYear (Text.take 4 dateStr)

Tmdb.scoreCandidate
  : Tmdb.ParsedRelease -> Tmdb.Result -> Tmdb.Confidence
Tmdb.scoreCandidate p r =
  q = Tmdb.normalize (Tmdb.ParsedRelease.title p)
  t = Tmdb.normalize (Tmdb.Result.title r)
  o = Tmdb.normalize (Tmdb.Result.originalTitle r)
  titleOk = Universal.eq q t || Universal.eq q o
  yearOk = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    Some y -> Universal.eq y (Tmdb.ParsedRelease.year p)
    None   -> false
  if titleOk && yearOk then Tmdb.Confidence.High
  else if titleOk then Tmdb.Confidence.Low "year mismatch"
  else if yearOk then Tmdb.Confidence.Low "title mismatch"
  else Tmdb.Confidence.Low "title and year mismatch"

-- Pick a single HIGH match if exactly one. More than one HIGH = ambiguous;
-- in strict mode we refuse to pick.
Tmdb.pickBest
  : [(Tmdb.Result, Tmdb.Confidence)]
  -> Optional (Tmdb.Result, Tmdb.Confidence)
Tmdb.pickBest scored =
  isHigh = cases
    (_, Tmdb.Confidence.High) -> true
    _                         -> false
  highs = List.filter isHigh scored
  match highs with
    []        -> None
    [single]  -> Some single
    _         -> None


-- ============================================================
-- Cache reader
-- ============================================================

Tmdb.Result.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.Result
Tmdb.Result.fromJson = do
  use Decoder optional!
  use object at at!
  tmdbId = at! "id" Decoder.nat
  title = at! "title" Decoder.text
  originalTitle = at! "original_title" Decoder.text
  releaseDate = Optional.getOrElse "" (optional! (at "release_date" Decoder.text))
  popularity = at! "popularity" Decoder.float
  overview = Optional.getOrElse "" (optional! (at "overview" Decoder.text))
  Tmdb.Result.Result tmdbId title originalTitle releaseDate popularity overview

Tmdb.SearchResponse.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.SearchResponse
Tmdb.SearchResponse.fromJson = do
  results = object.at! "results" (Decoder.array Tmdb.Result.fromJson)
  Tmdb.SearchResponse.SearchResponse results

Tmdb.CachedSearch.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.CachedSearch
Tmdb.CachedSearch.fromJson = do
  use Decoder optional!
  use object at at!
  folder = at! "folder" Decoder.text
  response = optional! (at "response" Tmdb.SearchResponse.fromJson)
  error = optional! (at "error" Decoder.text)
  Tmdb.CachedSearch.CachedSearch folder response error

Tmdb.readCache : Text ->{IO, Exception} Optional Tmdb.CachedSearch
Tmdb.readCache folderName =
  use Text ++
  jsonPath = FilePath (Tmdb.cacheRoot ++ "/" ++ folderName ++ ".json")
  match catch do
    raw = readFileUtf8 jsonPath
    Decoder.run Tmdb.CachedSearch.fromJson raw
  with
    Left _  -> None
    Right s -> Some s

-- ============================================================
-- Report (Phase 1 entry point)
-- ============================================================

Tmdb.printCandidate : (Tmdb.Result, Tmdb.Confidence) ->{IO, Exception} ()
Tmdb.printCandidate = cases
  (r, c) ->
    use Text join
    flag = match c with
      Tmdb.Confidence.High  -> "[HIGH ]"
      Tmdb.Confidence.Low _ -> "[low  ]"
    yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
      Some y -> Nat.toText y
      None   -> "????"
    reason = match c with
      Tmdb.Confidence.Low r -> Text.join "" [" (", r, ")"]
      Tmdb.Confidence.High  -> ""
    printLine
      (join ""
        [ "    ", flag, " tmdb:"
        , Nat.toText (Tmdb.Result.tmdbId r)
        , " \""
        , Tmdb.Result.title r
        , "\" ("
        , yearText
        , ") pop="
        , Float.toText (Tmdb.Result.popularity r)
        , reason ])

Tmdb.reportFolder : Text -> Text ->{IO, Exception} ()
Tmdb.reportFolder token folderName =
  use Text join
  parsed = Tmdb.parseReleaseName folderName
  _ = printLine (join "" ["FOLDER: ", folderName])
  match parsed with
    None ->
      _ = printLine "  parsed:  FAILED (no year followed by quality token)"
      _ = printLine "  verdict: SKIP"
      printLine ""
    Some p ->
      _ =
        printLine
          (join ""
            [ "  parsed:  title=\""
            , Tmdb.ParsedRelease.title p
            , "\", year="
            , Nat.toText (Tmdb.ParsedRelease.year p) ])
      result =
        Tmdb.cachedSearch
          token
          folderName
          (Tmdb.ParsedRelease.title p)
          (Tmdb.ParsedRelease.year p)
      match result with
        Left err ->
          _ = printLine (join "" ["  error:   ", err])
          _ = printLine "  verdict: SKIP"
          printLine ""
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored =
            List.map (r -> (r, Tmdb.scoreCandidate p r)) candidates
          _ =
            printLine
              (join ""
                [ "  candidates: "
                , Nat.toText (List.size candidates) ])
          _ = Db.foreach_ Tmdb.printCandidate scored
          _ =
            match Tmdb.pickBest scored with
              Some (r, _) ->
                printLine
                  (join ""
                    [ "  verdict: HIGH -> tmdb:"
                    , Nat.toText (Tmdb.Result.tmdbId r)
                    , " \""
                    , Tmdb.Result.title r
                    , "\"" ])
              None ->
                printLine
                  "  verdict: SKIP (no single high-confidence match)"
          printLine ""

-- Title cleanup: replace dots/underscores with spaces, collapse, trim.
-- Used after extracting a title prefix from a folder name.
Tmdb.cleanTitle : Text -> Text
Tmdb.cleanTitle t =
  s1 = replaceAll "." " " t
  s2 = replaceAll "_" " " s1
  parts = Text.split ?\s s2
  nonEmpty = List.filter (p -> Nat.gt (Text.size p) 0) parts
  trim (Text.join " " nonEmpty)

-- Look for an "(YYYY)" or "[YYYY]" pattern. Returns the title prefix
-- (everything before the opening bracket) and the year. The bracket
-- characters are passed as Text so we can reuse the function for both
-- paren and square-bracket forms.
Tmdb.findEnclosedYear : Text -> Text -> Text -> Optional (Text, Nat)
Tmdb.findEnclosedYear open close name =
  use Nat +
  go offset =
    sub = Text.drop offset name
    match Text.indexOf open sub with
      None -> None
      Some openIdx ->
        absOpen = offset + openIdx
        afterOpen = absOpen + Text.size open
        cand = Text.take 4 (Text.drop afterOpen name)
        closeAt = afterOpen + 4
        match Tmdb.tokenAsYear cand with
          Some y ->
            actualClose = Text.take (Text.size close) (Text.drop closeAt name)
            if Universal.eq actualClose close then
              Some (trim (Text.take absOpen name), y)
            else
              go (absOpen + 1)
          None -> go (absOpen + 1)
  go 0

-- Try parens first, then square brackets.
Tmdb.findEnclosedYearAny : Text -> Optional (Text, Nat)
Tmdb.findEnclosedYearAny name =
  match Tmdb.findEnclosedYear "(" ")" name with
    Some r -> Some r
    None   -> Tmdb.findEnclosedYear "[" "]" name

-- ============================================================
-- HTTP integration: read token, query TMDB, cache responses.
-- ============================================================

Tmdb.tokenPath : Text
Tmdb.tokenPath = "/home/bismuth/.config/uniDork/tmdb-token"

Tmdb.readToken : '{IO, Exception} Text
Tmdb.readToken = do trim (readFileUtf8 (FilePath Tmdb.tokenPath))

Tmdb.apiAuthority : Authority
Tmdb.apiAuthority =
  Authority None (HostName "api.themoviedb.org") None

Tmdb.searchURI : Text -> Nat -> URI
Tmdb.searchURI title year =
  use Path /
  path = Path.root / "3" / "search" / "movie"
  q =
    Query.empty
      & ("query", title)
      & ("year", Nat.toText year)
  URI Scheme.https (Some Tmdb.apiAuthority) path (fromQuery q) Fragment.empty

Tmdb.searchRequest : Text -> Text -> Nat -> HttpRequest
Tmdb.searchRequest token title year =
  use Text ++
  HttpRequest.get (Tmdb.searchURI title year)
    |> HttpRequest.addHeader "Authorization" ("Bearer " ++ token)
    |> HttpRequest.addHeader "Accept" "application/json"

-- Hit TMDB. Returns Left with a message on any failure (network, HTTP
-- non-2xx, malformed JSON).
Tmdb.search
  : Text -> Text -> Nat ->{IO} Either Text Tmdb.SearchResponse
Tmdb.search token title year =
  req = Tmdb.searchRequest token title year
  match catch do
    Threads.run do
      Http.run do
        resp = Http.request req
        ok = HttpResponse.ensureSuccess resp
        body = HttpResponse.bodyText ok
        Decoder.run Tmdb.SearchResponse.fromJson body
  with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

-- ====================================================================
-- Stage probe sidecar: CRC32 + selected ffprobe data, one JSON per
-- staging folder. Written by the unidork-stage-probe shell script.
-- ====================================================================

type Stage.VideoInfo
  = { codec : Text,
      width : Nat,
      height : Nat,
      bitDepth : Nat,
      pixFmt : Text,
      bitRate : Optional Nat }

type Stage.AudioInfo
  = { codec : Text, channels : Nat, channelLayout : Text }

type Stage.ProbeResult
  = { videoPath : Text,
      crc32 : Text,
      sizeBytes : Nat,
      durationSec : Float,
      video : Stage.VideoInfo,
      audio : Optional Stage.AudioInfo }

Stage.VideoInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.VideoInfo
Stage.VideoInfo.fromJson = do
  use Decoder optional!
  use object at at!
  codec = at! "codec" Decoder.text
  width = at! "width" Decoder.nat
  height = at! "height" Decoder.nat
  bitDepth = at! "bit_depth" Decoder.nat
  pixFmt = at! "pix_fmt" Decoder.text
  bitRate = optional! (at "bit_rate" Decoder.nat)
  Stage.VideoInfo.VideoInfo codec width height bitDepth pixFmt bitRate

Stage.AudioInfo.fromJson : '{unison_json_1_4_2.Decoder} Stage.AudioInfo
Stage.AudioInfo.fromJson = do
  use object at!
  codec = at! "codec" Decoder.text
  channels = at! "channels" Decoder.nat
  channelLayout = at! "channel_layout" Decoder.text
  Stage.AudioInfo.AudioInfo codec channels channelLayout

Stage.ProbeResult.fromJson : '{unison_json_1_4_2.Decoder} Stage.ProbeResult
Stage.ProbeResult.fromJson = do
  use Decoder optional!
  use object at at!
  videoPath = at! "video_path" Decoder.text
  crc32 = at! "crc32" Decoder.text
  sizeBytes = at! "size_bytes" Decoder.nat
  durationSec = at! "duration_sec" Decoder.float
  video = at! "video" Stage.VideoInfo.fromJson
  audio = optional! (at "audio" Stage.AudioInfo.fromJson)
  Stage.ProbeResult.ProbeResult
    videoPath crc32 sizeBytes durationSec video audio

Stage.cacheRoot : Text
Stage.cacheRoot = "/home/bismuth/.cache/uniDork/stage"

Stage.sidecarPath : Text -> FilePath
Stage.sidecarPath folderName =
  use Text ++
  FilePath (Stage.cacheRoot ++ "/" ++ folderName ++ ".json")

Stage.readSidecar
  : Text ->{IO, Exception} Optional Stage.ProbeResult
Stage.readSidecar folderName =
  match catch do
    raw = readFileUtf8 (Stage.sidecarPath folderName)
    Decoder.run Stage.ProbeResult.fromJson raw
  with
    Left _  -> None
    Right r -> Some r


-- ====================================================================
-- Rename: build canonical folder + filename matching filebot's amc
-- format, move the video, write an NFO, log per-folder outcome.
-- Conservative: any uncertainty produces a skip outcome, no move.
-- ====================================================================

Rename.targetRoot : Text
Rename.targetRoot =
  "/home/bismuth/NAS/video/_Unsorted/torrents/Complete/AMC/testMovies"

Rename.logDir : Text
Rename.logDir = "/home/bismuth/.cache/uniDork/rename-log"


-- ============================================================
-- Format helpers (Nat-only arithmetic, no Float formatting).
-- Filebot tokens:
--   {ny}=Title (YYYY), {gigabytes}=8.5, {vf}=1080p,
--   {vc}=x264|x265|..., {bitdepth}=8|10|12, {minutes}=int,
--   {crc32}=8-hex-upper, {resolution}=WxH, {mbps}=12.5,
--   {ac}=AC3|AAC|..., {channels}=5.1|7.1|2.0|...
-- ============================================================

-- Bytes -> "X.Y" gigabytes, 1 decimal, integer-only.
Rename.gigabytes : Nat -> Text
Rename.gigabytes bytes =
  use Text ++
  use Nat *
  use Nat /
  tenths = bytes * 10 / 1073741824
  whole = tenths / 10
  frac = Nat.mod tenths 10
  Nat.toText whole ++ "." ++ Nat.toText frac

-- Truncate Float seconds to Nat minutes.
Rename.minutes : Float -> Nat
Rename.minutes durationSec =
  use Nat /
  if Float.lt durationSec 0.0 then 0
  else
    asText = Float.toText durationSec
    intPart = match Text.indexOf "." asText with
      Some i -> Text.take i asText
      None   -> asText
    sec = Optional.getOrElse 0 (Nat.fromText intPart)
    sec / 60

-- Vertical-resolution tag from height.
Rename.vfTag : Nat -> Text
Rename.vfTag height =
  if Universal.eq height 2160 then "2160p"
  else if Universal.eq height 1440 then "1440p"
  else if Universal.eq height 1080 then "1080p"
  else if Universal.eq height 720 then "720p"
  else if Universal.eq height 576 then "576p"
  else if Universal.eq height 480 then "480p"
  else "SD"

-- Video codec mapping to filebot's lowercase short names.
Rename.vcTag : Text -> Text
Rename.vcTag raw =
  lower = Text.toLowercase raw
  if Universal.eq lower "hevc" then "x265"
  else if Universal.eq lower "h265" then "x265"
  else if Universal.eq lower "h264" then "x264"
  else if Universal.eq lower "avc" then "x264"
  else if Universal.eq lower "av1" then "av1"
  else if Universal.eq lower "vp9" then "vp9"
  else if Universal.eq lower "mpeg4" then "xvid"
  else lower

Rename.resolutionStr : Nat -> Nat -> Text
Rename.resolutionStr w h =
  use Text ++
  Nat.toText w ++ "x" ++ Nat.toText h

-- bit_rate (bits/sec) -> "X.Y" Mbps. None -> "0.0".
Rename.mbps : Optional Nat -> Text
Rename.mbps = cases
  None -> "0.0"
  Some br ->
    use Text ++
    use Nat /
    tenths = br / 100000
    whole = tenths / 10
    frac = Nat.mod tenths 10
    Nat.toText whole ++ "." ++ Nat.toText frac

-- Audio channel count -> layout label.
Rename.channelsTag : Nat -> Text
Rename.channelsTag ch =
  if Universal.eq ch 1 then "1.0"
  else if Universal.eq ch 2 then "2.0"
  else if Universal.eq ch 6 then "5.1"
  else if Universal.eq ch 8 then "7.1"
  else Nat.toText ch

Rename.acTag : Text -> Text
Rename.acTag raw =
  upper = Text.toUppercase raw
  if Universal.eq upper "AC3" then "AC3"
  else if Universal.eq upper "EAC3" then "EAC3"
  else if Universal.eq upper "AAC" then "AAC"
  else if Universal.eq upper "DTS" then "DTS"
  else if Universal.eq upper "TRUEHD" then "TrueHD"
  else if Universal.eq upper "FLAC" then "FLAC"
  else if Universal.eq upper "OPUS" then "Opus"
  else if Universal.eq upper "MP3" then "MP3"
  else upper

Rename.titleYear : Tmdb.Result -> Text
Rename.titleYear r =
  use Text ++
  yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate r) with
    Some y -> Nat.toText y
    None   -> "0000"
  Tmdb.Result.title r ++ " (" ++ yearText ++ ")"

Rename.fileExt : Text -> Text
Rename.fileExt path =
  lower = Text.toLowercase path
  if endsWith ".mkv" lower then ".mkv"
  else if endsWith ".mp4" lower then ".mp4"
  else if endsWith ".avi" lower then ".avi"
  else if endsWith ".mov" lower then ".mov"
  else if endsWith ".wmv" lower then ".wmv"
  else if endsWith ".flv" lower then ".flv"
  else ""

-- {ny} [{gigabytes}.{vf}.{vc}.{bitdepth}b.{minutes}min] ~{crc32}
Rename.folderName : Tmdb.Result -> Stage.ProbeResult -> Text
Rename.folderName tr pr =
  use Text ++
  vid = Stage.ProbeResult.video pr
  ny = Rename.titleYear tr
  parts =
    Rename.gigabytes (Stage.ProbeResult.sizeBytes pr)
      ++ "."
      ++ Rename.vfTag (Stage.VideoInfo.height vid)
      ++ "."
      ++ Rename.vcTag (Stage.VideoInfo.codec vid)
      ++ "."
      ++ Nat.toText (Stage.VideoInfo.bitDepth vid)
      ++ "b."
      ++ Nat.toText (Rename.minutes (Stage.ProbeResult.durationSec pr))
      ++ "min"
  ny ++ " [" ++ parts ++ "] ~" ++ Stage.ProbeResult.crc32 pr

-- {ny} [{vc}_{bitdepth}b_{resolution}_{mbps}_{ac}-{channels}] ~{crc32}
-- (tags and group dropped pending dedicated parsers.)
Rename.fileBaseName : Tmdb.Result -> Stage.ProbeResult -> Text
Rename.fileBaseName tr pr =
  use Text ++
  vid = Stage.ProbeResult.video pr
  ny = Rename.titleYear tr
  audioPart = match Stage.ProbeResult.audio pr with
    None -> "noaudio-0"
    Some a ->
      Rename.acTag (Stage.AudioInfo.codec a)
        ++ "-"
        ++ Rename.channelsTag (Stage.AudioInfo.channels a)
  bracketed =
    Rename.vcTag (Stage.VideoInfo.codec vid)
      ++ "_"
      ++ Nat.toText (Stage.VideoInfo.bitDepth vid)
      ++ "b_"
      ++ Rename.resolutionStr
          (Stage.VideoInfo.width vid)
          (Stage.VideoInfo.height vid)
      ++ "_"
      ++ Rename.mbps (Stage.VideoInfo.bitRate vid)
      ++ "_"
      ++ audioPart
  ny ++ " [" ++ bracketed ++ "] ~" ++ Stage.ProbeResult.crc32 pr


-- ============================================================
-- NFO builder (Kodi-compatible minimal).
-- ============================================================

Rename.escapeXml : Text -> Text
Rename.escapeXml t =
  t
    |> replaceAll "&" "&amp;"
    |> replaceAll "<" "&lt;"
    |> replaceAll ">" "&gt;"

Rename.buildNfo : Tmdb.Result -> Stage.ProbeResult -> Text
Rename.buildNfo tr pr =
  use Text ++
  esc = Rename.escapeXml
  yearText = match Tmdb.releaseYear (Tmdb.Result.releaseDate tr) with
    Some y -> Nat.toText y
    None   -> ""
  vid = Stage.ProbeResult.video pr
  audioLines = match Stage.ProbeResult.audio pr with
    None -> []
    Some a ->
      [ "      <audio>"
      , "        <codec>" ++ esc (Stage.AudioInfo.codec a) ++ "</codec>"
      , "        <channels>"
          ++ Nat.toText (Stage.AudioInfo.channels a)
          ++ "</channels>"
      , "      </audio>" ]
  baseLines =
    [ "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>"
    , "<movie>"
    , "  <title>" ++ esc (Tmdb.Result.title tr) ++ "</title>"
    , "  <originaltitle>"
        ++ esc (Tmdb.Result.originalTitle tr)
        ++ "</originaltitle>"
    , "  <year>" ++ yearText ++ "</year>"
    , "  <plot>" ++ esc (Tmdb.Result.overview tr) ++ "</plot>"
    , "  <uniqueid type=\"tmdb\" default=\"true\">"
        ++ Nat.toText (Tmdb.Result.tmdbId tr)
        ++ "</uniqueid>"
    , "  <fileinfo>"
    , "    <streamdetails>"
    , "      <video>"
    , "        <codec>" ++ esc (Stage.VideoInfo.codec vid) ++ "</codec>"
    , "        <width>"
        ++ Nat.toText (Stage.VideoInfo.width vid)
        ++ "</width>"
    , "        <height>"
        ++ Nat.toText (Stage.VideoInfo.height vid)
        ++ "</height>"
    , "      </video>" ]
  tailLines =
    [ "    </streamdetails>"
    , "  </fileinfo>"
    , "</movie>"
    , "" ]
  Text.join "\n" (baseLines List.++ audioLines List.++ tailLines)


-- ============================================================
-- Outcome type + per-folder log file.
-- ============================================================

type Rename.Outcome
  = Renamed Text Text
  | NoVideo Text
  | NoMatch Text Text
  | NoProbe Text
  | Conflict Text Text
  | RenameError Text Text

Rename.Outcome.toJson : Rename.Outcome -> Json
Rename.Outcome.toJson = cases
  Rename.Outcome.Renamed src tgt ->
    Json.object
      [ ("outcome", Json.text "renamed")
      , ("source", Json.text src)
      , ("target", Json.text tgt) ]
  Rename.Outcome.NoVideo src ->
    Json.object
      [ ("outcome", Json.text "no_video")
      , ("source", Json.text src) ]
  Rename.Outcome.NoMatch src reason ->
    Json.object
      [ ("outcome", Json.text "no_match")
      , ("source", Json.text src)
      , ("reason", Json.text reason) ]
  Rename.Outcome.NoProbe src ->
    Json.object
      [ ("outcome", Json.text "no_probe")
      , ("source", Json.text src) ]
  Rename.Outcome.Conflict src existing ->
    Json.object
      [ ("outcome", Json.text "conflict")
      , ("source", Json.text src)
      , ("existing", Json.text existing) ]
  Rename.Outcome.RenameError src msg ->
    Json.object
      [ ("outcome", Json.text "error")
      , ("source", Json.text src)
      , ("message", Json.text msg) ]

Rename.writeOutcome
  : Text -> Rename.Outcome ->{IO, Exception} ()
Rename.writeOutcome folderName o =
  use Text ++
  path = FilePath (Rename.logDir ++ "/" ++ folderName ++ ".json")
  writeFileUtf8 path (Json.toText (Rename.Outcome.toJson o))


-- ============================================================
-- Driver. One folder -> one outcome -> one log file.
-- Source folder is left as-is (becomes a stub after the video moves);
-- the absence of a video on a future run is the "already done" signal.
-- ============================================================

Rename.executeMove
  : FilePath
  -> Tmdb.Result
  -> Stage.ProbeResult
  ->{IO, Exception} Rename.Outcome
Rename.executeMove sourceFolder tr pr =
  use Text ++
  sourceText = filePathText sourceFolder
  sourceVideo = FilePath (Stage.ProbeResult.videoPath pr)
  videoExt = Rename.fileExt (Stage.ProbeResult.videoPath pr)
  base = Rename.fileBaseName tr pr
  targetFolderText = Rename.targetRoot ++ "/" ++ Rename.folderName tr pr
  targetFolder = FilePath targetFolderText
  targetVideo = pathJoin targetFolder (base ++ videoExt)
  targetNfo = pathJoin targetFolder (base ++ ".nfo")
  if isDirectory targetFolder then
    Rename.Outcome.Conflict sourceText targetFolderText
  else
    match catch do
      _ = createDirectory targetFolder
      _ = writeFileUtf8 targetNfo (Rename.buildNfo tr pr)
      renameFile sourceVideo targetVideo
    with
      Right _ -> Rename.Outcome.Renamed sourceText targetFolderText
      Left f  ->
        Rename.Outcome.RenameError sourceText (Failure.message f)

Rename.processFolder
  : Text -> FilePath ->{IO, Exception} Rename.Outcome
Rename.processFolder token folder =
  folderName = filePathBasename folder
  folderText = filePathText folder
  files = directoryContents.texts folder
  match findFirstVideo files with
    None -> Rename.Outcome.NoVideo folderText
    Some _ ->
      match Tmdb.parseReleaseName folderName with
        None ->
          Rename.Outcome.NoMatch
            folderText "parse failed (no year + quality token)"
        Some p ->
          searchResult =
            Tmdb.cachedSearch
              token
              folderName
              (Tmdb.ParsedRelease.title p)
              (Tmdb.ParsedRelease.year p)
          match searchResult with
            Left err ->
              Rename.Outcome.NoMatch
                folderText (Text.join "" ["search: ", err])
            Right resp ->
              candidates = Tmdb.SearchResponse.results resp
              scored =
                List.map
                  (r -> (r, Tmdb.scoreCandidate p r)) candidates
              match Tmdb.pickBest scored with
                None ->
                  Rename.Outcome.NoMatch
                    folderText "no single high-confidence match"
                Some (r, _) ->
                  match Stage.readSidecar folderName with
                    None    -> Rename.Outcome.NoProbe folderText
                    Some pr -> Rename.executeMove folder r pr

Rename.runOne : Text -> FilePath ->{IO, Exception} ()
Rename.runOne token folder =
  use Text ++
  folderName = filePathBasename folder
  _ = printLine ("processing: " ++ folderName)
  outcome = Rename.processFolder token folder
  _ = match outcome with
    Rename.Outcome.Renamed _ tgt ->
      printLine ("  RENAMED -> " ++ tgt)
    Rename.Outcome.NoVideo _ ->
      printLine "  skip: no video (already renamed?)"
    Rename.Outcome.NoMatch _ reason ->
      printLine ("  skip: " ++ reason)
    Rename.Outcome.NoProbe _ ->
      printLine "  skip: no probe sidecar (run unidork-stage-probe)"
    Rename.Outcome.Conflict _ t ->
      printLine ("  skip: target exists " ++ t)
    Rename.Outcome.RenameError _ msg ->
      printLine ("  ERROR: " ++ msg)
  Rename.writeOutcome folderName outcome

