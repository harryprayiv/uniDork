Rename.shrink : Text -> Text -> Text -> Text
Rename.shrink needle replacement t =
  t
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement
    |> replaceAll needle replacement

Rename.subLanguages : [Text]
Rename.subLanguages = ["en", "es", "th"]

Rename.targetHasCrc : FilePath -> Text ->{IO, Exception} Boolean
Rename.targetHasCrc targetFolder crc =
  use Text ++
  if isDirectory targetFolder then
    entries = directoryContents.texts targetFolder
    needle = "~" ++ crc
    List.any
      (n -> (match Text.indexOf needle (Text.toUppercase n) with
        Some _ -> true
        None   -> false)) entries
  else false

Rename.targetRoot : Text
Rename.targetRoot =
