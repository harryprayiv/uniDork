-- ============================================================
-- Tests for format helpers.
-- ============================================================

test> Rename.gigabytes.test =
  List.flatMap check
    [ Universal.eq (Rename.gigabytes 1073741824) "1.0"
    , Universal.eq (Rename.gigabytes 8589934592) "8.0"
    , Universal.eq (Rename.gigabytes 5368709120) "5.0"
    , Universal.eq (Rename.gigabytes 0) "0.0" ]

test> Rename.vfTag.test =
  List.flatMap check
    [ Universal.eq (Rename.vfTag 2160) "2160p"
    , Universal.eq (Rename.vfTag 1080) "1080p"
    , Universal.eq (Rename.vfTag 720) "720p"
    , Universal.eq (Rename.vfTag 999) "SD" ]

test> Rename.vcTag.test =
  List.flatMap check
    [ Universal.eq (Rename.vcTag "hevc") "x265"
    , Universal.eq (Rename.vcTag "HEVC") "x265"
    , Universal.eq (Rename.vcTag "h264") "x264"
    , Universal.eq (Rename.vcTag "av1") "av1" ]

test> Rename.mbps.test =
  List.flatMap check
    [ Universal.eq (Rename.mbps None) "0.0"
    , Universal.eq (Rename.mbps (Some 12500000)) "12.5"
    , Universal.eq (Rename.mbps (Some 1500000)) "1.5" ]

test> Rename.channelsTag.test =
  List.flatMap check
    [ Universal.eq (Rename.channelsTag 2) "2.0"
    , Universal.eq (Rename.channelsTag 6) "5.1"
    , Universal.eq (Rename.channelsTag 8) "7.1"
    , Universal.eq (Rename.channelsTag 3) "3" ]

-- ====================================================================
-- Loose-video support: handle videos sitting at the top of staging,
-- not inside a folder. Sidecar key is the file's basename without
-- extension (matches what unidork-stage-probe writes).
-- ====================================================================

Rename.basenameNoExt : Text -> Text
Rename.basenameNoExt filename =
  parts = Text.split ?. filename
  match List.reverse parts with
    _ +: []   -> filename
    _ +: rest -> Text.join "." (List.reverse rest)
    []        -> filename

Rename.looseVideos : FilePath ->{IO, Exception} [FilePath]
Rename.looseVideos dir =
  entries = directoryContents.texts dir
  videoNames = List.filter isVideo entries
  step acc n =
    fp = pathJoin dir n
    if isDirectory fp then acc else List.snoc acc fp
  List.foldLeft step [] videoNames

Rename.processLooseVideo
  : Text -> FilePath ->{IO, Exception} Rename.Outcome
Rename.processLooseVideo token videoFile =
  filename = filePathBasename videoFile
  name = Rename.basenameNoExt filename
  sourceText = filePathText videoFile
  match Tmdb.parseReleaseName name with
    None ->
      Rename.Outcome.NoMatch
        sourceText "parse failed (no year + quality token)"
    Some p ->
      searchResult =
        Tmdb.cachedSearch
          token
          name
          (Tmdb.ParsedRelease.title p)
          (Tmdb.ParsedRelease.year p)
      match searchResult with
        Left err ->
          Rename.Outcome.NoMatch
            sourceText (Text.join "" ["search: ", err])
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored =
            List.map
              (r -> (r, Tmdb.scoreCandidate p r)) candidates
          match Tmdb.pickBest scored with
            None ->
              Rename.Outcome.NoMatch
                sourceText "no single high-confidence match"
            Some (r, _) ->
              match Stage.readSidecar name with
                None    -> Rename.Outcome.NoProbe sourceText
                Some pr -> Rename.executeMove videoFile r pr

Rename.runOneLoose : Text -> FilePath ->{IO, Exception} ()
Rename.runOneLoose token videoFile =
  use Text ++
  filename = filePathBasename videoFile
  name = Rename.basenameNoExt filename
  _ = printLine ("processing (loose): " ++ filename)
  outcome = Rename.processLooseVideo token videoFile
  _ = match outcome with
    Rename.Outcome.Renamed _ tgt ->
      printLine ("  RENAMED -> " ++ tgt)
    Rename.Outcome.NoVideo _ ->
      printLine "  skip: no video"
    Rename.Outcome.NoMatch _ reason ->
      printLine ("  skip: " ++ reason)
    Rename.Outcome.NoProbe _ ->
      printLine "  skip: no probe sidecar (run unidork-stage-probe)"
    Rename.Outcome.Conflict _ t ->
      printLine ("  skip: target exists " ++ t)
    Rename.Outcome.RenameError _ msg ->
      printLine ("  ERROR: " ++ msg)
  Rename.writeOutcome name outcome


-- Replaces the previous uniDork.rename. Processes folders, then loose
-- top-level videos. The probe sidecar is keyed identically on both
-- sides, so cache hits work for both shapes.
uniDork.rename : '{IO, Exception} ()
uniDork.rename = do
  use Text ++
  staging = FilePath Tmdb.stagingDir
  if isDirectory staging then
    token = Tmdb.readToken()
    entries = directoryContents.texts staging
    folderNames =
      List.filter
        (n ->
          if Universal.eq n "." then false
          else if Universal.eq n ".." then false
          else isDirectory (pathJoin staging n))
        entries
    folders = List.map (n -> pathJoin staging n) folderNames
    loose = Rename.looseVideos staging
    _ =
      printLine
        ("scanning " ++ Nat.toText (List.size folders)
          ++ " folder(s) and " ++ Nat.toText (List.size loose)
          ++ " loose video(s) under " ++ Tmdb.stagingDir)
    _ = printLine ""
    _ = Db.foreach_ (Rename.runOne token) folders
    Db.foreach_ (Rename.runOneLoose token) loose
  else
    printLine ("staging not found: " ++ Tmdb.stagingDir)


uniDork.identify : '{IO, Exception} ()
uniDork.identify = do
  use Text join
  staging = FilePath Tmdb.stagingDir
  if isDirectory staging then
    token = Tmdb.readToken()
    entries = directoryContents.texts staging
    folderNames =
      List.filter
        (n ->
          if Universal.eq n "." then false
          else if Universal.eq n ".." then false
          else isDirectory (pathJoin staging n))
        entries
    _ =
      printLine
        (join ""
          [ "scanning "
          , Nat.toText (List.size folderNames)
          , " folder(s) under "
          , Tmdb.stagingDir ])
    _ = printLine ""
    Db.foreach_ (Tmdb.reportFolder token) folderNames
  else
    printLine (join "" ["staging not found: ", Tmdb.stagingDir])

-- ====================================================================
-- Batched import pipeline. Entry point: uniDork.batchedRun
-- ====================================================================

uniDork.batchSize : Nat
uniDork.batchSize = 50

List.chunk : Nat -> [a] -> [[a]]
List.chunk n xs =
  use List +: size
  use Nat <=
  if Universal.eq (size xs) 0 then []
  else
    if size xs <= n then [xs]
    else List.take n xs +: List.chunk n (List.drop n xs)

uniDork.collectFolders : [FilePath] ->{IO, Exception} [FilePath]
uniDork.collectFolders roots =
  addIfDir : FilePath -> [FilePath] -> Text ->{IO, Exception} [FilePath]
  addIfDir root acc name =
    use List +:
    fp = pathJoin root name
    if isDirectory fp then fp +: acc else acc
  perRoot root =
    basenames = directoryContents.texts root
    _ =
      printLine
        (Text.join
          ""
          [ "scanning: "
          , filePathText root
          , " ("
          , Nat.toText (List.size basenames)
          , " entries)"
          ])
    List.reverse (List.foldLeft (addIfDir root) [] basenames)
  List.flatMap perRoot roots

uniDork.processOne
  pcUpsert pcVid pcDVid pcAud pcDAud pcSub pcDSub
  pcAct pcDAct pcGen pcDGen pcTag pcDTag pcCou pcDCou
  pcStu pcDStu pcDir pcDDir pcCre pcDCre folder =
  match Nfo.processFolder folder with
    Left _ ->
      _ = printLine (Text.join "" ["  no nfo: ", filePathText folder])
      ()
    Right m ->
      actualRuntime = match Movie.videoFilePath m with
        None         -> None
        Some vidPath ->
          match Probe.readSidecar vidPath with
            None   -> None
            Some r -> Some (Probe.runtimeSec r)
      Db.upsertWith
        pcUpsert pcVid pcDVid pcAud pcDAud pcSub pcDSub
        pcAct pcDAct pcGen pcDGen pcTag pcDTag pcCou pcDCou
        pcStu pcDStu pcDir pcDDir pcCre pcDCre actualRuntime m

uniDork.processBatch : [FilePath] ->{IO, Exception} ()
uniDork.processBatch folders =
  singleIO Db.config do
    use PreparedCommand close
    pcUpsert = prepareCommand Db.upsertMovieSql
    pcVid = prepareCommand Db.insertVideoSql
    pcDVid = prepareCommand (Db.deleteChildSql "movie_video_streams")
    pcAud = prepareCommand Db.insertAudioSql
    pcDAud = prepareCommand (Db.deleteChildSql "movie_audio_tracks")
    pcSub = prepareCommand Db.insertSubSql
    pcDSub = prepareCommand (Db.deleteChildSql "movie_subtitles")
    pcAct = prepareCommand Db.insertActorSql
    pcDAct = prepareCommand (Db.deleteChildSql "movie_actors")
    pcGen = prepareCommand Db.insertGenreSql
    pcDGen = prepareCommand (Db.deleteChildSql "movie_genres")
    pcTag = prepareCommand Db.insertTagSql
    pcDTag = prepareCommand (Db.deleteChildSql "movie_tags")
    pcCou = prepareCommand Db.insertCountrySql
    pcDCou = prepareCommand (Db.deleteChildSql "movie_countries")
    pcStu = prepareCommand Db.insertStudioSql
    pcDStu = prepareCommand (Db.deleteChildSql "movie_studios")
    pcDir = prepareCommand Db.insertDirectorSql
    pcDDir = prepareCommand (Db.deleteChildSql "movie_directors")
    pcCre = prepareCommand Db.insertCreditSql
    pcDCre = prepareCommand (Db.deleteChildSql "movie_credits")
    _ =
      Db.foreach_
        (uniDork.processOne
          pcUpsert pcVid pcDVid pcAud pcDAud pcSub pcDSub
          pcAct pcDAct pcGen pcDGen pcTag pcDTag pcCou pcDCou
          pcStu pcDStu pcDir pcDDir pcCre pcDCre)
        folders
    _ = close pcUpsert
    _ = close pcVid
    _ = close pcDVid
    _ = close pcAud
    _ = close pcDAud
    _ = close pcSub
    _ = close pcDSub
    _ = close pcAct
    _ = close pcDAct
    _ = close pcGen
    _ = close pcDGen
    _ = close pcTag
    _ = close pcDTag
    _ = close pcCou
    _ = close pcDCou
    _ = close pcStu
    _ = close pcDStu
    _ = close pcDir
    _ = close pcDDir
    _ = close pcCre
    close pcDCre

uniDork.runBatchSafe : Nat -> Nat -> [FilePath] ->{IO, Exception} ()
uniDork.runBatchSafe i n batch =
  use Nat toText
  use Text join
  _ =
    printLine
      (join
        ""
        [ "batch "
        , toText i
        , "/"
        , toText n
        , " ("
        , toText (List.size batch)
        , " folders)"
        ])
  match catch do uniDork.processBatch batch with
    Right _ -> ()
    Left f  -> printLine (join "" ["  BATCH FAILED: ", Failure.message f])

uniDork.batchedMain : Text ->{IO, Exception} ()
uniDork.batchedMain configPath =
  use List size
  use Nat toText
  use Text join
  configText = readFileUtf8 (FilePath configPath)
  dirs = List.filterMap parseConfigLine (lines configText)
  _ = Db.createSchema()
  _ = printLine "collecting folders..."
  folders = uniDork.collectFolders dirs
  total = size folders
  _ = printLine (join "" ["found ", toText total, " folders to process"])
  batches = List.chunk uniDork.batchSize folders
  nBatches = size batches
  _ =
    printLine
      (join
        ""
        [ "processing in "
        , toText nBatches
        , " batches of (up to) "
        , toText uniDork.batchSize
        ])
  step i batch =
    use Nat +
    _ = uniDork.runBatchSafe i nBatches batch
    i + 1
  _ = List.foldLeft step 1 batches
  printLine "done"

uniDork.batchedRun : '{IO, Exception} ()
uniDork.batchedRun = do uniDork.batchedMain "./uniDork.conf"
