Stage.collectResult : [(a1, a, b)] -> (a1, a, Either a2 b) -> [(a1, a, b)]
Stage.collectResult acc = cases
  (folderOpt, videoPath, outcome) ->
    match outcome with
      Left _   -> acc
      Right pr -> (folderOpt, videoPath, pr) List.+: acc

Stage.collectWork : FilePath ->{IO, Exception} [(Optional Text, Text)]
Stage.collectWork staging =
  use List ++ map
  use Universal eq
  entries = directoryContents.texts staging
  folderNames =
    List.filter
      (n ->
        (if eq n "." then false
        else if eq n ".." then false else isDirectory (pathJoin staging n)))
      entries
  folders = map (n -> pathJoin staging n) folderNames
  folderWork =
    List.flatMap
      (folder ->
        map
          (v -> (Some (filePathText folder), filePathText v))
          (looseVideos folder))
      folders
  looseWork = map (v -> (None, filePathText v)) (looseVideos staging)
  folderWork ++ looseWork

Stage.drainHandle : Handle ->{IO, Exception} Text
Stage.drainHandle h =
  use Text ++
  go acc = if isEOF h then acc else go (acc ++ getLine h ++ "\n")
  go ""

Stage.emptyRawFormat : RawFormat
Stage.emptyRawFormat = RawFormat 0 0.0

