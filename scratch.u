Tmdb.tokenAsYear : Text -> Optional Nat
Tmdb.tokenAsYear t =
  use Nat <= >=
  if Universal.eq (Text.size t) 4 then
    match Nat.fromText t with
      Some n -> if n >= 1900 && n <= 2030 then Some n else None
      None   -> None
  else None

Tmdb.tokenize : Text -> [Text]
Tmdb.tokenize name =
  use List flatMap
  use Nat >
  use Text split
  s1 = split ?. name
  s2 = flatMap (p -> split ?_ p) s1
  s3 = flatMap (p -> split ?\s p) s2
  List.filter (p -> Text.size p > 0) s3

Tmdb.tokenOverlapPercent : Text -> Text -> Nat
Tmdb.tokenOverlapPercent a b =
  use List filter
  use Nat * / < >
  use Universal eq
  toks t = filter (p -> Text.size p > 0) (Text.split ?\s t)
  ta = toks a
  tb = toks b
  if eq (List.size ta) 0 then 0
  else
    if eq (List.size tb) 0 then 0
    else
      use List size
      smaller = if size ta < size tb then ta else tb
      larger = if size ta < size tb then tb else ta
      matching = filter (tok -> List.any (s -> eq s tok) larger) smaller
      size matching * 100 / size smaller

test> Tmdb.tokenOverlapPercent.test =
  use Universal eq
  List.flatMap
    check
    [ eq
        (tokenOverlapPercent "hot tube time machine" "hot tub time machine") 75
    , eq (tokenOverlapPercent "avatar fire and ash" "avatar fire and ash") 100
    , eq (tokenOverlapPercent "foo bar" "foo baz") 50
    , eq (tokenOverlapPercent "completely different" "totally other") 0
    , eq (tokenOverlapPercent "" "anything") 0
    , eq (tokenOverlapPercent "single" "single word") 100
    ]

