Rename.isLikelyGroupToken : Text -> Boolean
Rename.isLikelyGroupToken t =
  use Nat < >=
  sz = Text.size t
  hasAny needles =
    List.any
      (n -> (match Text.indexOf n t with
        Some _ -> true
        None   -> false)) needles
  if sz < 2 then false
  else
    if sz >= 30 then false
    else
      if startsWith "~" t then false
      else if hasAny [" ", ".", "(", ")", "[", "]"] then false else true

Rename.isStagingChild : FilePath -> Boolean
Rename.isStagingChild path =
  use Nat >
  use Text ++ size
  pt = filePathText path
  prefix = stagingDir ++ "/"
  startsWith prefix pt && size pt > size prefix

Rename.logDir : Text
Rename.logDir = "/home/bismuth/.cache/uniDork/rename-log"

Rename.logSubOutcomes : [SaveOutcome] ->{IO, Exception} ()
Rename.logSubOutcomes outcomes =
  use Text ++
  Db.foreach_
    (cases
      Saved lang p   -> printLine ("    SUB " ++ lang ++ " -> " ++ p)
      NotFound lang  -> printLine ("    SUB " ++ lang ++ " not found")
      Errored lang e -> printLine ("    SUB " ++ lang ++ " error: " ++ e))
    outcomes

Rename.looseVideos : FilePath ->{IO, Exception} [FilePath]
Rename.looseVideos dir =
  entries = directoryContents.texts dir
  videoNames = List.filter isVideo entries
  step acc n =
    use List :+
    fp = pathJoin dir n
    if isDirectory fp then acc else acc :+ fp
  List.foldLeft step [] videoNames

Rename.matchTmdbWith :
  PreparedQuery r3 a3 Text
  -> PreparedCommand r2 a2
  -> PreparedQuery r1 a1 Text
  -> PreparedCommand r a
  -> Text
  -> Text
  -> Optional Movie
  -> Optional Nat
  ->{IO, Postgres} Either Text Tmdb.Result
Rename.matchTmdbWith
  pqSearch pcSearch pqDet pcDet token name maybeNfo maybeProbeMin =
  match buildParsedRelease name maybeNfo with
    None -> Left "no title/year from NFO or folder name"
    Some p ->
      match cachedSearchWith
        pqSearch pcSearch token (ParsedRelease.title p) (ParsedRelease.year p) with
        Left err   -> Left err
        Right resp ->
          candidates = Tmdb.SearchResponse.results resp
          scored = List.map (r -> (r, scoreCandidate p r)) candidates
          match pickBestWithRuntime pqDet pcDet token maybeProbeMin scored with
            Some (r, _) -> Right r
            None        -> Left "no single high-scoring match"

Rename.maxCast : Nat
Rename.maxCast = 30

Rename.maybeFetchSubs :
  Optional Text -> Details -> FilePath -> Text ->{IO, Exception} ()
Rename.maybeFetchSubs maybeToken d targetFolder base =
  match maybeToken with
    None -> ()
    Some token ->
      if Universal.eq (List.size subLanguages) 0 then ()
      else
        outcomes =
          match Details.imdbId d with
            Some imdb ->
              fetchAndSaveByImdb token imdb targetFolder base subLanguages
            None ->
              fetchAndSaveByTmdb
                token (Details.tmdbId d) targetFolder base subLanguages
        logSubOutcomes outcomes

Rename.maybeFetchSubsM :
  Optional Text -> MovieRecord -> FilePath -> Text ->{IO, Exception} ()
Rename.maybeFetchSubsM maybeToken m targetFolder base =
  match maybeToken with
    None -> ()
    Some token ->
      if Universal.eq (List.size subLanguages) 0 then ()
      else
        outcomes =
          match MovieRecord.imdbId m with
            Some imdb ->
              fetchAndSaveByImdb token imdb targetFolder base subLanguages
            None ->
              fetchAndSaveByTmdb
                token (MovieRecord.tmdbId m) targetFolder base subLanguages
        logSubOutcomes outcomes

Rename.mbps : Nat -> Text
Rename.mbps bps =
  use Nat % * + / >= toText
  use Text ++
  oneMbps = 1000000
  tenths = (bps * 10 + oneMbps / 2) / oneMbps
  whole = tenths / 10
  if whole >= 10 then
    rounded = (bps + oneMbps / 2) / oneMbps
    toText rounded ++ " Mbps"
  else
    f = tenths % 10
    toText whole ++ "." ++ toText f ++ " Mbps"

test> Rename.mbps.test =
  use Universal eq
  List.flatMap
    check
    [ eq (mbps 0) "0.0 Mbps"
    , eq (mbps 1500000) "1.5 Mbps"
    , eq (mbps 5800000) "5.8 Mbps"
    , eq (mbps 11000000) "11 Mbps"
    , eq (mbps 31000000) "31 Mbps"
    ]

Rename.minimalNfo : Tmdb.Result -> Text
Rename.minimalNfo r =
  use Nat toText
  use Text ++
  yearText = match releaseYear (Result.releaseDate r) with
    Some y -> toText y
    None   -> ""
  tmdbText = toText (Result.tmdbId r)
  Text.join
    "\n"
    [ "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\" ?>"
    , "<movie>"
    , "  <title>" ++ escapeXml (Result.title r) ++ "</title>"
    , "  <originaltitle>"
        ++ escapeXml (Result.originalTitle r)
        ++ "</originaltitle>"
    , "  <year>" ++ yearText ++ "</year>"
    , "  <plot>" ++ escapeXml (Result.overview r) ++ "</plot>"
    , "  <uniqueid type=\"tmdb\" default=\"true\">"
        ++ tmdbText
        ++ "</uniqueid>"
    , "  <id>" ++ tmdbText ++ "</id>"
    , "</movie>"
    , ""
    ]

Rename.minimalNfoM : MovieRecord -> Text -> Text
Rename.minimalNfoM m crc =
  use Nat toText
  use Text ++
  yearText = match MovieRecord.year m with
    Some y -> toText y
    None   -> ""
  tmdbText = toText (MovieRecord.tmdbId m)
  Text.join
    "\n"
    [ "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\" ?>"
    , "<movie>"
    , "  <title>" ++ escapeXml (MovieRecord.title m) ++ "</title>"
    , "  <year>" ++ yearText ++ "</year>"
    , "  <uniqueid type=\"tmdb\" default=\"true\">"
        ++ tmdbText
        ++ "</uniqueid>"
    , "  <uniqueid type=\"crc32\">" ++ escapeXml crc ++ "</uniqueid>"
    , "  <id>" ++ tmdbText ++ "</id>"
    , "</movie>"
    , ""
    ]

Rename.minutes : Float -> Nat
Rename.minutes d =
  use Nat /
  durationSeconds d / 60

Rename.nfoBase : Text -> Text
Rename.nfoBase _videoBase = "movie"

Rename.Outcome.parts :
  Rename.Outcome -> (Text, Text, Optional Text, Optional Text)
Rename.Outcome.parts = cases
  Renamed s t          -> (s, "renamed", Some t, None)
  NoVideo s            -> (s, "no_video", None, None)
  NoMatch s r          -> (s, "no_match", None, Some r)
  NoProbe s            -> (s, "no_probe", None, None)
  Conflict s t         -> (s, "conflict", Some t, None)
  RenameError s m      -> (s, "error", None, Some m)
  DuplicateRemoved s t -> (s, "duplicate_removed", Some t, None)
  AlreadyDone s        -> (s, "already_done", None, None)

Rename.Outcome.toJson : Rename.Outcome -> Json
Rename.Outcome.toJson = cases
  Renamed src tgt ->
    Json.object
      [ ("outcome", Json.text "renamed")
      , ("source", Json.text src)
      , ("target", Json.text tgt)
      ]
  NoVideo src ->
    Json.object [("outcome", Json.text "no_video"), ("source", Json.text src)]
  NoMatch src reason ->
    Json.object
      [ ("outcome", Json.text "no_match")
      , ("source", Json.text src)
      , ("reason", Json.text reason)
      ]
  NoProbe src ->
    Json.object [("outcome", Json.text "no_probe"), ("source", Json.text src)]
  Conflict src existing ->
    Json.object
      [ ("outcome", Json.text "conflict")
      , ("source", Json.text src)
      , ("existing", Json.text existing)
      ]
  RenameError src msg ->
    Json.object
      [ ("outcome", Json.text "error")
      , ("source", Json.text src)
      , ("message", Json.text msg)
      ]
  DuplicateRemoved src existing ->
    Json.object
      [ ("outcome", Json.text "duplicate_removed")
      , ("source", Json.text src)
      , ("existing", Json.text existing)
      ]
  AlreadyDone src ->
    Json.object
      [("outcome", Json.text "already_done"), ("source", Json.text src)]

Rename.parentDir : FilePath -> FilePath
Rename.parentDir fp =
  use List reverse
  parts = Text.split ?/ (filePathText fp)
  match reverse parts with
    _ +: rest -> FilePath (Text.join "/" (reverse rest))
    []        -> fp

Rename.parseFormat : Text -> [FormatPart]
Rename.parseFormat template =
  use List ++
  use Nat >
  use Text size
  segments = Text.split ?{ template
  match segments with
    []            -> []
    [single]      -> if size single > 0 then [Literal single] else []
    first +: rest ->
      head = if size first > 0 then [Literal first] else []
      head ++ List.flatMap parseSegment rest

test> Rename.parseFormat.test =
  use Universal eq
  lit = Literal
  tok = FormatPart.Token
  List.flatMap
    check
    [ eq (parseFormat "") []
    , eq (parseFormat "hello") [lit "hello"]
    , eq (parseFormat "{a}") [tok "a"]
    , eq (parseFormat "x{a}y") [lit "x", tok "a", lit "y"]
    , eq (parseFormat "{a}{b}") [tok "a", tok "b"]
    , eq (parseFormat "{ny} [{vf}]") [tok "ny", lit " [", tok "vf", lit "]"]
    ]

Rename.parseSegment : Text -> [FormatPart]
Rename.parseSegment seg = match Text.indexOf "}" seg with
  None   -> [Literal (Text.join "" ["{", seg])]
  Some i ->
    use List ++
    use Nat + >
    tokenName = Text.take i seg
    rest = Text.drop (i + 1) seg
    tokenPart = [FormatPart.Token tokenName]
    if Text.size rest > 0 then tokenPart ++ [Literal rest] else tokenPart

Rename.pathExists : FilePath ->{IO, Exception} Boolean
Rename.pathExists fp = match catch do FilePath.exists fp with
  Right b -> b
  Left _  -> false

