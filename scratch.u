  hi =
    Subs.UnpackFile.UnpackFile
      "fHI"
      "x.srt"
      "rel"
      "EN"
      "srt"
      true
      100
      "/subtitle/n/fHI"
  match Subs.pickUnpackForLanguage "EN" [hi] with
    None        -> [Fail "should have picked the HI unpack as fallback"]
    Some chosen ->
      check (Universal.eq (Subs.UnpackFile.fileNId chosen) "fHI")

