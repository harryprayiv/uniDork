    check
    [ eq (Rename.mbps 0) "0.0 Mbps"
    , eq (Rename.mbps 1500000) "1.5 Mbps"
    , eq (Rename.mbps 5800000) "5.8 Mbps"
    , eq (Rename.mbps 11000000) "11 Mbps"
    , eq (Rename.mbps 31000000) "31 Mbps"
    ]

