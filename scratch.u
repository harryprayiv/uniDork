type Actor
  = { name : Text, role : Text }

type Audio
  = { codec : Text, language : Text, channels : Nat }

type FileInfo
  = { streams : StreamDetails }

type FolderMeta
  = { rawSize : Optional Text,
      resolution : Optional Text,
      videoCodec : Optional Text,
      bitDepth : Optional Nat,
      runtimeMin : Optional Nat,
      checksum : Optional Text }

type Movie
  = { id : MovieId,
      title : Title,
      collection : Optional Text,
      runtime : Optional Nat,
      scoring : Scoring,
      plot : Text,
      tagline : Text,
      taxonomy : Taxonomy,
      fileInfo : FileInfo,
      videoFilePath : Optional Text,
      checksum : Optional Text,
      actors : [Actor],
      folderPath : Optional Text,
      nfoPath : Optional Text,
      fileSizeBytes : Optional Nat,
      folderMeta : FolderMeta }

type MovieId
  = { kodi : Text,
      imdb : Optional Text,
      tmdb : Optional Text,
      tvdb : Optional Text }

type Probe.AudioTrack
  = { index : Nat,
      codec : Text,
      language : Optional Text,
      title : Optional Text,
      channels : Nat,
      channelLayout : Text,
      isDefault : Boolean,
      isComment : Boolean,
      isVisualImpaired : Boolean }

type Probe.Format
  = { duration : Float, sizeBytes : Optional Nat, bitRate : Optional Nat }

type Probe.Result
  = { format : Format }

type Relang.Decision
  = AlreadyCorrect Nat
  | NoCurrentDefault Nat
  | OriginalNotPresent Text
  | UnsupportedLanguage Text
  | SwitchTo Nat Nat

type Rename.Context
  = { tmdb : Tmdb.Result,
      probe : ProbeResult,
      group : Optional Text,
      tags : [Text],
      originalName : Text }

type Rename.FormatPart
  = Literal Text
  | Token Text

type Rename.MovieRecord
  = { tmdbId : Nat, imdbId : Optional Text, title : Text, year : Optional Nat }

type Rename.Outcome
  = NoVideo Text
  | NoProbe Text
  | AlreadyDone Text
  | Renamed Text Text
  | NoMatch Text Text
  | Conflict Text Text
  | RenameError Text Text
  | DuplicateRemoved Text Text

type Rename.RenameRow
  = { crc32 : Text,
      originalPath : Text,
      probeJson : Text,
      tmdbId : Nat,
      imdbId : Optional Text,
      title : Text,
      year : Optional Nat,
      detailsJson : Text }

type Resolve.FileRow
  = { fileId : Int,
      originalName : Text,
      durationSec : Float,
      hintTitle : Optional Text,
      hintYear : Optional Nat,
      hintTmdbId : Optional Nat }

type Resolve.Outcome
  = NoHint Int
  | NoTmdbMatch Int
  | ResolvedById Int Nat
  | ResolvedBySearch Int Nat Nat
  | SearchError Int Text

type Scoring
  = { year : Optional Nat, rating : Float, votes : Nat, mpaa : Text }

type Stage.AudioInfo
  = { codec : Text, channels : Nat, channelLayout : Text, language : Text }

type Stage.ProbeResult
  = { videoPath : Text,
      crc32 : Text,
      sizeBytes : Nat,
      durationSec : Float,
      video : VideoInfo,
      audios : [AudioInfo],
      subtitles : [SubtitleInfo] }

type Stage.RawFormat
  = { sizeBytes : Nat, durationSec : Float }

type Stage.RawProbe
  = { streams : [RawStream], format : RawFormat }

type Stage.RawStream
  = { codecType : Text,
      codecName : Text,
      width : Nat,
      height : Nat,
      pixFmt : Text,
      bitsPerRawSample : Optional Nat,
      bitRate : Optional Nat,
      channels : Nat,
      channelLayout : Text,
      language : Text }

type Stage.SubtitleInfo
  = { codec : Text, language : Text }

type Stage.VideoInfo
  = { codec : Text,
      width : Nat,
      height : Nat,
      bitDepth : Nat,
      pixFmt : Text,
      bitRate : Optional Nat }

type StreamDetails
  = { video : Video, audios : [Audio], subtitles : [Subtitle] }

type Subs.MovieResult
  = { imdbId : Optional Text,
      tmdbId : Optional Nat,
      sdId : Optional Nat,
      kind : Text,
      name : Text,
      year : Optional Nat }

type Subs.SaveOutcome
  = NotFound Text
  | Saved Text Text
  | Errored Text Text

type Subs.SearchResponse
  = { ok : Boolean,
      error : Optional Text,
      results : [MovieResult],
      subtitles : [SubtitleItem] }

type Subs.SubtitleItem
  = { releaseName : Text,
      fileName : Text,
      urlPath : Text,
      language : Optional Text,
      hearingImpaired : Optional Boolean,
      fullSeason : Optional Boolean,
      season : Optional Nat,
      episode : Optional Nat,
      unpackFiles : [UnpackFile] }

type Subs.UnpackFile
  = { fileNId : Text,
      name : Text,
      releaseName : Text,
      language : Text,
      format : Text,
      hearingImpaired : Boolean,
      size : Nat,
      urlPath : Text }

type Subtitle
  = { language : Text }

type Taxonomy
  = { genres : [Text],
      tags : [Text],
      countries : [Text],
      studios : [Text],
      directors : [Text],
      credits : [Text] }

type Title
  = { display : Text, original : Text, sort : Text }

type Tmdb.CachedSearch
  = { folder : Text,
      response : Optional Tmdb.SearchResponse,
      error : Optional Text }

type Tmdb.CastMember
  = { id : Nat, name : Text, character : Text, order : Nat }

type Tmdb.Collection
  = { id : Nat, name : Text }

type Tmdb.Confidence
  = High
  | Low Text

type Tmdb.Country
  = { code : Text, name : Text }

type Tmdb.Credits
  = { cast : [CastMember], crew : [CrewMember] }

type Tmdb.CrewMember
  = { id : Nat, name : Text, job : Text, department : Text }

type Tmdb.Details
  = { tmdbId : Nat,
      imdbId : Optional Text,
      runtime : Nat,
      title : Text,
      originalTitle : Text,
      originalLanguage : Text,
      overview : Text,
      tagline : Text,
      releaseDate : Text,
      voteAverage : Float,
      voteCount : Nat,
      genres : [Text],
      productionCountries : [Text],
      productionStudios : [Text],
      collection : Optional Text,
      mpaa : Text,
      directors : [Text],
      writers : [Text],
      cast : [(Text, Text)],
      tags : [Text] }

type Tmdb.ExternalIds
  = { imdbId : Optional Text }

type Tmdb.Genre
  = { id : Nat, name : Text }

type Tmdb.MovieDetails
  = { id : Nat,
      title : Text,
      originalTitle : Text,
      overview : Text,
      tagline : Text,
      releaseDate : Text,
      runtime : Optional Nat,
      voteAverage : Float,
      voteCount : Nat,
      genres : [Genre],
      productionCountries : [Country],
      productionCompanies : [Studio],
      collection : Optional Collection,
      posterPath : Optional Text,
      backdropPath : Optional Text,
      credits : Optional Credits,
      releaseDates : [ReleaseInfo],
      externalIds : Optional ExternalIds }

type Tmdb.ParsedRelease
  = { rawName : Text, title : Text, year : Nat, nfoTmdbId : Optional Nat }

type Tmdb.ReleaseInfo
  = { country : Text, certification : Text }

type Tmdb.Result
  = { tmdbId : Nat,
      title : Text,
      originalTitle : Text,
      originalLanguage : Text,
      releaseDate : Text,
      popularity : Float,
      overview : Text }

type Tmdb.SearchResponse
  = { results : [Tmdb.Result] }

type Tmdb.Studio
  = { id : Nat, name : Text }

type Video
  = { codec : Text, aspect : Float, width : Nat, height : Nat }

Actor.fromJson : '{unison_json_1_4_2.Decoder} Actor
Actor.fromJson = do
  use Decoder text
  use object at!
  name = at! "name" text
  role = at! "role" text
  Actor.Actor name role

Actor.toJson : Actor -> Json
Actor.toJson a =
  use Json text
  Json.object [("name", text (Actor.name a)), ("role", text (role a))]

actorsAsJson : [Actor] -> Text
actorsAsJson xs = Json.toText (Json.array (List.map Actor.toJson xs))

Audio.fromJson : '{unison_json_1_4_2.Decoder} Audio
Audio.fromJson = do
  use Decoder text
  use object at!
  codec = at! "codec" text
  language = at! "language" text
  channels = at! "channels" Decoder.nat
  Audio codec language channels

Audio.toJson : Audio -> Json
Audio.toJson a =
  use Json text
  Json.object
    [ ("codec", text (Audio.codec a))
    , ("language", text (Audio.language a))
    , ("channels", Json.nat (Audio.channels a))
    ]

audiosAsJson : [Audio] -> Text
audiosAsJson xs = Json.toText (Json.array (List.map Audio.toJson xs))

classifyPiece : Text -> FolderMeta -> FolderMeta
classifyPiece p m =
  if endsWith "min" p then runtimeMin.set (parseNatBefore "min" p) m
  else
    if endsWith "p" p then resolution.set (Some p) m
    else
      if endsWith "b" p then FolderMeta.bitDepth.set (parseNatBefore "b" p) m
      else
        if endsWith "G" p then rawSize.set (Some p) m
        else
          if endsWith "M" p then rawSize.set (Some p) m
          else
            if startsWith "x" p then videoCodec.set (Some p) m
            else
              if startsWith "h" p then videoCodec.set (Some p) m
              else if startsWith "av" p then videoCodec.set (Some p) m else m

cli : '{IO, Exception} ()
cli =
  do
    args = getArgs()
    match args with
      "import" +: _ -> batchedRun()
      "identify" +: _ -> Resolve.identify()
      "resolve" +: _ -> Resolve.run()
      "probe-stage" +: _ -> runProbeStage()
      "rename" +: rest ->
        match rest with
          format +: _ -> renameNewCombined format ()
          []          -> printLine "rename requires a format string"
      _ ->
        _ =
          printLine
            "usage: unidork-import <import|probe-stage|identify|resolve|rename> [format]"
        ()

Db.associationsDdl : Text
Db.associationsDdl =
  Text.join
    ""
    [ "CREATE TABLE IF NOT EXISTS associations ("
    , "  file_id       BIGINT NOT NULL REFERENCES files(file_id) ON DELETE CASCADE,"
    , "  tmdb_id       INTEGER NOT NULL REFERENCES movies(tmdb_id) ON DELETE CASCADE,"
    , "  confidence    INTEGER NOT NULL DEFAULT 0,"
    , "  match_source  TEXT NOT NULL DEFAULT '',"
    , "  associated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),"
    , "  PRIMARY KEY (file_id, tmdb_id)"
    , ")"
    ]

Db.cacheDdl : [Text]
Db.cacheDdl =
  [ "CREATE TABLE IF NOT EXISTS tmdb_search_cache (search_title TEXT NOT NULL, search_year INTEGER NOT NULL, payload TEXT NOT NULL, fetched_at TIMESTAMPTZ NOT NULL DEFAULT NOW(), PRIMARY KEY (search_title, search_year))"
  , "CREATE INDEX IF NOT EXISTS idx_tmdb_search_fetched ON tmdb_search_cache(fetched_at DESC)"
  ]

Db.childDdl : [Text]
Db.childDdl =
  [ "CREATE TABLE IF NOT EXISTS movie_video_streams (id SERIAL PRIMARY KEY, folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, codec TEXT NOT NULL DEFAULT '', aspect DOUBLE PRECISION NOT NULL DEFAULT 0, width INTEGER NOT NULL DEFAULT 0, height INTEGER NOT NULL DEFAULT 0)"
  , "CREATE TABLE IF NOT EXISTS movie_audio_tracks (id SERIAL PRIMARY KEY, folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, track_order INTEGER NOT NULL DEFAULT 0, codec TEXT NOT NULL DEFAULT '', language TEXT NOT NULL DEFAULT '', channels INTEGER NOT NULL DEFAULT 0)"
  , "CREATE TABLE IF NOT EXISTS movie_subtitles (id SERIAL PRIMARY KEY, folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, track_order INTEGER NOT NULL DEFAULT 0, language TEXT NOT NULL DEFAULT '')"
  , "CREATE TABLE IF NOT EXISTS movie_actors (id SERIAL PRIMARY KEY, folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, sort_order INTEGER NOT NULL DEFAULT 0, name TEXT NOT NULL DEFAULT '', role TEXT NOT NULL DEFAULT '')"
  , "CREATE TABLE IF NOT EXISTS movie_genres (folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, genre TEXT NOT NULL, PRIMARY KEY (folder_checksum, genre))"
  , "CREATE TABLE IF NOT EXISTS movie_tags (folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, tag TEXT NOT NULL, PRIMARY KEY (folder_checksum, tag))"
  , "CREATE TABLE IF NOT EXISTS movie_countries (folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, country TEXT NOT NULL, PRIMARY KEY (folder_checksum, country))"
  , "CREATE TABLE IF NOT EXISTS movie_studios (folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, studio TEXT NOT NULL, PRIMARY KEY (folder_checksum, studio))"
  , "CREATE TABLE IF NOT EXISTS movie_directors (folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, director TEXT NOT NULL, PRIMARY KEY (folder_checksum, director))"
  , "CREATE TABLE IF NOT EXISTS movie_credits (folder_checksum TEXT NOT NULL REFERENCES library_movies(folder_checksum) ON DELETE CASCADE, credit TEXT NOT NULL, PRIMARY KEY (folder_checksum, credit))"
  ]

Db.config : PostgresClientConfig
Db.config =
  PostgresClientConfig.default
    (HostName "localhost") (UserName "postgres") (DatabaseName "dork")
    |> PostgresClientConfig.port.set (Port "5434")

Db.countMovies : '{IO, Exception} ()
Db.countMovies = do
  singleIO Db.config do
    q = sql "SELECT COUNT(*) FROM movies" |> typedQuery bigint
    counts = Query.execute q
    match counts with
      n +: _ -> printLine (Text.join "" ["movies in db: ", Int.toText n])
      []     -> printLine "no result"

Db.createIndexSql : Text
Db.createIndexSql =
  "CREATE INDEX IF NOT EXISTS idx_movies_imdb_id ON movies(imdb_id)"

Db.createSchema : '{IO, Exception} ()
Db.createSchema = do
  singleIO Db.config do
    _ = runDDLList [libraryMoviesDdl]
    _ = runDDLList childDdl
    _ = runDDLList [tmdbMoviesDdl]
    _ = runDDLList [filesDdl]
    _ = runDDLList [probeCacheDdl]
    _ = runDDLList [associationsDdl]
    _ = runDDLList cacheDdl
    runDDLList indexDdl

