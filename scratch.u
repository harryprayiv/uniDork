  Text.join
    "\n"
    [ "{"
    , "  \"status\": true,"
    , "  \"results\": ["
    , "    {"
    , "      \"imdb_id\": \"tt1375666\","
    , "      \"tmdb_id\": 27205,"
    , "      \"type\": \"movie\","
