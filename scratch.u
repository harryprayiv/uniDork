    |> buildCommand

Rename.renderName : [FormatPart] -> MovieRecord -> ProbeResult -> Text
Rename.renderName parts m pr =
  render = cases
    Literal t             -> t
    FormatPart.Token name -> resolveTokenM m pr name
  tighten (Text.join "" (List.map render parts))

Rename.resolutionStr : Nat -> Nat -> Text
Rename.resolutionStr w h =
  use Nat toText
  use Text ++
  toText w ++ "x" ++ toText h

Rename.resolveToken : Rename.Context -> Text -> Text
Rename.resolveToken ctx tok =
  use Nat toText
  use ProbeResult durationSec primaryAudio sizeBytes
  use VideoInfo height width
  r = Context.tmdb ctx
  pr = probe ctx
  vid = ProbeResult.video pr
  match tok with
    "ny" -> titleYear r
    "n" -> sanitize (Result.title r)
    "y" ->
      match releaseYear (Result.releaseDate r) with
        Some y -> toText y
        None   -> "0000"
    "gigabytes" -> gigabytes (sizeBytes pr)
    "vf" -> vfTag (width vid) (height vid)
    "vc" -> vcTag (VideoInfo.codec vid)
    "bitdepth" -> toText (VideoInfo.bitDepth vid)
    "minutes" -> toText (Rename.minutes (durationSec pr))
    "crc32" -> ProbeResult.crc32 pr
    "resolution" -> resolutionStr (width vid) (height vid)
    "mbps" ->
      mbps
        (effectiveBitRate
          (VideoInfo.bitRate vid) (sizeBytes pr) (durationSec pr))
    "ac" ->
      match primaryAudio pr with
        Some a -> acTag (AudioInfo.codec a)
        None   -> "noaudio"
    "channels" ->
      match primaryAudio pr with
        Some a -> channelsTag (AudioInfo.channels a)
        None   -> "0"
    "group" -> Optional.getOrElse "" (Context.group ctx)
    "tags" -> Text.join " " (Context.tags ctx)
    _ -> ""

Rename.resolveTokenM : MovieRecord -> ProbeResult -> Text -> Text
Rename.resolveTokenM m pr tok =
  use Nat toText
  use ProbeResult durationSec primaryAudio sizeBytes
  use VideoInfo height width
  vid = ProbeResult.video pr
  match tok with
    "ny" -> titleYearM m
    "n" -> sanitize (MovieRecord.title m)
    "y" ->
      match MovieRecord.year m with
        Some y -> toText y
        None   -> "0000"
    "gigabytes" -> gigabytes (sizeBytes pr)
    "vf" -> vfTag (width vid) (height vid)
    "vc" -> vcTag (VideoInfo.codec vid)
    "bitdepth" -> toText (VideoInfo.bitDepth vid)
    "minutes" -> toText (Rename.minutes (durationSec pr))
    "crc32" -> ProbeResult.crc32 pr
    "resolution" -> resolutionStr (width vid) (height vid)
    "mbps" ->
      mbps
        (effectiveBitRate
          (VideoInfo.bitRate vid) (sizeBytes pr) (durationSec pr))
    "ac" ->
      match primaryAudio pr with
        Some a -> acTag (AudioInfo.codec a)
        None   -> "noaudio"
    "channels" ->
      match primaryAudio pr with
        Some a -> channelsTag (AudioInfo.channels a)
        None   -> "0"
    _ -> ""

Rename.resultFromDetails : Details -> Tmdb.Result
Rename.resultFromDetails d =
  Tmdb.Result.Result
    (Details.tmdbId d)
    (Details.title d)
    (Details.originalTitle d)
    (Details.originalLanguage d)
    (Details.releaseDate d)
    0.0
    (Details.overview d)

Rename.rowToRenameRow :
  (((((((Text, Text), Text), Int), Optional Text), Text), Optional Int), Text)
  -> RenameRow
Rename.rowToRenameRow = cases
  (((((((crc, opath), pjson), tid), imdb), ttl), yr), djson) ->
    tmdbNat = Optional.getOrElse 0 (Nat.fromInt tid)
    RenameRow crc opath pjson tmdbNat imdb ttl (optIntToNat yr) djson

Rename.runNew : Text -> Text -> '{IO, Exception} ()
Rename.runNew folderFmtText fileFmtText =
  do
    use Text ++
    folderFmt = parseFormat folderFmtText
    fileFmt = parseFormat fileFmtText
    subsToken = match catch do Subs.readToken() with
      Right t -> Some t
      Left _  -> None
    _ =
      if isDirectory (FilePath targetRoot) then ()
      else
        _ = catch do createDirectory (FilePath targetRoot)
        ()
    singleIO Db.config do
      pqRows = prepareQuery selectRenamableSql
      pcProposed = prepareCommand recordProposedSql
      pqProposed = prepareQuery selectProposedSql
      rows = match 
        catch do
          portal = bindQuery pqRows []
          (rs, _) = executeQueryPortal portal 0
          rs
       with
        Left f   ->
          _ = printLine ("[rename] QUERY FAILED: " ++ Failure.message f)
          []
        Right rs -> List.map rowToRenameRow rs
      _ =
        printLine
          ("[rename] " ++ Nat.toText (List.size rows) ++ " associated file(s)")
      step row = runStep pcProposed pqProposed folderFmt fileFmt subsToken row
      _ = Db.foreach_ step rows
      _ = PreparedQuery.close pqRows
      _ = PreparedCommand.close pcProposed
      _ = PreparedQuery.close pqProposed
      printLine "[rename] done"

Rename.runStep :
  PreparedCommand r1 a1
  -> PreparedQuery r a Text
  -> [FormatPart]
  -> [FormatPart]
  -> Optional Text
  -> RenameRow
  ->{IO, Exception, Postgres} ()
Rename.runStep pcProposed pqProposed folderFmt fileFmt subsToken row =
  use Text ++
  crc = RenameRow.crc32 row
  sourceText = originalPath row
  _ = printLine ("processing: " ++ sourceText)
  _ =
    match findPriorTargetForCrcWith pqProposed crc with
      Some prior ->
        printLine ("  note: previously renamed this file -> " ++ prior)
      None -> ()
  outcome = executeOne pcProposed folderFmt fileFmt subsToken row
  match outcome with
    Renamed _ tgt -> printLine ("  RENAMED -> " ++ tgt)
    DuplicateRemoved _ tgt ->
      printLine ("  DUPLICATE -> source removed (already at " ++ tgt ++ ")")
    NoVideo src -> printLine ("  SKIP: source file not found at " ++ src)
    NoProbe src -> printLine ("  SKIP: no probe for " ++ src)
    NoMatch src reason ->
      printLine ("  SKIP: no match for " ++ src ++ " (" ++ reason ++ ")")
    Conflict _ t -> printLine ("  SKIP: different file already at " ++ t)
    AlreadyDone src -> printLine ("  SKIP: already done " ++ src)
    RenameError _ msg -> printLine ("  ERROR: " ++ msg)

Rename.sanitize : Text -> Text
Rename.sanitize t =
  use List foldLeft
  use Nat >
  dropChars = ["'", "\"", "`"]
  spaceChars =
    [ ":"
    , ";"
    , ","
    , "."
    , "/"
    , "\\"
    , "?"
    , "*"
    , "<"
    , ">"
    , "|"
    , "!"
    , "@"
    , "#"
    , "$"
    , "%"
    , "^"
    , "&"
    , "+"
    , "="
    , "~"
    , "("
    , ")"
    , "["
    , "]"
    , "{"
    , "}"
    , "—"
    , "–"
    , "\n"
    , "\t"
    , "\r"
    ]
  dropped = foldLeft (acc c -> replaceAll c "" acc) t dropChars
  spaced = foldLeft (acc c -> replaceAll c " " acc) dropped spaceChars
  parts = Text.split ?\s spaced
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  trim (Text.join " " nonEmpty)

