Subs.fetchAndSaveByImdb :
  Text -> Text -> FilePath -> Text -> [Text] ->{IO} [SaveOutcome]
Subs.fetchAndSaveByImdb apiKey imdbId targetDir baseName langs =
  use List map
  langsParam = languagesParam langs
  match searchByImdb apiKey imdbId langsParam with
    Left err   -> map (l -> Errored (normLang l) err) langs
    Right resp ->
      allFiles = allUnpackFiles resp
      map (saveOneLanguage targetDir baseName allFiles) langs

Subs.fetchAndSaveByTmdb :
  Text -> Nat -> FilePath -> Text -> [Text] ->{IO} [SaveOutcome]
Subs.fetchAndSaveByTmdb apiKey tmdbId targetDir baseName langs =
  use List map
  langsParam = languagesParam langs
  match searchByTmdb apiKey tmdbId langsParam with
    Left err   -> map (l -> Errored (normLang l) err) langs
    Right resp ->
      allFiles = allUnpackFiles resp
      map (saveOneLanguage targetDir baseName allFiles) langs

Subs.imdbSearchURI : Text -> Text -> Text -> URI
Subs.imdbSearchURI apiKey imdbId languages =
  use Path /
  path = Path.root / "api" / "v1" / "subtitles"
  q =
    Query.empty
      & ("api_key", apiKey)
      & ("type", "movie")
      & ("subs_per_page", "30")
      & ("unpack", "1")
      & ("imdb_id", imdbId)
      & ("languages", languages)
  URI Scheme.https (Some Subs.apiAuthority) path (fromQuery q) Fragment.empty

Subs.isFullSeason : SubtitleItem -> Boolean
Subs.isFullSeason item = match fullSeason item with
  Some true -> true
  _         -> false

Subs.isHi : SubtitleItem -> Boolean
Subs.isHi item = match SubtitleItem.hearingImpaired item with
  Some true -> true
  _         -> false

Subs.languageMatches : Text -> SubtitleItem -> Boolean
Subs.languageMatches target item = match SubtitleItem.language item with
  None    -> false
  Some la -> Universal.eq (normLang la) (normLang target)

Subs.languagesParam : [Text] -> Text
Subs.languagesParam langs = Text.join "," (List.map Text.toUppercase langs)

test> Subs.languagesParam.test =
  use Universal eq
  List.flatMap
    check
    [ eq (languagesParam ["en", "es", "th"]) "EN,ES,TH"
    , eq (languagesParam ["EN"]) "EN"
    , eq (languagesParam []) ""
    ]

Subs.MovieResult.fromJson : '{unison_json_1_4_2.Decoder} MovieResult
Subs.MovieResult.fromJson = do
  use Decoder nat optional! text
  use object at at!
  imdbId = optional! (at "imdb_id" text)
  tmdbId = optional! (at "tmdb_id" nat)
  sdId = optional! (at "sd_id" nat)
  kind = at! "type" text
  name = at! "name" text
  year = optional! (at "year" nat)
  MovieResult imdbId tmdbId sdId kind name year

Subs.normLang : Text -> Text
Subs.normLang t = Text.toLowercase (trim t)

test> Subs.parseMovieFields.test =
  match catch do Decoder.run Subs.SearchResponse.fromJson exampleSearchJson with
    Left f -> [Fail (Failure.message f)]
    Right r ->
      match List.head (Subs.SearchResponse.results r) with
        None -> [Fail "no movie result"]
        Some m ->
          List.flatMap
            check
            [ Universal.eq (MovieResult.imdbId m) (Some "tt1375666")
            , Universal.eq (MovieResult.tmdbId m) (Some 27205)
            , Universal.eq (sdId m) (Some 123456)
            , Universal.eq (MovieResult.name m) "Inception"
            , Universal.eq (kind m) "movie"
            , Universal.eq (MovieResult.year m) (Some 2010)
            ]

test> Subs.parseShape.test =
  match catch do Decoder.run Subs.SearchResponse.fromJson exampleSearchJson with
    Left f -> [Fail (Failure.message f)]
    Right r ->
      List.flatMap
        check
        [ SearchResponse.ok r
        , Universal.eq (List.size (Subs.SearchResponse.results r)) 1
        , Universal.eq (List.size (SearchResponse.subtitles r)) 3
        ]

test> Subs.parseUnpacked.test =
  match catch do Decoder.run Subs.SearchResponse.fromJson exampleUnpackedJson with
    Left f  -> [Fail (Failure.message f)]
    Right r ->
      flat = allUnpackFiles r
      List.flatMap check [Universal.eq (List.size flat) 3]

test> Subs.pickBestDropsFullSeason.test =
  pack : SubtitleItem
  pack =
    SubtitleItem
      "Season Pack"
      "s1.zip"
      "/subtitle/pack.zip"
      (Some "EN")
      (Some false)
      (Some true)
      (Some 1)
      (Some 1)
      []
  match pickBestForMovie "EN" [pack] with
    Some _ -> [Fail "should have dropped the full-season pack"]
    None   -> check true

test> Subs.pickBestEmpty.test = match pickBestForMovie "EN" [] with
  Some _ -> [Fail "empty input should yield None"]
  None   -> check true

test> Subs.pickBestFallsBackToHi.test =
  hi : SubtitleItem
  hi =
    SubtitleItem
      "HI release"
      "hi.srt"
      "/subtitle/x.zip"
      (Some "EN")
      (Some true)
      (Some false)
      None
      None
      []
  match pickBestForMovie "EN" [hi] with
    None -> [Fail "should have picked the HI track as fallback"]
    Some chosen ->
      check (Universal.eq (SubtitleItem.urlPath chosen) "/subtitle/x.zip")

Subs.pickBestForMovie : Text -> [SubtitleItem] -> Optional SubtitleItem
Subs.pickBestForMovie lang items =
  use List filter head
  notSeason = filter (i -> (if isFullSeason i then false else true)) items
  withLang = filter (languageMatches lang) notSeason
  pool = if Universal.eq (List.size withLang) 0 then notSeason else withLang
  nonHi = filter (i -> (if isHi i then false else true)) pool
  match head nonHi with
    Some s -> Some s
    None   -> head pool

test> Subs.pickBestLanguageFallback.test =
  fr : SubtitleItem
  fr =
    SubtitleItem
      "Only French"
      "fr.srt"
      "/subtitle/fr.zip"
      (Some "FR")
      (Some false)
      (Some false)
      None
      None
      []
  match pickBestForMovie "EN" [fr] with
    None -> [Fail "should fall back to the full pool"]
    Some chosen ->
      check (Universal.eq (SubtitleItem.urlPath chosen) "/subtitle/fr.zip")

test> Subs.pickBestPrefersNonHi.test =
  match catch do Decoder.run Subs.SearchResponse.fromJson exampleSearchJson with
    Left f -> [Fail (Failure.message f)]
    Right r ->
      use Universal eq
      subs = SearchResponse.subtitles r
      match pickBestForMovie "EN" subs with
        None -> [Fail "expected a pick"]
        Some chosen ->
          List.flatMap
            check
            [ eq (SubtitleItem.urlPath chosen) "/subtitle/1111-2222.zip"
            , eq (isHi chosen) false
            , eq (SubtitleItem.language chosen) (Some "EN")
            ]

test> Subs.pickUnpackFallsBackToHi.test =
  hi : UnpackFile
  hi = UnpackFile "fHI" "x.srt" "rel" "EN" "srt" true 100 "/subtitle/n/fHI"
  match pickUnpackForLanguage "EN" [hi] with
    None        -> [Fail "should have picked the HI unpack as fallback"]
    Some chosen -> check (Universal.eq (fileNId chosen) "fHI")

Subs.pickUnpackForLanguage : Text -> [UnpackFile] -> Optional UnpackFile
Subs.pickUnpackForLanguage lang files =
  use List filter head
  langMatches = filter (unpackLanguageMatches lang) files
  srtMatches = filter unpackIsSrt langMatches
  pool =
    if Universal.eq (List.size srtMatches) 0 then langMatches else srtMatches
  nonHi = filter (uf -> (if unpackIsHi uf then false else true)) pool
  match head nonHi with
    Some s -> Some s
    None   -> head pool

test> Subs.pickUnpackPicksEachLanguage.test =
  match catch do Decoder.run Subs.SearchResponse.fromJson exampleUnpackedJson with
    Left f -> [Fail (Failure.message f)]
    Right r ->
      use Optional map
      use Universal eq
      flat = allUnpackFiles r
      en = pickUnpackForLanguage "EN" flat
      es = pickUnpackForLanguage "ES" flat
      th = pickUnpackForLanguage "TH" flat
      enId = map fileNId en
      esId = map fileNId es
      List.flatMap
        check [eq enId (Some "fileEN1"), eq esId (Some "fileES1"), eq th None]

test> Subs.pickUnpackPrefersNonHi.test =
  match catch do Decoder.run Subs.SearchResponse.fromJson exampleUnpackedJson with
    Left f -> [Fail (Failure.message f)]
    Right r ->
      use Universal eq
      flat = allUnpackFiles r
      match pickUnpackForLanguage "EN" flat with
        None -> [Fail "expected an EN pick"]
        Some chosen ->
          List.flatMap
            check
            [ eq (fileNId chosen) "fileEN1"
            , eq (UnpackFile.hearingImpaired chosen) false
            , eq (UnpackFile.format chosen) "srt"
            ]

Subs.readToken : '{IO, Exception} Text
Subs.readToken = do trim (readFileUtf8 (FilePath Subs.tokenPath))

Subs.saveOneLanguage :
  FilePath -> Text -> [UnpackFile] -> Text ->{IO} SaveOutcome
Subs.saveOneLanguage targetDir baseName allFiles lang =
  use Text ++
  langCode = normLang lang
  match pickUnpackForLanguage lang allFiles with
    None    -> NotFound langCode
    Some uf ->
      match downloadUnpackRaw uf with
        Left err   -> Errored langCode err
        Right body ->
          ext = normLang (UnpackFile.format uf)
          filename = baseName ++ "." ++ langCode ++ "." ++ ext
          path = pathJoin targetDir filename
          match catch do writeFileUtf8 path body with
            Left f  -> Errored langCode (Failure.message f)
            Right _ -> Saved langCode (filePathText path)

Subs.searchByImdb : Text -> Text -> Text ->{IO} Either Text Subs.SearchResponse
Subs.searchByImdb apiKey imdbId languages =
  req = searchRequestImdb apiKey imdbId languages
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          body = bodyText ok
          Decoder.run Subs.SearchResponse.fromJson body
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Subs.searchByTmdb : Text -> Nat -> Text ->{IO} Either Text Subs.SearchResponse
Subs.searchByTmdb apiKey tmdbId languages =
  req = searchRequestTmdb apiKey tmdbId languages
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          body = bodyText ok
          Decoder.run Subs.SearchResponse.fromJson body
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Subs.searchRequestImdb : Text -> Text -> Text -> HttpRequest
Subs.searchRequestImdb apiKey imdbId languages =
  HttpRequest.get (imdbSearchURI apiKey imdbId languages)
    |> HttpRequest.addHeader "Accept" "application/json"

Subs.searchRequestTmdb : Text -> Nat -> Text -> HttpRequest
Subs.searchRequestTmdb apiKey tmdbId languages =
  HttpRequest.get (tmdbSearchURI apiKey tmdbId languages)
    |> HttpRequest.addHeader "Accept" "application/json"

Subs.SearchResponse.fromJson : '{unison_json_1_4_2.Decoder} Subs.SearchResponse
Subs.SearchResponse.fromJson =
  do
    use Decoder array optional!
    use Optional getOrElse
    use object at
    ok = object.at! "status" Decoder.boolean
    error = optional! (at "error" Decoder.text)
    results =
      getOrElse [] (optional! (at "results" (array MovieResult.fromJson)))
    subtitles =
      getOrElse [] (optional! (at "subtitles" (array SubtitleItem.fromJson)))
    Subs.SearchResponse.SearchResponse ok error results subtitles

Subs.SubtitleItem.downloadURI : SubtitleItem -> URI
Subs.SubtitleItem.downloadURI s = Subs.downloadURI (SubtitleItem.urlPath s)

Subs.SubtitleItem.fromJson : '{unison_json_1_4_2.Decoder} SubtitleItem
Subs.SubtitleItem.fromJson =
  do
    use Decoder boolean nat optional! text
    use Optional getOrElse
    use object at
    releaseName = getOrElse "" (optional! (at "release_name" text))
    fileName = getOrElse "" (optional! (at "name" text))
    urlPath = object.at! "url" text
    language = optional! (at "language" text)
    hi = optional! (at "hi" boolean)
    fullSeason = optional! (at "full_season" boolean)
    season = optional! (at "season" nat)
    episode = optional! (at "episode" nat)
    unpackFiles =
      getOrElse
        [] (optional! (at "unpack_files" (Decoder.array UnpackFile.fromJson)))
    SubtitleItem
      releaseName
      fileName
      urlPath
      language
      hi
      fullSeason
      season
      episode
      unpackFiles

Subs.tmdbSearchURI : Text -> Nat -> Text -> URI
Subs.tmdbSearchURI apiKey tmdbId languages =
  use Path /
  path = Path.root / "api" / "v1" / "subtitles"
  q =
    Query.empty
      & ("api_key", apiKey)
      & ("type", "movie")
      & ("subs_per_page", "30")
      & ("unpack", "1")
      & ("tmdb_id", Nat.toText tmdbId)
      & ("languages", languages)
  URI Scheme.https (Some Subs.apiAuthority) path (fromQuery q) Fragment.empty

Subs.tokenPath : Text
Subs.tokenPath = "/home/bismuth/.config/uniDork/sub-token"

Subs.UnpackFile.downloadURI : UnpackFile -> URI
Subs.UnpackFile.downloadURI uf = Subs.downloadURI (UnpackFile.urlPath uf)

Subs.UnpackFile.fromJson : '{unison_json_1_4_2.Decoder} UnpackFile
Subs.UnpackFile.fromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at at!
  fileNId = at! "file_n_id" text
  name = at! "name" text
  releaseName = getOrElse "" (optional! (at "release_name" text))
  language = at! "language" text
  format = at! "format" text
  hi = getOrElse false (optional! (at "hi" Decoder.boolean))
  size = getOrElse 0 (optional! (at "size" Decoder.nat))
  urlPath = at! "url" text
  UnpackFile fileNId name releaseName language format hi size urlPath

Subs.unpackIsHi : UnpackFile -> Boolean
Subs.unpackIsHi uf = UnpackFile.hearingImpaired uf

Subs.unpackIsSrt : UnpackFile -> Boolean
Subs.unpackIsSrt uf = Universal.eq (normLang (UnpackFile.format uf)) "srt"

Subs.unpackLanguageMatches : Text -> UnpackFile -> Boolean
Subs.unpackLanguageMatches target uf =
  Universal.eq (normLang (UnpackFile.language uf)) (normLang target)

Subtitle.fromJson : '{unison_json_1_4_2.Decoder} Subtitle
Subtitle.fromJson = do
  language = object.at! "language" Decoder.text
  Subtitle language

Subtitle.toJson : Subtitle -> Json
Subtitle.toJson s = Json.object [("language", Json.text (Subtitle.language s))]

subtitlesAsJson : [Subtitle] -> Text
subtitlesAsJson xs = Json.toText (Json.array (List.map Subtitle.toJson xs))

Taxonomy.fromJson : '{unison_json_1_4_2.Decoder} Taxonomy
Taxonomy.fromJson = do
  use Decoder array text
  use object at!
  genres = at! "genres" (array text)
  tags = at! "tags" (array text)
  countries = at! "countries" (array text)
  studios = at! "studios" (array text)
  directors = at! "directors" (array text)
  credits = at! "credits" (array text)
  Taxonomy genres tags countries studios directors credits

Taxonomy.toJson : Taxonomy -> Json
Taxonomy.toJson t =
  use Json array text
  use List map
  Json.object
    [ ("genres", array (map text (Taxonomy.genres t)))
    , ("tags", array (map text (Taxonomy.tags t)))
    , ("countries", array (map text (countries t)))
    , ("studios", array (map text (studios t)))
    , ("directors", array (map text (Taxonomy.directors t)))
    , ("credits", array (map text (Taxonomy.credits t)))
    ]

textAfter : Text -> Text -> Optional Text
textAfter sep t = match Text.indexOf sep t with
  None   -> None
  Some i -> Some (trim (Text.drop (i Nat.+ Text.size sep) t))

textBetween : Text -> Text -> Text -> Optional Text
textBetween startD endD t = match Text.indexOf startD t with
  None   -> None
  Some i ->
    use Nat +
    after = Text.drop (i + Text.size startD) t
    match Text.indexOf endD after with
      None   -> None
      Some j -> Some (Text.take j after)

textsAsJson : [Text] -> Text
textsAsJson xs = Json.toText (Json.array (List.map Json.text xs))

Title.fromJson : '{unison_json_1_4_2.Decoder} Title
Title.fromJson = do
  use Decoder text
  use object at!
  display = at! "display" text
  original = at! "original" text
  sort = at! "sort" text
  Title display original sort

Title.toJson : Title -> Json
Title.toJson t =
  use Json text
  Json.object
    [ ("display", text (display t))
    , ("original", text (original t))
    , ("sort", text (Title.sort t))
    ]

Tmdb.apiAuthority : Authority
Tmdb.apiAuthority = Authority None (HostName "api.themoviedb.org") None

Tmdb.buildParsedRelease : Text -> Optional Movie -> Optional ParsedRelease
Tmdb.buildParsedRelease folderName maybeNfo =
  nfoId = match maybeNfo with
    None   -> None
    Some m -> extractTmdbId m
  fromNfo = match maybeNfo with
    None   -> None
    Some m ->
      match (extractTitle m, extractYear m) with
        (Some t, Some y) -> Some (t, y)
        _                -> None
  match fromNfo with
    Some (t, y) -> Some (ParsedRelease folderName t y nfoId)
    None        ->
      match parseReleaseName folderName with
        None   -> None
        Some p -> Some (nfoTmdbId.set nfoId p)

Tmdb.cachedDetails : Text -> Nat ->{IO} Either Text MovieDetails
Tmdb.cachedDetails token tmdbId = match cachedDetailsRaw token tmdbId with
  Right raw ->
    match catch do Decoder.run MovieDetails.fromJson raw with
      Right v -> Right v
      Left f  -> Left (Failure.message f)
  Left e    -> Left e

Tmdb.cachedDetailsRaw : Text -> Nat ->{IO} Either Text Text
Tmdb.cachedDetailsRaw token tmdbId =
  fromCache = catch do readFileUtf8 (detailsCachePath tmdbId)
  match fromCache with
    Right raw -> Right raw
    Left _    ->
      match detailsRaw token tmdbId with
        Right raw ->
          _ = catch do writeFileUtf8 (detailsCachePath tmdbId) raw
          Right raw
        Left e    -> Left e

Tmdb.cachedDetailsWith :
  PreparedQuery r1 a1 Text
  -> PreparedCommand r a
  -> Text
  -> Nat
  ->{IO, Postgres} Either Text Details
Tmdb.cachedDetailsWith pq pc token tmdbId =
  parse body = match catch do Decoder.run Details.fromJson body with
    Right d -> Right d
    Left f  -> Left (Failure.message f)
  match readDetailsBodyWith pq tmdbId with
    Some body -> parse body
    None      ->
      match detailsRaw token tmdbId with
        Left err   -> Left err
        Right body ->
          _ = writeDetailsBodyWith pc tmdbId body
          parse body

Tmdb.cachedSearch :
  Text -> Text -> Text -> Nat ->{IO} Either Text Tmdb.SearchResponse
Tmdb.cachedSearch token sourcePath title year =
  match readDbCache sourcePath with
    Some cached -> cached
    None        ->
      result = Tmdb.search token title year
      _ = writeDbCache sourcePath title year result
      result

Tmdb.CachedSearch.fromJson : '{unison_json_1_4_2.Decoder} CachedSearch
Tmdb.CachedSearch.fromJson = do
  use Decoder optional! text
  use object at
  folder = object.at! "folder" text
  response = optional! (at "response" Tmdb.SearchResponse.fromJson)
  error = optional! (at "error" text)
  CachedSearch folder response error

Tmdb.CachedSearch.toJson : CachedSearch -> Json
Tmdb.CachedSearch.toJson c =
  use Json text
  use List ++
  base = [("folder", text (folder c))]
  resp = match CachedSearch.response c with
    Some r -> [("response", SearchResponse.toJson r)]
    None   -> []
  err = match CachedSearch.error c with
    Some e -> [("error", text e)]
    None   -> []
  Json.object (base ++ resp ++ err)

Tmdb.cachedSearchWith :
  PreparedQuery r1 a1 Text
  -> PreparedCommand r a
  -> Text
  -> Text
  -> Nat
  ->{IO, Postgres} Either Text Tmdb.SearchResponse
Tmdb.cachedSearchWith pq pc token title year =
  match readDbCacheWith pq title year with
    Some cached -> cached
    None        ->
      result = Tmdb.search token title year
      _ = writeDbCacheWith pc title year result
      result

Tmdb.cachePath : Text -> FilePath
Tmdb.cachePath folderName =
  use Text ++
  FilePath (Tmdb.cacheRoot ++ "/" ++ folderName ++ ".json")

Tmdb.cacheRoot : Text
Tmdb.cacheRoot = "/home/bismuth/.cache/uniDork/tmdb/search"

Tmdb.CastMember.fromJson : '{unison_json_1_4_2.Decoder} CastMember
Tmdb.CastMember.fromJson = do
  use Decoder nat optional! text
  use Optional getOrElse
  use object at at!
  id = at! "id" nat
  name = at! "name" text
  character = getOrElse "" (optional! (at "character" text))
  order = getOrElse 0 (optional! (at "order" nat))
  CastMember id name character order

Tmdb.castMemberFromJson : '{unison_json_1_4_2.Decoder} (Text, Text)
Tmdb.castMemberFromJson =
  do
    use Decoder text
    name = object.at! "name" text
    character =
      Optional.getOrElse "" (Decoder.optional! (object.at "character" text))
    (name, character)

Tmdb.cleanTitle : Text -> Text
Tmdb.cleanTitle t =
  use Nat >
  s1 = replaceAll "." " " t
  s2 = replaceAll "_" " " s1
  parts = Text.split ?\s s2
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  trim (Text.join " " nonEmpty)

Tmdb.Collection.fromJson : '{unison_json_1_4_2.Decoder} Collection
Tmdb.Collection.fromJson = do
  use object at!
  id = at! "id" Decoder.nat
  name = at! "name" Decoder.text
  Collection id name

Tmdb.Country.fromJson : '{unison_json_1_4_2.Decoder} Country
Tmdb.Country.fromJson = do
  use Decoder text
  use object at!
  code = at! "iso_3166_1" text
  name = at! "name" text
  Country code name

Tmdb.countryReleaseFromJson : '{unison_json_1_4_2.Decoder} (Text, [Text])
Tmdb.countryReleaseFromJson = do
  use object at!
  country = at! "iso_3166_1" Decoder.text
  releases = at! "release_dates" (Decoder.array singleCertFromJson)
  (country, releases)

Tmdb.Credits.fromJson : '{unison_json_1_4_2.Decoder} Credits
Tmdb.Credits.fromJson = do
  use Decoder array optional!
  use Optional getOrElse
  use object at
  cast = getOrElse [] (optional! (at "cast" (array CastMember.fromJson)))
  crew = getOrElse [] (optional! (at "crew" (array CrewMember.fromJson)))
  Credits cast crew

Tmdb.CrewMember.fromJson : '{unison_json_1_4_2.Decoder} CrewMember
Tmdb.CrewMember.fromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at at!
  id = at! "id" Decoder.nat
  name = at! "name" text
  job = getOrElse "" (optional! (at "job" text))
  department = getOrElse "" (optional! (at "department" text))
  CrewMember id name job department

Tmdb.crewMemberFromJson : '{unison_json_1_4_2.Decoder} (Text, Text, Text)
Tmdb.crewMemberFromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at
  name = object.at! "name" text
  job = getOrElse "" (optional! (at "job" text))
  department = getOrElse "" (optional! (at "department" text))
  (name, job, department)

Tmdb.Details.fromJson : '{unison_json_1_4_2.Decoder} Details
Tmdb.Details.fromJson =
  do
    use Decoder array nat optional! text
    use List filterMap find
    use Nat >
    use Optional getOrElse
    use Text size
    use Universal eq
    use object at at!
    tmdbId = at! "id" nat
    rawImdbId = getOrElse "" (optional! (at "imdb_id" text))
    imdbId = if eq (size rawImdbId) 0 then None else Some rawImdbId
    runtime = getOrElse 0 (optional! (at "runtime" nat))
    title = at! "title" text
    originalTitle = getOrElse "" (optional! (at "original_title" text))
    originalLanguage = getOrElse "" (optional! (at "original_language" text))
    overview = getOrElse "" (optional! (at "overview" text))
    tagline = getOrElse "" (optional! (at "tagline" text))
    releaseDate = getOrElse "" (optional! (at "release_date" text))
    voteAverage = getOrElse 0.0 (optional! (at "vote_average" Decoder.float))
    voteCount = getOrElse 0 (optional! (at "vote_count" nat))
    genres = getOrElse [] (optional! (at "genres" (array namedObjectFromJson)))
    countries =
      getOrElse
        [] (optional! (at "production_countries" (array isoCountryFromJson)))
    studios =
      getOrElse
        [] (optional! (at "production_companies" (array namedObjectFromJson)))
    collection = optional! (at "belongs_to_collection" do at! "name" text)
    releaseResults =
      getOrElse
        []
        (optional!
          (at "release_dates" do at! "results" (array countryReleaseFromJson)))
    certForUS = cases (c, _) -> eq c "US"
    nonEmpty c = size c > 0
    mpaa = match find certForUS releaseResults with
      Some (_, certs) ->
        match find nonEmpty certs with
          Some c -> c
          None   -> ""
      None            -> ""
    cast =
      getOrElse
        [] (optional! (at "credits" do at! "cast" (array castMemberFromJson)))
    crew =
      getOrElse
        [] (optional! (at "credits" do at! "crew" (array crewMemberFromJson)))
    isDirector = cases (n, j, _) -> if eq j "Director" then Some n else None
    isWriter = cases (n, _, d) -> if eq d "Writing" then Some n else None
    directors = distinctText (filterMap isDirector crew)
    writers = distinctText (filterMap isWriter crew)
    tags =
      getOrElse
        []
        (optional!
          (at "keywords" do at! "keywords" (array namedObjectFromJson)))
    Details
      tmdbId
      imdbId
      runtime
      title
      originalTitle
      originalLanguage
      overview
      tagline
      releaseDate
      voteAverage
      voteCount
      genres
      countries
      studios
      collection
      mpaa
      directors
      writers
      cast
      tags

Tmdb.detailsCachePath : Nat -> FilePath
Tmdb.detailsCachePath tmdbId =
  use Text ++
  FilePath (detailsCacheRoot ++ "/" ++ Nat.toText tmdbId ++ ".json")

Tmdb.detailsCacheRoot : Text
Tmdb.detailsCacheRoot = "/home/bismuth/.cache/uniDork/tmdb/details"

Tmdb.detailsFromResult : Tmdb.Result -> Details
Tmdb.detailsFromResult r =
  Details
    (Result.tmdbId r)
    None
    0
    (Result.title r)
    (Result.originalTitle r)
    (Result.originalLanguage r)
    (Result.overview r)
    ""
    (Result.releaseDate r)
    0.0
    0
    []
    []
    []
    None
    ""
    []
    []
    []
    []

Tmdb.detailsRaw : Text -> Nat ->{IO} Either Text Text
Tmdb.detailsRaw token tmdbId =
  req = detailsRequest token tmdbId
  match 
    catch do
      Threads.run do
        Http.run do
          resp = request req
          ok = ensureSuccess resp
          bodyText ok
   with
    Right v -> Right v
    Left f  -> Left (Failure.message f)

Tmdb.detailsRequest : Text -> Nat -> HttpRequest
Tmdb.detailsRequest token tmdbId =
  use HttpRequest addHeader
  use Text ++
  HttpRequest.get (detailsURI tmdbId)
    |> addHeader "Authorization" ("Bearer " ++ token)
    |> addHeader "Accept" "application/json"

Tmdb.detailsURI : Nat -> URI
Tmdb.detailsURI tmdbId =
  use Path /
  path = Path.root / "3" / "movie" / Nat.toText tmdbId
  q = Query.empty & ("append_to_response", "credits,release_dates,keywords")
  URI Scheme.https (Some Tmdb.apiAuthority) path (fromQuery q) Fragment.empty

Tmdb.ExternalIds.fromJson : '{unison_json_1_4_2.Decoder} ExternalIds
Tmdb.ExternalIds.fromJson = do
  imdb = Decoder.optional! (object.at "imdb_id" Decoder.text)
  ExternalIds imdb

Tmdb.findEnclosedYear : Text -> Text -> Text -> Optional (Text, Nat)
Tmdb.findEnclosedYear open close name =
  go offset =
    use Nat +
    use Text drop size take
    sub = drop offset name
    match Text.indexOf open sub with
      None -> None
      Some openIdx ->
        absOpen = offset + openIdx
        afterOpen = absOpen + size open
        cand = take 4 (drop afterOpen name)
        closeAt = afterOpen + 4
        match tokenAsYear cand with
          Some y ->
            actualClose = take (size close) (drop closeAt name)
            if Universal.eq actualClose close then
              Some (trim (take absOpen name), y)
            else go (absOpen + 1)
          None -> go (absOpen + 1)
  go 0

Tmdb.findEnclosedYearAny : Text -> Optional (Text, Nat)
Tmdb.findEnclosedYearAny name = match findEnclosedYear "(" ")" name with
  Some r -> Some r
  None   -> findEnclosedYear "[" "]" name

Tmdb.findYearIndex : [Text] -> Optional Nat
Tmdb.findYearIndex tokens =
  use Nat +
  pairs = withIndex tokens
  qualifying =
    List.filterMap
      (cases
        (i, t) ->
          match tokenAsYear t with
            None   -> None
            Some _ ->
              match Tmdb.nth (i + 1) tokens with
                Some next -> if isQualityToken next then Some i else None
                None      -> None) pairs
  List.head qualifying

Tmdb.Genre.fromJson : '{unison_json_1_4_2.Decoder} Genre
Tmdb.Genre.fromJson = do
  use object at!
  id = at! "id" Decoder.nat
  name = at! "name" Decoder.text
  Genre id name

Tmdb.isoCountryFromJson : '{unison_json_1_4_2.Decoder} Text
Tmdb.isoCountryFromJson = do object.at! "iso_3166_1" Decoder.text

Tmdb.isQualityToken : Text -> Boolean
Tmdb.isQualityToken t =
  lower = Text.toLowercase t
  List.any (q -> Universal.eq q lower) qualityTokens

Tmdb.maxScore : [(Tmdb.Result, Nat)] -> Optional Nat
Tmdb.maxScore xs =
  use Nat <
  step acc = cases
    (_, s) ->
      match acc with
        None   -> Some s
        Some a -> if a < s then Some s else Some a
  List.foldLeft step None xs

Tmdb.MovieDetails.castList : MovieDetails -> [CastMember]
Tmdb.MovieDetails.castList d = match MovieDetails.credits d with
  None   -> []
  Some c -> Credits.cast c

Tmdb.MovieDetails.directors : MovieDetails -> [CrewMember]
Tmdb.MovieDetails.directors d = match MovieDetails.credits d with
  None   -> []
  Some c -> List.filter (m -> Universal.eq (job m) "Director") (crew c)

Tmdb.MovieDetails.fromJson : '{unison_json_1_4_2.Decoder} MovieDetails
Tmdb.MovieDetails.fromJson =
  do
    use Decoder array nat optional! text
    use Optional getOrElse
    use object at at!
    id = at! "id" nat
    title = at! "title" text
    originalTitle = at! "original_title" text
    overview = getOrElse "" (optional! (at "overview" text))
    tagline = getOrElse "" (optional! (at "tagline" text))
    releaseDate = getOrElse "" (optional! (at "release_date" text))
    runtime = optional! (at "runtime" nat)
    voteAverage = getOrElse 0.0 (optional! (at "vote_average" Decoder.float))
    voteCount = getOrElse 0 (optional! (at "vote_count" nat))
    genres = getOrElse [] (optional! (at "genres" (array Genre.fromJson)))
    productionCountries =
      getOrElse
        [] (optional! (at "production_countries" (array Country.fromJson)))
    productionCompanies =
      getOrElse
        [] (optional! (at "production_companies" (array Studio.fromJson)))
    collection = optional! (at "belongs_to_collection" Collection.fromJson)
    posterPath = optional! (at "poster_path" text)
    backdropPath = optional! (at "backdrop_path" text)
    credits = optional! (at "credits" Credits.fromJson)
    releaseDates =
      getOrElse [] (optional! (at "release_dates" releaseDatesParser))
    externalIds = optional! (at "external_ids" ExternalIds.fromJson)
    MovieDetails
      id
      title
      originalTitle
      overview
      tagline
      releaseDate
      runtime
      voteAverage
      voteCount
      genres
      productionCountries
      productionCompanies
      collection
      posterPath
      backdropPath
      credits
      releaseDates
      externalIds

Tmdb.MovieDetails.imdb : MovieDetails -> Optional Text
Tmdb.MovieDetails.imdb d = match externalIds d with
  None   -> None
  Some e -> ExternalIds.imdbId e

Tmdb.MovieDetails.mpaa : MovieDetails -> Text
Tmdb.MovieDetails.mpaa d =
  use List find
  use Nat >
  rds = releaseDates d
  isUs = cases r -> Universal.eq (country r) "US"
  hasCert = cases r -> Text.size (certification r) > 0
  match find (r -> isUs r && hasCert r) rds with
    Some r -> certification r
    None ->
      Optional.getOrElse "" (Optional.map certification (find hasCert rds))

Tmdb.MovieDetails.writers : MovieDetails -> [CrewMember]
Tmdb.MovieDetails.writers d = match MovieDetails.credits d with
  None   -> []
  Some c -> List.filter (m -> Universal.eq (department m) "Writing") (crew c)

Tmdb.namedObjectFromJson : '{unison_json_1_4_2.Decoder} Text
Tmdb.namedObjectFromJson = do object.at! "name" Decoder.text

Tmdb.normalize : Text -> Text
Tmdb.normalize t =
  use List foldLeft
  use Nat >
  use Text drop
  lower = Text.toLowercase t
  dropChars = ["'", "\"", "`", "‘", "’", "“", "”"]
  spaceChars =
    [ "."
    , ","
    , ":"
    , "꞉"
    , "ː"
    , ";"
    , "!"
    , "?"
    , "("
    , ")"
    , "["
    , "]"
    , "{"
    , "}"
    , "-"
    , "–"
    , "—"
    , "_"
    , "&"
    , "/"
    ]
  dropped = foldLeft (acc c -> replaceAll c "" acc) lower dropChars
  noPunct = foldLeft (acc p -> replaceAll p " " acc) dropped spaceChars
  parts = Text.split ?\s noPunct
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  joined = Text.join " " nonEmpty
  if startsWith "the " joined then drop 4 joined
  else
    if startsWith "an " joined then drop 3 joined
    else if startsWith "a " joined then drop 2 joined else joined

test> Tmdb.normalize.unicode.test =
  use Tmdb normalize
  use Universal eq
  List.flatMap
    check
    [ eq (normalize "Avatar꞉ Fire and Ash") "avatar fire and ash"
    , eq (normalize "Avatar: Fire and Ash") "avatar fire and ash"
    , eq (normalize "Movie—Title") "movie title"
    , eq (normalize "Don’t Look Up") "dont look up"
    , eq (normalize "The Matrix") "matrix"
    ]

Tmdb.nth : Nat -> [a] -> Optional a
Tmdb.nth i xs = List.head (List.drop i xs)

Tmdb.parseReleaseName : Text -> Optional ParsedRelease
Tmdb.parseReleaseName name =
  match findEnclosedYearAny name with
    Some (titlePrefix, year) ->
      cleaned = cleanTitle titlePrefix
      if Universal.eq (Text.size cleaned) 0 then None
      else Some (ParsedRelease name cleaned year None)
    None ->
      tokens = tokenize name
      match findYearIndex tokens with
        None -> None
        Some i ->
          match Tmdb.nth i tokens with
            None -> None
            Some yt ->
              match tokenAsYear yt with
                None -> None
                Some y ->
                  titleStr = trim (Text.join " " (List.take i tokens))
                  if Universal.eq (Text.size titleStr) 0 then None
                  else Some (ParsedRelease name titleStr y None)

Tmdb.pickBest : [(Tmdb.Result, Nat)] -> Optional (Tmdb.Result, Nat)
Tmdb.pickBest scored =
  use Float *
  threshold = 40
  popularityRatio = 3.0
  belowThreshold n = n Nat.< threshold
  popularityClearWinner winner second =
    second * popularityRatio Float.< popularity winner
  match maxScore scored with
    None -> None
    Some best ->
      if belowThreshold best then None
      else
        tied = List.filter (cases (_, s) -> Universal.eq s best) scored
        match tied with
          [] -> None
          [only] -> Some only
          _ ->
            match popularityWinner tied with
              Some (winner, second) ->
                (rWinner, _) = winner
                if popularityClearWinner rWinner second then Some winner
                else None
              None -> None

Tmdb.pickBestWithRuntime :
  PreparedQuery r1 a1 Text
  -> PreparedCommand r a
  -> Text
  -> Optional Nat
  -> [(Tmdb.Result, Nat)]
  ->{IO, Postgres} Optional (Tmdb.Result, Nat)
Tmdb.pickBestWithRuntime pqDet pcDet token maybeProbeMin scored =
  use Float *
  threshold = 40
  popularityRatio = 3.0
  belowThreshold n = n Nat.< threshold
  popularityClearWinner winner second =
    second * popularityRatio Float.< popularity winner
  match maxScore scored with
    None -> None
    Some best ->
      if belowThreshold best then None
      else
        tied = List.filter (cases (_, s) -> Universal.eq s best) scored
        match tied with
          [] -> None
          [only] -> Some only
          _ ->
            runtimePick = match maybeProbeMin with
              Some probeMin -> runtimeWinner pqDet pcDet token probeMin tied
              None          -> None
            match runtimePick with
              Some w -> Some w
              None ->
                match popularityWinner tied with
                  Some (winner, second) ->
                    (rWinner, _) = winner
                    if popularityClearWinner rWinner second then Some winner
                    else None
                  None -> None

Tmdb.popularityWinner :
  [(Tmdb.Result, Nat)] -> Optional ((Tmdb.Result, Nat), Float)
Tmdb.popularityWinner tied =
  use Float >
  step acc cur =
    (rCur, _) = cur
    pCur = popularity rCur
    match acc with
      None -> Some (cur, 0.0)
      Some (best, runnerUp) ->
        (rBest, _) = best
        pBest = popularity rBest
        if pCur > pBest then Some (cur, pBest)
        else
          if pCur > runnerUp then Some (best, pCur) else Some (best, runnerUp)
  List.foldLeft step None tied

Tmdb.printCandidate : (Tmdb.Result, Nat) ->{IO, Exception} ()
Tmdb.printCandidate = cases
  (r, score) ->
    use Nat >=
    label =
      if Universal.eq score 100 then "[100%]"
      else
        if score >= 80 then "[ 80%]"
        else
          if score >= 50 then "[ 50%]"
          else if score >= 40 then "[ 40%]" else "[ low]"
    yearText = match releaseYear (Result.releaseDate r) with
      Some y -> Nat.toText y
      None   -> "????"
    printLine
      (Text.join
        ""
        [ "    "
        , label
        , " ("
        , Nat.toText score
        , "%) tmdb:"
        , Nat.toText (Result.tmdbId r)
        , " \""
        , Result.title r
        , "\" ("
        , yearText
        , ") pop="
        , Float.toText (popularity r)
        ])

