test> Subs.parseShape.test =
  match
    catch do
      Decoder.run Subs.SearchResponse.fromJson Subs.exampleSearchJson
  with
    Left f  -> [Fail (Failure.message f)]
    Right r ->
      use Subs.SearchResponse ok results subtitles
      use Universal eq
      List.flatMap
        check
        [ ok r
        , eq (List.size (results r)) 1
        , eq (List.size (subtitles r)) 3
        ]

test> Subs.parseMovieFields.test =
  match
    catch do
      Decoder.run Subs.SearchResponse.fromJson Subs.exampleSearchJson
  with
    Left f  -> [Fail (Failure.message f)]
    Right r ->
      use Universal eq
      match List.head (Subs.SearchResponse.results r) with
        None   -> [Fail "no movie result"]
        Some m ->
          List.flatMap
            check
            [ eq (Subs.MovieResult.imdbId m) (Some "tt1375666")
            , eq (Subs.MovieResult.tmdbId m) (Some 27205)
            , eq (Subs.MovieResult.sdId m) (Some 123456)
            , eq (Subs.MovieResult.name m) "Inception"
            , eq (Subs.MovieResult.kind m) "movie"
            , eq (Subs.MovieResult.year m) (Some 2010)
            ]

test> Subs.pickBestPrefersNonHi.test =
  match
    catch do
      Decoder.run Subs.SearchResponse.fromJson Subs.exampleSearchJson
  with
    Left f  -> [Fail (Failure.message f)]
    Right r ->
      subs = Subs.SearchResponse.subtitles r
      match Subs.pickBestForMovie "EN" subs with
        None         -> [Fail "expected a pick"]
        Some chosen ->
          use Universal eq
          List.flatMap
            check
            [ eq (Subs.SubtitleItem.urlPath chosen) "/subtitle/1111-2222.zip"
            , eq (Subs.isHi chosen) false
            , eq (Subs.SubtitleItem.language chosen) (Some "EN")
            ]

test> Subs.pickBestFallsBackToHi.test =
  hi : Subs.SubtitleItem
  hi =
    Subs.SubtitleItem.SubtitleItem
      "HI release"
      "hi.srt"
      "/subtitle/x.zip"
      (Some "EN")
      (Some true)
      (Some false)
      None
      None
      []
  match Subs.pickBestForMovie "EN" [hi] with
    None        -> [Fail "should have picked the HI track as fallback"]
    Some chosen ->
      check (Universal.eq (Subs.SubtitleItem.urlPath chosen) "/subtitle/x.zip")

test> Subs.pickBestDropsFullSeason.test =
  pack : Subs.SubtitleItem
  pack =
    Subs.SubtitleItem.SubtitleItem
      "Season Pack"
      "s1.zip"
      "/subtitle/pack.zip"
      (Some "EN")
      (Some false)
      (Some true)
      (Some 1)
      (Some 1)
      []
  match Subs.pickBestForMovie "EN" [pack] with
    Some _ -> [Fail "should have dropped the full-season pack"]
    None   -> check true

test> Subs.pickBestEmpty.test =
  match Subs.pickBestForMovie "EN" [] with
    Some _ -> [Fail "empty input should yield None"]
    None   -> check true

test> Subs.pickBestLanguageFallback.test =
  fr : Subs.SubtitleItem
  fr =
    Subs.SubtitleItem.SubtitleItem
      "Only French"
      "fr.srt"
      "/subtitle/fr.zip"
      (Some "FR")
      (Some false)
      (Some false)
      None
      None
      []
  match Subs.pickBestForMovie "EN" [fr] with
    None        -> [Fail "should fall back to the full pool"]
    Some chosen ->
      check (Universal.eq (Subs.SubtitleItem.urlPath chosen) "/subtitle/fr.zip")

test> Subs.parseUnpacked.test =
