Tmdb.writeCacheEntry : Text -> Either Text Tmdb.SearchResponse ->{IO} ()
Tmdb.writeCacheEntry folderName result =
  entry = match result with
    Right r -> CachedSearch folderName (Some r) None
    Left e  -> CachedSearch folderName None (Some e)
  payload = Json.toText (CachedSearch.toJson entry)
  _ = catch do writeFileUtf8 (cachePath folderName) payload
  ()

Tmdb.writeDbCache :
  Text -> Text -> Nat -> Either Text Tmdb.SearchResponse ->{IO} ()
Tmdb.writeDbCache sourcePath title year result =
  use List ++
  entry = match result with
    Right r -> CachedSearch sourcePath (Some r) None
    Left e  -> CachedSearch sourcePath None (Some e)
  payload = Json.toText (CachedSearch.toJson entry)
  _ = 
    catch do
      singleIO Db.config do
        pc = prepareCommand upsertSearchSql
        _ =
          bindAndExecuteCommand
            pc
            (pt sourcePath ++ pt title ++ Db.pi (Nat.toInt year) ++ pt payload)
        PreparedCommand.close pc
  ()

Tmdb.writeDbCacheWith :
  PreparedCommand r a1
  -> Text
  -> Nat
  -> Either a Tmdb.SearchResponse
  ->{Postgres} ()
Tmdb.writeDbCacheWith pc title year = cases
  Left _ -> ()
  Right r ->
    use List ++
    entry = CachedSearch title (Some r) None
    payload = Json.toText (CachedSearch.toJson entry)
    _ = 
      catch do
        bindAndExecuteCommand
          pc (pt title ++ Db.pi (Nat.toInt year) ++ pt payload)
    ()

Tmdb.writeDetailsBodyWith : PreparedCommand r a -> Nat -> Text ->{Postgres} ()
Tmdb.writeDetailsBodyWith pc tmdbId body =
  match catch do Decoder.run Details.fromJson body with
    Left _ -> ()
    Right d ->
      use Db pi
      use Details runtime
      use List ++
      use Nat toInt
      yearOpt = match releaseYear (Details.releaseDate d) with
        Some y -> Some (toInt y)
        None   -> None
      runtimeOpt =
        if Universal.eq (runtime d) 0 then None else Some (toInt (runtime d))
      _ = 
        catch do
          bindAndExecuteCommand
            pc
            (pi (toInt tmdbId)
              ++ pot (Details.imdbId d)
              ++ pot None
              ++ pt (Details.title d)
              ++ pt (Details.originalTitle d)
              ++ pt (Details.originalLanguage d)
              ++ poi yearOpt
              ++ poi runtimeOpt
              ++ pt (Details.overview d)
              ++ pt (Details.tagline d)
              ++ pt (Details.mpaa d)
              ++ pf (Details.voteAverage d)
              ++ pi (toInt (Details.voteCount d))
              ++ pot (Details.collection d)
              ++ pt body)
      ()

toJsonOpt : (a ->{g} Json) -> Optional a ->{g} Json
toJsonOpt f = cases
  None   -> Json.null
  Some a -> f a

tryXml : '{Throw XMLError} a -> Optional a
tryXml = Throw.toOptional

uniDork.batchedMain : Text ->{IO, Exception} ()
uniDork.batchedMain configPath =
  use List size
  use Nat toText
  use Text join
  configText = readFileUtf8 (FilePath configPath)
  dirs = List.filterMap parseConfigLine (lines configText)
  _ = createSchema()
  _ = printLine "collecting folders..."
  folders = collectFolders dirs
  total = size folders
  _ = printLine (join "" ["found ", toText total, " folders to process"])
  batches = List.chunk batchSize folders
  nBatches = size batches
  _ =
    printLine
      (join
        ""
        [ "processing in "
        , toText nBatches
        , " batches of (up to) "
        , toText batchSize
        ])
  step i batch =
    use Nat +
    _ = runBatchSafe i nBatches batch
    i + 1
  _ = List.foldLeft step 1 batches
  printLine "done"

uniDork.batchedRun : '{IO, Exception} ()
uniDork.batchedRun = do
  args = getArgs()
  configPath = match args with
    _ +: rest ->
      match rest with
        p +: _ -> p
        []     -> "./uniDork.conf"
    []        -> "./uniDork.conf"
  batchedMain configPath

uniDork.batchSize : Nat
uniDork.batchSize = 50

uniDork.collectFolders : [FilePath] ->{IO, Exception} [FilePath]
uniDork.collectFolders roots =
  addIfDir : FilePath -> [FilePath] -> Text ->{IO, Exception} [FilePath]
  addIfDir root acc name =
    use List +:
    fp = pathJoin root name
    if isDirectory fp then fp +: acc else acc
  perRoot root =
    basenames = directoryContents.texts root
    _ =
      printLine
        (Text.join
          ""
          [ "scanning: "
          , filePathText root
          , " ("
          , Nat.toText (List.size basenames)
          , " entries)"
          ])
    List.reverse (List.foldLeft (addIfDir root) [] basenames)
  List.flatMap perRoot roots

uniDork.identify : '{IO, Exception} ()
uniDork.identify =
  do
    use Db foreach_
    use List size
    use Nat toText
    use PreparedCommand close
    use Text ++
    use Universal eq
    staging = FilePath stagingDir
    if isDirectory staging then
      token = Tmdb.readToken()
      entries = directoryContents.texts staging
      folderNames =
        List.filter
          (n ->
            (if eq n "." then false
            else if eq n ".." then false else isDirectory (pathJoin staging n)))
          entries
      folders = List.map (n -> pathJoin staging n) folderNames
      loose = looseVideos staging
      _ =
        printLine
          (Text.join
            ""
            [ "scanning "
            , toText (size folders)
            , " folder(s) and "
            , toText (size loose)
            , " loose video(s) under "
            , stagingDir
            ])
      _ = printLine ""
      singleIO Db.config do
        pq = prepareQuery selectSearchSql
        pc = prepareCommand upsertSearchSql
        pqStage = prepareQuery selectProbeSql
        pqDet = prepareQuery selectDetailsSql
        pcDet = prepareCommand upsertDetailsSql
        _ = foreach_ (reportFolderWith pq pc pqStage pqDet pcDet token) folders
        _ =
          foreach_ (reportLooseVideoWith pq pc pqStage pqDet pcDet token) loose
        _ = close pc
        close pcDet
    else printLine ("staging not found: " ++ stagingDir)

uniDork.processBatch : [FilePath] ->{IO, Exception} ()
uniDork.processBatch folders = 
  singleIO Db.config do
    use PreparedCommand close
    pcUpsert = prepareCommand upsertMovieSql
    pcVid = prepareCommand insertVideoSql
    pcDVid = prepareCommand (deleteChildSql "movie_video_streams")
    pcAud = prepareCommand insertAudioSql
    pcDAud = prepareCommand (deleteChildSql "movie_audio_tracks")
    pcSub = prepareCommand insertSubSql
    pcDSub = prepareCommand (deleteChildSql "movie_subtitles")
    pcAct = prepareCommand insertActorSql
    pcDAct = prepareCommand (deleteChildSql "movie_actors")
    pcGen = prepareCommand insertGenreSql
    pcDGen = prepareCommand (deleteChildSql "movie_genres")
    pcTag = prepareCommand insertTagSql
    pcDTag = prepareCommand (deleteChildSql "movie_tags")
    pcCou = prepareCommand insertCountrySql
    pcDCou = prepareCommand (deleteChildSql "movie_countries")
    pcStu = prepareCommand insertStudioSql
    pcDStu = prepareCommand (deleteChildSql "movie_studios")
    pcDir = prepareCommand insertDirectorSql
    pcDDir = prepareCommand (deleteChildSql "movie_directors")
    pcCre = prepareCommand insertCreditSql
    pcDCre = prepareCommand (deleteChildSql "movie_credits")
    _ =
      Db.foreach_
        (processOne
          pcUpsert
          pcVid
          pcDVid
          pcAud
          pcDAud
          pcSub
          pcDSub
          pcAct
          pcDAct
          pcGen
          pcDGen
          pcTag
          pcDTag
          pcCou
          pcDCou
          pcStu
          pcDStu
          pcDir
          pcDDir
          pcCre
          pcDCre)
        folders
    _ = close pcUpsert
    _ = close pcVid
    _ = close pcDVid
    _ = close pcAud
    _ = close pcDAud
    _ = close pcSub
    _ = close pcDSub
    _ = close pcAct
    _ = close pcDAct
    _ = close pcGen
    _ = close pcDGen
    _ = close pcTag
    _ = close pcDTag
    _ = close pcCou
    _ = close pcDCou
    _ = close pcStu
    _ = close pcDStu
    _ = close pcDir
    _ = close pcDDir
    _ = close pcCre
    close pcDCre

uniDork.processOne :
  PreparedCommand r20 a20
  -> PreparedCommand r19 a19
  -> PreparedCommand r18 a18
  -> PreparedCommand r17 a17
  -> PreparedCommand r16 a16
  -> PreparedCommand r15 a15
  -> PreparedCommand r14 a14
  -> PreparedCommand r13 a13
  -> PreparedCommand r12 a12
  -> PreparedCommand r11 a11
  -> PreparedCommand r10 a10
  -> PreparedCommand r9 a9
  -> PreparedCommand r8 a8
  -> PreparedCommand r7 a7
  -> PreparedCommand r6 a6
  -> PreparedCommand r5 a5
  -> PreparedCommand r4 a4
  -> PreparedCommand r3 a3
  -> PreparedCommand r2 a2
  -> PreparedCommand r1 a1
  -> PreparedCommand r a
  -> FilePath
  ->{IO, Exception, Postgres} ()
uniDork.processOne
  pcUpsert
  pcVid
  pcDVid
  pcAud
  pcDAud
  pcSub
  pcDSub
  pcAct
  pcDAct
  pcGen
  pcDGen
  pcTag
  pcDTag
  pcCou
  pcDCou
  pcStu
  pcDStu
  pcDir
  pcDDir
  pcCre
  pcDCre
  folder =
  match processFolder folder with
    Left _ ->
      _ = printLine (Text.join "" ["  no nfo: ", filePathText folder])
      ()
    Right m ->
      actualRuntime = match videoFilePath m with
        None         -> None
        Some vidPath ->
          match Probe.readSidecar vidPath with
            None   -> None
            Some r -> Some (runtimeSec r)
      upsertWith
        pcUpsert
        pcVid
        pcDVid
        pcAud
        pcDAud
        pcSub
        pcDSub
        pcAct
        pcDAct
        pcGen
        pcDGen
        pcTag
        pcDTag
        pcCou
        pcDCou
        pcStu
        pcDStu
        pcDir
        pcDDir
        pcCre
        pcDCre
        actualRuntime
        m

uniDork.renameGo : '{IO, Exception} ()
uniDork.renameGo =
  renameNewCombined
    "{ny} [{gigabytes}.{vf}.{vc}.{bitdepth}b.{minutes}min] ~{crc32}/{ny} [{vc}_{bitdepth}b_{resolution}_{mbps}_{ac}-{channels}] ~{crc32}"

uniDork.renameNewCombined : Text -> '{IO, Exception} ()
uniDork.renameNewCombined fullFormat =
  do
    use List reverse
    parts = Text.split ?/ fullFormat
    match reverse parts with
      [] ->
        _ = printLine "empty format"
        ()
      [_] ->
        _ =
          printLine
            "format must contain '/' separating folder and file templates"
        ()
      fileFmt +: folderParts ->
        folderFmt = Text.join "/" (reverse folderParts)
        runNew folderFmt fileFmt ()

uniDork.runBatchSafe : Nat -> Nat -> [FilePath] ->{IO, Exception} ()
uniDork.runBatchSafe i n batch =
  use Nat toText
  use Text join
  _ =
    printLine
      (join
        ""
        [ "batch "
        , toText i
        , "/"
        , toText n
        , " ("
        , toText (List.size batch)
        , " folders)"
        ])
  match catch do processBatch batch with
    Right _ -> ()
    Left f  -> printLine (join "" ["  BATCH FAILED: ", Failure.message f])

Video.fromJson : '{unison_json_1_4_2.Decoder} Video
Video.fromJson = do
  use Decoder nat
  use object at!
  codec = at! "codec" Decoder.text
  aspect = at! "aspect" Decoder.float
  width = at! "width" nat
  height = at! "height" nat
  Video.Video codec aspect width height

Video.toJson : Video -> Json
Video.toJson v =
  use Json nat
  Json.object
    [ ("codec", Json.text (Video.codec v))
    , ("aspect", Json.float (aspect v))
    , ("width", nat (Video.width v))
    , ("height", nat (Video.height v))
    ]

videoExtensions : [Text]
videoExtensions = [".mkv", ".mp4", ".avi", ".mov", ".wmv", ".flv"]

