Rename.tighten : Text -> Text
Rename.tighten t =
  t
    |> collapseSpaces
    |> shrink "__" "_"
    |> replaceAll "_]" "]"
    |> replaceAll "[_" "["
    |> replaceAll "_ " " "
    |> replaceAll " _" " "
    |> trim

test> Rename.tighten.test =
  use Universal eq
  List.flatMap
    check
    [ eq (tighten "hello  world") "hello world"
    , eq (tighten "  hello   world  ") "hello world"
    , eq (tighten "a__b") "a_b"
    , eq (tighten "a___b") "a_b"
    , eq (tighten "[x_y_]") "[x_y]"
    , eq (tighten "[_x_y]") "[x_y]"
    ]

Rename.titleYear : Tmdb.Result -> Text
Rename.titleYear r =
  use Text ++
  yearText = match releaseYear (Result.releaseDate r) with
    Some y -> Nat.toText y
    None   -> "0000"
  sanitize (Result.title r) ++ " (" ++ yearText ++ ")"

Rename.titleYearM : MovieRecord -> Text
Rename.titleYearM m =
  use Text ++
  yearText = match MovieRecord.year m with
    Some y -> Nat.toText y
    None   -> "0000"
  sanitize (MovieRecord.title m) ++ " (" ++ yearText ++ ")"

Rename.toMovieRecord : RenameRow -> MovieRecord
Rename.toMovieRecord row =
  MovieRecord
    (RenameRow.tmdbId row)
    (RenameRow.imdbId row)
    (RenameRow.title row)
    (RenameRow.year row)

Rename.vcTag : Text -> Text
Rename.vcTag raw =
  use Universal eq
  lower = Text.toLowercase raw
  if eq lower "hevc" then "x265"
  else
    if eq lower "h265" then "x265"
    else
      if eq lower "h264" then "x264"
      else
        if eq lower "avc" then "x264"
        else
          if eq lower "av1" then "av1"
          else
            if eq lower "vp9" then "vp9"
            else if eq lower "mpeg4" then "xvid" else lower

test> Rename.vcTag.test =
  use Universal eq
  List.flatMap
    check
    [ eq (vcTag "hevc") "x265"
    , eq (vcTag "HEVC") "x265"
    , eq (vcTag "h264") "x264"
    , eq (vcTag "av1") "av1"
    ]

Rename.vfTag : Nat -> Nat -> Text
Rename.vfTag width height =
  use Nat >=
  if width >= 3000 || height >= 1700 then "2160p"
  else
    if width >= 2300 || height >= 1300 then "1440p"
    else
      if width >= 1800 || height >= 800 then "1080p"
      else
        if width >= 1100 || height >= 700 then "720p"
        else
          if height >= 540 then "576p"
          else if height >= 380 then "480p" else "SD"

test> Rename.vfTag.test =
  use Universal eq
  List.flatMap
    check
    [ eq (vfTag 3840 2160) "2160p"
    , eq (vfTag 3840 2080) "2160p"
    , eq (vfTag 1920 1080) "1080p"
    , eq (vfTag 1920 800) "1080p"
    , eq (vfTag 1920 1040) "1080p"
    , eq (vfTag 1280 720) "720p"
    , eq (vfTag 720 576) "576p"
    , eq (vfTag 720 404) "480p"
    , eq (vfTag 640 360) "SD"
    ]

Rename.writeOutcome : Text -> Rename.Outcome ->{IO, Exception} ()
Rename.writeOutcome _unused o =
  use List ++
  (src, outcome, target, reason) = parts o
  _ = 
    catch do
      singleIO Db.config do
        pc = prepareCommand insertLogSql
        _ =
          bindAndExecuteCommand
            pc (pt src ++ pt outcome ++ pot target ++ pot reason)
        PreparedCommand.close pc
  ()

Rename.writeOutcomeWith : PreparedCommand r a -> Rename.Outcome ->{Postgres} ()
Rename.writeOutcomeWith pc o =
  use List ++
  (src, outcome, target, reason) = parts o
  _ = 
    catch do
      bindAndExecuteCommand
        pc (pt src ++ pt outcome ++ pot target ++ pot reason)
  ()

