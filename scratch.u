type MovieId
  = { kodi : Text,
      imdb : Optional Text,
      tmdb : Optional Text,
      tvdb : Optional Text }

type Title
  = { display : Text, original : Text, sort : Text }

type Scoring
  = { year : Optional Nat, rating : Float, votes : Nat, mpaa : Text }

type Taxonomy
  = { genres : [Text],
      tags : [Text],
      countries : [Text],
      studios : [Text],
      directors : [Text],
      credits : [Text] }

type Video
  = { codec : Text, aspect : Float, width : Nat, height : Nat }

type Audio
  = { codec : Text, language : Text, channels : Nat }

type Subtitle
  = { language : Text }

type StreamDetails
  = { video : Video, audios : [Audio], subtitles : [Subtitle] }

type FileInfo
  = { streams : StreamDetails }

type Actor
  = { name : Text, role : Text }

type FolderMeta
  = { rawSize : Optional Text,
      resolution : Optional Text,
      videoCodec : Optional Text,
      bitDepth : Optional Nat,
      runtimeMin : Optional Nat,
      checksum : Optional Text }

type Movie
  = { id : MovieId,
      title : Title,
      collection : Optional Text,
      runtime : Optional Nat,
      scoring : Scoring,
      plot : Text,
      tagline : Text,
      taxonomy : Taxonomy,
      fileInfo : FileInfo,
      videoFilePath : Optional Text,
      checksum : Optional Text,
      actors : [Actor],
      folderPath : Optional Text,
      nfoPath : Optional Text,
      fileSizeBytes : Optional Nat,
      folderMeta : FolderMeta }

emptyFolderMeta : FolderMeta
emptyFolderMeta = FolderMeta.FolderMeta None None None None None None

exampleMovie : Movie
exampleMovie =
  use Actor Actor
  Movie.Movie
    (MovieId.MovieId "tt0167260" (Some "tt0167260") (Some "122") None)
    (Title.Title
      "The Lord of the Rings: The Return of the King"
      "The Lord of the Rings: The Return of the King"
      "Lord of the Rings, The: The Return of the King")
    (Some "The Lord of the Rings Collection")
    (Some 201)
    (Scoring.Scoring (Some 2003) 8.9 12000 "PG-13")
    "Aragorn leads the World of Men against Sauron's army..."
    "The eye of the enemy is moving."
    (Taxonomy.Taxonomy
      ["Adventure", "Fantasy"]
      []
      ["New Zealand", "United States"]
      ["New Line Cinema"]
      ["Peter Jackson"]
      ["Fran Walsh"])
    (FileInfo.FileInfo
      (StreamDetails.StreamDetails
        (Video.Video "h264" 2.39 1920 800)
        [Audio.Audio "ac3" "eng" 6]
        [Subtitle.Subtitle "eng"]))
    (Some "/movies/lotr-rotk/lotr-rotk.mkv")
    (Some "a3f1c9")
    [Actor "Elijah Wood" "Frodo Baggins", Actor "Viggo Mortensen" "Aragorn"]
    (Some "/movies/lotr-rotk")
    (Some "/movies/lotr-rotk/lotr-rotk.nfo")
    None
    emptyFolderMeta

toJsonOpt : (a -> Json) -> Optional a -> Json
toJsonOpt f = cases
  None   -> Json.null
  Some a -> f a

Title.toJson : Title -> Json
Title.toJson t =
  use Json text
  Json.object
    [ ("display", text (Title.display t))
    , ("original", text (Title.original t))
    , ("sort", text (Title.sort t))
    ]

MovieId.toJson : MovieId -> Json
MovieId.toJson m =
  use Json text
  Json.object
    [ ("kodi", text (MovieId.kodi m))
    , ("imdb", toJsonOpt text (MovieId.imdb m))
    , ("tmdb", toJsonOpt text (MovieId.tmdb m))
    , ("tvdb", toJsonOpt text (MovieId.tvdb m))
    ]

Scoring.toJson : Scoring -> Json
Scoring.toJson s =
  use Json nat
  Json.object
    [ ("year", toJsonOpt nat (Scoring.year s))
    , ("rating", Json.float (Scoring.rating s))
    , ("votes", nat (Scoring.votes s))
    , ("mpaa", Json.text (Scoring.mpaa s))
    ]

Taxonomy.toJson : Taxonomy -> Json
Taxonomy.toJson t =
  use Json array text
  use List map
  Json.object
    [ ("genres", array (map text (Taxonomy.genres t)))
    , ("tags", array (map text (Taxonomy.tags t)))
    , ("countries", array (map text (Taxonomy.countries t)))
    , ("studios", array (map text (Taxonomy.studios t)))
    , ("directors", array (map text (Taxonomy.directors t)))
    , ("credits", array (map text (Taxonomy.credits t)))
    ]

Video.toJson : Video -> Json
Video.toJson v =
  use Json nat
  Json.object
    [ ("codec", Json.text (Video.codec v))
    , ("aspect", Json.float (Video.aspect v))
    , ("width", nat (Video.width v))
    , ("height", nat (Video.height v))
    ]

Audio.toJson : Audio -> Json
Audio.toJson a =
  use Json text
  Json.object
    [ ("codec", text (Audio.codec a))
    , ("language", text (Audio.language a))
    , ("channels", Json.nat (Audio.channels a))
    ]

Subtitle.toJson : Subtitle -> Json
Subtitle.toJson s = Json.object [("language", Json.text (Subtitle.language s))]

StreamDetails.toJson : StreamDetails -> Json
StreamDetails.toJson s =
  use Json array
  use List map
  Json.object
    [ ("video", Video.toJson (StreamDetails.video s))
    , ("audios", array (map Audio.toJson (StreamDetails.audios s)))
    , ("subtitles", array (map Subtitle.toJson (StreamDetails.subtitles s)))
    ]

FileInfo.toJson : FileInfo -> Json
FileInfo.toJson f =
  Json.object [("streams", StreamDetails.toJson (FileInfo.streams f))]

Actor.toJson : Actor -> Json
Actor.toJson a =
  use Json text
  Json.object [("name", text (Actor.name a)), ("role", text (Actor.role a))]

FolderMeta.toJson : FolderMeta -> Json
FolderMeta.toJson f =
  use Json nat text
  Json.object
    [ ("rawSize", toJsonOpt text (FolderMeta.rawSize f))
    , ("resolution", toJsonOpt text (FolderMeta.resolution f))
    , ("videoCodec", toJsonOpt text (FolderMeta.videoCodec f))
    , ("bitDepth", toJsonOpt nat (FolderMeta.bitDepth f))
    , ("runtimeMin", toJsonOpt nat (FolderMeta.runtimeMin f))
    , ("checksum", toJsonOpt text (FolderMeta.checksum f))
    ]

Movie.toJson : Movie -> Json
Movie.toJson m =
  use Json nat text
  Json.object
    [ ("id", MovieId.toJson (Movie.id m))
    , ("title", Title.toJson (Movie.title m))
    , ("collection", toJsonOpt text (Movie.collection m))
    , ("runtime", toJsonOpt nat (Movie.runtime m))
    , ("scoring", Scoring.toJson (Movie.scoring m))
    , ("plot", text (Movie.plot m))
    , ("tagline", text (Movie.tagline m))
    , ("taxonomy", Taxonomy.toJson (Movie.taxonomy m))
    , ("fileInfo", FileInfo.toJson (Movie.fileInfo m))
    , ("videoFilePath", toJsonOpt text (Movie.videoFilePath m))
    , ("checksum", toJsonOpt text (Movie.checksum m))
    , ("actors", Json.array (List.map Actor.toJson (Movie.actors m)))
    , ("folderPath", toJsonOpt text (Movie.folderPath m))
    , ("nfoPath", toJsonOpt text (Movie.nfoPath m))
    , ("fileSizeBytes", toJsonOpt nat (Movie.fileSizeBytes m))
    , ("folderMeta", FolderMeta.toJson (Movie.folderMeta m))
    ]

Title.fromJson : '{unison_json_1_4_2.Decoder} Title
Title.fromJson = do
  use Decoder text
  use object at!
  display = at! "display" text
  original = at! "original" text
  sort = at! "sort" text
  Title.Title display original sort

MovieId.fromJson : '{unison_json_1_4_2.Decoder} MovieId
MovieId.fromJson = do
  use Decoder optional! text
  use object at
  kodi = object.at! "kodi" text
  imdb = optional! (at "imdb" text)
  tmdb = optional! (at "tmdb" text)
  tvdb = optional! (at "tvdb" text)
  MovieId.MovieId kodi imdb tmdb tvdb

Scoring.fromJson : '{unison_json_1_4_2.Decoder} Scoring
Scoring.fromJson = do
  use Decoder nat
  use object at!
  year = Decoder.optional! (object.at "year" nat)
  rating = at! "rating" Decoder.float
  votes = at! "votes" nat
  mpaa = at! "mpaa" Decoder.text
  Scoring.Scoring year rating votes mpaa

Taxonomy.fromJson : '{unison_json_1_4_2.Decoder} Taxonomy
Taxonomy.fromJson = do
  use Decoder array text
  use object at!
  genres = at! "genres" (array text)
  tags = at! "tags" (array text)
  countries = at! "countries" (array text)
  studios = at! "studios" (array text)
  directors = at! "directors" (array text)
  credits = at! "credits" (array text)
  Taxonomy.Taxonomy genres tags countries studios directors credits

Video.fromJson : '{unison_json_1_4_2.Decoder} Video
Video.fromJson = do
  use Decoder nat
  use object at!
  codec = at! "codec" Decoder.text
  aspect = at! "aspect" Decoder.float
  width = at! "width" nat
  height = at! "height" nat
  Video.Video codec aspect width height

Audio.fromJson : '{unison_json_1_4_2.Decoder} Audio
Audio.fromJson = do
  use Decoder text
  use object at!
  codec = at! "codec" text
  language = at! "language" text
  channels = at! "channels" Decoder.nat
  Audio.Audio codec language channels

Subtitle.fromJson : '{unison_json_1_4_2.Decoder} Subtitle
Subtitle.fromJson = do
  language = object.at! "language" Decoder.text
  Subtitle.Subtitle language

StreamDetails.fromJson : '{unison_json_1_4_2.Decoder} StreamDetails
StreamDetails.fromJson = do
  use Decoder array
  use object at!
  video = at! "video" Video.fromJson
  audios = at! "audios" (array Audio.fromJson)
  subtitles = at! "subtitles" (array Subtitle.fromJson)
  StreamDetails.StreamDetails video audios subtitles

FileInfo.fromJson : '{unison_json_1_4_2.Decoder} FileInfo
FileInfo.fromJson = do
  streams = object.at! "streams" StreamDetails.fromJson
  FileInfo.FileInfo streams

Actor.fromJson : '{unison_json_1_4_2.Decoder} Actor
Actor.fromJson = do
  use Decoder text
  use object at!
  name = at! "name" text
  role = at! "role" text
  Actor.Actor name role

FolderMeta.fromJson : '{unison_json_1_4_2.Decoder} FolderMeta
FolderMeta.fromJson =
  do
    use Decoder nat optional! text
    use object at
    rawSize = optional! (at "rawSize" text)
    resolution = optional! (at "resolution" text)
    videoCodec = optional! (at "videoCodec" text)
    bitDepth = optional! (at "bitDepth" nat)
    runtimeMin = optional! (at "runtimeMin" nat)
    checksum = optional! (at "checksum" text)
    FolderMeta.FolderMeta
      rawSize resolution videoCodec bitDepth runtimeMin checksum

Movie.fromJson : '{unison_json_1_4_2.Decoder} Movie
Movie.fromJson =
  do
    use Decoder nat optional! text
    use object at at!
    id = at! "id" MovieId.fromJson
    title = at! "title" Title.fromJson
    collection = optional! (at "collection" text)
    runtime = optional! (at "runtime" nat)
    scoring = at! "scoring" Scoring.fromJson
    plot = at! "plot" text
    tagline = at! "tagline" text
    taxonomy = at! "taxonomy" Taxonomy.fromJson
    fileInfo = at! "fileInfo" FileInfo.fromJson
    videoFilePath = optional! (at "videoFilePath" text)
    checksum = optional! (at "checksum" text)
    actors = at! "actors" (Decoder.array Actor.fromJson)
    folderPath = optional! (at "folderPath" text)
    nfoPath = optional! (at "nfoPath" text)
    fileSizeBytes = optional! (at "fileSizeBytes" nat)
    folderMeta = at! "folderMeta" FolderMeta.fromJson
    Movie.Movie
      id
      title
      collection
      runtime
      scoring
      plot
      tagline
      taxonomy
      fileInfo
      videoFilePath
      checksum
      actors
      folderPath
      nfoPath
      fileSizeBytes
      folderMeta

Movie.toNdjsonLine : Movie -> Text
Movie.toNdjsonLine m =
  use Text ++
  Json.toText (Movie.toJson m) ++ "\n"

Movie.fromNdjsonLine : Text -> Either Failure Movie
Movie.fromNdjsonLine line = catch do Decoder.run Movie.fromJson (trim line)

Tmdb.Result.fromJson : '{unison_json_1_4_2.Decoder} Tmdb.Result
Tmdb.Result.fromJson = do
  use Decoder optional! text
  use Optional getOrElse
  use object at at!
  tmdbId = at! "id" Decoder.nat
  title = at! "title" text
  originalTitle = at! "original_title" text
  originalLanguage = getOrElse "" (optional! (at "original_language" text))
  releaseDate = getOrElse "" (optional! (at "release_date" text))
  popularity = at! "popularity" Decoder.float
  overview = getOrElse "" (optional! (at "overview" text))
  Tmdb.Result.Result
    tmdbId title originalTitle originalLanguage releaseDate popularity overview

Tmdb.Result.toJson : Tmdb.Result -> Json
Tmdb.Result.toJson r =
  use Json text
  Json.object
    [ ("id", Json.nat (Tmdb.Result.tmdbId r))
    , ("title", text (Tmdb.Result.title r))
    , ("original_title", text (Tmdb.Result.originalTitle r))
    , ("original_language", text (Tmdb.Result.originalLanguage r))
    , ("release_date", text (Tmdb.Result.releaseDate r))
    , ("popularity", Json.float (Tmdb.Result.popularity r))
    , ("overview", text (Tmdb.Result.overview r))
    ]

Tmdb.SearchResponse.toJson : Tmdb.SearchResponse -> Json
Tmdb.SearchResponse.toJson r =
  Json.object
    [ ( "results"
      , Json.array
          (List.map Tmdb.Result.toJson (Tmdb.SearchResponse.results r))
      )
    ]

Tmdb.normalize : Text -> Text
Tmdb.normalize t =
  use Nat >
  use Text drop
  lower = Text.toLowercase t
  dropChars = ["'", "\"", "`"]
  spaceChars =
    [ ".", ",", ":", ";", "!", "?", "(", ")"
    , "[", "]", "{", "}", "-", "_", "&", "/"
    ]
  dropped = List.foldLeft (acc c -> replaceAll c "" acc) lower dropChars
  noPunct = List.foldLeft (acc p -> replaceAll p " " acc) dropped spaceChars
  parts = Text.split ?\s noPunct
  nonEmpty = List.filter (p -> Text.size p > 0) parts
  joined = Text.join " " nonEmpty
  if startsWith "the " joined then drop 4 joined
  else
    if startsWith "an " joined then drop 3 joined
    else if startsWith "a " joined then drop 2 joined else joined

Tmdb.CachedSearch.toJson : Tmdb.CachedSearch -> Json
Tmdb.CachedSearch.toJson c =
  use Json text
  use List ++
  base = [("folder", text (Tmdb.CachedSearch.folder c))]
  resp = match Tmdb.CachedSearch.response c with
    Some r -> [("response", Tmdb.SearchResponse.toJson r)]
    None   -> []
  err = match Tmdb.CachedSearch.error c with
    Some e -> [("error", text e)]
    None   -> []
  Json.object (base ++ resp ++ err)

test> Movie.roundtrip.test =
  encoded = Movie.toNdjsonLine exampleMovie
  match Movie.fromNdjsonLine encoded with
    Left failure -> [Fail (Failure.message failure)]
    Right m      -> check (Universal.eq m exampleMovie)

textBetween : Text -> Text -> Text -> Optional Text
textBetween startD endD t = match Text.indexOf startD t with
  None   -> None
  Some i ->
    use Nat +
    after = Text.drop (i + Text.size startD) t
    match Text.indexOf endD after with
      None   -> None
      Some j -> Some (Text.take j after)

textAfter : Text -> Text -> Optional Text
textAfter sep t = match Text.indexOf sep t with
  None   -> None
  Some i -> Some (trim (Text.drop (i Nat.+ Text.size sep) t))

parseNatBefore : Text -> Text -> Optional Nat
parseNatBefore suffix t =
  use Nat -
  use Text size
  if endsWith suffix t then
    sz = size t - size suffix
    Nat.fromText (Text.take sz t)
  else None

classifyPiece : Text -> FolderMeta -> FolderMeta
classifyPiece p m =
  if endsWith "min" p then FolderMeta.runtimeMin.set (parseNatBefore "min" p) m
  else
    if endsWith "p" p then FolderMeta.resolution.set (Some p) m
    else
      if endsWith "b" p then FolderMeta.bitDepth.set (parseNatBefore "b" p) m
      else
        if endsWith "G" p then FolderMeta.rawSize.set (Some p) m
        else
          if endsWith "M" p then FolderMeta.rawSize.set (Some p) m
          else
            if startsWith "x" p then FolderMeta.videoCodec.set (Some p) m
            else
              if startsWith "h" p then FolderMeta.videoCodec.set (Some p) m
              else
                if startsWith "av" p then FolderMeta.videoCodec.set (Some p) m
                else m

Nfo.parseFolderName : Text -> FolderMeta
Nfo.parseFolderName name =
  csum = textAfter "~" name
  brackets = textBetween "[" "]" name
  base = FolderMeta.checksum.set csum emptyFolderMeta
  match brackets with
    None -> base
    Some content ->
      List.foldLeft
        (acc p -> classifyPiece (trim p) acc) base (Text.split ?\s content)

tryXml : '{Throw XMLError} a -> Optional a
tryXml = Throw.toOptional

silentBranches : '{Each, Throw XMLError} a -> [a]
silentBranches thunk =
  List.filterMap (x -> x) (Each.toList do Throw.toOptional thunk)

Nfo.allText : Soup ->{Throw XMLError} Text
Nfo.allText s = Text.join "" (Soup.texts s)

Nfo.optText : Text -> Soup -> Optional Text
Nfo.optText tag s = match tryXml do Nfo.allText (Soup.findFirst tag s) with
  Some t -> if Universal.eq (Text.size t) 0 then None else Some t
  None   -> None

Nfo.requireText : Text -> Soup ->{Throw XMLError} Text
Nfo.requireText tag s = Nfo.allText (Soup.findFirst tag s)

Nfo.textOr : Text -> Text -> Soup -> Text
Nfo.textOr default tag s = Optional.getOrElse default (Nfo.optText tag s)

Nfo.texts : Text -> Soup -> [Text]
Nfo.texts tag s = silentBranches do
  g = Soup.named tag s
  Nfo.allText g

Nfo.natOr : Nat -> Text -> Nat
Nfo.natOr default t = Optional.getOrElse default (Nat.fromText t)

Nfo.floatOr : Float -> Text -> Float
Nfo.floatOr default t = Optional.getOrElse default (Float.fromText t)

Nfo.descendantAttr : Text -> Text -> Soup -> Optional Text
Nfo.descendantAttr elemName attrName s = 
  Throw.toOptional do Soup.attribute attrName (Soup.findFirst elemName s)

Nfo.uniqueIdOfType : Text -> Soup -> Optional Text
Nfo.uniqueIdOfType wantType s =
  candidates : [(Text, Text)]
  candidates = silentBranches do
    u = Soup.named "uniqueid" s
    typeAttr = Soup.attribute "type" u
    textVal = Nfo.allText u
    (typeAttr, textVal)
  match List.find (cases (t, _) -> Universal.eq t wantType) candidates with
    Some (_, v) -> Some (trim v)
    None        -> None

Nfo.parseCollection : Soup -> Optional Text
Nfo.parseCollection s =
  use Soup findFirst
  modern = Throw.toOptional do
    setElem = findFirst "set" s
    nameElem = findFirst "name" setElem
    Nfo.allText nameElem
  match modern with
    Some n ->
      trimmed = trim n
      if Universal.eq (Text.size trimmed) 0 then Nfo.optText "set" s
      else Some trimmed
    None -> Nfo.optText "set" s

Nfo.parseRatingAndVotes : Soup -> (Float, Nat)
Nfo.parseRatingAndVotes s =
  use List find
  use Optional getOrElse
  use Soup attribute findFirst
  use Throw toOptional
  use Universal eq
  ratingsElem = toOptional do findFirst "ratings" s
  match ratingsElem with
    None    ->
      r = Nfo.floatOr 0.0 (Nfo.textOr "0" "rating" s)
      v = Nfo.natOr 0 (Nfo.textOr "0" "votes" s)
      (r, v)
    Some rs ->
      candidates : [(Optional Text, Optional Text, Float, Nat)]
      candidates = silentBranches do
        r = Soup.named "rating" rs
        name = toOptional do attribute "name" r
        dflt = toOptional do attribute "default" r
        valStr = Nfo.allText (findFirst "value" r)
        votesStr = Nfo.allText (findFirst "votes" r)
        val = getOrElse 0.0 (Float.fromText (trim valStr))
        vc = getOrElse 0 (Nat.fromText (trim votesStr))
        (name, dflt, val, vc)
      defaultMatch = find (cases (_, d, _, _) -> eq d (Some "true")) candidates
      imdbMatch = find (cases (n, _, _, _) -> eq n (Some "imdb")) candidates
      best = match defaultMatch with
        Some x -> Some x
        None   ->
          match imdbMatch with
            Some x -> Some x
            None   -> List.head candidates
      match best with
        Some (_, _, r, v) -> (r, v)
        None              -> (0.0, 0)

Nfo.parseTitle : Soup ->{Throw XMLError} Title
Nfo.parseTitle s =
  display = Nfo.textOr "" "title" s
  original = Nfo.textOr "" "originaltitle" s
  sort = Nfo.textOr "" "sorttitle" s
  Title.Title display original sort

Nfo.parseMovieId : Soup ->{Throw XMLError} MovieId
Nfo.parseMovieId s =
  imdb = match Nfo.uniqueIdOfType "imdb" s with
    Some v -> Some v
    None   -> Nfo.descendantAttr "imdb" "id" s
  tmdb = match Nfo.uniqueIdOfType "tmdb" s with
    Some v -> Some v
    None   -> Nfo.descendantAttr "tmdb" "id" s
  tvdb = match Nfo.uniqueIdOfType "tvdb" s with
    Some v -> Some v
    None   -> Nfo.descendantAttr "tvdb" "id" s
  kodi = match Nfo.optText "id" s with
    Some k -> k
    None   -> Optional.getOrElse "" imdb
  MovieId.MovieId kodi imdb tmdb tvdb

Nfo.parseScoring : Soup ->{Throw XMLError} Scoring
Nfo.parseScoring s =
  year = Optional.map (Nfo.natOr 0) (Nfo.optText "year" s)
  (rating, votes) = Nfo.parseRatingAndVotes s
  mpaa = Nfo.textOr "" "mpaa" s
  Scoring.Scoring year rating votes mpaa

Nfo.parseTaxonomy : Soup -> Taxonomy
Nfo.parseTaxonomy s =
  Taxonomy.Taxonomy
    (Nfo.texts "genre" s)
    (Nfo.texts "tag" s)
    (Nfo.texts "country" s)
    (Nfo.texts "studio" s)
    (Nfo.texts "director" s)
    (Nfo.texts "credits" s)

Nfo.parseVideo : Soup ->{Throw XMLError} Video
Nfo.parseVideo s =
  codec = Nfo.textOr "" "codec" s
  aspect = Nfo.floatOr 0.0 (Nfo.textOr "0" "aspect" s)
  width = Nfo.natOr 0 (Nfo.textOr "0" "width" s)
  height = Nfo.natOr 0 (Nfo.textOr "0" "height" s)
  Video.Video codec aspect width height

Nfo.parseAudio : Soup ->{Throw XMLError} Audio
Nfo.parseAudio s =
  codec = Nfo.textOr "" "codec" s
  language = Nfo.textOr "" "language" s
  channels = Nfo.natOr 0 (Nfo.textOr "0" "channels" s)
  Audio.Audio codec language channels

Nfo.parseSubtitle : Soup ->{Throw XMLError} Subtitle
Nfo.parseSubtitle s =
  language = Nfo.textOr "" "language" s
  Subtitle.Subtitle language

Nfo.parseStreamDetails : Soup ->{Throw XMLError} StreamDetails
Nfo.parseStreamDetails s =
  use Soup named
  video = Nfo.parseVideo (Soup.findFirst "video" s)
  audios = silentBranches do
    a = named "audio" s
    Nfo.parseAudio a
  subs = silentBranches do
    sb = named "subtitle" s
    Nfo.parseSubtitle sb
  StreamDetails.StreamDetails video audios subs

Nfo.parseFileInfo : Soup ->{Throw XMLError} FileInfo
Nfo.parseFileInfo s =
  streams = Nfo.parseStreamDetails (Soup.findFirst "streamdetails" s)
  FileInfo.FileInfo streams

Nfo.parseActor : Soup ->{Throw XMLError} Actor
Nfo.parseActor s =
  name = Nfo.textOr "" "name" s
  role = Nfo.textOr "" "role" s
  Actor.Actor name role

Nfo.parseActors : Soup -> [Actor]
Nfo.parseActors s = silentBranches do
  a = Soup.named "actor" s
  Nfo.parseActor a

Nfo.parseMovie : Soup ->{Throw XMLError} Movie
Nfo.parseMovie s =
  id = Nfo.parseMovieId s
  title = Nfo.parseTitle s
  collection = Nfo.parseCollection s
  runtime = Optional.map (Nfo.natOr 0) (Nfo.optText "runtime" s)
  scoring = Nfo.parseScoring s
  plot = Nfo.textOr "" "plot" s
  tagline = Nfo.textOr "" "tagline" s
  taxonomy = Nfo.parseTaxonomy s
  fileInfo =
    match catch do Nfo.parseFileInfo s with
      Left _ ->
        FileInfo.FileInfo
          (StreamDetails.StreamDetails (Video.Video "" 0.0 0 0) [] [])
      Right f -> f
  Movie.Movie
    id
    title
    collection
    runtime
    scoring
    plot
    tagline
    taxonomy
    fileInfo
    None
    None
    (Nfo.parseActors s)
    None
    None
    None
    emptyFolderMeta

Nfo.parse : Text -> Either Text Movie
Nfo.parse xml = match withXML xml Nfo.parseMovie with
  Left err       -> Left err
  Right (m +: _) -> Right m
  Right []       -> Left "no <movie> element found"

pathJoin : FilePath -> Text -> FilePath
pathJoin base name =
  use Text ++
  (FilePath t) = base
  FilePath (t ++ "/" ++ name)

filePathText : FilePath -> Text
filePathText = cases FilePath t -> t

filePathBasename : FilePath -> Text
filePathBasename fp = match List.reverse (Text.split ?/ (filePathText fp)) with
  last +: _ -> last
  []        -> filePathText fp

videoExtensions : [Text]
videoExtensions = [".mkv", ".mp4", ".avi", ".mov", ".wmv", ".flv"]

isNfo : Text -> Boolean
isNfo name = endsWith ".nfo" name

isVideo : Text -> Boolean
isVideo name = List.any (ext -> endsWith ext name) videoExtensions

findFirstNfo : [Text] -> Optional Text
findFirstNfo = List.find isNfo

findFirstVideo : [Text] -> Optional Text
findFirstVideo = List.find isVideo

Nfo.processFolder : FilePath ->{IO, Exception} Either FilePath Movie
Nfo.processFolder folder =
  files = directoryContents.texts folder
  match findFirstNfo files with
    None -> Left folder
    Some nfoName ->
      nfoFp = pathJoin folder nfoName
      xml = readFileUtf8 nfoFp
      match Nfo.parse xml with
        Left _ -> Left folder
        Right m ->
          videoPath =
            Optional.map
              (vf -> filePathText (pathJoin folder vf)) (findFirstVideo files)
          folderName = filePathBasename folder
          folderMeta = Nfo.parseFolderName folderName
          Right
            (m
              |> Movie.videoFilePath.set videoPath
              |> Movie.checksum.set (FolderMeta.checksum folderMeta)
              |> Movie.folderPath.set (Some (filePathText folder))
              |> Movie.nfoPath.set (Some (filePathText nfoFp))
              |> Movie.folderMeta.set folderMeta)

parseConfigLine : Text -> Optional FilePath
parseConfigLine l =
  trimmed = trim l
  if Universal.eq (Text.size trimmed) 0 then None else Some (FilePath trimmed)

Db.config : PostgresClientConfig
Db.config =
  PostgresClientConfig.default
    (HostName "localhost") (UserName "postgres") (DatabaseName "dork")
    |> PostgresClientConfig.port.set (Port "5434")

Db.runDDL cmd =
  pc = prepareCommand cmd
  ignore (bindAndExecuteCommand pc (Command.encodeArgs cmd))

Db.runDDLList stmts =
  _ = List.map (s -> Db.runDDL (sql s |> buildCommand)) stmts
  ()

