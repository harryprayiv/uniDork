Tmdb.writeDbCacheWith pc sourcePath title year result =
  use Nat toInt
  use Tmdb.CachedSearch CachedSearch
  entry = match result with
    Right r -> CachedSearch sourcePath (Some r) None
    Left e  -> CachedSearch sourcePath None (Some e)
  payload = Json.toText (Tmdb.CachedSearch.toJson entry)
  _ = catch do
    bindAndExecuteCommand
      pc
      (Db.pt sourcePath
        ++ Db.pt title
        ++ Db.pi (toInt year)
        ++ Db.pt payload)
  ()

