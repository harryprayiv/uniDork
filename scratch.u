Db.insertPairSql table col =
  use Codec text
  q =
    Text.join
      "" ["INSERT INTO ", table, " (folder_checksum, ", col, ") VALUES ("]
  sql q %% var text %% sql ", " %% var text %% sql ") ON CONFLICT DO NOTHING"
    |> buildCommand

Db.insertGenreSql = Db.insertPairSql "movie_genres" "genre"

Db.insertTagSql = Db.insertPairSql "movie_tags" "tag"

Db.insertCountrySql = Db.insertPairSql "movie_countries" "country"

Db.insertStudioSql = Db.insertPairSql "movie_studios" "studio"

Db.insertDirectorSql = Db.insertPairSql "movie_directors" "director"

Db.insertCreditSql = Db.insertPairSql "movie_credits" "credit"

Db.upsertMovieSql =
  use Codec optional text
  sql
    "INSERT INTO movies (kodi_id, imdb_id, tmdb_id, tvdb_id, title, original_title, sort_title, collection, year, rating, votes, mpaa, runtime, plot, tagline, folder_path, nfo_path, video_file_path, file_size_bytes, folder_checksum, parsed_size_str, parsed_resolution, parsed_codec, parsed_bit_depth, parsed_runtime_min, actual_runtime_sec) VALUES ("
    %% var text
